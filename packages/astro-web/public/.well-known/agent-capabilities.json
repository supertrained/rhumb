{
  "name": "Rhumb",
  "version": "0.8.2",
  "description": "Agent-native infrastructure for discovering, evaluating, and executing external tools. 695+ services scored for AI agent compatibility (AN Score), 414 capabilities across 92 categories, 16 callable providers.",
  "url": "https://rhumb.dev",
  "api": {
    "base_url": "https://api.rhumb.dev/v1",
    "docs": "https://rhumb.dev/docs",
    "authentication": {
      "methods": ["x402", "api_key", "byok"],
      "x402": {
        "description": "Zero-signup per-call payment. No API key or account required.",
        "currency": "USDC",
        "network": "Base",
        "flow": "POST /v1/capabilities/{id}/execute → receive 402 with payment details → submit on-chain USDC payment → retry with X-Payment header containing tx proof (tx_hash, network, wallet_address)"
      },
      "api_key": {
        "description": "Bearer token from signup. Free tier: 1,000 executions/month.",
        "header": "X-Rhumb-Key: rhumb_live_{key}",
        "signup_url": "https://rhumb.dev/auth/login"
      },
      "byok": {
        "description": "Bring your own API keys for external services. Free passthrough."
      }
    }
  },
  "mcp": {
    "activation": "npx rhumb-mcp@latest",
    "tools": 17,
    "tool_list": [
      "find_services",
      "get_score",
      "get_alternatives",
      "get_failure_modes",
      "discover_capabilities",
      "resolve_capability",
      "execute_capability",
      "estimate_capability",
      "credential_ceremony",
      "check_credentials",
      "budget",
      "spend",
      "routing",
      "usage_telemetry",
      "check_balance",
      "get_payment_url",
      "get_ledger"
    ]
  },
  "coverage": {
    "services_scored": 695,
    "capabilities": 414,
    "categories": 92,
    "domains": 50,
    "callable_providers": 16,
    "comparisons": 13,
    "autopsies": 4
  },
  "pricing": {
    "free_tier": {
      "executions_per_month": 1000,
      "signup_required": false,
      "credit_card_required": false
    },
    "x402": {
      "margin": "15% over upstream cost",
      "currency": "USDC",
      "signup_required": false
    },
    "managed": {
      "margin": "20% over upstream cost",
      "signup_required": true
    },
    "byok": {
      "cost": "free",
      "description": "You pay external providers directly"
    }
  },
  "trust": {
    "neutrality": "Scores are computed, not curated. No pay-to-rank.",
    "methodology": "https://rhumb.dev/methodology",
    "self_score": "https://rhumb.dev/blog/rhumb-self-score",
    "disputes": "providers@supertrained.ai"
  },
  "discovery": {
    "llms_txt": "https://rhumb.dev/llms.txt",
    "llms_full_txt": "https://rhumb.dev/llms-full.txt",
    "agent_capabilities": "https://rhumb.dev/.well-known/agent-capabilities.json",
    "capabilities_browse": "https://rhumb.dev/capabilities"
  },
  "contact": {
    "providers": "providers@supertrained.ai",
    "github": "https://github.com/supertrained/rhumb"
  }
}
