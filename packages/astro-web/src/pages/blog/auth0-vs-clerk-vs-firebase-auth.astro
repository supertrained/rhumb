---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import ScoreDisplay from "../../components/ScoreDisplay.astro";
import TierBadge from "../../components/TierBadge.astro";
import { getServiceScore } from "../../lib/api";
import type { ServiceScoreViewModel } from "../../lib/types";

const scoreMap = {
  clerk: await getServiceScore("clerk"),
  auth0: await getServiceScore("auth0"),
  "firebase-auth": await getServiceScore("firebase-auth"),
} satisfies Record<string, ServiceScoreViewModel | null>;

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Auth0 vs Clerk vs Firebase Auth for AI Agents",
  datePublished: "2026-03-17T00:00:00Z",
  author: { "@type": "Person", name: "Pedro Nunes" },
  description:
    "Side-by-side comparison of Auth0, Clerk, and Firebase Auth for AI agent authentication workflows — using live Rhumb AN Score data.",
  url: "https://rhumb.dev/blog/auth0-vs-clerk-vs-firebase-auth",
  publisher: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
};

type ComparedService = {
  slug: "clerk" | "auth0" | "firebase-auth";
  name: string;
  accent: string;
  accentSoft: string;
  tagline: string;
  bestFor: string;
  avoidWhen: string;
  friction: string;
  decision: string;
  support: string;
  data: ServiceScoreViewModel | null;
};

const compared: ComparedService[] = [
  {
    slug: "clerk",
    name: "Clerk",
    accent: "#8B5CF6",
    accentSoft: "rgba(139,92,246,0.16)",
    tagline: "default",
    bestFor: "Agents that need the cleanest path from API key to user management. Highest execution score, modern API design, and the most agent-friendly SDK surface of the three.",
    avoidWhen: "You need deep enterprise compliance (HIPAA, FedRAMP) or the organization is locked into Okta/Auth0 contracts. Clerk is newer and its compliance surface is still growing.",
    friction: "JWT clock skew can cause intermittent auth rejections in distributed systems. Webhook delivery has no retry — events lost to processing latency are gone permanently. Both require defensive coding from day one.",
    decision: "Pick Clerk unless an enterprise compliance requirement or existing contract pushes you elsewhere.",
    support: "Highest aggregate score. The SDK surface is designed for modern frameworks (Next.js, React, etc.) and the Backend API is clean REST. Self-serve billing removes sales friction. Documented failure modes make agent hardening easier.",
    data: scoreMap.clerk,
  },
  {
    slug: "auth0",
    name: "Auth0",
    accent: "#F97316",
    accentSoft: "rgba(249,115,22,0.16)",
    tagline: "enterprise bridge",
    bestFor: "Organizations that need HIPAA, SOC 2 Type II, SCIM, and deep RBAC with custom roles. Auth0 has the governance ceiling when compliance is the gating constraint.",
    avoidWhen: "You are building a greenfield project and do not need enterprise compliance features. Auth0's Management API and Rules/Actions pipeline carry complexity that is unnecessary for simple auth flows.",
    friction: "Management API rate limits are strict (varies by plan). The Rules → Actions migration creates confusion about which extensibility model to use. Okta acquisition introduced billing and dashboard changes that fragment the documentation surface.",
    decision: "Pick Auth0 when the organization needs the deepest compliance surface or is already in the Okta ecosystem.",
    support: "Highest governance score (9.0) but lower access readiness (5.0). The enterprise compliance surface is genuinely strong: HIPAA BAA, custom roles, audit log export, data residency. But the API surface reflects years of feature accumulation and two extensibility models.",
    data: scoreMap.auth0,
  },
  {
    slug: "firebase-auth",
    name: "Firebase Auth",
    accent: "#F59E0B",
    accentSoft: "rgba(245,158,11,0.16)",
    tagline: "google ecosystem",
    bestFor: "Projects already on Firebase/GCP where auth is just one layer in a broader Google Cloud stack. The free tier (50K MAU) is the most generous of the three.",
    avoidWhen: "You want a standalone auth solution or need to avoid Google Cloud lock-in. Firebase Auth is tightly coupled to the Firebase SDK ecosystem — using it outside that context adds friction.",
    friction: "Admin SDK is the only agent-friendly interface; client SDKs assume browser context. Google Cloud Console setup is multi-step with IAM, service accounts, and project configuration. Token verification requires Google's public key rotation awareness.",
    decision: "Pick Firebase Auth when the project is already on Firebase/GCP and auth is a feature, not the product.",
    support: "Highest execution of the two runners-up (7.5), but the lowest access readiness (4.8) reflects the reality that Firebase Auth is not designed as a standalone service. It works best as part of a Firebase project — trying to use it in isolation fights the design grain.",
    data: scoreMap["firebase-auth"],
  },
];

const available = compared.filter((item) => item.data !== null);
const ranked = [...available].sort(
  (a, b) => (b.data?.aggregateRecommendationScore ?? 0) - (a.data?.aggregateRecommendationScore ?? 0)
);
const winner = ranked[0];
const updatedAt = winner?.data?.calculatedAt
  ? new Date(winner.data.calculatedAt).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : "recently";
const updatedAtISO = winner?.data?.calculatedAt
  ? new Date(winner.data.calculatedAt).toISOString()
  : new Date().toISOString();
(ARTICLE_JSON_LD as any).dateModified = updatedAtISO;

function formatScore(value: number | null | undefined): string {
  return value == null ? "—" : value.toFixed(1);
}
function formatConfidence(value: number | null | undefined): string {
  return value == null ? "—" : `${Math.round(value * 100)}%`;
}

function failureCopy(item: ComparedService): string[] {
  if (item.slug === "clerk") {
    return [
      "JWT verification clock skew in distributed systems causes intermittent auth rejections. Agents see users randomly appear logged out — hard to reproduce, easy to misdiagnose.",
      "Webhook events have no retry mechanism. If the agent's processing queue has latency at receipt time, the event is permanently lost. No recovery path.",
      "Organization-level RBAC requires careful scoping. An agent managing multi-tenant auth needs to track organization context on every request or risk cross-tenant data leaks.",
    ];
  }
  if (item.slug === "auth0") {
    return [
      "Management API rate limits vary by plan and are strict enough to break bulk user operations. Agents need pagination and backoff logic from the first integration.",
      "Two extensibility models (legacy Rules vs current Actions) create confusion. Documentation references both; agents following stale docs will build on the deprecated model.",
      "Okta acquisition changed the billing, dashboard, and some API surfaces. Search results and documentation may reference pre-acquisition patterns that no longer work.",
    ];
  }
  return [
    "Admin SDK is the only real agent interface — client SDKs assume browser context with DOM access. Agents must use the Admin SDK or raw REST with service account credentials.",
    "Google Cloud project setup requires IAM configuration, service account key generation, and Firebase project linking — a multi-step process that cannot be automated without GCP admin access.",
    "Token verification requires awareness of Google's public key rotation schedule. Caching JWKs without rotation handling causes periodic auth failures that look like application bugs.",
  ];
}

const scenarioCards = [
  {
    title: "New project needs user auth with modern framework",
    pick: "Clerk",
    why: "Cleanest SDK surface, highest execution score, self-serve billing, and the most framework integrations. Productive in under an hour.",
    href: "/service/clerk",
  },
  {
    title: "Enterprise requires HIPAA/SOC 2 compliance for auth layer",
    pick: "Auth0",
    why: "Deepest compliance surface: HIPAA BAA, custom RBAC, audit log export, SCIM provisioning, data residency options.",
    href: "/service/auth0",
  },
  {
    title: "App already runs on Firebase/GCP stack",
    pick: "Firebase Auth",
    why: "Auth is free up to 50K MAU and integrates natively with Firestore, Cloud Functions, and other Firebase services.",
    href: "/service/firebase-auth",
  },
];

const agentRules = [
  "If the operator has no auth provider yet, default to Clerk. It has the shortest path to working authentication.",
  "If the operator mentions HIPAA, FedRAMP, or enterprise compliance as requirements, route to Auth0 before evaluating alternatives.",
  "If the operator is already on Firebase or GCP, recommend Firebase Auth — the migration cost away from it exceeds the ergonomic gain.",
  "For Clerk: implement clock skew tolerance (±10s) in JWT verification from day one. This is not optional.",
  "For Auth0: confirm whether the operator is on Rules or Actions before writing any extensibility code. Never mix the two.",
  "For all three: auth is a trust-critical surface. Never store tokens in logs, error messages, or diagnostic output.",
];
---

<Layout
  title="Auth0 vs Clerk vs Firebase Auth for AI Agents | Rhumb"
  description="Compare Auth0, Clerk, and Firebase Auth for agent authentication. Clerk leads on ergonomics, Auth0 on enterprise control, Firebase inside Google Cloud."
  canonical="/blog/auth0-vs-clerk-vs-firebase-auth"
  ogTitle="Auth0 vs Clerk vs Firebase Auth for AI Agents"
  ogDescription="Which authentication provider should an AI agent use? Clerk wins by default, Auth0 wins for enterprise compliance, Firebase Auth wins inside GCP."
  ogUrl="https://rhumb.dev/blog/auth0-vs-clerk-vs-firebase-auth"
  ogType="article"
  twitterTitle="Auth0 vs Clerk vs Firebase Auth for AI Agents"
  twitterDescription="A side-by-side decision page for operators and agents choosing an authentication provider."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen overflow-hidden">
    <section class="relative border-b border-slate-800/80">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_left,rgba(139,92,246,0.12),transparent_32%),radial-gradient(circle_at_top_right,rgba(249,115,22,0.10),transparent_28%),radial-gradient(circle_at_bottom,rgba(245,158,11,0.08),transparent_35%)]"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-14 pb-16">
        <div class="max-w-3xl">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="text-xs font-mono font-semibold text-amber uppercase tracking-[0.28em]">Comparison</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-slate-500">March 17, 2026</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-emerald-400/70">Updated {updatedAt}</span>
          </div>

          <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl leading-[0.95] tracking-tight text-slate-100 max-w-4xl text-balance">
            Auth0 vs Clerk vs Firebase Auth for AI agents
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-slate-300 leading-relaxed max-w-3xl">
            <span class="text-slate-100 font-semibold">Short answer:</span>
            Clerk is the cleanest default for new projects,
            Auth0 is the enterprise compliance bridge,
            and Firebase Auth makes sense when the project already lives on Google Cloud.
          </p>

          <div class="mt-8 inline-flex max-w-3xl items-start gap-3 rounded-2xl border border-violet-500/20 bg-violet-500/8 px-5 py-4">
            <div class="mt-0.5 h-2.5 w-2.5 rounded-full bg-violet-400 shrink-0"></div>
            <p class="text-sm leading-6 text-slate-300">
              <span class="font-semibold text-slate-100">Verdict:</span>
              Clerk leads because it combines the highest execution reliability with modern API design and the fewest legacy surfaces.
              Auth0 has the governance edge for enterprises that need HIPAA or deep RBAC. Firebase Auth is the right default
              inside Google Cloud but fights you everywhere else. Scores shown here reflect published Rhumb data as of {updatedAt}.
            </p>
          </div>
        </div>

        <div class="mt-12 grid gap-5 lg:grid-cols-3">
          {compared.map((item, index) => (
            <article
              class:list={[
                "group relative overflow-hidden rounded-[28px] border bg-surface/90 backdrop-blur-sm p-6 sm:p-7 reveal",
                index === 0 ? "lg:-translate-y-4" : "",
              ]}
              style={`border-color:${item.accent}40; background-image:linear-gradient(180deg, ${item.accentSoft} 0%, rgba(15,23,42,0.85) 26%, rgba(15,23,42,0.92) 100%); animation-delay:${index * 80}ms;`}
            >
              <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`background:radial-gradient(circle_at_top_right, ${item.accentSoft} 0%, transparent 38%);`}></div>
              <div class="relative">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">{item.tagline}</p>
                    <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">{item.name}</h2>
                  </div>
                  <ScoreDisplay score={item.data?.aggregateRecommendationScore ?? null} size="large" showLabel />
                </div>

                <div class="mt-4 flex items-center gap-3 flex-wrap">
                  <TierBadge tier={item.data?.tier ?? null} label={item.data?.tierLabel ?? undefined} />
                  <span class="text-xs font-mono text-slate-500">confidence {formatConfidence(item.data?.confidence)}</span>
                </div>

                <p class="mt-5 text-sm leading-6 text-slate-300">{item.bestFor}</p>

                <dl class="mt-6 grid grid-cols-3 gap-3">
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Exec</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.executionScore)}</dd>
                  </div>
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Access</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.accessReadinessScore)}</dd>
                  </div>
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Autonomy</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.p1Score)}</dd>
                  </div>
                </dl>

                <div class="mt-6 rounded-2xl border border-white/6 bg-navy/70 p-4">
                  <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Why it lands here</p>
                  <p class="mt-2 text-sm leading-6 text-slate-300">{item.support}</p>
                </div>

                <div class="mt-4 space-y-3">
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Biggest friction</p>
                    <p class="mt-1 text-sm leading-6 text-slate-400">{item.friction}</p>
                  </div>
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Avoid when</p>
                    <p class="mt-1 text-sm leading-6 text-slate-400">{item.avoidWhen}</p>
                  </div>
                </div>

                <div class="mt-6 flex items-center justify-between gap-4 border-t border-white/8 pt-4">
                  <p class="text-sm font-semibold text-slate-200 max-w-[20rem]">{item.decision}</p>
                  <a href={`/service/${item.slug}`} class="text-xs font-mono uppercase tracking-[0.2em] text-amber hover:text-amber-dark transition-colors">Service page →</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-14">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="rounded-[28px] border border-slate-800 bg-surface/80 overflow-hidden reveal">
          <div class="border-b border-slate-800 px-6 py-5 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0))]">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Operator scoreboard</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">What the numbers actually say</h2>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full min-w-[720px]">
              <thead>
                <tr class="border-b border-slate-800 text-left">
                  <th class="px-6 py-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Metric</th>
                  {compared.map((item) => (
                    <th class="px-6 py-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">{item.name}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Aggregate AN Score</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 font-semibold text-slate-100">{formatScore(item.data?.aggregateRecommendationScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Execution</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.executionScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Access Readiness</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.accessReadinessScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Governance</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.g1Score)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Confidence</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatConfidence(item.data?.confidence)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80 align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Free tier</td>
                  <td class="px-6 py-4 text-sm text-slate-300">10K MAU<br/><span class="text-slate-500">generous for prototyping</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">7.5K MAU<br/><span class="text-slate-500">legacy; varies</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">50K MAU<br/><span class="text-slate-500">most generous</span></td>
                </tr>
                <tr class="border-b border-slate-800/80 align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Auth model</td>
                  <td class="px-6 py-4 text-sm text-slate-300">API key + JWT<br/><span class="text-slate-500">per-key permissions</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">OAuth 2.0<br/><span class="text-slate-500">M2M client credentials</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">Service account<br/><span class="text-slate-500">GCP IAM</span></td>
                </tr>
                <tr class="align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Compliance</td>
                  <td class="px-6 py-4 text-sm text-slate-300">SOC 2 Type II<br/><span class="text-slate-500">SCIM, SSO</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">SOC 2, HIPAA<br/><span class="text-slate-500">ISO, FedRAMP</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">SOC 2, ISO<br/><span class="text-slate-500">via GCP</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <aside class="space-y-5 reveal">
          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Agent brief</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">Routing rules</h2>
            <ol class="mt-5 space-y-3">
              {agentRules.map((rule, idx) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full border border-slate-700 bg-navy text-[11px] font-mono text-slate-300 shrink-0">{idx + 1}</span>
                  <span class="text-sm leading-6 text-slate-300">{rule}</span>
                </li>
              ))}
            </ol>
          </div>

          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Decision pattern</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">One-line rule</h2>
            <p class="mt-4 text-base leading-7 text-slate-300">
              <span class="font-semibold text-slate-100">Clerk for clean agent-first auth.</span>
              {' '}Auth0 when enterprise compliance is the gating constraint.
              {' '}Firebase Auth when Google Cloud already owns the infrastructure.
            </p>
            <div class="mt-5 rounded-2xl border border-violet/20 bg-violet-500/8 p-4 text-sm leading-6 text-slate-300">
              Auth is a trust-critical surface. Unlike payments or email, a mistake here is a security incident, not a failed transaction. Agents should prefer the option with the most documented failure modes — that is where hardening is most possible.
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-14">
      <div class="rounded-[32px] border border-slate-800 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(2,6,23,0.4))] p-6 sm:p-8 reveal">
        <div class="max-w-2xl">
          <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Friction map</p>
          <h2 class="mt-2 font-display font-bold text-2xl sm:text-3xl text-slate-100">Where each one breaks in practice</h2>
          <p class="mt-4 text-slate-400 leading-relaxed">
            Authentication is a trust-critical surface — failures here are security incidents, not just UX friction.
            Each provider has distinct failure patterns that agents need to defend against from day one.
          </p>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-3">
          {compared.map((item, index) => (
            <article class="rounded-[26px] border bg-navy/55 p-6" style={`border-color:${item.accent}30; animation-delay:${index * 90}ms;`}>
              <div class="flex items-center justify-between gap-4">
                <h3 class="font-display font-bold text-xl text-slate-100">{item.name}</h3>
                <span class="h-2.5 w-2.5 rounded-full" style={`background:${item.accent}`}></span>
              </div>
              <ul class="mt-5 space-y-3">
                {failureCopy(item).map((line) => (
                  <li class="flex items-start gap-3 text-sm leading-6 text-slate-300">
                    <span class="mt-2 h-1.5 w-1.5 rounded-full bg-slate-500 shrink-0"></span>
                    <span>{line}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-16">
      <div class="grid gap-5 lg:grid-cols-3 reveal">
        {scenarioCards.map((card, index) => (
          <article class="rounded-[28px] border border-slate-800 bg-surface/85 p-6" style={`animation-delay:${index * 80}ms;`}>
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Scenario</p>
            <h3 class="mt-2 font-display font-bold text-xl text-slate-100 leading-snug">{card.title}</h3>
            <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/8 px-3 py-1">
              <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-emerald-300">Pick</span>
              <span class="text-sm font-semibold text-slate-100">{card.pick}</span>
            </div>
            <p class="mt-4 text-sm leading-6 text-slate-400">{card.why}</p>
            <a href={card.href} class="mt-6 inline-flex text-xs font-mono uppercase tracking-[0.2em] text-amber hover:text-amber-dark transition-colors">Open scorecard →</a>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-[30px] border border-slate-800 bg-surface/80 p-8 text-center reveal">
        <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Related</p>
