---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import fs from "node:fs";
import path from "node:path";

const RELATED_READING = [
  {
    href: "/blog/llm-apis-agent-loops",
    title: "LLM APIs in Agent Loops: What Actually Breaks at Scale",
    description: "The loop-level failure view once retries, tool calls, and unattended execution are live.",
  },
  {
    href: "/blog/api-reliability-checklist",
    title: "Before Your Agent Calls an API at 3am: A Reliability Checklist",
    description: "A short preflight for failure clarity, retries, rate-limit recovery, and credential shape before launch.",
  },
  {
    href: "/blog/api-credentials-agent-fleets",
    title: "API Credentials in Autonomous Agent Fleets",
    description: "The credential-lifecycle architecture that keeps auth failures from becoming fleet-wide outages.",
  },
  {
    href: "/blog/capability-first-agent-onboarding",
    title: "Capability-First Agent Onboarding: Managed Superpowers First",
    description: "Where bounded execution starts once the workflow is well-scoped enough to trust.",
  },
];

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Designing Agent Fleets That Survive Rate Limits",
  datePublished: "2026-03-30T00:00:00Z",
  dateModified: "2026-04-29T00:00:00Z",
  author: {
    "@type": "Person",
    name: "Pedro Nunes",
  },
  description:
    "Production architecture patterns for agent fleets that need to survive rate limits, dynamic capacity shifts, and 2am retry storms.",
  url: "https://rhumb.dev/blog/agent-fleet-rate-limit-design",
  publisher: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};

function markdownToHtml(md: string): string {
  let html = md;

  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_match, _lang, code) => {
    return `<pre class="bg-elevated border border-slate-800 rounded-lg p-4 my-6 overflow-x-auto text-sm font-mono text-slate-300"><code>${code.replace(/</g, '&lt;').replace(/>/g, '&gt;').trim()}</code></pre>`;
  });

  html = html.replace(/^---$/gm, '<hr class="border-slate-800 my-10" />');

  html = html.replace(/(?:^\|.+\|$\n?)+/gm, (block) => {
    const rows = block.trim().split('\n').filter(r => !r.match(/^\|[\s-:|]+\|$/));
    if (rows.length === 0) return block;
    const headerCells = rows[0].split('|').filter(c => c.trim()).map(c =>
      `<th class="px-4 py-3 text-left text-xs font-mono font-semibold text-slate-300 uppercase tracking-wider">${c.trim()}</th>`
    ).join('\n');
    const bodyRows = rows.slice(1).map(row => {
      const cells = row.split('|').filter(c => c.trim()).map(c =>
        `<td class="px-4 py-3 text-sm text-slate-400">${c.trim()}</td>`
      ).join('\n');
      return `<tr class="border-t border-slate-800">${cells}</tr>`;
    }).join('\n');
    return `<div class="overflow-x-auto my-6"><table class="w-full border border-slate-800 rounded-lg"><thead class="bg-elevated"><tr>${headerCells}</tr></thead><tbody>${bodyRows}</tbody></table></div>`;
  });

  html = html.replace(/^#### (.+)$/gm, '<h4 class="font-display font-semibold text-base text-slate-300 mt-6 mb-2">$1</h4>');
  html = html.replace(/^### (.+)$/gm, '<h3 class="font-display font-semibold text-lg text-slate-200 mt-8 mb-3">$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2 class="font-display font-bold text-2xl text-slate-100 mt-12 mb-4 tracking-tight">$1</h2>');

  html = html.replace(/^> (.+)$/gm, '<blockquote class="border-l-2 border-amber/50 pl-4 my-6 text-slate-400 italic"><p>$1</p></blockquote>');

  html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-slate-200 font-semibold">$1</strong>');
  html = html.replace(/\*(.+?)\*/g, '<em class="text-slate-300 italic">$1</em>');
  html = html.replace(/`([^`]+)`/g, '<code class="font-mono text-sm bg-elevated px-1.5 py-0.5 rounded text-amber">$1</code>');

  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, text, href) => {
    if (href.startsWith('/')) {
      return `<a href="${href}" class="text-amber hover:underline underline-offset-2">${text}</a>`;
    }
    return `<a href="${href}" target="_blank" rel="noopener noreferrer" class="text-amber hover:underline underline-offset-2">${text}</a>`;
  });

  html = html.replace(/(?:^- .+$\n?)+/gm, (block) => {
    const items = block.trim().split('\n').map(line => {
      const content = line.replace(/^- /, '');
      return `<li class="leading-relaxed">${content}</li>`;
    }).join('\n');
    return `<ul class="list-disc list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ul>`;
  });

  html = html.replace(/(?:^\d+\. .+$\n?)+/gm, (block) => {
    const items = block.trim().split('\n').map(line => {
      const content = line.replace(/^\d+\. /, '');
      return `<li class="leading-relaxed">${content}</li>`;
    }).join('\n');
    return `<ol class="list-decimal list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ol>`;
  });

  const lines = html.split('\n');
  const result: string[] = [];
  let inBlock = false;

  for (const line of lines) {
    const trimmed = line.trim();

    if (trimmed.startsWith('<pre') || trimmed.startsWith('<ul') || trimmed.startsWith('<ol') || trimmed.startsWith('<blockquote') || trimmed.startsWith('<h') || trimmed.startsWith('<hr') || trimmed.startsWith('<div')) {
      inBlock = true;
    }

    if (inBlock) {
      result.push(line);
      if (trimmed.startsWith('</pre>') || trimmed.startsWith('</ul>') || trimmed.startsWith('</ol>') || trimmed.startsWith('</blockquote>') || trimmed.endsWith('</h2>') || trimmed.endsWith('</h3>') || trimmed.endsWith('</h4>') || trimmed.startsWith('<hr') || trimmed.endsWith('</div>')) {
        inBlock = false;
      }
      continue;
    }

    if (trimmed === '') {
      result.push('');
      continue;
    }

    if (!trimmed.startsWith('<')) {
      result.push(`<p class="text-slate-400 leading-relaxed mb-4">${trimmed}</p>`);
    } else {
      result.push(line);
    }
  }

  return result.join('\n');
}

let content = "";
try {
  const mdPath = path.join(process.cwd(), "public", "guides", "blog-agent-fleet-rate-limit-design.md");
  const raw = fs.readFileSync(mdPath, "utf-8");
  content = raw.replace(/^---[\s\S]*?---\n/, "");
  content = content.replace(/^# .+\n+/, "");
} catch {
  content = "Article content could not be loaded. Please check back shortly.";
}

const htmlContent = markdownToHtml(content);
---

<Layout
  title="Designing Agent Fleets That Survive Rate Limits | Rhumb"
  description="Production architecture patterns for agent fleets that need to survive rate limits, dynamic capacity shifts, and 2am retry storms."
  canonical="/blog/agent-fleet-rate-limit-design"
  ogTitle="Designing Agent Fleets That Survive Rate Limits"
  ogDescription="The question is not whether an API has limits. It is whether your fleet can interpret them, slow down cleanly, and keep one burst from becoming a morning of false incidents."
  ogUrl="https://rhumb.dev/blog/agent-fleet-rate-limit-design"
  ogType="article"
  twitterTitle="Designing Agent Fleets That Survive Rate Limits"
  twitterDescription="Per-agent budgets, jitter, scheduling discipline, and auth-vs-429 separation are what keep a fleet alive at 2am."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <article class="max-w-3xl mx-auto px-6 pt-14 pb-24">
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">Infrastructure</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-500">March 30, 2026</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-emerald-400/70">Updated April 29, 2026</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-600">Pedro Nunes</span>
        </div>

        <h1 class="font-display font-bold text-3xl sm:text-4xl text-slate-100 leading-tight tracking-tight mb-6">
          Designing Agent Fleets That Survive Rate Limits
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed">
          Rate limits stop being a single-request nuisance once multiple agents are live. The real job is making sure one burst, one 429 window, or one weak provider surface does not turn into a fleet-wide retry storm.
        </p>
      </header>

      <div class="prose-rhumb" set:html={htmlContent} />

      <section class="mt-16 rounded-[28px] border border-emerald-500/20 bg-emerald-500/5 p-8 text-center sm:text-left">
        <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-emerald-300 mb-3">Next honest step</div>
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-3">
          Keep the rate budget narrow before you widen the authority surface
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6 max-w-2xl mx-auto sm:mx-0">
          Fleet reliability only matters if the workflow is still bounded enough to reason about. Start with capability-first onboarding when you are still separating reads, writes, and authority boundaries. Open the direct managed path once the lane is already well-scoped and one governed key is the honest fit.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row sm:justify-start">
          <a
            data-rhumb-propagate
            href="/blog/capability-first-agent-onboarding?rhumb_experiment=e004&rhumb_source=fleet-rate-limit-onboarding"
            class="inline-flex items-center justify-center rounded-xl bg-emerald-400 px-5 py-3 text-sm font-display font-semibold text-navy hover:bg-emerald-300 transition-colors duration-200"
          >
            See the capability-first handoff &rarr;
          </a>
          <a
            data-rhumb-propagate
            href="/start-managed-execution?rhumb_experiment=e004&rhumb_source=fleet-rate-limit-direct"
            class="inline-flex items-center justify-center rounded-xl border border-emerald-500/30 px-5 py-3 text-sm font-display font-semibold text-emerald-200 hover:border-emerald-400/60 hover:text-emerald-100 transition-colors duration-200"
          >
            Open the managed path &rarr;
          </a>
        </div>
      </section>

      <section class="mt-12" data-section="fleet-follow-through">
        <div class="rounded-[28px] border border-slate-800 bg-surface/70 p-6">
          <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Fleet follow-through</div>
          <h2 class="mb-3 font-display text-2xl font-semibold tracking-tight text-slate-100">
            Rate budgets only hold if the rest of the lane is governed too
          </h2>
          <p class="mb-5 leading-relaxed text-slate-300">
            Shared rate windows are only one failure surface. The same fleet also needs clean retry behavior inside agent loops, credential lifecycle controls that do not create surprise auth outages, and an onboarding path that keeps the first execution lane narrow enough to reason about. These three pages fill in that operator picture.
          </p>
          <div class="grid gap-3 sm:grid-cols-3">
            <a href="/blog/llm-apis-agent-loops" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">LLM APIs in Agent Loops</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">What actually breaks before the 429, after retries, tool use, and multi-step plans start compounding.</p>
            </a>
            <a href="/blog/api-credentials-agent-fleets" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">API Credentials in Autonomous Agent Fleets</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Why rate discipline still collapses if one shared key rotates badly or carries more scope than the lane needs.</p>
            </a>
            <a href="/blog/capability-first-agent-onboarding" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Capability-First Agent Onboarding</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">How to start with a bounded workflow before a rate-limited provider becomes a fleet-wide incident source.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="mt-12" data-section="runtime-budget-follow-through">
        <div class="rounded-[28px] border border-slate-800 bg-surface/70 p-6">
          <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Runtime budget follow-through</div>
          <h2 class="mb-3 font-display text-2xl font-semibold tracking-tight text-slate-100">
            Quota discipline only works when token burn is visible and authority stays narrow
          </h2>
          <p class="mb-5 leading-relaxed text-slate-300">
            A 429 storm usually starts earlier: oversized tool output, repeated intermediate chatter, or a loop that can see more authority than the task actually needs. These follow-on pages keep the rate-limit story anchored to spend attribution, session evidence, and tighter tool boundaries.
          </p>
          <div class="grid gap-3 sm:grid-cols-3">
            <a href="/blog/mcp-observability-logging-auditing-debugging" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">MCP Observability</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Why token burn, side effects, and retry safety only become governable once the trace shows who spent what and where the loop degraded.</p>
            </a>
            <a href="/blog/tool-level-permission-scoping-mcp" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Tool-Level Permission Scoping</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Shared budget incidents get smaller when one noisy workflow cannot inherit a broader tool surface than it needs.</p>
            </a>
            <a href="/blog/remote-mcp-auth-identity-vs-authority" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Identity vs Authority</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Quota failures are easier to contain when the trace can separate who authenticated from which tenant-scoped authority actually acted.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="font-display font-semibold text-lg text-slate-100 mb-4">Related</h2>
        <div class="space-y-4">
          {RELATED_READING.map((item) => (
            <a href={item.href} class="block bg-surface border border-slate-800 rounded-lg p-5 hover:border-amber/30 transition-colors">
              <span class="text-xs font-mono text-amber uppercase tracking-widest">Owned surface</span>
              <h3 class="font-display font-semibold text-slate-100 mt-2">{item.title}</h3>
              <p class="text-sm text-slate-500 mt-1">{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    (() => {
      if (typeof window === "undefined") return;
      const params = new URLSearchParams(window.location.search);
      const experiment = params.get("rhumb_experiment");
      const source = params.get("rhumb_source");
      const parentSource = params.get("rhumb_parent_source");
      if (!experiment && !source && !parentSource) return;

      document.querySelectorAll("a[data-rhumb-propagate]").forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;
        const url = new URL(href, window.location.origin);
        if (experiment && !url.searchParams.has("rhumb_experiment")) url.searchParams.set("rhumb_experiment", experiment);
        if (source) url.searchParams.set("rhumb_parent_source", source);
        if (parentSource) url.searchParams.set("rhumb_grandparent_source", parentSource);
        link.setAttribute("href", `${url.pathname}${url.search}${url.hash}`);
      });
    })();
  </script>
</Layout>
