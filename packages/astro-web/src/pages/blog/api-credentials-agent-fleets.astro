---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import fs from "node:fs";
import path from "node:path";

const RELATED_READING = [
  {
    href: "/blog/agent-credential-paths-managed-key-byok-agent-vault-x402",
    title: "Agent Credential Paths: Managed Key, BYOK, Agent Vault, x402, or Provider Pinning?",
    description: "Choose the right execution rail before an agent repeats a paid or customer-owned API call.",
  },
  {
    href: "/blog/securing-keys-for-agents",
    title: "Securing Keys for Agents",
    description: "The authority-boundary view once you move from secret storage to governed capability design.",
  },
  {
    href: "/blog/remote-mcp-auth-identity-vs-authority",
    title: "Remote MCP Auth: Identity vs Authority",
    description: "Why auth proving who connected still does not answer which tools stay visible or which backend principal actually acts.",
  },
  {
    href: "/blog/agent-fleet-rate-limit-design",
    title: "Designing Agent Fleets That Survive Rate Limits",
    description: "The retry and orchestration patterns that keep auth and rate-limit failures from blending together.",
  },
  {
    href: "/blog/llm-apis-agent-loops",
    title: "LLM APIs in Agent Loops: What Actually Breaks at Scale",
    description: "What changes once retries, tool calls, and unattended execution are live.",
  },
  {
    href: "/blog/capability-first-agent-onboarding",
    title: "Capability-First Agent Onboarding: Managed Superpowers First",
    description: "Where bounded execution starts once the authority surface is narrow enough to trust.",
  },
];

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "API Credentials in Autonomous Agent Fleets",
  datePublished: "2026-03-31T00:00:00Z",
  dateModified: "2026-05-02T00:00:00Z",
  author: {
    "@type": "Person",
    name: "Pedro Nunes",
  },
  description:
    "A secrets and credential-lifecycle architecture guide for autonomous agent fleets that need to survive rotation, expiry, revocation, and scope drift.",
  url: "https://rhumb.dev/blog/api-credentials-agent-fleets",
  publisher: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};

function markdownToHtml(md: string): string {
  let html = md;

  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_match, _lang, code) => {
    return `<pre class="bg-elevated border border-slate-800 rounded-lg p-4 my-6 overflow-x-auto text-sm font-mono text-slate-300"><code>${code.replace(/</g, '&lt;').replace(/>/g, '&gt;').trim()}</code></pre>`;
  });

  html = html.replace(/^---$/gm, '<hr class="border-slate-800 my-10" />');

  html = html.replace(/(?:^\|.+\|$\n?)+/gm, (block) => {
    const rows = block.trim().split('\n').filter(r => !r.match(/^\|[\s-:|]+\|$/));
    if (rows.length === 0) return block;
    const headerCells = rows[0].split('|').filter(c => c.trim()).map(c =>
      `<th class="px-4 py-3 text-left text-xs font-mono font-semibold text-slate-300 uppercase tracking-wider">${c.trim()}</th>`
    ).join('\n');
    const bodyRows = rows.slice(1).map(row => {
      const cells = row.split('|').filter(c => c.trim()).map(c =>
        `<td class="px-4 py-3 text-sm text-slate-400">${c.trim()}</td>`
      ).join('\n');
      return `<tr class="border-t border-slate-800">${cells}</tr>`;
    }).join('\n');
    return `<div class="overflow-x-auto my-6"><table class="w-full border border-slate-800 rounded-lg"><thead class="bg-elevated"><tr>${headerCells}</tr></thead><tbody>${bodyRows}</tbody></table></div>`;
  });

  html = html.replace(/^#### (.+)$/gm, '<h4 class="font-display font-semibold text-base text-slate-300 mt-6 mb-2">$1</h4>');
  html = html.replace(/^### (.+)$/gm, '<h3 class="font-display font-semibold text-lg text-slate-200 mt-8 mb-3">$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2 class="font-display font-bold text-2xl text-slate-100 mt-12 mb-4 tracking-tight">$1</h2>');

  html = html.replace(/^> (.+)$/gm, '<blockquote class="border-l-2 border-amber/50 pl-4 my-6 text-slate-400 italic"><p>$1</p></blockquote>');

  html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-slate-200 font-semibold">$1</strong>');
  html = html.replace(/\*(.+?)\*/g, '<em class="text-slate-300 italic">$1</em>');
  html = html.replace(/`([^`]+)`/g, '<code class="font-mono text-sm bg-elevated px-1.5 py-0.5 rounded text-amber">$1</code>');

  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, text, href) => {
    if (href.startsWith('/')) {
      return `<a href="${href}" class="text-amber hover:underline underline-offset-2">${text}</a>`;
    }
    return `<a href="${href}" target="_blank" rel="noopener noreferrer" class="text-amber hover:underline underline-offset-2">${text}</a>`;
  });

  html = html.replace(/(?:^- .+$\n?)+/gm, (block) => {
    const items = block.trim().split('\n').map(line => {
      const content = line.replace(/^- /, '');
      return `<li class="leading-relaxed">${content}</li>`;
    }).join('\n');
    return `<ul class="list-disc list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ul>`;
  });

  html = html.replace(/(?:^\d+\. .+$\n?)+/gm, (block) => {
    const items = block.trim().split('\n').map(line => {
      const content = line.replace(/^\d+\. /, '');
      return `<li class="leading-relaxed">${content}</li>`;
    }).join('\n');
    return `<ol class="list-decimal list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ol>`;
  });

  const lines = html.split('\n');
  const result: string[] = [];
  let inBlock = false;

  for (const line of lines) {
    const trimmed = line.trim();

    if (trimmed.startsWith('<pre') || trimmed.startsWith('<ul') || trimmed.startsWith('<ol') || trimmed.startsWith('<blockquote') || trimmed.startsWith('<h') || trimmed.startsWith('<hr') || trimmed.startsWith('<div')) {
      inBlock = true;
    }

    if (inBlock) {
      result.push(line);
      if (trimmed.startsWith('</pre>') || trimmed.startsWith('</ul>') || trimmed.startsWith('</ol>') || trimmed.startsWith('</blockquote>') || trimmed.endsWith('</h2>') || trimmed.endsWith('</h3>') || trimmed.endsWith('</h4>') || trimmed.startsWith('<hr') || trimmed.endsWith('</div>')) {
        inBlock = false;
      }
      continue;
    }

    if (trimmed === '') {
      result.push('');
      continue;
    }

    if (!trimmed.startsWith('<')) {
      result.push(`<p class="text-slate-400 leading-relaxed mb-4">${trimmed}</p>`);
    } else {
      result.push(line);
    }
  }

  return result.join('\n');
}

let content = "";
try {
  const mdPath = path.join(process.cwd(), "public", "guides", "blog-api-credentials-agent-fleets.md");
  const raw = fs.readFileSync(mdPath, "utf-8");
  content = raw.replace(/^---[\s\S]*?---\n/, "");
  content = content.replace(/^# .+\n+/, "");
} catch {
  content = "Article content could not be loaded. Please check back shortly.";
}

const htmlContent = markdownToHtml(content);

const PERSONAL_GATEWAY_BROKERAGE = [
  "Separate the gateway owner from the provider principal. A personal MCP gateway should not make every downstream call look like one ambient human account.",
  "Bind each attached service to a credential lane, scope, quota owner, and revocation path before it appears in the shared tool catalog.",
  "Treat local convenience as a different trust class from remote brokerage. The moment another agent, host, or workflow uses the gateway, credential provenance becomes production evidence.",
  "Record denied neighbors for every brokered provider: wrong workspace, neighboring tenant, blocked tool, expired secret, or quota owner mismatch should fail before the provider sees the call.",
];
---

<Layout
  title="API Credentials in Autonomous Agent Fleets | Rhumb"
  description="A secrets and credential-lifecycle architecture guide for autonomous agent fleets that need to survive rotation, expiry, revocation, and scope drift."
  canonical="/blog/api-credentials-agent-fleets"
  ogTitle="API Credentials in Autonomous Agent Fleets"
  ogDescription="The hard part is not just storing secrets. It is surviving rotation, expiry, scope drift, and revocation without turning one auth event into a fleet outage."
  ogUrl="https://rhumb.dev/blog/api-credentials-agent-fleets"
  ogType="article"
  twitterTitle="API Credentials in Autonomous Agent Fleets"
  twitterDescription="Autonomous fleets need credential lifecycle design, not just secret storage. Rotation blindness and shared-key cascades are the real failure modes."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <article class="max-w-3xl mx-auto px-6 pt-14 pb-24">
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">Infrastructure</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-500">March 31, 2026</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-emerald-400/70">Updated April 28, 2026</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-600">Pedro Nunes</span>
        </div>

        <h1 class="font-display font-bold text-3xl sm:text-4xl text-slate-100 leading-tight tracking-tight mb-6">
          API Credentials in Autonomous Agent Fleets
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed">
          Secure storage is only the floor. The real production problem is whether a fleet can survive rotation, expiry, revocation, and scope drift without one auth event turning into a shared outage.
        </p>
      </header>

      <div class="prose-rhumb" set:html={htmlContent} />

      <section class="mt-14 rounded-[28px] border border-sky-500/20 bg-sky-500/5 p-6 sm:p-8">
        <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-sky-300 mb-3">Personal gateway brokerage</div>
        <h2 class="font-display font-bold text-2xl text-slate-100 tracking-tight mb-3">
          A self-hosted MCP gateway still has to broker credentials, not just hide them.
        </h2>
        <p class="text-slate-300 leading-relaxed mb-5">
          Personal MCP gateways sound safer because the operator controls the box. That helps, but it does not answer which downstream credential the agent inherits, whose quota burns, or how a blocked provider lane proves it failed before touching the wrong workspace. Once several tools sit behind one gateway, credential brokerage becomes the trust boundary.
        </p>
        <ul class="grid gap-3 sm:grid-cols-2">
          {PERSONAL_GATEWAY_BROKERAGE.map((item) => (
            <li class="rounded-2xl border border-sky-500/20 bg-navy/60 p-4 text-sm leading-6 text-slate-300">{item}</li>
          ))}
        </ul>
      </section>

      <section class="mt-16 rounded-[28px] border border-emerald-500/20 bg-emerald-500/5 p-8 text-center sm:text-left">
        <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-emerald-300 mb-3">Next honest step</div>
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-3">
          Keep the authority boundary narrow before you chase automation breadth
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6 max-w-2xl mx-auto sm:mx-0">
          If you still need to separate read, write, admin, and human-approval boundaries, capability-first onboarding is the honest move. Open the direct managed path once the workflow is already bounded enough that one governed key is a controlled fit, not a leap of faith.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row sm:justify-start">
          <a
            data-rhumb-propagate
            href="/blog/capability-first-agent-onboarding?rhumb_experiment=e004&rhumb_source=credential-fleet-onboarding"
            class="inline-flex items-center justify-center rounded-xl bg-emerald-400 px-5 py-3 text-sm font-display font-semibold text-navy hover:bg-emerald-300 transition-colors duration-200"
          >
            See the capability-first handoff &rarr;
          </a>
          <a
            data-rhumb-propagate
            href="/start-managed-execution?rhumb_experiment=e004&rhumb_source=credential-fleet-direct"
            class="inline-flex items-center justify-center rounded-xl border border-emerald-500/30 px-5 py-3 text-sm font-display font-semibold text-emerald-200 hover:border-emerald-400/60 hover:text-emerald-100 transition-colors duration-200"
          >
            Open the managed path &rarr;
          </a>
        </div>
      </section>

      <section class="mt-12" data-section="fleet-follow-through">
        <div class="rounded-[28px] border border-slate-800 bg-surface/70 p-6">
          <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Fleet follow-through</div>
          <h2 class="mb-3 font-display text-2xl font-semibold tracking-tight text-slate-100">
            Credential hygiene only works when the surrounding lane is disciplined too
          </h2>
          <p class="mb-5 leading-relaxed text-slate-300">
            Rotation, expiry, and revocation are only part of the fleet problem. The same workflow also needs a clean identity-versus-authority split after auth, retry behavior that does not amplify failures, shared rate budgets that do not let one agent burn everyone else, and a first execution surface that stays narrow enough to keep the trust boundary legible. These four pages complete that control path.
          </p>
          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <a href="/blog/remote-mcp-auth-identity-vs-authority" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Remote MCP Auth: Identity vs Authority</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Why a fresh credential still is not enough if discovery scope and backend authority stay broader than the intended lane.</p>
            </a>
            <a href="/blog/llm-apis-agent-loops" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">LLM APIs in Agent Loops</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">What breaks upstream when agents keep retrying, chaining tools, and hiding auth failures inside the loop.</p>
            </a>
            <a href="/blog/agent-fleet-rate-limit-design" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Designing Agent Fleets That Survive Rate Limits</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">How to keep one credentialed workflow from burning the shared provider budget for the rest of the fleet.</p>
            </a>
            <a href="/blog/capability-first-agent-onboarding" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Capability-First Agent Onboarding</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Why the first honest control is narrowing the lane before you start handing long-lived credentials to more agents.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="mt-12" data-section="runtime-evidence-follow-through">
        <div class="rounded-[28px] border border-slate-800 bg-surface/70 p-6">
          <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Runtime evidence follow-through</div>
          <h2 class="mb-3 font-display text-2xl font-semibold tracking-tight text-slate-100">
            Credential hygiene still needs spend evidence and smaller tool surfaces
          </h2>
          <p class="mb-5 leading-relaxed text-slate-300">
            Rotation and revocation are only half the control problem. Operators also need traces that show which session burned quota before auth degraded, plus permission boundaries that stop one credentialed loop from touching more tools than the lane requires.
          </p>
          <div class="grid gap-3 sm:grid-cols-3">
            <a href="/blog/mcp-observability-logging-auditing-debugging" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">MCP Observability</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Why auth expiry, token burn, and retry safety only become debuggable once the trace keeps principal, spend, and side effects together.</p>
            </a>
            <a href="/blog/agent-fleet-rate-limit-design" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Designing Agent Fleets That Survive Rate Limits</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Shared keys fail faster when one noisy loop burns the budget for the rest of the fleet before rotation or reauth even starts.</p>
            </a>
            <a href="/blog/tool-level-permission-scoping-mcp" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-slate-700">
              <div class="text-sm font-semibold text-slate-100">Tool-Level Permission Scoping</div>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">Credential incidents shrink when the same token cannot silently unlock a broader execution surface than the task actually needs.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="font-display font-semibold text-lg text-slate-100 mb-4">Related</h2>
        <div class="space-y-4">
          {RELATED_READING.map((item) => (
            <a href={item.href} class="block bg-surface border border-slate-800 rounded-lg p-5 hover:border-amber/30 transition-colors">
              <span class="text-xs font-mono text-amber uppercase tracking-widest">Owned surface</span>
              <h3 class="font-display font-semibold text-slate-100 mt-2">{item.title}</h3>
              <p class="text-sm text-slate-500 mt-1">{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    (() => {
      if (typeof window === "undefined") return;
      const params = new URLSearchParams(window.location.search);
      const experiment = params.get("rhumb_experiment");
      const source = params.get("rhumb_source");
      const parentSource = params.get("rhumb_parent_source");
      if (!experiment && !source && !parentSource) return;

      document.querySelectorAll("a[data-rhumb-propagate]").forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;
        const url = new URL(href, window.location.origin);
        if (experiment && !url.searchParams.has("rhumb_experiment")) url.searchParams.set("rhumb_experiment", experiment);
        if (source) url.searchParams.set("rhumb_parent_source", source);
        if (parentSource) url.searchParams.set("rhumb_grandparent_source", parentSource);
        link.setAttribute("href", `${url.pathname}${url.search}${url.hash}`);
      });
    })();
  </script>
</Layout>
