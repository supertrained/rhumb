const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "A Production Readiness Checklist for Remote MCP Servers",
  datePublished: "2026-04-14T00:00:00Z",
  dateModified: "2026-05-12T08:16:00Z",
  author: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
