---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import { PUBLIC_TRUTH } from "../../lib/public-truth";
import { getServiceScore } from "../../lib/api";
import { getTierInfo } from "../../lib/utils";
import type { ServiceScoreViewModel } from "../../lib/types";

const servicesLabel = PUBLIC_TRUTH.servicesLabel;
const categoriesLabel = PUBLIC_TRUTH.categoriesLabel;

const scoreMap = {
  stripe: await getServiceScore("stripe"),
  "lemon-squeezy": await getServiceScore("lemon-squeezy"),
  square: await getServiceScore("square"),
  adyen: await getServiceScore("adyen"),
  braintree: await getServiceScore("braintree"),
  paypal: await getServiceScore("paypal"),
} satisfies Record<string, ServiceScoreViewModel | null>;

type ScoreFallback = {
  agg: number;
  exec: number;
  access: number;
  confidence: number;
  tier: string;
  tierLabel: string;
};

type PaymentService = {
  slug: keyof typeof scoreMap;
  name: string;
  bestFor: string;
  agentFriction: string;
  routingRule: string;
  fallback: ScoreFallback;
  data: ServiceScoreViewModel | null;
};

const payments: PaymentService[] = [
  {
    slug: "stripe",
    name: "Stripe",
    bestFor: "Software-native subscriptions, invoices, checkout, and usage-billing loops where retry safety matters more than channel coverage.",
    agentFriction: "Restricted-key scope mistakes and webhook version drift are the main ways agents get misleading partial evidence.",
    routingRule: "Default to Stripe unless the workflow is explicitly physical-commerce, PayPal-native, or enterprise-acquirer constrained.",
    fallback: { agg: 8.1, exec: 9.0, access: 6.6, confidence: 0.9, tier: "L4", tierLabel: "Native" },
    data: scoreMap.stripe,
  },
  {
    slug: "lemon-squeezy",
    name: "Lemon Squeezy",
    bestFor: "Simple software-product payments when tax handling and merchant-of-record packaging matter more than deep payment orchestration.",
    agentFriction: "Clean API shape, but less programmatic breadth and weaker enterprise control surface than Stripe.",
    routingRule: "Use when the product needs merchant-of-record simplicity; do not use it as the default programmable payment rail.",
    fallback: { agg: 6.8, exec: 7.1, access: 6.2, confidence: 0.52, tier: "L3", tierLabel: "Ready" },
    data: scoreMap["lemon-squeezy"],
  },
  {
    slug: "square",
    name: "Square",
    bestFor: "Retail, catalog, location, inventory, and point-of-sale workflows where payment is attached to physical commerce.",
    agentFriction: "Merchant/KYC setup, conservative limits, and location-scoped operating context make autonomous setup less smooth than Stripe.",
    routingRule: "Choose Square when locations or in-person commerce are first-class objects, not when you just need internet payments.",
    fallback: { agg: 6.27, exec: 7.3, access: 5.2, confidence: 0.92, tier: "L3", tierLabel: "Ready" },
    data: scoreMap.square,
  },
  {
    slug: "adyen",
    name: "Adyen",
    bestFor: "High-volume, multi-region, enterprise commerce that needs acquiring, risk, and payout machinery in one platform.",
    agentFriction: "Manual onboarding, merchant-account setup, and enterprise assumptions make it a poor default for cold-start agents.",
    routingRule: "Route to Adyen only when scale, region, acquiring, or compliance constraints justify the enterprise setup cost.",
    fallback: { agg: 8.8, exec: 8.9, access: 8.5, confidence: 0.61, tier: "L4", tierLabel: "Native" },
    data: scoreMap.adyen,
  },
  {
    slug: "braintree",
    name: "Braintree",
    bestFor: "PayPal-adjacent card processing where a team already lives inside the PayPal/Braintree account model.",
    agentFriction: "Legacy API patterns, sandbox complexity, and less transparent rate-limit behavior add avoidable agent control-plane work.",
    routingRule: "Prefer it when PayPal ecosystem constraints are real; otherwise Stripe and Square are cleaner agent targets.",
    fallback: { agg: 8.3, exec: 8.5, access: 8.0, confidence: 0.56, tier: "L4", tierLabel: "Native" },
    data: scoreMap.braintree,
  },
  {
    slug: "paypal",
    name: "PayPal",
    bestFor: "Buyer-trust, wallet, or payout requirements where PayPal itself is the product requirement.",
    agentFriction: "Older state machines, account verification, webhook verification, and dashboard-heavy workflows force more human-era handling.",
    routingRule: "Use PayPal because the market demands PayPal, not because it is the most agent-native payment API.",
    fallback: { agg: 4.89, exec: 5.9, access: 3.7, confidence: 0.95, tier: "L2", tierLabel: "Developing" },
    data: scoreMap.paypal,
  },
];

function aggregate(item: PaymentService): number {
  return item.data?.aggregateRecommendationScore ?? item.fallback.agg;
}
function execution(item: PaymentService): number {
  return item.data?.executionScore ?? item.fallback.exec;
}
function access(item: PaymentService): number {
  return item.data?.accessReadinessScore ?? item.fallback.access;
}
function confidence(item: PaymentService): number {
  return item.data?.confidence ?? item.fallback.confidence;
}
function tier(item: PaymentService): string {
  return item.data?.tier ?? item.fallback.tier;
}
function tierLabel(item: PaymentService): string {
  return item.data?.tierLabel ?? item.fallback.tierLabel;
}
function scoreDate(item: PaymentService): string | null {
  return item.data?.calculatedAt ?? null;
}
function fmt(value: number): string {
  return value.toFixed(1);
}
function fmtConfidence(value: number): string {
  return `${Math.round(value * 100)}%`;
}

const ranked = [...payments].sort((a, b) => aggregate(b) - aggregate(a));
const winner = ranked[0];
const lastScoreDate = ranked.map(scoreDate).filter(Boolean).sort().at(-1);
const updatedAt = lastScoreDate
  ? new Date(lastScoreDate).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : "May 26, 2026";
const updatedAtISO = lastScoreDate ? new Date(lastScoreDate).toISOString() : "2026-05-26T00:00:00.000Z";
const scoreRange = `${fmt(aggregate(ranked[ranked.length - 1]))}–${fmt(aggregate(winner))}`;

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Payment API Scorecard for AI Agents",
  datePublished: "2026-03-09T00:00:00Z",
  dateModified: updatedAtISO,
  author: {
    "@type": "Person",
    name: "Pedro Nunes",
  },
  description:
    "Rhumb's payment API scorecard compares Stripe, Lemon Squeezy, Square, Adyen, Braintree, and PayPal for autonomous AI-agent workflows.",
  url: "https://rhumb.dev/blog/payments-for-agents",
  publisher: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};

const decisionRows = [
  ["Raw score winner", `${winner.name} leads the scorecard at ${fmt(aggregate(winner))}; treat confidence and onboarding context as tie-breakers before routing production money.`],
  ["Selling software or subscriptions", "Start with Stripe; consider Lemon Squeezy when merchant-of-record simplicity is the binding requirement."],
  ["Physical commerce or inventory", "Start with Square because locations, catalogs, and point-of-sale context are first-class."],
  ["Enterprise acquiring / global risk", "Evaluate Adyen after confirming onboarding and merchant-account requirements are acceptable."],
  ["PayPal buyer demand", "Use PayPal or Braintree because the market requires it, not because the agent path is cleaner."],
];
---

<Layout
  title="Payment API Scorecard for AI Agents | Rhumb"
  description={`Rhumb scored six payment APIs for AI-agent compatibility. Current range: ${scoreRange}. Adyen leads raw score; Stripe stays the software-native default; PayPal remains constraint-driven.`}
  canonical="/blog/payments-for-agents"
  ogTitle="Payment API Scorecard for AI Agents"
  ogDescription="Adyen, Braintree, Stripe, Lemon Squeezy, Square, and PayPal ranked by Rhumb's Agent-Native Score."
  ogImage="/api/og?title=Payment+API+Scorecard&subtitle=Agent-Native+Scores+for+AI+agents"
  ogUrl="https://rhumb.dev/blog/payments-for-agents"
  ogType="article"
  twitterTitle="Payment API Scorecard for AI Agents"
  twitterDescription="Six payment APIs ranked by Rhumb's Agent-Native Score, plus the practical routing rule for agents."
  twitterImage="/api/og?title=Payment+API+Scorecard&subtitle=Agent-Native+Scores+for+AI+agents"
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen overflow-hidden">
    <article class="max-w-5xl mx-auto px-6 pt-14 pb-24">
      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="text-xs font-mono font-semibold text-amber uppercase tracking-[0.28em]">Scorecard</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-500">March 9, 2026</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-emerald-400/70">Updated {updatedAt}</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-600">{servicesLabel} services · {categoriesLabel} categories</span>
        </div>

        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 leading-tight tracking-tight mb-6">
          Payment API scorecard for AI agents
        </h1>

        <p class="text-lg text-slate-300 leading-relaxed max-w-3xl">
          Humans choose payment processors by brand, price, and sales context. Agents need a different answer:
          which API can they call, retry, scope, audit, and recover from without human babysitting?
          If the agent is operating inside an autonomous task market, use the companion
          <a href="/blog/task-market-payment-provider-profiles" class="text-emerald-300 hover:text-emerald-200 underline decoration-emerald-500/40 underline-offset-4">payment-provider profile guide</a>
          to make the provider choice planner-readable.
        </p>

        <div class="mt-8 rounded-2xl border border-emerald-500/20 bg-emerald-500/8 p-5">
          <p class="text-sm leading-6 text-slate-300">
            <span class="font-semibold text-slate-100">Current verdict:</span>
            {" "}{winner.name} leads the raw payment scorecard at <span class="font-mono text-emerald-300">{fmt(aggregate(winner))}</span>.
            Stripe remains the cleanest software-native default because its score has higher confidence and fewer enterprise onboarding assumptions.
            PayPal sits at <span class="font-mono text-amber-300">{fmt(aggregate(payments.find((item) => item.slug === "paypal")!))}</span>,
            so treat it as a distribution constraint rather than the default agent rail.
          </p>
        </div>
      </header>

      <section class="mb-12">
        <h2 class="font-display font-semibold text-2xl text-slate-100 mb-5">Ranked payment APIs</h2>
        <div class="grid gap-4">
          {ranked.map((tool, index) => {
            const tierStyle = getTierInfo(aggregate(tool));
            return (
              <div class="rounded-2xl border border-slate-800 bg-surface/90 p-5 hover:border-slate-700 transition-colors">
                <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-3">
                      <span class="font-mono text-sm text-slate-600">#{index + 1}</span>
                      <a href={`/service/${tool.slug}`} class="font-display font-semibold text-xl text-slate-100 hover:text-amber transition-colors">
                        {tool.name}
                      </a>
                      <span class={`text-xs font-mono px-2 py-1 rounded border ${tierStyle.bgClass} ${tierStyle.borderClass} ${tierStyle.textClass}`}>
                        {tier(tool)} {tierLabel(tool)}
                      </span>
                      <span class="text-xs font-mono text-slate-500">confidence {fmtConfidence(confidence(tool))}</span>
                    </div>
                    <p class="mt-3 text-sm leading-6 text-slate-300">{tool.bestFor}</p>
                    <p class="mt-2 text-sm leading-6 text-slate-500"><span class="text-slate-400">Agent friction:</span> {tool.agentFriction}</p>
                  </div>

                  <div class="grid grid-cols-3 gap-3 md:w-80 shrink-0">
                    <div class="rounded-xl border border-white/6 bg-navy/65 px-4 py-3 text-center">
                      <div class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">AN</div>
                      <div class="mt-1 font-mono text-xl font-bold text-slate-100">{fmt(aggregate(tool))}</div>
                    </div>
                    <div class="rounded-xl border border-white/6 bg-navy/65 px-4 py-3 text-center">
                      <div class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Exec</div>
                      <div class="mt-1 font-mono text-xl font-bold text-slate-100">{fmt(execution(tool))}</div>
                    </div>
                    <div class="rounded-xl border border-white/6 bg-navy/65 px-4 py-3 text-center">
                      <div class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Access</div>
                      <div class="mt-1 font-mono text-xl font-bold text-slate-100">{fmt(access(tool))}</div>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
        <p class="mt-3 text-xs font-mono text-slate-600">
          Agent-Native Score: Execution 70% + Access Readiness 30%. Scores load from Rhumb's public service-score surface, with May 26, 2026 production-API fallback values embedded for build resilience.
        </p>
      </section>

      <section class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr] mb-12">
        <div class="rounded-2xl border border-slate-800 bg-surface p-6">
          <h2 class="font-display font-semibold text-xl text-slate-100 mb-4">The rule agents should use</h2>
          <p class="text-slate-300 leading-7">
            Do not ask “which payment API is biggest?” Ask “which one gives the agent the most recoverable control plane for this route?”
            The raw winner is Adyen, mostly because enterprise governance and execution score well. The practical cold-start default is still Stripe: high confidence, strong execution, and lower onboarding ambiguity for software-native agents.
          </p>
        </div>

        <div class="rounded-2xl border border-slate-800 bg-surface p-6">
          <h2 class="font-display font-semibold text-xl text-slate-100 mb-4">Decision table</h2>
          <div class="space-y-3">
            {decisionRows.map(([constraint, pick]) => (
              <div class="grid gap-2 rounded-xl border border-white/6 bg-navy/55 p-4 md:grid-cols-[190px_1fr]">
                <div class="text-xs font-mono uppercase tracking-[0.18em] text-slate-500">{constraint}</div>
                <div class="text-sm leading-6 text-slate-300">{pick}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="prose-rhumb max-w-none">
        <h2>What changed from the old payment article</h2>
        <p>
          The previous version of this page hard-coded an older six-service snapshot. This version is tied back to Rhumb's current score surface and keeps the comparison anchored in the product: the scored service index, not a generic payments checklist.
        </p>
        <p>
          The useful market claim is narrower and stronger: agents should not optimize for payment brand familiarity. They should optimize for execution reliability, access readiness, scoped authority, retry safety, and evidence that lets an operator debug the route after money moves.
        </p>
      </section>

      <footer class="mt-14 flex flex-wrap items-center gap-4 border-t border-slate-800 pt-8">
        <a href="/leaderboard/payments" class="inline-flex items-center rounded-lg bg-amber px-5 py-3 font-semibold text-navy hover:bg-amber/90 transition-colors">
          View the payments leaderboard
        </a>
        <a href="/blog/stripe-vs-square-vs-paypal" class="inline-flex items-center rounded-lg border border-slate-700 px-5 py-3 font-semibold text-slate-200 hover:border-amber/70 hover:text-amber transition-colors">
          Compare Stripe, Square, and PayPal
        </a>
      </footer>
    </article>
  </div>
</Layout>
