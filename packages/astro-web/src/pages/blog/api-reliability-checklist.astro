---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import fs from "node:fs";
import path from "node:path";

const RETIRED_DEPENDENCY_GUARDRAILS = [
  "Inventory pinned model IDs, version enums, and fallback defaults across env vars, framework wrappers, credential tests, and dashboards.",
  "Check availability before execution and classify not-found or retirement errors as deterministic migration work, not retry noise.",
  "Treat the replacement as a new operating profile: parameters, stop reasons, tool behavior, rate limits, and price can all shift together.",
  "Fail closed when the workflow cannot prove compatibility yet, especially in auth checks and health checks that otherwise burn time before the real call even starts.",
];

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Before Your Agent Calls an API at 3am: A Reliability Checklist",
  datePublished: "2026-03-28T00:00:00Z",
  dateModified: "2026-04-23T00:00:00Z",
  author: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
  description:
    "Five practical questions that separate APIs which merely work in demos from APIs that still behave clearly and safely when your agent is running unattended.",
  url: "https://rhumb.dev/blog/api-reliability-checklist",
  publisher: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
  mainEntityOfPage: "https://rhumb.dev/blog/api-reliability-checklist",
};

const RELATED_READING = [
  {
    href: "/blog/how-to-evaluate-apis-for-agents",
    label: "Methodology",
    title: "How to Evaluate APIs for AI Agents",
    description: "The 20-dimension scoring framework behind the checklist.",
  },
  {
    href: "/blog/complete-guide-api-selection-for-ai-agents",
    label: "Guide",
    title: "The Complete Guide to API Selection for AI Agents",
    description: "The broader selection map once you move past a single checklist.",
  },
  {
    href: "/blog/machine-parseable-change-communication-for-agent-ready-apis",
    label: "Change Discipline",
    title: "API Versioning Is Table Stakes. Agent Readiness Depends on Machine-Parseable Change Communication",
    description: "Why retired model IDs and shifting parameter rules belong in the same operator checklist as retries, idempotency, and error quality.",
  },
  {
    href: "/blog/remote-mcp-production-readiness-checklist",
    label: "Production Readiness",
    title: "A Production Readiness Checklist for Remote MCP Servers",
    description: "The operator view once the surface is shared and the runtime is live.",
  },
  {
    href: "/blog/hubspot-api-autopsy",
    label: "Failure-mode Evidence",
    title: "HubSpot API Autopsy",
    description: "A concrete example of why reliability proof matters more than vendor familiarity.",
  },
];

function markdownToHtml(md: string): string {
  let html = md;

  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_match, _lang, code) => {
    return `<pre class="bg-elevated border border-slate-800 rounded-lg p-4 my-6 overflow-x-auto text-sm font-mono text-slate-300"><code>${code.replace(/</g, "&lt;").replace(/>/g, "&gt;").trim()}</code></pre>`;
  });

  html = html.replace(/^---$/gm, '<hr class="border-slate-800 my-10" />');

  html = html.replace(/(?:^\|.+\|$\n?)+/gm, (block) => {
    const rows = block.trim().split("\n").filter((r) => !r.match(/^\|[\s-:|]+\|$/));
    if (rows.length === 0) return block;
    const headerCells = rows[0]
      .split("|")
      .filter((c) => c.trim())
      .map((c) => `<th class="px-4 py-3 text-left text-xs font-mono font-semibold text-slate-300 uppercase tracking-wider">${c.trim()}</th>`)
      .join("\n");
    const bodyRows = rows
      .slice(1)
      .map((row) => {
        const cells = row
          .split("|")
          .filter((c) => c.trim())
          .map((c) => `<td class="px-4 py-3 text-sm text-slate-400">${c.trim()}</td>`)
          .join("\n");
        return `<tr class="border-t border-slate-800">${cells}</tr>`;
      })
      .join("\n");
    return `<div class="overflow-x-auto my-6"><table class="w-full border border-slate-800 rounded-lg"><thead class="bg-elevated"><tr>${headerCells}</tr></thead><tbody>${bodyRows}</tbody></table></div>`;
  });

  html = html.replace(/^#### (.+)$/gm, '<h4 class="font-display font-semibold text-base text-slate-300 mt-6 mb-2">$1</h4>');
  html = html.replace(/^### (.+)$/gm, '<h3 class="font-display font-semibold text-lg text-slate-200 mt-8 mb-3">$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2 class="font-display font-bold text-2xl text-slate-100 mt-12 mb-4 tracking-tight">$1</h2>');

  html = html.replace(/^> (.+)$/gm, '<blockquote class="border-l-2 border-amber/50 pl-4 my-6 text-slate-400 italic"><p>$1</p></blockquote>');

  html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-slate-200 font-semibold">$1</strong>');
  html = html.replace(/\*(.+?)\*/g, '<em class="text-slate-300 italic">$1</em>');
  html = html.replace(/`([^`]+)`/g, '<code class="font-mono text-sm bg-elevated px-1.5 py-0.5 rounded text-amber">$1</code>');

  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, text, href) => {
    if (href.startsWith("/")) {
      return `<a href="${href}" class="text-amber hover:underline underline-offset-2">${text}</a>`;
    }
    return `<a href="${href}" target="_blank" rel="noopener noreferrer" class="text-amber hover:underline underline-offset-2">${text}</a>`;
  });

  html = html.replace(/(?:^- .+$\n?)+/gm, (block) => {
    const items = block
      .trim()
      .split("\n")
      .map((line) => `<li class="leading-relaxed">${line.replace(/^- /, "")}</li>`)
      .join("\n");
    return `<ul class="list-disc list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ul>`;
  });

  html = html.replace(/(?:^\d+\. .+$\n?)+/gm, (block) => {
    const items = block
      .trim()
      .split("\n")
      .map((line) => `<li class="leading-relaxed">${line.replace(/^\d+\. /, "")}</li>`)
      .join("\n");
    return `<ol class="list-decimal list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ol>`;
  });

  const lines = html.split("\n");
  const result: string[] = [];
  let inBlock = false;

  for (const line of lines) {
    const trimmed = line.trim();

    if (
      trimmed.startsWith("<pre") ||
      trimmed.startsWith("<ul") ||
      trimmed.startsWith("<ol") ||
      trimmed.startsWith("<blockquote") ||
      trimmed.startsWith("<h") ||
      trimmed.startsWith("<hr") ||
      trimmed.startsWith("<div")
    ) {
      inBlock = true;
    }

    if (inBlock) {
      result.push(line);
      if (
        trimmed.startsWith("</pre>") ||
        trimmed.startsWith("</ul>") ||
        trimmed.startsWith("</ol>") ||
        trimmed.startsWith("</blockquote>") ||
        trimmed.endsWith("</h2>") ||
        trimmed.endsWith("</h3>") ||
        trimmed.endsWith("</h4>") ||
        trimmed.startsWith("<hr") ||
        trimmed.endsWith("</div>")
      ) {
        inBlock = false;
      }
      continue;
    }

    if (trimmed === "") {
      result.push("");
      continue;
    }

    if (!trimmed.startsWith("<")) {
      result.push(`<p class="text-slate-400 leading-relaxed mb-4">${trimmed}</p>`);
    } else {
      result.push(line);
    }
  }

  return result.join("\n");
}

let content = "";
try {
  const mdPath = path.join(process.cwd(), "public", "guides", "blog-api-reliability-checklist.md");
  const raw = fs.readFileSync(mdPath, "utf-8");
  content = raw.replace(/^---[\s\S]*?---\n/, "");
  content = content.replace(/^# .+\n+/, "");
} catch {
  content = "Article content could not be loaded. Please check back shortly.";
}

const htmlContent = markdownToHtml(content);
---

<Layout
  title="Before Your Agent Calls an API at 3am: A Reliability Checklist | Rhumb"
  description="Five practical questions that separate APIs which merely work in demos from APIs that still behave clearly and safely when your agent is running unattended."
  canonical="/blog/api-reliability-checklist"
  ogTitle="Before Your Agent Calls an API at 3am: A Reliability Checklist"
  ogDescription="The useful preflight is not feature breadth. It is whether the API still behaves legibly when your agent retries in the dark."
  ogUrl="https://rhumb.dev/blog/api-reliability-checklist"
  ogType="article"
  twitterTitle="Before Your Agent Calls an API at 3am: A Reliability Checklist"
  twitterDescription="Five questions before you let an unattended agent touch a real API."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen overflow-hidden">
    <section class="relative border-b border-slate-800/80">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_left,rgba(217,119,6,0.12),transparent_32%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.1),transparent_35%)]"></div>

      <div class="relative max-w-5xl mx-auto px-6 pt-14 pb-16">
        <div class="max-w-4xl">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <a href="/blog" class="text-xs font-mono text-slate-500 hover:text-amber transition-colors">&larr; Blog</a>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono font-semibold text-amber uppercase tracking-[0.28em]">Reliability</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-slate-500">March 28, 2026</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-emerald-400/70">Updated April 23, 2026</span>
          </div>

          <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl leading-[0.97] tracking-tight text-slate-100 max-w-5xl text-balance">
            Before your agent calls an API at 3am, run this reliability checklist
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-slate-300 leading-relaxed max-w-4xl">
            The useful question is not whether the integration worked once in a human-supervised demo. It is whether the API still behaves clearly, safely, and recoverably when the workflow retries without you awake to interpret the failure.
          </p>

          <div class="mt-8 inline-flex max-w-4xl items-start gap-3 rounded-2xl border border-emerald-500/20 bg-emerald-500/8 px-5 py-4">
            <div class="mt-0.5 h-2.5 w-2.5 rounded-full bg-emerald-400 shrink-0"></div>
            <p class="text-sm leading-6 text-slate-300">
              <span class="font-semibold text-slate-100">Short answer:</span>
              If the API fails on error clarity, idempotency, retry guidance, credential autonomy, or deterministic behavior, your agent is going to invent operator pain for you later.
            </p>
          </div>
        </div>
      </div>
    </section>

    <article class="max-w-3xl mx-auto px-6 pt-12 pb-24">
      <div class="prose-rhumb" set:html={htmlContent} />

      <section class="mt-10 rounded-[28px] border border-rose-500/20 bg-rose-500/5 p-6">
        <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-rose-300 mb-3">Fresh operator signal</div>
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-3">
          Reliability failures also start when a hard dependency quietly retires
        </h2>
        <p class="text-slate-300 leading-relaxed mb-4">
          A workflow can be perfectly healthy one day and fail closed the next because a pinned model ID, version enum, or credential-test default no longer exists. That is still a reliability problem. Nothing in your code changed, but the boundary became deterministic overnight and the system needs migration logic, not blind retries.
        </p>
        <ul class="list-disc list-outside ml-5 space-y-2 text-slate-300 leading-relaxed mb-4">
          {RETIRED_DEPENDENCY_GUARDRAILS.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <p class="text-slate-300 leading-relaxed">
          This is where <a href="/blog/machine-parseable-change-communication-for-agent-ready-apis" class="text-amber hover:underline underline-offset-2">machine-parseable change communication</a> and <a href="/blog/llm-apis-agent-loops" class="text-amber hover:underline underline-offset-2">loop-reliability design</a> stop being separate topics and become part of the same pre-flight checklist.
        </p>
      </section>

      <section class="mt-16 rounded-[28px] border border-emerald-500/20 bg-emerald-500/5 p-8 text-center sm:text-left">
        <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-emerald-300 mb-3">Next honest step</div>
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-3">
          If this checklist already feels familiar, move into a bounded execution lane
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6 max-w-2xl mx-auto sm:mx-0">
          If your team already knows the integration will need real execution, keep the authority boundary explicit. Start with capability-first onboarding or open the direct managed path instead of wiring a giant connector list all at once.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row sm:justify-start">
          <a
            data-rhumb-propagate
            href="/blog/capability-first-agent-onboarding?rhumb_experiment=e004&rhumb_source=api-reliability-checklist-onboarding"
            class="inline-flex items-center justify-center rounded-xl bg-emerald-400 px-5 py-3 text-sm font-display font-semibold text-navy hover:bg-emerald-300 transition-colors duration-200"
          >
            See the capability-first handoff &rarr;
          </a>
          <a
            data-rhumb-propagate
            href="/start-managed-execution?rhumb_experiment=e004&rhumb_source=api-reliability-checklist-direct"
            class="inline-flex items-center justify-center rounded-xl border border-emerald-500/30 px-5 py-3 text-sm font-display font-semibold text-emerald-200 hover:border-emerald-400/60 hover:text-emerald-100 transition-colors duration-200"
          >
            Open the managed path &rarr;
          </a>
        </div>
      </section>

      <section class="mt-12 rounded-[28px] border border-slate-800 bg-surface/80 p-8">
        <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500 mb-3">Fleet follow-through</div>
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-3">
          Reliability starts at the checklist, then survives in the loop
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6 max-w-2xl">
          The preflight only matters if the workflow can keep running once retries stack, shared budgets tighten, and credentials start failing under load. These are the next three pages to read when the checklist moves from theory into live operations.
        </p>
        <div class="space-y-4">
          <a
            href="/blog/llm-apis-agent-loops"
            class="block bg-navy/60 border border-slate-800 rounded-lg p-5 hover:border-amber/30 transition-colors"
          >
            <span class="text-xs font-mono text-amber uppercase tracking-widest">
              Loop Reliability
            </span>
            <h3 class="font-display font-semibold text-slate-100 mt-2">
              LLM APIs in Agent Loops: What Actually Breaks at Scale
            </h3>
            <p class="text-sm text-slate-500 mt-1">
              The overnight-ops view once tool calls, retries, and longer chains are live.
            </p>
          </a>
          <a
            href="/blog/agent-fleet-rate-limit-design"
            class="block bg-navy/60 border border-slate-800 rounded-lg p-5 hover:border-amber/30 transition-colors"
          >
            <span class="text-xs font-mono text-amber uppercase tracking-widest">
              Rate-limit Architecture
            </span>
            <h3 class="font-display font-semibold text-slate-100 mt-2">
              Designing Agent Fleets That Survive Rate Limits
            </h3>
            <p class="text-sm text-slate-500 mt-1">
              The orchestration patterns that keep retry storms from turning into a fleet-wide outage.
            </p>
          </a>
          <a
            href="/blog/api-credentials-agent-fleets"
            class="block bg-navy/60 border border-slate-800 rounded-lg p-5 hover:border-amber/30 transition-colors"
          >
            <span class="text-xs font-mono text-amber uppercase tracking-widest">
              Credential Lifecycle
            </span>
            <h3 class="font-display font-semibold text-slate-100 mt-2">
              API Credentials in Autonomous Agent Fleets
            </h3>
            <p class="text-sm text-slate-500 mt-1">
              The secrets architecture that keeps rotation, expiry, and revocation from spreading across the lane.
            </p>
          </a>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="font-display font-semibold text-lg text-slate-100 mb-4">Related</h2>
        <div class="space-y-4">
          {RELATED_READING.map((item) => (
            <a
              href={item.href}
              class="block bg-surface border border-slate-800 rounded-lg p-5 hover:border-amber/30 transition-colors"
            >
              <span class="text-xs font-mono text-amber uppercase tracking-widest">{item.label}</span>
              <h3 class="font-display font-semibold text-slate-100 mt-2">{item.title}</h3>
              <p class="text-sm text-slate-500 mt-1">{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    (() => {
      if (typeof window === "undefined") return;
      const params = new URLSearchParams(window.location.search);
      const experiment = params.get("rhumb_experiment");
      const source = params.get("rhumb_source");
      const parentSource = params.get("rhumb_parent_source");
      if (!experiment && !source && !parentSource) return;

      document.querySelectorAll("a[data-rhumb-propagate]").forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;

        const url = new URL(href, window.location.origin);
        if (experiment && !url.searchParams.has("rhumb_experiment")) {
          url.searchParams.set("rhumb_experiment", experiment);
        }
        if (source) {
          url.searchParams.set("rhumb_parent_source", source);
        }
        if (parentSource) {
          url.searchParams.set("rhumb_grandparent_source", parentSource);
        }

        link.setAttribute("href", `${url.pathname}${url.search}${url.hash}`);
      });
    })();
  </script>
</Layout>
