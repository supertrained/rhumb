---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import ScoreDisplay from "../../components/ScoreDisplay.astro";
import TierBadge from "../../components/TierBadge.astro";
import { getServiceScore } from "../../lib/api";
import type { ServiceScoreViewModel } from "../../lib/types";

const scoreMap = {
  posthog: await getServiceScore("posthog"),
  mixpanel: await getServiceScore("mixpanel"),
  amplitude: await getServiceScore("amplitude"),
} satisfies Record<string, ServiceScoreViewModel | null>;

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "PostHog vs Mixpanel vs Amplitude for AI Agents",
  datePublished: "2026-03-17T00:00:00Z",
  author: { "@type": "Person", name: "Pedro Nunes" },
  description:
    "Side-by-side comparison of PostHog, Mixpanel, and Amplitude for AI agent analytics workflows — using live Rhumb AN Score data.",
  url: "https://rhumb.dev/blog/posthog-vs-mixpanel-vs-amplitude",
  publisher: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
};

type ComparedService = {
  slug: "posthog" | "mixpanel" | "amplitude";
  name: string;
  accent: string;
  accentSoft: string;
  tagline: string;
  bestFor: string;
  avoidWhen: string;
  friction: string;
  decision: string;
  support: string;
  data: ServiceScoreViewModel | null;
};

const compared: ComparedService[] = [
  {
    slug: "posthog",
    name: "PostHog",
    accent: "#F54E00",
    accentSoft: "rgba(245,78,0,0.14)",
    tagline: "default",
    bestFor: "Agents that need full analytics stack access — event tracking, feature flags, session replay, and experimentation — through a single API with the most generous free tier (1M events/month).",
    avoidWhen: "The organization needs a pure managed SaaS with no self-hosting complexity, or when deep BI integrations (warehouse-native analytics) are the primary use case.",
    friction: "Self-hosted deployments add infrastructure overhead the agent cannot manage. Event ingestion has eventual consistency — agents querying immediately after writing events may see stale results. API surface is broad but some endpoints are less documented than others.",
    decision: "Pick PostHog unless a specific managed-SaaS or warehouse-native requirement pushes you elsewhere.",
    support: "Highest aggregate score and highest payment autonomy (8.0). Open-source core means the API surface is inspectable and forkable. The all-in-one platform (analytics + feature flags + experiments + session replay) means one integration covers what would require 3-4 separate tools.",
    data: scoreMap.posthog,
  },
  {
    slug: "mixpanel",
    name: "Mixpanel",
    accent: "#7856FF",
    accentSoft: "rgba(120,86,255,0.14)",
    tagline: "event specialist",
    bestFor: "Organizations focused on deep event-based behavioral analytics — funnels, retention curves, and cohort analysis — where the agent's job is to query and interpret user behavior patterns.",
    avoidWhen: "You need feature flags, session replay, or experimentation alongside analytics. Mixpanel is a pure analytics tool; anything beyond that requires additional integrations.",
    friction: "JQL (JavaScript Query Language) for advanced queries is a custom dialect agents must learn. Free tier is generous (20M events) but rate limits on the API can throttle high-frequency agent queries. Data export for warehouse integration requires separate ETL configuration.",
    decision: "Pick Mixpanel when deep behavioral analytics is the core need and the organization does not need the broader product stack.",
    support: "Middle score driven by strong event tracking and query capabilities, but lower access readiness reflects the learning curve of JQL and less complete API documentation compared to PostHog's open-source transparency.",
    data: scoreMap.mixpanel,
  },
  {
    slug: "amplitude",
    name: "Amplitude",
    accent: "#1D72F2",
    accentSoft: "rgba(29,114,242,0.14)",
    tagline: "enterprise analytics",
    bestFor: "Enterprise organizations that need warehouse-native analytics, deep BI integrations, and governance controls for cross-functional analytics teams. Best when analytics data already lives in Snowflake, BigQuery, or Databricks.",
    avoidWhen: "You want the simplest path to agent-readable analytics. Amplitude's API surface is the most complex of the three, and its warehouse-native positioning means many workflows assume SQL-level data access rather than pure API interaction.",
    friction: "API surface carries enterprise complexity — taxonomy management, group analytics, and behavioral cohorting each have separate API patterns. Rate limits are strict on lower tiers. Dashboard is a complex React SPA that is difficult for agents to navigate programmatically.",
    decision: "Pick Amplitude when the organization's analytics architecture is warehouse-native and enterprise governance is a hard requirement.",
    support: "Lowest aggregate score reflects real agent friction: the most complex API surface, the strictest rate limits, and the highest dependence on warehouse infrastructure that agents typically cannot self-provision. Strong governance (7.0) but at the cost of access simplicity.",
    data: scoreMap.amplitude,
  },
];

const available = compared.filter((item) => item.data !== null);
const ranked = [...available].sort(
  (a, b) => (b.data?.aggregateRecommendationScore ?? 0) - (a.data?.aggregateRecommendationScore ?? 0)
);
const winner = ranked[0];
const updatedAt = winner?.data?.calculatedAt
  ? new Date(winner.data.calculatedAt).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : "recently";
const updatedAtISO = winner?.data?.calculatedAt
  ? new Date(winner.data.calculatedAt).toISOString()
  : new Date().toISOString();
(ARTICLE_JSON_LD as any).dateModified = updatedAtISO;

function formatScore(value: number | null | undefined): string {
  return value == null ? "—" : value.toFixed(1);
}
function formatConfidence(value: number | null | undefined): string {
  return value == null ? "—" : `${Math.round(value * 100)}%`;
}

function failureCopy(item: ComparedService): string[] {
  if (item.slug === "posthog") {
    return [
      "Event ingestion is eventually consistent. Agents that write events and immediately query for them will see stale data — add a deliberate delay or polling pattern.",
      "Self-hosted deployments require infrastructure management (Kubernetes, ClickHouse) that is outside the agent's control surface. Cloud-hosted eliminates this but has different rate limit profiles.",
      "The breadth of the API (analytics, feature flags, experiments, session replay) means endpoint discovery is non-trivial. Agents need clear guidance on which subset of the API applies to their task.",
    ];
  }
  if (item.slug === "mixpanel") {
    return [
      "JQL (JavaScript Query Language) is a Mixpanel-specific query dialect. Agents cannot transfer SQL or standard query knowledge — they need Mixpanel-specific examples and documentation.",
      "The Ingestion API and the Query API are separate systems with different authentication patterns. Agents managing both read and write paths need to handle two credential types.",
      "Data export for warehouse integration requires separate ETL setup that typically involves human configuration of connectors (Segment, Fivetran, etc.).",
    ];
  }
  return [
    "Taxonomy management (event types, properties, categories) adds a governance layer that can block event ingestion if the agent sends events that do not match the approved taxonomy.",
    "Group analytics and behavioral cohorting have separate API patterns from basic event queries — agents cannot use a single client pattern for all analytics operations.",
    "Warehouse-native mode assumes the agent has SQL-level access to Snowflake/BigQuery/Databricks, which is a separate access provisioning challenge beyond the Amplitude API itself.",
  ];
}

const scenarioCards = [
  {
    title: "Agent needs analytics + feature flags + experiments in one tool",
    pick: "PostHog",
    why: "Only option where a single integration covers analytics, feature flags, experimentation, and session replay. Best free tier (1M events/mo).",
    href: "/service/posthog",
  },
  {
    title: "Deep behavioral analytics: funnels, retention, cohort analysis",
    pick: "Mixpanel",
    why: "Purpose-built for event-based behavioral analytics. JQL enables complex queries once the agent learns the dialect. 20M events/mo free.",
    href: "/service/mixpanel",
  },
  {
    title: "Enterprise warehouse-native analytics with governance",
    pick: "Amplitude",
    why: "Best option when analytics data lives in Snowflake/BigQuery and enterprise governance (taxonomy management, cross-team access controls) is required.",
    href: "/service/amplitude",
  },
];

const agentRules = [
  "If the operator has no analytics tool yet, default to PostHog. It covers the broadest surface with the least integration overhead.",
  "If the operator asks specifically about behavioral analytics (funnels, retention), examine Mixpanel before defaulting to PostHog — it is purpose-built for that use case.",
  "If the operator mentions warehouse-native analytics or has data in Snowflake/BigQuery/Databricks, Amplitude is the path of least resistance for the existing data architecture.",
  "For PostHog: always account for eventual consistency when writing then reading events. Add a minimum 2-second delay between ingestion and query.",
  "For Mixpanel: confirm whether JQL or the standard query API is needed. Most agent tasks can use the standard query API; JQL adds complexity that may not be necessary.",
  "For all three: analytics APIs are read-heavy. Implement response caching to avoid rate limit exhaustion on repeated queries.",
];
---

<Layout
  title="PostHog vs Mixpanel vs Amplitude for AI Agents | Rhumb"
  description="Compare PostHog, Mixpanel, and Amplitude for agent analytics. PostHog leads on breadth, Mixpanel on behavior analysis, Amplitude for enterprise."
  canonical="/blog/posthog-vs-mixpanel-vs-amplitude"
  ogTitle="PostHog vs Mixpanel vs Amplitude for AI Agents"
  ogDescription="Which analytics platform should an AI agent use? PostHog wins by default, Mixpanel for behavioral depth, Amplitude for warehouse-native enterprise."
  ogUrl="https://rhumb.dev/blog/posthog-vs-mixpanel-vs-amplitude"
  ogType="article"
  twitterTitle="PostHog vs Mixpanel vs Amplitude for AI Agents"
  twitterDescription="A side-by-side decision page for operators and agents choosing an analytics platform."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen overflow-hidden">
    <section class="relative border-b border-slate-800/80">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_left,rgba(245,78,0,0.12),transparent_32%),radial-gradient(circle_at_top_right,rgba(120,86,255,0.10),transparent_28%),radial-gradient(circle_at_bottom,rgba(29,114,242,0.08),transparent_35%)]"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-14 pb-16">
        <div class="max-w-3xl">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="text-xs font-mono font-semibold text-amber uppercase tracking-[0.28em]">Comparison</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-slate-500">March 17, 2026</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-emerald-400/70">Updated {updatedAt}</span>
          </div>

          <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl leading-[0.95] tracking-tight text-slate-100 max-w-4xl text-balance">
            PostHog vs Mixpanel vs Amplitude for AI agents
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-slate-300 leading-relaxed max-w-3xl">
            <span class="text-slate-100 font-semibold">Short answer:</span>
            PostHog is the broadest and most agent-friendly default,
            Mixpanel wins when deep behavioral analytics is the singular focus,
            and Amplitude makes sense when the organization is already warehouse-native.
          </p>

          <div class="mt-8 inline-flex max-w-3xl items-start gap-3 rounded-2xl border border-orange-500/20 bg-orange-500/8 px-5 py-4">
            <div class="mt-0.5 h-2.5 w-2.5 rounded-full bg-orange-400 shrink-0"></div>
            <p class="text-sm leading-6 text-slate-300">
              <span class="font-semibold text-slate-100">Verdict:</span>
              PostHog leads because it combines the broadest feature surface (analytics + flags + experiments + replay)
              with the highest payment autonomy and the most generous free tier. For agents, fewer integrations means fewer
              failure surfaces. Scores shown here reflect published Rhumb data as of {updatedAt}.
            </p>
          </div>
        </div>

        <div class="mt-12 grid gap-5 lg:grid-cols-3">
          {compared.map((item, index) => (
            <article
              class:list={[
                "group relative overflow-hidden rounded-[28px] border bg-surface/90 backdrop-blur-sm p-6 sm:p-7 reveal",
                index === 0 ? "lg:-translate-y-4" : "",
              ]}
              style={`border-color:${item.accent}40; background-image:linear-gradient(180deg, ${item.accentSoft} 0%, rgba(15,23,42,0.85) 26%, rgba(15,23,42,0.92) 100%); animation-delay:${index * 80}ms;`}
            >
              <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`background:radial-gradient(circle_at_top_right, ${item.accentSoft} 0%, transparent 38%);`}></div>
              <div class="relative">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">{item.tagline}</p>
                    <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">{item.name}</h2>
                  </div>
                  <ScoreDisplay score={item.data?.aggregateRecommendationScore ?? null} size="large" showLabel />
                </div>

                <div class="mt-4 flex items-center gap-3 flex-wrap">
                  <TierBadge tier={item.data?.tier ?? null} label={item.data?.tierLabel ?? undefined} />
                  <span class="text-xs font-mono text-slate-500">confidence {formatConfidence(item.data?.confidence)}</span>
                </div>

                <p class="mt-5 text-sm leading-6 text-slate-300">{item.bestFor}</p>

                <dl class="mt-6 grid grid-cols-3 gap-3">
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Exec</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.executionScore)}</dd>
                  </div>
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Access</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.accessReadinessScore)}</dd>
                  </div>
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Autonomy</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.p1Score)}</dd>
                  </div>
                </dl>

                <div class="mt-6 rounded-2xl border border-white/6 bg-navy/70 p-4">
                  <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Why it lands here</p>
                  <p class="mt-2 text-sm leading-6 text-slate-300">{item.support}</p>
                </div>

                <div class="mt-4 space-y-3">
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Biggest friction</p>
                    <p class="mt-1 text-sm leading-6 text-slate-400">{item.friction}</p>
                  </div>
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Avoid when</p>
                    <p class="mt-1 text-sm leading-6 text-slate-400">{item.avoidWhen}</p>
                  </div>
                </div>

                <div class="mt-6 flex items-center justify-between gap-4 border-t border-white/8 pt-4">
                  <p class="text-sm font-semibold text-slate-200 max-w-[20rem]">{item.decision}</p>
                  <a href={`/service/${item.slug}`} class="text-xs font-mono uppercase tracking-[0.2em] text-amber hover:text-amber-dark transition-colors">Service page →</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-14">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="rounded-[28px] border border-slate-800 bg-surface/80 overflow-hidden reveal">
          <div class="border-b border-slate-800 px-6 py-5 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0))]">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Operator scoreboard</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">What the numbers actually say</h2>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full min-w-[720px]">
              <thead>
                <tr class="border-b border-slate-800 text-left">
                  <th class="px-6 py-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Metric</th>
                  {compared.map((item) => (
                    <th class="px-6 py-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">{item.name}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Aggregate AN Score</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 font-semibold text-slate-100">{formatScore(item.data?.aggregateRecommendationScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Execution</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.executionScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Access Readiness</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.accessReadinessScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Payment Autonomy</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.p1Score)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Confidence</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatConfidence(item.data?.confidence)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80 align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Free tier</td>
                  <td class="px-6 py-4 text-sm text-slate-300">1M events/mo<br/><span class="text-slate-500">most generous</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">20M events/mo<br/><span class="text-slate-500">event volume</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">50K MTUs<br/><span class="text-slate-500">user-based</span></td>
                </tr>
                <tr class="align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Unique strength</td>
                  <td class="px-6 py-4 text-sm text-slate-300">All-in-one<br/><span class="text-slate-500">flags + replay + experiments</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">Behavioral depth<br/><span class="text-slate-500">funnels + cohorts + JQL</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">Warehouse-native<br/><span class="text-slate-500">Snowflake/BQ/Databricks</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <aside class="space-y-5 reveal">
          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Agent brief</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">Routing rules</h2>
            <ol class="mt-5 space-y-3">
              {agentRules.map((rule, idx) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full border border-slate-700 bg-navy text-[11px] font-mono text-slate-300 shrink-0">{idx + 1}</span>
                  <span class="text-sm leading-6 text-slate-300">{rule}</span>
                </li>
              ))}
            </ol>
          </div>

          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Decision pattern</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">One-line rule</h2>
            <p class="mt-4 text-base leading-7 text-slate-300">
              <span class="font-semibold text-slate-100">PostHog for the broadest agent analytics surface.</span>
              {' '}Mixpanel for deep behavioral analytics without the platform overhead.
              {' '}Amplitude when the data already lives in a warehouse.
            </p>
            <div class="mt-5 rounded-2xl border border-orange-500/20 bg-orange-500/8 p-4 text-sm leading-6 text-slate-300">
              The agent version: PostHog's all-in-one approach reduces integration count. For agents, fewer integrations means fewer authentication surfaces, fewer rate limit regimes, and fewer failure modes to defend against.
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-14">
      <div class="rounded-[32px] border border-slate-800 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(2,6,23,0.4))] p-6 sm:p-8 reveal">
        <div class="max-w-2xl">
          <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Friction map</p>
          <h2 class="mt-2 font-display font-bold text-2xl sm:text-3xl text-slate-100">Where each one breaks in practice</h2>
          <p class="mt-4 text-slate-400 leading-relaxed">
            Analytics APIs are read-heavy and query-intensive. The friction patterns cluster around
            query language complexity, eventual consistency, and infrastructure coupling.
          </p>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-3">
          {compared.map((item, index) => (
            <article class="rounded-[26px] border bg-navy/55 p-6" style={`border-color:${item.accent}30; animation-delay:${index * 90}ms;`}>
              <div class="flex items-center justify-between gap-4">
                <h3 class="font-display font-bold text-xl text-slate-100">{item.name}</h3>
                <span class="h-2.5 w-2.5 rounded-full" style={`background:${item.accent}`}></span>
              </div>
              <ul class="mt-5 space-y-3">
                {failureCopy(item).map((line) => (
                  <li class="flex items-start gap-3 text-sm leading-6 text-slate-300">
                    <span class="mt-2 h-1.5 w-1.5 rounded-full bg-slate-500 shrink-0"></span>
                    <span>{line}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-16">
      <div class="grid gap-5 lg:grid-cols-3 reveal">
        {scenarioCards.map((card, index) => (
          <article class="rounded-[28px] border border-slate-800 bg-surface/85 p-6" style={`animation-delay:${index * 80}ms;`}>
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Scenario</p>
            <h3 class="mt-2 font-display font-bold text-xl text-slate-100 leading-snug">{card.title}</h3>
            <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/8 px-3 py-1">
              <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-emerald-300">Pick</span>
              <span class="text-sm font-semibold text-slate-100">{card.pick}</span>
            </div>
            <p class="mt-4 text-sm leading-6 text-slate-400">{card.why}</p>
            <a href={card.href} class="mt-6 inline-flex text-xs font-mono uppercase tracking-[0.2em] text-amber hover:text-amber-dark transition-colors">Open scorecard →</a>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-[30px] border border-emerald-500/20 bg-emerald-500/5 p-8 reveal">
        <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-emerald-300">Next honest step</p>
        <h2 class="mt-2 font-display font-bold text-2xl sm:text-3xl text-slate-100">Choose the execution boundary after you choose the analytics stack</h2>
        <p class="mt-4 max-w-3xl text-slate-300 leading-relaxed">
          Analytics choice decides where the evidence lives, not how much downstream authority the agent should hold. If you still need to separate read-heavy evaluation from repeat experiment, flag, or event workflows, start with capability-first onboarding. If the workflow is already bounded and one governed key is the honest fit, open the managed path directly.
        </p>
