---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Switching from Smithery to Rhumb: An Honest Comparison",
  datePublished: "2026-03-21T00:00:00Z",
  author: { "@type": "Person", name: "Pedro Nunes" },
  description:
    "A transparent comparison of Smithery and Rhumb for AI agent tool discovery. Where Smithery wins, where Rhumb wins, and how they complement each other.",
  url: "https://rhumb.dev/blog/switching-from-smithery",
  publisher: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
};

type ComparisonRow = {
  dimension: string;
  smithery: string;
  rhumb: string;
  verdict: "smithery" | "rhumb" | "tie";
};

const comparisons: ComparisonRow[] = [
  {
    dimension: "Catalog size",
    smithery: "4,000+ MCP servers indexed",
    rhumb: "525+ services scored across 86 categories",
    verdict: "smithery",
  },
  {
    dimension: "Quality signal",
    smithery: "Star ratings, install counts",
    rhumb: "20-dimension AN Score: execution, access, autonomy. Machine-readable. Confidence-weighted.",
    verdict: "rhumb",
  },
  {
    dimension: "Failure documentation",
    smithery: "Not available — agents discover failures at runtime",
    rhumb: "Failure modes documented per service. Agents know how a tool fails before calling it.",
    verdict: "rhumb",
  },
  {
    dimension: "Credential modes",
    smithery: "Managed OAuth (human-session-oriented)",
    rhumb: "Three modes: BYOK (your keys), Rhumb-managed (we hold keys), x402 USDC (no account needed)",
    verdict: "rhumb",
  },
  {
    dimension: "Agent payments",
    smithery: "Credit card billing, subscription tiers",
    rhumb: "x402 per-call USDC on Base — agents pay at the HTTP layer, no signup required",
    verdict: "rhumb",
  },
  {
    dimension: "Free tier",
    smithery: "25,000 RPCs/month",
    rhumb: "Discovery is always free. Executions are pay-as-you-go with route, health, and cost checks before execution.",
    verdict: "smithery",
  },
  {
    dimension: "Onboarding speed",
    smithery: "Web UI, one-click install, visual browser",
    rhumb: "API-first with curl examples. MCP via npx. No web UI for browsing yet.",
    verdict: "smithery",
  },
  {
    dimension: "Cost transparency",
    smithery: "Per-plan pricing ($0/free, $30/pro)",
    rhumb: "Per-call route, health, and cost checks before execution. You see the exact path and price before committing.",
    verdict: "rhumb",
  },
  {
    dimension: "Alternatives / routing",
    smithery: "Manual browsing of similar servers",
    rhumb: "460+ alternative relationships mapped. API returns scored alternatives automatically.",
    verdict: "rhumb",
  },
  {
    dimension: "Protocol support",
    smithery: "MCP-native, hosted MCP servers",
    rhumb: "MCP + REST API. 16 MCP tools. Full REST coverage for non-MCP agents.",
    verdict: "tie",
  },
];

const verdictColors = {
  smithery: { bg: "bg-blue-500/10", text: "text-blue-400", label: "Smithery" },
  rhumb: { bg: "bg-amber-500/10", text: "text-amber-400", label: "Rhumb" },
  tie: { bg: "bg-slate-500/10", text: "text-slate-400", label: "Tie" },
};
---

<Layout
  title="Switching from Smithery to Rhumb"
  description="An honest comparison of Smithery and Rhumb for AI agent tool discovery. Where each product wins, catalog overlap, and migration steps."
  canonical="/blog/switching-from-smithery"
  ogTitle="Switching from Smithery to Rhumb — Honest Comparison"
  ogDescription="Smithery has 4,000+ MCP servers. Rhumb has 525+ scored services with failure modes and agent-native payments. Here's how they compare."
  ogUrl="https://rhumb.dev/blog/switching-from-smithery"
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen" data-testid="smithery-migration-page" data-page-type="guide">
    <div class="max-w-4xl mx-auto px-6 py-16">
      <header class="max-w-3xl" data-section="hero">
        <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Migration Guide</p>
        <h1 class="font-display font-bold text-3xl sm:text-4xl text-slate-100 leading-tight tracking-tight">
          Switching from Smithery to Rhumb
        </h1>
        <p class="mt-6 text-lg text-slate-400 leading-relaxed">
          Smithery and Rhumb solve related but different problems. Smithery is the tool shelf — the
          largest MCP server catalog available. Rhumb is the quality layer — trust scores, failure
          documentation, and agent-native execution. Many teams use both.
        </p>
        <p class="mt-4 text-sm text-slate-500">
          This guide is honest about where Smithery wins. We believe the best way to earn trust is to
          tell you exactly when a competitor is the better choice.
        </p>
      </header>

      <!-- TL;DR -->
      <div class="mt-10 bg-surface border border-amber/20 rounded-xl p-6" data-section="tldr">
        <h2 class="font-display text-lg font-semibold text-slate-100">TL;DR</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-400">
          <li class="flex gap-2">
            <span class="text-amber shrink-0">→</span>
            <span><strong class="text-slate-200">Use Smithery</strong> if you need the widest catalog, visual browsing, or quick experimentation with new MCP servers.</span>
          </li>
          <li class="flex gap-2">
            <span class="text-amber shrink-0">→</span>
            <span><strong class="text-slate-200">Use Rhumb</strong> if you need to know which tools actually work for agents, how they fail, what they cost per-call, and you want autonomous agent payments.</span>
          </li>
          <li class="flex gap-2">
            <span class="text-amber shrink-0">→</span>
            <span><strong class="text-slate-200">Use both</strong> if you discover on Smithery and validate on Rhumb before production deployment.</span>
          </li>
        </ul>
      </div>

      <!-- Head-to-head comparison -->
      <section class="mt-12" data-section="comparison">
        <h2 class="font-display text-2xl font-bold text-slate-100">Head-to-head comparison</h2>
        <p class="mt-2 text-sm text-slate-400">10 dimensions. We call it honestly — including where Smithery wins.</p>

        <div class="mt-6 space-y-4">
          {comparisons.map((row) => (
            <div class="bg-surface border border-slate-800 rounded-lg p-5" data-dimension={row.dimension}>
              <div class="flex items-center justify-between gap-4 mb-3">
                <h3 class="text-sm font-semibold text-slate-200">{row.dimension}</h3>
                <span class={`text-xs font-mono px-2 py-0.5 rounded ${verdictColors[row.verdict].bg} ${verdictColors[row.verdict].text}`}>
                  {verdictColors[row.verdict].label}
                </span>
              </div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <p class="text-xs font-mono text-blue-400/70 mb-1">Smithery</p>
                  <p class="text-sm text-slate-400">{row.smithery}</p>
                </div>
                <div>
                  <p class="text-xs font-mono text-amber/70 mb-1">Rhumb</p>
                  <p class="text-sm text-slate-400">{row.rhumb}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 bg-surface border border-slate-800 rounded-lg p-5">
          <p class="text-sm text-slate-400">
            <strong class="text-slate-200">Score:</strong> Smithery wins on 3 dimensions (catalog, free tier, onboarding).
            Rhumb wins on 6 (quality signal, failure docs, credentials, payments, cost transparency, alternatives).
            1 tie (protocol support). The pattern is clear: Smithery wins breadth and ease; Rhumb wins depth and trust.
          </p>
        </div>
      </section>

      <!-- When to stay with Smithery -->
      <section class="mt-12" data-section="stay-with-smithery">
        <h2 class="font-display text-2xl font-bold text-slate-100">When to stay with Smithery</h2>
        <div class="mt-4 space-y-3">
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <h3 class="text-sm font-semibold text-slate-200">You're exploring, not deploying</h3>
            <p class="text-sm text-slate-400 mt-1">Smithery's visual browser and 4,000+ server catalog is unbeatable for discovery and experimentation. If you're trying tools to see what's possible, start there.</p>
          </div>
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <h3 class="text-sm font-semibold text-slate-200">You need a niche MCP server</h3>
            <p class="text-sm text-slate-400 mt-1">With 8x our catalog size, Smithery likely has tools we haven't scored yet. If the tool you need isn't in Rhumb's directory, Smithery probably has it.</p>
          </div>
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <h3 class="text-sm font-semibold text-slate-200">Your budget is zero</h3>
            <p class="text-sm text-slate-400 mt-1">Smithery's free tier (25,000 RPCs/month) is generous. Rhumb charges per call from the first call, though discovery is always free.</p>
          </div>
        </div>
      </section>

      <!-- When to switch to Rhumb -->
      <section class="mt-12" data-section="switch-to-rhumb">
        <h2 class="font-display text-2xl font-bold text-slate-100">When to switch to Rhumb</h2>
        <div class="mt-4 space-y-3">
          <div class="bg-surface border border-amber/20 rounded-lg p-5">
            <h3 class="text-sm font-semibold text-slate-200">Your agent needs to choose tools autonomously</h3>
            <p class="text-sm text-slate-400 mt-1">Star ratings and install counts don't tell an agent whether a tool's auth flow works without human intervention. The AN Score measures exactly that — execution quality, access readiness, and autonomy dimensions that matter for unattended operation.</p>
          </div>
          <div class="bg-surface border border-amber/20 rounded-lg p-5">
            <h3 class="text-sm font-semibold text-slate-200">You've been burned by silent failures</h3>
            <p class="text-sm text-slate-400 mt-1">Rhumb documents how every scored service fails — before your agent encounters it. Failure modes include blast radius, recovery steps, and prevention guidance. Your agent knows the failure surface of every tool before making a single call.</p>
          </div>
          <div class="bg-surface border border-amber/20 rounded-lg p-5">
            <h3 class="text-sm font-semibold text-slate-200">Your agent needs to pay for itself</h3>
            <p class="text-sm text-slate-400 mt-1">x402 payments let agents pay per-call with USDC at the HTTP layer when zero-signup, request-level payment authorization is the point. It is powerful, but it is not the default repeat-traffic rail; for that, use governed API key or wallet-prefund on <code class="text-amber">X-Rhumb-Key</code>, and bring BYOK only when provider control is the point.</p>
          </div>
          <div class="bg-surface border border-amber/20 rounded-lg p-5">
            <h3 class="text-sm font-semibold text-slate-200">You need production reliability guarantees</h3>
            <p class="text-sm text-slate-400 mt-1">Rhumb's fail-closed billing, per-agent rate limiting, budget controls, and documented runbooks are built for production. If an upstream provider is degraded, you get a 502 with an alternatives endpoint — not a cryptic timeout.</p>
          </div>
        </div>
      </section>

      <!-- Migration steps -->
      <section class="mt-12" data-section="migration-steps">
        <h2 class="font-display text-2xl font-bold text-slate-100">Migration steps</h2>
        <p class="mt-2 text-sm text-slate-400">If you're adding Rhumb alongside or replacing Smithery, here's the path.</p>

        <div class="mt-6 space-y-6">
          <div class="flex gap-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm shrink-0">1</span>
            <div>
              <h3 class="text-sm font-semibold text-slate-200">Audit your current tool usage</h3>
              <p class="text-sm text-slate-400 mt-1">List the MCP servers you're actively calling through Smithery. Search for each one on Rhumb: <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">curl https://api.rhumb.dev/v1/search?q=resend</code></p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm shrink-0">2</span>
            <div>
              <h3 class="text-sm font-semibold text-slate-200">Check AN Scores for your tools</h3>
              <p class="text-sm text-slate-400 mt-1">For each service, review the AN Score, failure modes, and alternatives: <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">curl https://api.rhumb.dev/v1/services/resend/score</code></p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm shrink-0">3</span>
            <div>
              <h3 class="text-sm font-semibold text-slate-200">Choose your credential mode</h3>
              <p class="text-sm text-slate-400 mt-1">BYOK if you already have provider keys. Rhumb-managed if you want us to handle credentials. x402 if your agent should pay autonomously. <a href="/quickstart" class="text-amber hover:underline">Quickstart guide →</a></p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm shrink-0">4</span>
            <div>
              <h3 class="text-sm font-semibold text-slate-200">Connect via MCP or REST</h3>
              <p class="text-sm text-slate-400 mt-1">MCP: <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">npx rhumb-mcp</code> — drop-in alongside your Smithery connection. REST: call <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">https://api.rhumb.dev/v1</code> directly.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm shrink-0">5</span>
            <div>
              <h3 class="text-sm font-semibold text-slate-200">Run both in parallel</h3>
              <p class="text-sm text-slate-400 mt-1">There's no reason to hard-cut. Use Smithery for discovery and experimentation. Use Rhumb for production execution and trust decisions. They're complementary.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- What we don't do -->
      <section class="mt-12 bg-surface border border-slate-800 rounded-xl p-6" data-section="honest-gaps">
        <h2 class="font-display text-lg font-semibold text-slate-100">What Rhumb doesn't do (yet)</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-400">
          <li class="flex gap-2"><span class="text-slate-600">•</span> Visual web UI for browsing tools (API and MCP only today)</li>
          <li class="flex gap-2"><span class="text-slate-600">•</span> Hosted MCP servers (Rhumb is a layer, not a host)</li>
          <li class="flex gap-2"><span class="text-slate-600">•</span> 4,000+ server catalog (we're at 525+ and growing daily)</li>
          <li class="flex gap-2"><span class="text-slate-600">•</span> Team management and role-based access (planned)</li>
          <li class="flex gap-2"><span class="text-slate-600">•</span> Usage analytics dashboard (planned)</li>
        </ul>
      </section>

      <!-- Footer -->
      <footer class="mt-12 border-t border-slate-800 pt-8">
        <div class="flex flex-wrap gap-4 text-sm">
          <a href="/quickstart" class="text-slate-400 hover:text-amber transition-colors">Quickstart →</a>
          <a href="/docs" class="text-slate-400 hover:text-amber transition-colors">API Reference →</a>
          <a href="/compare" class="text-slate-400 hover:text-amber transition-colors">Tool Comparisons →</a>
          <a href="/docs/failure-modes" class="text-slate-400 hover:text-amber transition-colors">Failure Modes →</a>
          <a href="/pricing" class="text-slate-400 hover:text-amber transition-colors">Pricing →</a>
        </div>
      </footer>
    </div>
  </div>
</Layout>
