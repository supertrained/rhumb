---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import ResolveComparisonCta from "../../components/ResolveComparisonCta.astro";
import fs from "node:fs";
import path from "node:path";

const RELATED_READING = [
  {
    href: "/blog/complete-guide-api-selection-for-ai-agents",
    title: "The Complete Guide to API Selection for AI Agents (2026)",
    description: "The broader operator map for evaluating APIs once real autonomous workflows are live.",
  },
  {
    href: "/blog/api-reliability-checklist",
    title: "Before Your Agent Calls an API at 3am: A Reliability Checklist",
    description: "A short preflight for failure clarity, retries, rate-limit recovery, and credential shape before launch.",
  },
  {
    href: "/blog/llm-apis-agent-loops",
    title: "LLM APIs in Agent Loops: What Actually Breaks at Scale",
    description: "What changes once results turn into multi-step agent behavior, retries, and unattended execution.",
  },
  {
    href: "/blog/capability-first-agent-onboarding",
    title: "Capability-First Agent Onboarding: Managed Superpowers First",
    description: "Where bounded execution starts once the research phase is done.",
  },
];

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Exa vs Tavily vs Serper vs Brave Search for AI Agents",
  datePublished: "2026-03-30T00:00:00Z",
  dateModified: "2026-04-18T00:00:00Z",
  author: {
    "@type": "Person",
    name: "Pedro Nunes",
  },
  description:
    "Web search API comparison for AI agents: Exa vs Tavily vs Serper vs Brave Search, with the execution and contract failures that matter once research loops run unattended.",
  url: "https://rhumb.dev/blog/exa-vs-tavily-vs-serper-vs-brave-search",
  publisher: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};

function markdownToHtml(md: string): string {
  let html = md;

  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_match, _lang, code) => {
    return `<pre class="bg-elevated border border-slate-800 rounded-lg p-4 my-6 overflow-x-auto text-sm font-mono text-slate-300"><code>${code.replace(/</g, '&lt;').replace(/>/g, '&gt;').trim()}</code></pre>`;
  });

  html = html.replace(/^---$/gm, '<hr class="border-slate-800 my-10" />');

  html = html.replace(/(?:^\|.+\|$\n?)+/gm, (block) => {
    const rows = block.trim().split('\n').filter(r => !r.match(/^\|[\s-:|]+\|$/));
    if (rows.length === 0) return block;
    const headerCells = rows[0].split('|').filter(c => c.trim()).map(c =>
      `<th class="px-4 py-3 text-left text-xs font-mono font-semibold text-slate-300 uppercase tracking-wider">${c.trim()}</th>`
    ).join('\n');
    const bodyRows = rows.slice(1).map(row => {
      const cells = row.split('|').filter(c => c.trim()).map(c =>
        `<td class="px-4 py-3 text-sm text-slate-400">${c.trim()}</td>`
      ).join('\n');
      return `<tr class="border-t border-slate-800">${cells}</tr>`;
    }).join('\n');
    return `<div class="overflow-x-auto my-6"><table class="w-full border border-slate-800 rounded-lg"><thead class="bg-elevated"><tr>${headerCells}</tr></thead><tbody>${bodyRows}</tbody></table></div>`;
  });

  html = html.replace(/^#### (.+)$/gm, '<h4 class="font-display font-semibold text-base text-slate-300 mt-6 mb-2">$1</h4>');
  html = html.replace(/^### (.+)$/gm, '<h3 class="font-display font-semibold text-lg text-slate-200 mt-8 mb-3">$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2 class="font-display font-bold text-2xl text-slate-100 mt-12 mb-4 tracking-tight">$1</h2>');

  html = html.replace(/^> (.+)$/gm, '<blockquote class="border-l-2 border-amber/50 pl-4 my-6 text-slate-400 italic"><p>$1</p></blockquote>');

  html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="text-slate-200 font-semibold">$1</strong>');
  html = html.replace(/\*(.+?)\*/g, '<em class="text-slate-300 italic">$1</em>');
  html = html.replace(/`([^`]+)`/g, '<code class="font-mono text-sm bg-elevated px-1.5 py-0.5 rounded text-amber">$1</code>');

  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, text, href) => {
    if (href.startsWith('/')) {
      return `<a href="${href}" class="text-amber hover:underline underline-offset-2">${text}</a>`;
    }
    return `<a href="${href}" target="_blank" rel="noopener noreferrer" class="text-amber hover:underline underline-offset-2">${text}</a>`;
  });

  html = html.replace(/(?:^- .+$\n?)+/gm, (block) => {
    const items = block.trim().split('\n').map(line => {
      const content = line.replace(/^- /, '');
      return `<li class="leading-relaxed">${content}</li>`;
    }).join('\n');
    return `<ul class="list-disc list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ul>`;
  });

  html = html.replace(/(?:^\d+\. .+$\n?)+/gm, (block) => {
    const items = block.trim().split('\n').map(line => {
      const content = line.replace(/^\d+\. /, '');
      return `<li class="leading-relaxed">${content}</li>`;
    }).join('\n');
    return `<ol class="list-decimal list-outside ml-5 mb-4 space-y-1 text-slate-400">\n${items}\n</ol>`;
  });

  const lines = html.split('\n');
  const result: string[] = [];
  let inBlock = false;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    const trimmed = line.trim();

    if (trimmed.startsWith('<pre') || trimmed.startsWith('<ul') || trimmed.startsWith('<ol') || trimmed.startsWith('<blockquote') || trimmed.startsWith('<h') || trimmed.startsWith('<hr') || trimmed.startsWith('<div')) {
      inBlock = true;
    }

    if (inBlock) {
      result.push(line);
      if (trimmed.startsWith('</pre>') || trimmed.startsWith('</ul>') || trimmed.startsWith('</ol>') || trimmed.startsWith('</blockquote>') || trimmed.endsWith('</h2>') || trimmed.endsWith('</h3>') || trimmed.endsWith('</h4>') || trimmed.startsWith('<hr') || trimmed.endsWith('</div>')) {
        inBlock = false;
      }
      continue;
    }

    if (trimmed === '') {
      result.push('');
      continue;
    }

    if (!trimmed.startsWith('<')) {
      result.push(`<p class="text-slate-400 leading-relaxed mb-4">${trimmed}</p>`);
    } else {
      result.push(line);
    }
  }

  return result.join('\n');
}

let content = "";
try {
  const mdPath = path.join(process.cwd(), "public", "guides", "blog-exa-vs-tavily-vs-serper-vs-brave-search.md");
  const raw = fs.readFileSync(mdPath, "utf-8");
  content = raw.replace(/^---[\s\S]*?---\n/, "");
  content = content.replace(/^# .+\n+/, "");
} catch {
  content = "Article content could not be loaded. Please check back shortly.";
}

const htmlContent = markdownToHtml(content);
---

<Layout
  title="Exa vs Tavily vs Serper vs Brave Search for AI Agents | Rhumb"
  description="Web search API comparison for AI agents: Exa vs Tavily vs Serper vs Brave Search, with the execution and contract failures that matter once research loops run unattended."
  canonical="/blog/exa-vs-tavily-vs-serper-vs-brave-search"
  ogTitle="Exa vs Tavily vs Serper vs Brave Search for AI Agents"
  ogDescription="Search is the first primitive most agents use. The hard part is which surface stays legible, structured, and recoverable once research loops run unattended."
  ogUrl="https://rhumb.dev/blog/exa-vs-tavily-vs-serper-vs-brave-search"
  ogType="article"
  twitterTitle="Exa vs Tavily vs Serper vs Brave Search for AI Agents"
  twitterDescription="Semantic retrieval, agent-first depth control, Google-backed freshness, or index independence, the hard part is how the contract behaves at 3am."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <article class="max-w-3xl mx-auto px-6 pt-14 pb-24">
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">
            Comparison
          </span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-500">
            March 30, 2026
          </span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-emerald-400/70">Updated April 18, 2026</span>
          <span class="text-slate-700">&middot;</span>
          <span class="text-xs font-mono text-slate-600">Pedro Nunes</span>
        </div>

        <h1 class="font-display font-bold text-3xl sm:text-4xl text-slate-100 leading-tight tracking-tight mb-6">
          Exa vs Tavily vs Serper vs Brave Search for AI Agents
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed">
          Search is the first primitive most agents touch. The real separation is not who returns one good result. It is which surface keeps retrieval structured, rate limits legible, and the contract honest once research loops run unattended.
        </p>
      </header>

      <ResolveComparisonCta
        source="exa-vs-tavily-vs-serper-vs-brave-search"
        capability="web search and retrieval"
        callableServices={[{ name: "Exa", href: "/service/exa" }, { name: "Tavily", href: "/service/tavily" }, { name: "Brave Search", href: "/service/brave-search-api" }]}
        discoveryOnlyServices={[{ name: "Serper", href: "/service/serper" }]}
      />

      <div class="prose-rhumb" set:html={htmlContent} />

      <section class="mt-16 rounded-[28px] border border-emerald-500/20 bg-emerald-500/5 p-8 text-center sm:text-left">
        <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-emerald-300 mb-3">Next honest step</div>
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-3">
          Choose the retrieval surface, then keep the execution boundary narrow
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6 max-w-2xl mx-auto sm:mx-0">
          Search is rarely the only capability in the workflow. If the agent still needs separate authority for fetch, summarization, extraction, or downstream writes, start with capability-first onboarding. Open the direct managed path once the workflow is already bounded and one governed key is the honest fit.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row sm:justify-start">
          <a
            data-rhumb-propagate
            href="/blog/capability-first-agent-onboarding?rhumb_experiment=e004&rhumb_source=web-search-comparison-onboarding"
            class="inline-flex items-center justify-center rounded-xl bg-emerald-400 px-5 py-3 text-sm font-display font-semibold text-navy hover:bg-emerald-300 transition-colors duration-200"
          >
            See the capability-first handoff &rarr;
          </a>
          <a
            data-rhumb-propagate
            href="/start-managed-execution?rhumb_experiment=e004&rhumb_source=web-search-comparison-direct"
            class="inline-flex items-center justify-center rounded-xl border border-emerald-500/30 px-5 py-3 text-sm font-display font-semibold text-emerald-200 hover:border-emerald-400/60 hover:text-emerald-100 transition-colors duration-200"
          >
            Open the managed path &rarr;
          </a>
        </div>
      </section>

      <section class="mt-12" data-section="fleet-follow-through">
        <div class="rounded-[28px] border border-slate-800 bg-surface/70 p-6">
          <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500 mb-3">Fleet follow-through</div>
          <h2 class="font-display font-semibold text-2xl text-slate-100 tracking-tight mb-3">
            Choosing the search API is only the first operator decision
          </h2>
          <p class="text-slate-300 leading-relaxed mb-5">
            Once research loops run unattended, the next questions are what breaks in the loop, how shared search budgets get contained, and how retrieval credentials stay narrow when more tools attach to the same lane. These three pages carry the search comparison into live operations.
          </p>
          <div class="grid gap-3 sm:grid-cols-3">
            <a data-rhumb-propagate href="/blog/llm-apis-agent-loops" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 hover:border-slate-700 transition-colors">
              <div class="text-sm font-semibold text-slate-100">LLM APIs in Agent Loops</div>
              <p class="mt-2 text-sm text-slate-400 leading-relaxed">What actually breaks once retrieval, summarization, and repair calls start compounding inside live research runs.</p>
            </a>
            <a data-rhumb-propagate href="/blog/agent-fleet-rate-limit-design" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 hover:border-slate-700 transition-colors">
              <div class="text-sm font-semibold text-slate-100">Designing Agent Fleets That Survive Rate Limits</div>
              <p class="mt-2 text-sm text-slate-400 leading-relaxed">How shared query budgets and retry bursts turn a good research surface into a fleet coordination problem.</p>
            </a>
            <a data-rhumb-propagate href="/blog/api-credentials-agent-fleets" class="rounded-2xl border border-slate-800 bg-navy/60 p-4 hover:border-slate-700 transition-colors">
              <div class="text-sm font-semibold text-slate-100">API Credentials in Autonomous Agent Fleets</div>
              <p class="mt-2 text-sm text-slate-400 leading-relaxed">Why search feels safe until provider keys, downstream fetch access, and shared scopes widen faster than the trust model.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="font-display font-semibold text-lg text-slate-100 mb-4">Related</h2>
        <div class="space-y-4">
          {RELATED_READING.map((item) => (
            <a
              href={item.href}
              class="block bg-surface border border-slate-800 rounded-lg p-5 hover:border-amber/30 transition-colors"
            >
              <span class="text-xs font-mono text-amber uppercase tracking-widest">Owned surface</span>
              <h3 class="font-display font-semibold text-slate-100 mt-2">{item.title}</h3>
              <p class="text-sm text-slate-500 mt-1">{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    (() => {
      if (typeof window === "undefined") return;
      const params = new URLSearchParams(window.location.search);
      const experiment = params.get("rhumb_experiment");
      const source = params.get("rhumb_source");
      const parentSource = params.get("rhumb_parent_source");
      if (!experiment && !source && !parentSource) return;

      document.querySelectorAll("a[data-rhumb-propagate]").forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;

        const url = new URL(href, window.location.origin);
        if (experiment && !url.searchParams.has("rhumb_experiment")) {
          url.searchParams.set("rhumb_experiment", experiment);
        }
        if (source) {
          url.searchParams.set("rhumb_parent_source", source);
        }
        if (parentSource) {
          url.searchParams.set("rhumb_grandparent_source", parentSource);
        }

        link.setAttribute("href", `${url.pathname}${url.search}${url.hash}`);
      });
    })();
  </script>
</Layout>
