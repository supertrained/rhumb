---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import { PUBLIC_TRUTH } from "../../lib/public-truth";

const FAST_ANSWER = [
  "Choose a web search API for agents by matching the retrieval job first: semantic research, agent-shaped answers, Google-style freshness, or independent index coverage.",
  "Do not stop at the vendor comparison. Route the first production call through a bounded capability path so resolve, estimate, credential rail, budget owner, and trace evidence are explicit before the agent loops.",
  "Exa is strongest when semantic retrieval quality matters, Tavily when agent-ready answer packaging matters, Brave when independent index coverage matters, and Serper when Google SERP freshness is the target — but Serper should stay discovery-qualified unless your execution path is verified.",
  `Rhumb's public scope is ${PUBLIC_TRUTH.servicesLabel} scored services and ${PUBLIC_TRUTH.capabilitiesLabel} capability definitions for discovery, with ${PUBLIC_TRUTH.callableProvidersLabel} callable providers strongest for ${PUBLIC_TRUTH.beachheadLabel}. Use that scope boundary before treating a comparison page as an execution promise.`,
];

const SEARCH_JOBS = [
  {
    job: "Semantic research",
    useWhen: "The agent needs concept-level matches, related pages, or research recall rather than a literal keyword result.",
    likelyFit: "Exa",
    routeRisk: "semantic score drift and source-evidence gaps",
  },
  {
    job: "Agent-ready answer packaging",
    useWhen: "The loop wants cleaned snippets, depth controls, include/exclude domains, and answer-shaped retrieval for downstream synthesis.",
    likelyFit: "Tavily",
    routeRisk: "over-trusting packaged answers without preserving raw source context",
  },
  {
    job: "Fresh SERP-style lookup",
    useWhen: "The workflow depends on current public web ranking, news, local/fresh pages, or Google-like result ordering.",
    likelyFit: "Serper",
    routeRisk: "treating discovery-qualified SERP access as a verified governed execution lane",
  },
  {
    job: "Independent index coverage",
    useWhen: "The agent should avoid dependence on one dominant search backend or needs privacy/index independence as part of the operator constraint.",
    likelyFit: "Brave Search",
    routeRisk: "ranking/coverage differences that change recall without an explicit fallback rule",
  },
];

const ROUTING_SEQUENCE = [
  {
    step: "1",
    title: "Name the search job",
    body: "Write the job in one sentence: research a market, verify a URL, find recent incidents, enrich one company, or collect source-backed alternatives. The job decides the provider class before the score does.",
  },
  {
    step: "2",
    title: "Resolve before execution",
    body: "Use a capability route such as search.query to check whether Rhumb has a current managed path. Resolve is a read/preflight step; it is not permission to spend budget or call every scored provider.",
  },
  {
    step: "3",
    title: "Estimate the rail",
    body: "Estimate the concrete provider, credential mode, and cost envelope before the first paid or authorized call. If the estimate cannot name the rail, do not let the agent loop.",
  },
  {
    step: "4",
    title: "Preserve trace evidence",
    body: "Keep query, normalized provider path, result count, denied domains, credential rail, budget owner, and source evidence together so a bad result can be debugged as retrieval drift, auth drift, quota pressure, or contract drift.",
  },
];

const PREFLIGHT_CHECKS = [
  "What result shape does the agent need: URLs, answer text, snippets, highlights, crawled page content, or source-backed citations?",
  "What is the freshness boundary: today, last week, stable documentation, or evergreen conceptual recall?",
  "Which domains or result classes must be denied before provider calls happen?",
  "Which credential rail burns budget: governed Rhumb key, wallet/x402, BYOK, Agent Vault, or direct provider pinning?",
  "What retry rule prevents a bad query, empty result, 429, or provider outage from becoming a runaway research loop?",
  "What evidence would convince you the answer was routed safely enough to repeat tomorrow?",
];

const COMMON_FAILURES = [
  {
    title: "Ranking confidence becomes execution confidence",
    body: "A provider can be the right research pick and still be the wrong first managed execution rail for your workflow. Keep comparison, resolve, estimate, and execute as separate decisions.",
  },
  {
    title: "Freshness beats source evidence",
    body: "Fresh web results are useful only if the agent preserves source URLs and enough context to explain why a result was trusted, skipped, or denied.",
  },
  {
    title: "One query turns into an unpriced loop",
    body: "Agents rephrase, retry, fan out, and synthesize. Put result-count caps, retry budgets, and cost ceilings on the search job before the first unattended run.",
  },
  {
    title: "Discovery-only providers get treated as callable",
    body: "A scored service can be discoverable without being verified for the current governed execution path. That distinction should be visible to the agent before it chooses a route.",
  },
];

const RELATED = [
  {
    href: "/blog/exa-vs-tavily-vs-serper-vs-brave-search",
    title: "Exa vs Tavily vs Serper vs Brave Search",
    description: "The underlying provider comparison this guide turns into a routing decision.",
  },
  {
    href: "/quickstart#web-search-resolve",
    title: "Run the web-search Resolve quickstart",
    description: "Resolve, estimate, and execute search.query through the bounded quickstart path.",
  },
  {
    href: "/start-managed-execution?rhumb_experiment=e006&rhumb_source=web-search-routing-guide-proof-sprint",
    title: "Scope a managed search proof sprint",
    description: "Name one repeat search workflow, budget ceiling, denial case, and trace proof.",
  },
  {
    href: "/blog/api-reliability-checklist",
    title: "API Reliability Checklist",
    description: "The preflight gates that keep search from turning into an unattended failure loop.",
  },
];

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "How to Choose a Web Search API for Agents, Then Route the Call Safely",
  datePublished: "2026-05-01T00:00:00Z",
  dateModified: "2026-05-01T00:00:00Z",
  author: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
  description:
    "A practical guide to choosing Exa, Tavily, Serper, or Brave Search for AI agents, then routing search.query through resolve, estimate, credentials, budget, and trace evidence.",
  url: "https://rhumb.dev/blog/choose-web-search-api-for-ai-agents-route-safely",
  publisher: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
  mainEntityOfPage: "https://rhumb.dev/blog/choose-web-search-api-for-ai-agents-route-safely",
};
---

<Layout
  title="How to Choose a Web Search API for Agents | Rhumb"
  description="Choose Exa, Tavily, Serper, or Brave Search for an AI-agent workflow, then route search.query safely through resolve, estimate, credentials, budget, and trace evidence."
  canonical="/blog/choose-web-search-api-for-ai-agents-route-safely"
  ogTitle="How to Choose a Web Search API for Agents"
  ogDescription="Provider choice is only half the job. The first production search call needs resolve, estimate, credential rail, budget owner, and trace evidence."
  ogUrl="https://rhumb.dev/blog/choose-web-search-api-for-ai-agents-route-safely"
  ogType="article"
  twitterTitle="How to Choose a Web Search API for Agents"
  twitterDescription="Exa, Tavily, Serper, or Brave Search — then route the call safely before the agent loops."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="min-h-screen bg-navy">
    <section class="relative overflow-hidden border-b border-slate-800">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="absolute inset-x-0 top-0 h-56 bg-gradient-to-b from-amber/10 via-emerald-500/5 to-transparent pointer-events-none"></div>
      <div class="relative mx-auto max-w-6xl px-6 py-16">
        <div class="mb-6 flex flex-wrap items-center gap-3 text-xs font-mono">
          <a href="/blog" class="text-slate-500 transition-colors hover:text-amber">&larr; Blog</a>
          <span class="text-slate-800">&middot;</span>
          <span class="uppercase tracking-widest text-emerald-300">Resolve guide</span>
          <span class="text-slate-800">&middot;</span>
          <span class="text-slate-500">April 30, 2026</span>
          <span class="text-slate-800">&middot;</span>
          <span class="text-slate-600">Rhumb</span>
          <span class="text-slate-800">&middot;</span>
          <span class="text-slate-600">9 min read</span>
        </div>

        <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <div>
            <div class="mb-4 inline-flex rounded-full border border-amber/25 bg-amber/10 px-4 py-2 text-xs font-mono uppercase tracking-[0.22em] text-amber">
              Answer target: web search API for agents
            </div>
            <h1 class="max-w-4xl font-display text-4xl font-bold leading-tight tracking-tight text-slate-100 sm:text-5xl">
              How to Choose a Web Search API for Agents, Then Route the Call Safely
            </h1>
            <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-400">
              Search is often the first external API an agent touches. The provider decision matters — Exa, Tavily, Serper, and Brave optimize for different jobs — but the production question is whether the first repeat search call has a bounded route, credential rail, budget owner, and source evidence before it runs unattended.
            </p>
          </div>

          <aside class="rounded-[32px] border border-slate-800 bg-surface/80 p-6 shadow-[0_24px_80px_rgba(8,15,28,0.45)]">
            <div class="mb-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Fast answer</div>
            <div class="space-y-3">
              {FAST_ANSWER.map((point) => (
                <div class="rounded-2xl border border-slate-800 bg-navy/70 p-4 text-sm leading-6 text-slate-300">{point}</div>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <article class="mx-auto max-w-6xl px-6 py-12">
      <div class="mb-10 rounded-[32px] border border-emerald-500/20 bg-emerald-500/5 p-6 sm:p-8">
        <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.24em] text-emerald-300">Decision rule</div>
        <p class="text-lg leading-relaxed text-slate-300">
          Pick the search provider for the retrieval job, then pick the execution route for the risk. A good agent workflow separates those decisions: provider fit answers <em>which search surface</em>; Resolve and estimate answer <em>which governed path can safely run this call now</em>.
        </p>
      </div>

      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-start">
        <div class="space-y-14">
          <section>
            <h2 class="mb-4 font-display text-2xl font-bold tracking-tight text-slate-100">Start with the search job, not the logo</h2>
            <p class="mb-6 leading-relaxed text-slate-400">
              Web search APIs are not interchangeable once an agent loops over them. Some are better at semantic recall, some at answer packaging, some at SERP freshness, and some at index independence. The wrong abstraction is “best search API.” The right abstraction is “best search route for this repeat workflow.”
            </p>
            <div class="grid gap-4 md:grid-cols-2">
              {SEARCH_JOBS.map((item) => (
                <div class="rounded-[28px] border border-slate-800 bg-surface/75 p-6">
                  <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.22em] text-amber">{item.likelyFit}</div>
                  <h3 class="mb-2 font-display text-xl font-semibold tracking-tight text-slate-100">{item.job}</h3>
                  <p class="mb-4 text-sm leading-6 text-slate-400">{item.useWhen}</p>
                  <p class="rounded-2xl border border-slate-800 bg-navy/70 p-4 text-xs leading-5 text-slate-400">
                    <span class="font-mono uppercase tracking-widest text-slate-500">Watch:</span> {item.routeRisk}
                  </p>
                </div>
              ))}
            </div>
          </section>

          <section>
            <h2 class="mb-4 font-display text-2xl font-bold tracking-tight text-slate-100">Then route the call safely</h2>
            <p class="mb-6 leading-relaxed text-slate-400">
              A search comparison page can identify a candidate provider. It cannot prove that your current credential path, quota owner, result shape, denied-domain rule, and retry budget are safe for a live agent. That proof starts when the call becomes a capability route.
            </p>
            <div class="grid gap-4 md:grid-cols-2">
              {ROUTING_SEQUENCE.map((item) => (
                <div class="rounded-[28px] border border-slate-800 bg-surface/75 p-6">
                  <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-full border border-emerald-500/30 bg-emerald-500/10 font-mono text-sm text-emerald-300">{item.step}</div>
                  <h3 class="mb-2 font-display text-xl font-semibold tracking-tight text-slate-100">{item.title}</h3>
                  <p class="text-sm leading-6 text-slate-400">{item.body}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="rounded-[32px] border border-amber/25 bg-amber/8 p-6 sm:p-8" id="search-query-route">
            <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.24em] text-amber">Runnable path</div>
            <h2 class="mb-4 font-display text-2xl font-bold tracking-tight text-slate-100">Use <code class="font-mono text-amber">search.query</code> as the bounded first workflow</h2>
            <p class="mb-5 leading-relaxed text-slate-300">
              If the workflow is “my agent needs web research,” do not wire a provider SDK directly into an unattended loop on day one. Resolve <code class="font-mono text-amber">search.query</code>, estimate the concrete rail, then execute only after the key or payment path is explicit.
            </p>
            <div class="grid gap-4 lg:grid-cols-3">
              <div class="rounded-2xl border border-slate-800 bg-navy p-5">
                <p class="mb-2 text-xs font-mono uppercase tracking-widest text-emerald-300">1. Resolve</p>
                <pre class="overflow-x-auto text-xs font-mono text-slate-300"><code>{`curl "https://api.rhumb.dev/v1/capabilities/search.query/resolve"`}</code></pre>
              </div>
              <div class="rounded-2xl border border-slate-800 bg-navy p-5">
                <p class="mb-2 text-xs font-mono uppercase tracking-widest text-emerald-300">2. Estimate</p>
                <pre class="overflow-x-auto text-xs font-mono text-slate-300"><code>{`curl "https://api.rhumb.dev/v1/capabilities/search.query/execute/estimate"`}</code></pre>
              </div>
              <div class="rounded-2xl border border-slate-800 bg-navy p-5">
                <p class="mb-2 text-xs font-mono uppercase tracking-widest text-emerald-300">3. Execute</p>
                <pre class="overflow-x-auto text-xs font-mono text-slate-300"><code>{`curl -X POST "https://api.rhumb.dev/v1/capabilities/search.query/execute" \\
  -H "X-Rhumb-Key: rhumb_live_..." \\
  -H "Content-Type: application/json" \\
  -d '{"body":{"query":"best CRM for seed-stage B2B SaaS","max_results":5}}'`}</code></pre>
              </div>
            </div>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/quickstart#web-search-resolve" class="inline-flex items-center justify-center rounded-xl bg-amber px-5 py-3 text-sm font-display font-semibold text-navy transition-colors hover:bg-amber-dark">
                Run the quickstart &rarr;
              </a>
              <a href="/start-managed-execution?rhumb_experiment=e006&rhumb_source=web-search-routing-guide-main-cta" class="inline-flex items-center justify-center rounded-xl border border-slate-700 px-5 py-3 text-sm font-display font-semibold text-slate-200 transition-colors hover:border-emerald-400 hover:text-emerald-300">
                Scope a proof sprint &rarr;
              </a>
            </div>
          </section>

          <section>
            <h2 class="mb-4 font-display text-2xl font-bold tracking-tight text-slate-100">Preflight questions before the first repeat search</h2>
            <div class="rounded-[28px] border border-slate-800 bg-surface/75 p-6">
              <ul class="ml-5 list-disc list-outside space-y-3 leading-relaxed text-slate-300">
                {PREFLIGHT_CHECKS.map((check) => (<li>{check}</li>))}
              </ul>
            </div>
          </section>

          <section>
            <h2 class="mb-4 font-display text-2xl font-bold tracking-tight text-slate-100">Common failure modes</h2>
            <div class="space-y-4">
              {COMMON_FAILURES.map((failure) => (
                <div class="rounded-[28px] border border-slate-800 bg-surface/75 p-6">
                  <h3 class="mb-2 font-display text-xl font-semibold tracking-tight text-slate-100">{failure.title}</h3>
                  <p class="text-sm leading-6 text-slate-400">{failure.body}</p>
                </div>
              ))}
            </div>
          </section>
        </div>

        <aside class="space-y-5 lg:sticky lg:top-24">
          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <div class="mb-3 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Conversion hypothesis</div>
            <p class="text-sm leading-6 text-slate-400">
              Web-search comparison readers should move into the quickstart or E-006 proof sprint when they have one repeat research workflow worth pricing and tracing.
            </p>
          </div>
          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <div class="mb-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Related reading</div>
            <div class="space-y-4">
              {RELATED.map((item) => (
                <a href={item.href} class="block rounded-2xl border border-slate-800 bg-navy/60 p-4 transition-colors hover:border-amber/50">
                  <div class="mb-1 font-display text-sm font-semibold tracking-tight text-slate-100">{item.title}</div>
                  <p class="text-xs leading-5 text-slate-500">{item.description}</p>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </article>
  </div>
</Layout>
