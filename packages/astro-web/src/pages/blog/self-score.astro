  description="Rhumb's initial March 11 self-assessment baseline: 3.5/10 before launch. This page stays public as the original reference point, with a newer fuller self-assessment linked inside."
  canonical="/blog/self-score"
  ogTitle="We Scored Ourselves First — Here's What We Found"
  ogDescription="Rhumb's original March 11 baseline self-assessment: 3.5/10 before launch. Historical reference, kept public alongside the later fuller self-assessment."
  ogUrl="https://rhumb.dev/blog/self-score"
  ogType="article"
  twitterTitle="We Scored Ourselves First — Here's What We Found"
  twitterDescription="Rhumb's original March 11 baseline self-assessment: 3.5/10 before launch."
  jsonLd={ARTICLE_JSON_LD}
>
