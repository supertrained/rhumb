---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import ResolveComparisonCta from "../../components/ResolveComparisonCta.astro";
import ScoreDisplay from "../../components/ScoreDisplay.astro";
import TierBadge from "../../components/TierBadge.astro";
import { getServiceScore } from "../../lib/api";
import type { ServiceScoreViewModel } from "../../lib/types";

const scoreMap = {
  supabase: await getServiceScore("supabase"),
  planetscale: await getServiceScore("planetscale"),
  neon: await getServiceScore("neon"),
} satisfies Record<string, ServiceScoreViewModel | null>;

const ARTICLE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Supabase vs PlanetScale vs Neon for AI Agents",
  datePublished: "2026-03-17T00:00:00Z",
  author: { "@type": "Person", name: "Pedro Nunes" },
  description:
    "Side-by-side comparison of Supabase, PlanetScale, and Neon for AI agent database workflows — using live Rhumb AN Score data.",
  url: "https://rhumb.dev/blog/supabase-vs-planetscale-vs-neon",
  publisher: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
};

type ComparedService = {
  slug: "supabase" | "planetscale" | "neon";
  name: string;
  accent: string;
  accentSoft: string;
  tagline: string;
  bestFor: string;
  avoidWhen: string;
  friction: string;
  decision: string;
  support: string;
  data: ServiceScoreViewModel | null;
};

const compared: ComparedService[] = [
  {
    slug: "supabase",
    name: "Supabase",
    accent: "#3ECF8E",
    accentSoft: "rgba(62,207,142,0.14)",
    tagline: "full-stack platform",
    bestFor: "Agents that need a database AND auth, storage, edge functions, and realtime subscriptions through a single platform. The broadest surface area — one integration covers what would require 4-5 separate services.",
    avoidWhen: "You need a pure database with maximum SQL control, complex multi-region topologies, or want to avoid platform lock-in. Supabase wraps Postgres with opinions that may conflict with advanced database administration.",
    friction: "Row-level security (RLS) policies are powerful but add a layer agents must understand and configure correctly — misconfigured RLS silently returns empty results, not errors. Realtime subscriptions use websockets which add connection management complexity for agents.",
    decision: "Pick Supabase when the agent needs more than just a database — auth, storage, and realtime come free.",
    support: "Highest confidence score (88%) means the most measured and verified of the three. The platform breadth (Postgres + Auth + Storage + Edge Functions + Realtime) gives it the widest agent utility surface. REST and GraphQL APIs mean agents never need a direct database connection.",
    data: scoreMap.supabase,
  },
  {
    slug: "planetscale",
    name: "PlanetScale",
    accent: "#000000",
    accentSoft: "rgba(120,120,120,0.14)",
    tagline: "mysql branching",
    bestFor: "Teams that need MySQL with Vitess-powered horizontal scaling, schema branching for safe migrations, and zero-downtime DDL changes. Best when the existing codebase is MySQL-native.",
    avoidWhen: "You need Postgres features (JSON operators, full-text search, extensions) or a broad platform play beyond just the database. PlanetScale is a pure database service — no auth, storage, or functions bundled.",
    friction: "Foreign key constraints are not supported in the traditional sense (Vitess limitation). Agents expecting referential integrity enforcement at the database level will see silent data inconsistencies. Schema branching workflow adds complexity for agents that just need a connection string.",
    decision: "Pick PlanetScale when the project is MySQL-native and needs safe schema migrations at scale.",
    support: "Mid-range score with lower confidence (56%) — less measured than Supabase. The Vitess-powered scaling is genuinely strong for MySQL workloads, but the foreign key limitation is a significant constraint that agents often discover too late.",
    data: scoreMap.planetscale,
  },
  {
    slug: "neon",
    name: "Neon",
    accent: "#00E599",
    accentSoft: "rgba(0,229,153,0.14)",
    tagline: "serverless postgres",
    bestFor: "Agents that want pure serverless Postgres with branching, autoscaling to zero, and the lowest cold-start latency of the three. Best when the project needs Postgres without platform opinions.",
    avoidWhen: "You need a full platform play (auth, storage, functions) or the project has sustained high-throughput workloads where connection pooling overhead matters. Neon's serverless model excels at bursty workloads, not steady-state.",
    friction: "Serverless cold starts add latency for the first query after idle periods. Connection pooling through their proxy adds a layer between the agent and Postgres that can mask connection errors. Branch creation is fast but branch management (cleanup, promotion) requires explicit API calls.",
    decision: "Pick Neon when you want pure Postgres with serverless economics and don't need the broader platform.",
    support: "Highest raw score (7.6, L4 tier) but lowest confidence (59%) — the score reflects strong architectural decisions but less measurement depth. Serverless Postgres with branching is a genuinely differentiated offering. The autoscale-to-zero model is most cost-efficient for agent workloads that are inherently bursty.",
    data: scoreMap.neon,
  },
];

const available = compared.filter((item) => item.data !== null);
const ranked = [...available].sort(
  (a, b) => (b.data?.aggregateRecommendationScore ?? 0) - (a.data?.aggregateRecommendationScore ?? 0)
);
const winner = ranked[0];
const updatedAt = winner?.data?.calculatedAt
  ? new Date(winner.data.calculatedAt).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })
  : "recently";
const updatedAtISO = winner?.data?.calculatedAt
  ? new Date(winner.data.calculatedAt).toISOString()
  : new Date().toISOString();
(ARTICLE_JSON_LD as any).dateModified = updatedAtISO;

function formatScore(value: number | null | undefined): string {
  return value == null ? "—" : value.toFixed(1);
}
function formatConfidence(value: number | null | undefined): string {
  return value == null ? "—" : `${Math.round(value * 100)}%`;
}

function failureCopy(item: ComparedService): string[] {
  if (item.slug === "supabase") {
    return [
      "Row-level security (RLS) misconfiguration silently returns empty result sets instead of errors. An agent seeing zero results cannot distinguish between 'no data' and 'no permission' without checking the RLS policy.",
      "The REST API (PostgREST) maps SQL to URL query parameters. Complex joins and subqueries hit the limits of URL-based query expression — agents need to fall back to the SQL endpoint for advanced queries.",
      "Realtime subscriptions require websocket connection management. If the agent's runtime doesn't support persistent connections, realtime features are effectively unavailable.",
    ];
  }
  if (item.slug === "planetscale") {
    return [
      "Foreign key constraints are not enforced at the database level (Vitess architecture). Agents that assume referential integrity will encounter orphaned rows and inconsistent state with no database-level error.",
      "Schema branching adds a workflow layer between 'write migration' and 'apply migration.' Agents expecting direct DDL execution need to learn the branch → deploy request → merge cycle.",
      "Connection string format changes between branches and production. Agents managing multiple environments need separate credential handling per branch.",
    ];
  }
  return [
    "Serverless cold starts add 100-500ms latency for the first query after idle periods. Agents making time-sensitive queries need a keep-alive strategy or must account for variable first-query latency.",
    "Connection pooling through Neon's proxy can mask the real error when a connection fails — the agent sees a proxy timeout rather than the underlying Postgres error, making debugging harder.",
    "Branch management (creation is automatic, but cleanup and promotion are not) can accumulate stale branches that consume compute resources. Agents need explicit branch lifecycle management.",
  ];
}

const scenarioCards = [
  {
    title: "Agent needs database + auth + storage in one integration",
    pick: "Supabase",
    why: "Only option where a single integration covers Postgres, auth, file storage, edge functions, and realtime. Highest confidence score means the most predictable behavior.",
    href: "/service/supabase",
  },
  {
    title: "Existing MySQL codebase needs safe schema migrations at scale",
    pick: "PlanetScale",
    why: "Vitess-powered MySQL with schema branching and zero-downtime DDL. The only option if the project is MySQL-native.",
    href: "/service/planetscale",
  },
  {
    title: "Pure Postgres with serverless economics and minimal overhead",
    pick: "Neon",
    why: "Serverless Postgres that scales to zero. Lowest cost for bursty agent workloads. Database branching for safe testing without the platform overhead.",
    href: "/service/neon",
  },
];

const agentRules = [
  "If the operator has no database yet and needs more than just data storage, default to Supabase. The platform breadth reduces total integration count.",
  "If the operator mentions MySQL, Vitess, or existing MySQL workloads, route to PlanetScale — do not try to migrate them to Postgres.",
  "If the operator wants pure Postgres without platform opinions, recommend Neon. It is the thinnest wrapper around serverless Postgres.",
  "For Supabase: always verify RLS policies before reporting empty query results. An empty result set may be a permissions issue, not missing data.",
  "For PlanetScale: do not assume foreign key constraints exist. Validate referential integrity in application logic, not database constraints.",
  "For Neon: implement connection keep-alive for latency-sensitive workloads. The first query after idle will be slow; subsequent queries are fast.",
  "Confidence matters here: Supabase at 88% is the most measured; Neon and PlanetScale at ~57% may shift as more evidence accumulates.",
];
---

<Layout
  title="Supabase vs PlanetScale vs Neon for AI Agents | Rhumb"
  description="Compare Supabase, PlanetScale, and Neon for agent database workflows. Supabase leads on breadth, Neon on serverless Postgres, PlanetScale on MySQL."
  canonical="/blog/supabase-vs-planetscale-vs-neon"
  ogTitle="Supabase vs PlanetScale vs Neon for AI Agents"
  ogDescription="Which database should an AI agent use? The closest race in any category — scores within 0.4 of each other, but confidence tells a different story."
  ogUrl="https://rhumb.dev/blog/supabase-vs-planetscale-vs-neon"
  ogType="article"
  twitterTitle="Supabase vs PlanetScale vs Neon for AI Agents"
  twitterDescription="A side-by-side decision page for operators and agents choosing a database platform."
  jsonLd={ARTICLE_JSON_LD}
>
  <div class="bg-navy min-h-screen overflow-hidden">
    <section class="relative border-b border-slate-800/80">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_left,rgba(62,207,142,0.12),transparent_32%),radial-gradient(circle_at_top_right,rgba(120,120,120,0.08),transparent_28%),radial-gradient(circle_at_bottom,rgba(0,229,153,0.10),transparent_35%)]"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-14 pb-16">
        <div class="max-w-3xl">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="text-xs font-mono font-semibold text-amber uppercase tracking-[0.28em]">Comparison</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-slate-500">March 17, 2026</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-emerald-400/70">Updated {updatedAt}</span>
          </div>

          <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl leading-[0.95] tracking-tight text-slate-100 max-w-4xl text-balance">
            Supabase vs PlanetScale vs Neon for AI agents
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-slate-300 leading-relaxed max-w-3xl">
            <span class="text-slate-100 font-semibold">Short answer:</span>
            The closest race in any category we've scored.
            Neon edges on raw score, Supabase on confidence and platform breadth,
            PlanetScale when MySQL is non-negotiable.
          </p>

          <div class="mt-8 inline-flex max-w-3xl items-start gap-3 rounded-2xl border border-emerald-500/20 bg-emerald-500/8 px-5 py-4">
            <div class="mt-0.5 h-2.5 w-2.5 rounded-full bg-emerald-400 shrink-0"></div>
            <p class="text-sm leading-6 text-slate-300">
              <span class="font-semibold text-slate-100">Verdict:</span>
              All three score between 7.2 and 7.6 — a 0.4-point spread that is within margin of error.
              The real differentiator is not the score but the <em>shape</em> of the offering: Supabase is a platform,
              PlanetScale is a MySQL scaling engine, Neon is a serverless Postgres primitive.
              Confidence matters: Supabase at 88% is the most measured; Neon and PlanetScale at ~57% may shift.
              Scores shown here reflect published Rhumb data as of {updatedAt}.
            </p>
          </div>
        </div>

        <div class="mt-12 grid gap-5 lg:grid-cols-3">
          {compared.map((item, index) => (
            <article
              class="group relative overflow-hidden rounded-[28px] border bg-surface/90 backdrop-blur-sm p-6 sm:p-7 reveal"
              style={`border-color:${item.accent}40; background-image:linear-gradient(180deg, ${item.accentSoft} 0%, rgba(15,23,42,0.85) 26%, rgba(15,23,42,0.92) 100%); animation-delay:${index * 80}ms;`}
            >
              <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`background:radial-gradient(circle_at_top_right, ${item.accentSoft} 0%, transparent 38%);`}></div>
              <div class="relative">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">{item.tagline}</p>
                    <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">{item.name}</h2>
                  </div>
                  <ScoreDisplay score={item.data?.aggregateRecommendationScore ?? null} size="large" showLabel />
                </div>

                <div class="mt-4 flex items-center gap-3 flex-wrap">
                  <TierBadge tier={item.data?.tier ?? null} label={item.data?.tierLabel ?? undefined} />
                  <span class="text-xs font-mono text-slate-500">confidence {formatConfidence(item.data?.confidence)}</span>
                </div>

                <p class="mt-5 text-sm leading-6 text-slate-300">{item.bestFor}</p>

                <dl class="mt-6 grid grid-cols-3 gap-3">
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Exec</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.executionScore)}</dd>
                  </div>
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Access</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.accessReadinessScore)}</dd>
                  </div>
                  <div class="rounded-2xl border border-white/6 bg-navy/65 px-4 py-3">
                    <dt class="text-[10px] font-mono uppercase tracking-[0.22em] text-slate-500">Autonomy</dt>
                    <dd class="mt-1 text-lg font-semibold text-slate-100">{formatScore(item.data?.p1Score)}</dd>
                  </div>
                </dl>

                <div class="mt-6 rounded-2xl border border-white/6 bg-navy/70 p-4">
                  <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Why it lands here</p>
                  <p class="mt-2 text-sm leading-6 text-slate-300">{item.support}</p>
                </div>

                <div class="mt-4 space-y-3">
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Biggest friction</p>
                    <p class="mt-1 text-sm leading-6 text-slate-400">{item.friction}</p>
                  </div>
                  <div>
                    <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Avoid when</p>
                    <p class="mt-1 text-sm leading-6 text-slate-400">{item.avoidWhen}</p>
                  </div>
                </div>

                <div class="mt-6 flex items-center justify-between gap-4 border-t border-white/8 pt-4">
                  <p class="text-sm font-semibold text-slate-200 max-w-[20rem]">{item.decision}</p>
                  <a href={`/service/${item.slug}`} class="text-xs font-mono uppercase tracking-[0.2em] text-amber hover:text-amber-dark transition-colors">Service page →</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

      <ResolveComparisonCta
        source="supabase-vs-planetscale-vs-neon"
        capability="database-backed application workflows"
        callableServices={[]}
        discoveryOnlyServices={[{ name: "Supabase", href: "/service/supabase" }, { name: "PlanetScale", href: "/service/planetscale" }, { name: "Neon", href: "/service/neon" }]}
      />


    <section class="max-w-6xl mx-auto px-6 py-14">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="rounded-[28px] border border-slate-800 bg-surface/80 overflow-hidden reveal">
          <div class="border-b border-slate-800 px-6 py-5 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0))]">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Operator scoreboard</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">What the numbers actually say</h2>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full min-w-[720px]">
              <thead>
                <tr class="border-b border-slate-800 text-left">
                  <th class="px-6 py-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">Metric</th>
                  {compared.map((item) => (
                    <th class="px-6 py-4 text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">{item.name}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Aggregate AN Score</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 font-semibold text-slate-100">{formatScore(item.data?.aggregateRecommendationScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Execution</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.executionScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Access Readiness</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatScore(item.data?.accessReadinessScore)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="px-6 py-4 text-sm text-slate-300">Confidence</td>
                  {compared.map((item) => (
                    <td class="px-6 py-4 text-slate-200">{formatConfidence(item.data?.confidence)}</td>
                  ))}
                </tr>
                <tr class="border-b border-slate-800/80 align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Engine</td>
                  <td class="px-6 py-4 text-sm text-slate-300">PostgreSQL<br/><span class="text-slate-500">+ Auth + Storage + Realtime</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">MySQL (Vitess)<br/><span class="text-slate-500">horizontal sharding</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">PostgreSQL<br/><span class="text-slate-500">serverless, scales to zero</span></td>
                </tr>
                <tr class="border-b border-slate-800/80 align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Free tier</td>
                  <td class="px-6 py-4 text-sm text-slate-300">500 MB + 2 projects<br/><span class="text-slate-500">generous for prototyping</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">5 GB + 1B reads/mo<br/><span class="text-slate-500">high read volume</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">512 MB + 191 hrs/mo<br/><span class="text-slate-500">compute-hour based</span></td>
                </tr>
                <tr class="align-top">
                  <td class="px-6 py-4 text-sm text-slate-300">Agent API</td>
                  <td class="px-6 py-4 text-sm text-slate-300">REST + GraphQL + SQL<br/><span class="text-slate-500">3 access modes</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">MySQL protocol<br/><span class="text-slate-500">+ REST API</span></td>
                  <td class="px-6 py-4 text-sm text-slate-300">Postgres protocol<br/><span class="text-slate-500">+ HTTP/SQL API</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <aside class="space-y-5 reveal">
          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Agent brief</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">Routing rules</h2>
            <ol class="mt-5 space-y-3">
              {agentRules.map((rule, idx) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full border border-slate-700 bg-navy text-[11px] font-mono text-slate-300 shrink-0">{idx + 1}</span>
                  <span class="text-sm leading-6 text-slate-300">{rule}</span>
                </li>
              ))}
            </ol>
          </div>

          <div class="rounded-[28px] border border-slate-800 bg-surface/80 p-6">
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Confidence note</p>
            <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">When scores are this close</h2>
            <p class="mt-4 text-base leading-7 text-slate-300">
              A 0.4-point spread between 7.2 and 7.6 is within measurement uncertainty.
              When scores are this close, <span class="font-semibold text-slate-100">confidence becomes the deciding factor.</span>
              {' '}Supabase at 88% has the most stable score. Neon and PlanetScale at ~57% may shift
              significantly as more evidence accumulates.
            </p>
            <div class="mt-5 rounded-2xl border border-emerald-500/20 bg-emerald-500/8 p-4 text-sm leading-6 text-slate-300">
              The honest read: all three are good enough. The decision should be driven by what you already use
              (Postgres vs MySQL) and how much platform you want around your database, not by a 0.4-point score difference.
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-14">
      <div class="rounded-[32px] border border-slate-800 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(2,6,23,0.4))] p-6 sm:p-8 reveal">
        <div class="max-w-2xl">
          <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Friction map</p>
          <h2 class="mt-2 font-display font-bold text-2xl sm:text-3xl text-slate-100">Where each one breaks in practice</h2>
          <p class="mt-4 text-slate-400 leading-relaxed">
            Database failures are state-corrupting — harder to recover from than API errors in stateless services.
            Each platform has distinct failure patterns that agents need to anticipate.
          </p>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-3">
          {compared.map((item, index) => (
            <article class="rounded-[26px] border bg-navy/55 p-6" style={`border-color:${item.accent}30; animation-delay:${index * 90}ms;`}>
              <div class="flex items-center justify-between gap-4">
                <h3 class="font-display font-bold text-xl text-slate-100">{item.name}</h3>
                <span class="h-2.5 w-2.5 rounded-full" style={`background:${item.accent}`}></span>
              </div>
              <ul class="mt-5 space-y-3">
                {failureCopy(item).map((line) => (
                  <li class="flex items-start gap-3 text-sm leading-6 text-slate-300">
                    <span class="mt-2 h-1.5 w-1.5 rounded-full bg-slate-500 shrink-0"></span>
                    <span>{line}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-16">
      <div class="grid gap-5 lg:grid-cols-3 reveal">
        {scenarioCards.map((card, index) => (
          <article class="rounded-[28px] border border-slate-800 bg-surface/85 p-6" style={`animation-delay:${index * 80}ms;`}>
            <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Scenario</p>
            <h3 class="mt-2 font-display font-bold text-xl text-slate-100 leading-snug">{card.title}</h3>
            <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/8 px-3 py-1">
