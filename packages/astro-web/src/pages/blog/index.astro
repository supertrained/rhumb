---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";

const POSTS = [
  {
    slug: "posthog-vs-mixpanel-vs-amplitude",
    title: "PostHog vs Mixpanel vs Amplitude for AI Agents",
    description:
      "PostHog wins on breadth and agent-friendliness, Mixpanel on behavioral depth, Amplitude for warehouse-native enterprise. A side-by-side decision page.",
    date: "March 17, 2026",
    tag: "Comparison",
    readTime: "9 min read",
  },
  {
    slug: "auth0-vs-clerk-vs-firebase-auth",
    title: "Auth0 vs Clerk vs Firebase Auth for AI Agents",
    description:
      "Clerk wins on agent ergonomics, Auth0 wins on enterprise compliance, Firebase Auth wins inside Google Cloud. A side-by-side decision page.",
    date: "March 17, 2026",
    tag: "Comparison",
    readTime: "9 min read",
  },
  {
    slug: "hubspot-vs-salesforce-vs-pipedrive",
    title: "HubSpot vs Salesforce vs Pipedrive for AI Agents",
    description:
      "No CRM is agent-native yet. Pipedrive has the least friction, Salesforce has the governance ceiling, and HubSpot has the broadest surface.",
    date: "March 17, 2026",
    tag: "Comparison",
    readTime: "10 min read",
  },
  {
    slug: "resend-vs-sendgrid-vs-postmark",
    title: "Resend vs SendGrid vs Postmark for AI Agents",
    description:
      "Resend wins by default, Postmark wins for critical deliverability, and SendGrid wins in Twilio stacks. A side-by-side decision page for operators and agents.",
    date: "March 17, 2026",
    tag: "Comparison",
    readTime: "9 min read",
  },
  {
    slug: "stripe-vs-square-vs-paypal",
    title: "Stripe vs Square vs PayPal for AI Agents",
    description:
      "Stripe wins by default, Square wins when physical commerce matters, and PayPal is mostly a constraint-driven choice. A side-by-side decision page for operators and agents.",
    date: "March 17, 2026",
    tag: "Comparison",
    readTime: "9 min read",
  },
  {
    slug: "how-agents-pay",
    title: "How AI Agents Get Wallets and Pay for Things",
    description:
      "Three paths to agent-autonomous payments: prepaid credits, x402 USDC on Base, and enterprise agent cards. Working code for each.",
    date: "March 17, 2026",
    tag: "Agent Infrastructure",
    readTime: "11 min read",
  },
  {
    slug: "agent-native-frontend-stack",
    title: "The Agent-Native Frontend Stack",
    description:
      "We ranked every major frontend framework by how hard it is to accidentally build something agents can't read. Astro wins. Here's why.",
    date: "March 14, 2026",
    tag: "Agent Infrastructure",
    readTime: "12 min read",
  },
  {
    slug: "agent-cards-invisible",
    title: "Why 'Agent Cards' Are Invisible to Agents",
    description:
      "We fetched Ramp's Agent Cards page the way an agent would. It extracted 3 words. Here's the full audit and the fix pattern.",
    date: "March 14, 2026",
    tag: "Agent Readability",
    readTime: "7 min read",
  },
  {
    slug: "agent-passport-ranking",
    title: "Which SSO Gives Agents the Most Power?",
    description:
      "We tried to bootstrap 23 developer tools autonomously. GitHub unlocked 8. Email unlocked 0. The full agent passport ranking.",
    date: "March 14, 2026",
    tag: "Access",
    readTime: "9 min read",
  },
  {
    slug: "self-score",
    title: "We Scored Ourselves First — Here's What We Found",
    description:
      "Rhumb's honest assessment of its own agent-nativeness using our own framework. 3.5/10 (Limited). Why transparency is the credibility moat.",
    date: "March 11, 2026",
    tag: "Transparency",
    readTime: "12 min read",
  },
  {
    slug: "aag-framework",
    title:
      "The WCAG for AI Agents: Why Your Web App Isn't Built for Its Fastest-Growing User Base",
    description:
      "Agent Accessibility Guidelines (AAG): 6 interaction channels x 3 compliance levels. The framework for making web apps work for autonomous AI agents.",
    date: "March 10, 2026",
    tag: "Framework",
    readTime: "10 min read",
  },
  {
    slug: "payments-for-agents",
    title: "Why Stripe Scores 8.1 and PayPal Scores 4.9 for AI Agents",
    description:
      "We scored 6 payment APIs on how well they work for AI agents — not humans. The most popular one scored the worst.",
    date: "March 9, 2026",
    tag: "Tool Autopsy",
    readTime: "8 min read",
  },
];

const BLOG_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Rhumb Blog",
  url: "https://rhumb.dev/blog",
  description: "Tool autopsies, scoring methodology deep-dives, and agent infrastructure insights.",
  publisher: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
  blogPost: POSTS.map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    description: post.description,
    url: `https://rhumb.dev/blog/${post.slug}`,
    datePublished: post.date,
  })),
};
---


<Layout
  title="Blog | Rhumb"
  description="Tool autopsies and agent-native infrastructure insights."
  canonical="https://rhumb.dev/blog"
  ogTitle="Blog | Rhumb"
  ogDescription="Tool autopsies and agent-native infrastructure insights."
  ogUrl="https://rhumb.dev/blog"
  ogImage="https://rhumb.dev/api/og"
  jsonLd={BLOG_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <!-- Header -->
    <section class="relative border-b border-slate-800 overflow-hidden">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="relative max-w-3xl mx-auto px-6 py-14">
        <p class="text-xs font-mono text-amber uppercase tracking-widest mb-3">Writing</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 tracking-tight">Blog</h1>
        <p class="mt-3 text-slate-400 leading-relaxed">
          Tool autopsies, scoring methodology deep-dives, and agent infrastructure insights.
        </p>
      </div>
    </section>

    <!-- Post list -->
    <section class="max-w-3xl mx-auto px-6 py-12">
      <div class="space-y-4">
        {POSTS.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="block group"
          >
            <article class="bg-surface border border-slate-800 rounded-xl p-7 transition-all duration-200 hover:border-slate-600 hover:bg-elevated">
              <!-- Meta row -->
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">
                  {post.tag}
                </span>
                <span class="text-slate-800">&middot;</span>
                <span class="text-xs font-mono text-slate-500">{post.date}</span>
                <span class="text-slate-800">&middot;</span>
                <span class="text-xs font-mono text-slate-600">{post.readTime}</span>
              </div>

              <!-- Title -->
              <h2 class="font-display font-bold text-xl text-slate-100 leading-snug group-hover:text-amber transition-colors mb-3">
                {post.title}
              </h2>

              <!-- Excerpt -->
              <p class="text-slate-400 text-sm leading-relaxed">
                {post.description}
              </p>

              <!-- Read link -->
              <div class="mt-5 text-xs font-mono text-slate-600 group-hover:text-amber transition-colors">
                Read post &rarr;
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>
