<Layout
  title="Blog | Rhumb"
  description="API autopsies, head-to-head comparisons, and agent infrastructure insights for the agent-native era."
  canonical="https://rhumb.dev/blog"
  ogTitle="Blog | Rhumb"
  ogDescription="API autopsies, head-to-head comparisons, and agent infrastructure insights."
  ogUrl="https://rhumb.dev/blog"
  ogImage="https://rhumb.dev/api/og"
  jsonLd={BLOG_JSON_LD}
>
  {/* Agent meta tags (AAG Level AA) */}
  <meta name="ai:content-type" content="blog-index" />
  <meta name="ai:post-count" content={String(POSTS.length)} />
  <meta name="ai:content-types" content="comparison,autopsy,guide,article" />
  <meta name="ai:data-format" content="structured-cards" />

  <div class="bg-navy min-h-screen noise-overlay" data-testid="blog-index">

    <!-- ── Hero ──────────────────────────────────────────────── -->
    <section class="relative border-b border-slate-800/60 overflow-hidden">
      <div class="absolute inset-0 bg-grid opacity-20 pointer-events-none"></div>
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[350px] rounded-full pointer-events-none"
        style="background: radial-gradient(ellipse, rgba(245,158,11,0.05) 0%, transparent 70%);"
      ></div>

      <div class="relative max-w-6xl mx-auto px-6 py-16 md:py-20">
        <!-- Eyebrow -->
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs font-mono text-amber uppercase tracking-[0.2em]">Rhumb Intelligence</span>
          <span class="h-px w-10 bg-amber/30"></span>
          <span class="text-xs font-mono text-slate-600">api research · tool scoring</span>
        </div>

        <h1 class="font-display font-bold text-5xl md:text-6xl text-slate-100 tracking-tight leading-none mb-4">
          API Intelligence
        </h1>
        <p class="text-slate-400 text-lg max-w-2xl leading-relaxed mb-10">
          Tool autopsies, head-to-head comparisons, and agent infrastructure deep-dives.
          <span class="text-slate-600">Structured for autonomous parsing. Readable by humans.</span>
        </p>

        <!-- Stats strip -->
        <div class="flex flex-wrap items-center gap-6">
