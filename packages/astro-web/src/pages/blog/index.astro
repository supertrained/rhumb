    ...(post.contentType === "Guide"
      ? {
          additionalProperty: [
            { "@type": "PropertyValue", name: "contentType", value: "Guide" },
            { "@type": "PropertyValue", name: "difficulty", value: post.difficulty },
            { "@type": "PropertyValue", name: "timeEstimate", value: post.timeEstimate },
          ],
        }
      : {}),
  })),
};
---

<Layout
  title="Blog | Rhumb"
  description="API autopsies, head-to-head comparisons, and agent infrastructure insights for the agent-native era."
  canonical="https://rhumb.dev/blog"
  ogTitle="Blog | Rhumb"
  ogDescription="API autopsies, head-to-head comparisons, and agent infrastructure insights."
  ogUrl="https://rhumb.dev/blog"
  ogImage="https://rhumb.dev/api/og"
  jsonLd={BLOG_JSON_LD}
>
  {/* Agent meta tags (AAG Level AA) */}
  <meta name="ai:content-type" content="blog-index" />
  <meta name="ai:post-count" content={String(POSTS.length)} />
  <meta name="ai:content-types" content="comparison,autopsy,guide,article" />
  <meta name="ai:data-format" content="structured-cards" />

  <div class="bg-navy min-h-screen noise-overlay" data-testid="blog-index">

    <!-- ── Hero ──────────────────────────────────────────────── -->
    <section class="relative border-b border-slate-800/60 overflow-hidden">
      <div class="absolute inset-0 bg-grid opacity-20 pointer-events-none"></div>
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[350px] rounded-full pointer-events-none"
        style="background: radial-gradient(ellipse, rgba(245,158,11,0.05) 0%, transparent 70%);"
      ></div>

      <div class="relative max-w-6xl mx-auto px-6 py-16 md:py-20">
        <!-- Eyebrow -->
        <div class="flex items-center gap-3 mb-6">
          <span class="text-xs font-mono text-amber uppercase tracking-[0.2em]">Rhumb Intelligence</span>
          <span class="h-px w-10 bg-amber/30"></span>
          <span class="text-xs font-mono text-slate-600">api research · tool scoring</span>
        </div>

        <h1 class="font-display font-bold text-5xl md:text-6xl text-slate-100 tracking-tight leading-none mb-4">
          API Intelligence
        </h1>
        <p class="text-slate-400 text-lg max-w-2xl leading-relaxed mb-10">
          Tool autopsies, head-to-head comparisons, and agent infrastructure deep-dives.
          <span class="text-slate-600">Structured for autonomous parsing. Readable by humans.</span>
        </p>

        <!-- Stats strip -->
        <div class="flex flex-wrap items-center gap-6">
          <div class="flex items-baseline gap-2">
            <span class="font-mono font-bold text-3xl text-amber" style="font-variant-numeric: tabular-nums;">{POSTS.length}</span>
            <span class="text-sm font-mono text-slate-500">posts</span>
          </div>
          <div class="w-px h-6 bg-slate-800 hidden sm:block"></div>
          <div class="flex items-baseline gap-2">
            <span class="font-mono font-bold text-2xl text-blue-400">{COUNTS["Comparison"] ?? 0}</span>
            <span class="text-sm font-mono text-slate-600">comparisons</span>
          </div>
          <div class="flex items-baseline gap-2">
            <span class="font-mono font-bold text-2xl text-red-400">{COUNTS["Autopsy"] ?? 0}</span>
            <span class="text-sm font-mono text-slate-600">autopsies</span>
          </div>
          <div class="flex items-baseline gap-2">
            <span class="font-mono font-bold text-2xl text-emerald-400">{COUNTS["Guide"] ?? 0}</span>
            <span class="text-sm font-mono text-slate-600">guides</span>
          </div>
          <div class="flex items-baseline gap-2">
            <span class="font-mono font-bold text-2xl text-violet-400">{COUNTS["Article"] ?? 0}</span>
            <span class="text-sm font-mono text-slate-600">articles</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Filter tabs ────────────────────────────────────────── -->
    <div class="sticky top-0 z-20 bg-navy/95 backdrop-blur-sm border-b border-slate-800/60">
      <div class="max-w-6xl mx-auto px-6">
        <div id="filter-bar" role="tablist" aria-label="Filter posts by content type" class="flex gap-0 overflow-x-auto -mb-px">
          <button
            role="tab"
            aria-selected="true"
            data-filter="all"
            class="filter-tab active-tab px-4 py-4 text-xs font-mono whitespace-nowrap border-b-2 transition-all duration-150 border-amber text-amber-100 bg-slate-900/70"
          >
            All
            <span class="ml-1.5 text-slate-300">{POSTS.length}</span>
          </button>
          <button
            role="tab"
            aria-selected="false"
            data-filter="Comparison"
            class="filter-tab px-4 py-4 text-xs font-mono whitespace-nowrap border-b-2 border-transparent text-slate-200 hover:text-white transition-all duration-150"
          >
            <span class="mr-1.5 text-slate-300">⚖</span>Comparisons
            <span class="ml-1.5 text-slate-400">{COUNTS["Comparison"] ?? 0}</span>
          </button>
          <button
            role="tab"
            aria-selected="false"
            data-filter="Autopsy"
            class="filter-tab px-4 py-4 text-xs font-mono whitespace-nowrap border-b-2 border-transparent text-slate-200 hover:text-white transition-all duration-150"
          >
            <span class="mr-1.5 text-slate-300">⚕</span>Autopsies
            <span class="ml-1.5 text-slate-400">{COUNTS["Autopsy"] ?? 0}</span>
          </button>
          <button
            role="tab"
            aria-selected="false"
            data-filter="Guide"
            class="filter-tab px-4 py-4 text-xs font-mono whitespace-nowrap border-b-2 border-transparent text-slate-200 hover:text-white transition-all duration-150"
          >
            <span class="mr-1.5 text-slate-300">→</span>Guides
            <span class="ml-1.5 text-slate-400">{COUNTS["Guide"] ?? 0}</span>
          </button>
          <button
            role="tab"
            aria-selected="false"
            data-filter="Article"
            class="filter-tab px-4 py-4 text-xs font-mono whitespace-nowrap border-b-2 border-transparent text-slate-200 hover:text-white transition-all duration-150"
          >
            <span class="mr-1.5 text-slate-300">✦</span>Articles
            <span class="ml-1.5 text-slate-400">{COUNTS["Article"] ?? 0}</span>
          </button>
        </div>
      </div>
    </div>

    <!-- ── Posts grid ─────────────────────────────────────────── -->
    <main class="max-w-6xl mx-auto px-6 py-10">
      <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">

        {SORTED_POSTS.map((post) => {
          const tier = post.tier ?? (post.score != null ? getScoreTier(post.score) : undefined);
          const tierColor = tier ? TIER_COLORS[tier] : undefined;
          const tierLabel = tier ? TIER_LABELS[tier] : undefined;

          // Left accent border color per type
          const borderColor =
            post.contentType === "Comparison" ? "#3B82F6" :
            post.contentType === "Autopsy" ? (tierColor ?? "#EF4444") :
            post.contentType === "Guide" ? "#10B981" :
            "#8B5CF6";

          return (
            <article
              data-post-type={post.contentType}
              data-post-slug={post.slug}
              data-post-category={post.category}
              data-winner={post.winner ?? null}
              data-score={post.score ?? null}
              data-tier={tier ?? null}
              role="article"
              class="group relative bg-surface border border-slate-800/80 rounded-xl overflow-hidden card-lift"
              style={`border-left: 3px solid ${borderColor};`}
            >
              <!-- Full-card invisible link overlay -->
              <a
                href={`/blog/${post.slug}`}
                class="absolute inset-0 z-0 rounded-xl focus-glow"
                tabindex="0"
                aria-label={`Read: ${post.title}`}
              ></a>

              <!-- Card content (pointer-events-none so the overlay link catches clicks) -->
              <div class="relative z-10 p-6 pointer-events-none">

                <!-- Type badge row -->
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-2">
                    <!-- Content type chip -->
                    {post.contentType === "Comparison" && (
                      <span class="inline-flex items-center gap-1 text-[10px] font-mono font-semibold uppercase tracking-widest px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/25">
                        ⚖ Comparison
                      </span>
                    )}
                    {post.contentType === "Autopsy" && (
                      <span
                        class="inline-flex items-center gap-1 text-[10px] font-mono font-semibold uppercase tracking-widest px-2 py-0.5 rounded border"
                        style={`background: #0f172a; color: ${tierColor}; border-color: ${tierColor}40;`}
                      >
                        ⚕ Autopsy
                      </span>
                    )}
                    {post.contentType === "Guide" && (
                      <span class="inline-flex items-center gap-1 text-[10px] font-mono font-semibold uppercase tracking-widest px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/25">
                        → Guide
                      </span>
                    )}
                    {post.contentType === "Article" && (
                      <span class="inline-flex items-center gap-1 text-[10px] font-mono font-semibold uppercase tracking-widest px-2 py-0.5 rounded bg-violet-500/10 text-violet-400 border border-violet-500/25">
                        ✦ {post.category}
                      </span>
                    )}
                  </div>

                  <!-- Prominent verdict stat (right side) -->
                  {post.contentType === "Comparison" && post.winner && (
                    <span class="inline-flex items-center gap-1.5 text-xs font-mono font-semibold bg-amber/10 text-amber border border-amber/25 px-2.5 py-1 rounded-md">
                      🏆 {post.winner} wins
                    </span>
                  )}
                  {post.contentType === "Autopsy" && post.score != null && tier && (
                    <span
                      class="inline-flex items-center gap-1.5 text-xs font-mono font-bold px-2.5 py-1 rounded-md"
                      style={`background: #0f172a; color: ${tierColor}; border: 1px solid ${tierColor}40;`}
                    >
                      {post.score.toFixed(1)}<span class="ml-0.5 text-slate-100">/10</span>
                    </span>
                  )}
                  {post.contentType === "Guide" && post.difficulty && (
                    <span class="inline-flex items-center gap-1.5 text-xs font-mono bg-emerald-500/10 text-emerald-400 border border-emerald-500/25 px-2.5 py-1 rounded-md">
                      {post.difficulty}
                    </span>
                  )}
                </div>

                <!-- Title -->
                <h2 class="font-display font-bold text-[1.0625rem] leading-snug text-slate-100 group-hover:text-amber transition-colors duration-200 mb-3">
                  {post.title}
                </h2>

                <!-- Type-specific insight line (the verdict / key finding) -->
                {post.contentType === "Comparison" && post.verdict && (
                  <p class="text-sm text-slate-300 font-medium leading-snug mb-3 border-l-2 border-blue-500/30 pl-3">
                    {post.verdict}
                  </p>
                )}
                {post.contentType === "Autopsy" && post.keyFinding && (
                  <p
                    class="text-sm font-medium leading-snug mb-3 border-l-2 pl-3"
                    style={`color: ${tierColor}cc; border-color: ${tierColor}40;`}
                  >
                    {post.keyFinding}
                  </p>
                )}

                <!-- Description -->
                <p class="text-sm text-slate-300 leading-relaxed mb-5">
                  {post.description}
                </p>

                <!-- Meta row -->
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2.5 text-[11px] font-mono text-slate-300">
                    <span>{post.date}</span>
                    <span>·</span>
                    <span>{post.readTime} read</span>
                    {post.contentType === "Comparison" && post.scoreRange && (
                      <>
                        <span>·</span>
                        <span class="text-slate-200">AN {post.scoreRange}</span>
                      </>
                    )}
                    {post.contentType === "Guide" && post.timeEstimate && (
                      <>
                        <span>·</span>
                        <span class="text-emerald-300">{post.timeEstimate}</span>
                      </>
                    )}
                  </div>
                  <span class="text-[11px] font-mono text-slate-200 group-hover:text-amber transition-colors duration-200 flex-shrink-0">
                    Read →
                  </span>
                </div>

              </div>

              <!-- Related posts (z-20, pointer-events-auto so links work) -->
              {post.related && post.related.length > 0 && (
                <div
                  class="relative z-20 pointer-events-auto px-6 pb-5 -mt-1"
                  role="navigation"
                  aria-label="Related posts"
                >
                  <div class="flex flex-wrap gap-1.5 pt-4 border-t border-slate-800/50">
                    {post.related.map((rel) => (
                      <a
                        href={`/blog/${rel.slug}`}
                        class="text-[10px] font-mono text-slate-700 hover:text-amber transition-colors duration-150 px-2 py-1 rounded border border-slate-800/80 hover:border-slate-700 bg-navy/60 max-w-[220px] truncate"
                        title={rel.title}
                      >
                        ↗ {rel.title.length > 35 ? rel.title.substring(0, 35) + "…" : rel.title}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </article>
          );
        })}

      </div>

      <!-- Empty state (hidden by default, shown via JS when filter has no results) -->
      <div id="empty-state" class="hidden text-center py-20">
        <p class="text-slate-600 font-mono text-sm">No posts match this filter.</p>
      </div>
    </main>

    <!-- ── Agent index (machine-readable content map) ─────────── -->
    <section
      class="max-w-6xl mx-auto px-6 pb-16"
      aria-label="Machine-readable blog index"
      data-agent-index="true"
    >
      <div class="border border-slate-800/60 rounded-xl overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-800/60 flex items-center justify-between bg-surface/60">
          <div class="flex items-center gap-2.5">
            <span class="text-[10px] font-mono text-amber uppercase tracking-[0.18em]">Agent Index</span>
            <span class="text-[10px] font-mono text-slate-700">·</span>
            <span class="text-[10px] font-mono text-slate-600">machine-parseable content map</span>
          </div>
          <span class="text-[10px] font-mono text-slate-700">{POSTS.length} entries</span>
        </div>
        <div
          class="p-4 grid gap-0.5"
          role="list"
          aria-label="Blog post index"
          itemscope
          itemtype="https://schema.org/ItemList"
        >
          {SORTED_POSTS.map((post, i) => {
            const tier = post.tier ?? (post.score != null ? getScoreTier(post.score) : undefined);
            const tierColor = tier ? TIER_COLORS[tier] : undefined;
            return (
              <div
                role="listitem"
                itemprop="itemListElement"
                itemscope
                itemtype="https://schema.org/ListItem"
                class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5 py-1 px-2 rounded hover:bg-elevated/40 transition-colors group/row"
                data-index={i + 1}
                data-type={post.contentType}
                data-winner={post.winner ?? null}
                data-score={post.score ?? null}
                data-tier={tier ?? null}
              >
                <meta itemprop="position" content={String(i + 1)} />
                <a
                  href={`/blog/${post.slug}`}
                  itemprop="url"
                  class="text-[11px] font-mono text-slate-600 hover:text-amber transition-colors group-hover/row:text-slate-400 flex-shrink-0"
                >
                  /blog/{post.slug}
                </a>
                <span
                  class="text-[11px] font-mono flex-shrink-0"
                  style={
                    post.contentType === "Comparison" ? "color: #3B82F6;" :
                    post.contentType === "Autopsy" ? `color: ${tierColor ?? "#EF4444"};` :
                    post.contentType === "Guide" ? "color: #10B981;" :
                    "color: #8B5CF6;"
                  }
                >
                  [{post.contentType}]
                </span>
                {post.winner && (
                  <span class="text-[11px] font-mono text-amber/60 flex-shrink-0">winner={post.winner}</span>
                )}
                {post.score != null && (
                  <span class="text-[11px] font-mono flex-shrink-0" style={`color: ${tierColor}99;`}>score={post.score.toFixed(1)}</span>
                )}
                {tier && !post.winner && (
                  <span class="text-[11px] font-mono flex-shrink-0" style={`color: ${tierColor}66;`}>tier={tier}</span>
                )}
                {post.category && (
                  <span class="text-[11px] font-mono text-slate-800 flex-shrink-0">cat={post.category.toLowerCase().replace(/\s+/g, "-")}</span>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>

  </div><!-- /noise-overlay -->
</Layout>

<script>
  const filterBar = document.getElementById("filter-bar");
  const postsGrid = document.getElementById("posts-grid");
  const emptyState = document.getElementById("empty-state");

  if (filterBar && postsGrid) {
    filterBar.addEventListener("click", (e) => {
      const tab = (e.target as HTMLElement).closest<HTMLElement>(".filter-tab");
      if (!tab) return;

      const filter = tab.dataset.filter ?? "all";

      // Update tab states
      filterBar.querySelectorAll<HTMLElement>(".filter-tab").forEach((t) => {
        const isActive = t === tab;
        t.classList.toggle("active-tab", isActive);
        t.classList.toggle("border-amber", isActive);
        t.classList.toggle("text-amber-100", isActive);
        t.classList.toggle("bg-slate-900/70", isActive);
        t.classList.toggle("border-transparent", !isActive);
        t.classList.toggle("text-slate-200", !isActive);
        t.classList.toggle("hover:text-white", !isActive);
        t.setAttribute("aria-selected", String(isActive));
      });

      // Filter posts
      const posts = postsGrid.querySelectorAll<HTMLElement>("[data-post-type]");
      let visibleCount = 0;

      posts.forEach((post) => {
        const matches = filter === "all" || post.dataset.postType === filter;
        post.style.display = matches ? "" : "none";
        if (matches) visibleCount++;
      });

      // Show/hide empty state
      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    });
  }
</script>
