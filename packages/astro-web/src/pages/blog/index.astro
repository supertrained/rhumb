// Sort by content type priority: Comparison → Autopsy → Guide → Article
const CONTENT_ORDER: Record<ContentType, number> = {
  Comparison: 0,
  Autopsy: 1,
  Guide: 2,
  Article: 3,
};

const SORTED_POSTS = [...POSTS].sort(
  (a, b) => CONTENT_ORDER[a.contentType] - CONTENT_ORDER[b.contentType]
);

const COUNTS = POSTS.reduce(
  (acc, p) => {
    acc[p.contentType] = (acc[p.contentType] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

// Score tier color config
const TIER_COLORS: Record<ScoreTier, string> = {
  native:     "#10B981",
  ready:      "#3B82F6",
  developing: "#F59E0B",
  emerging:   "#EF4444",
};
const TIER_LABELS: Record<ScoreTier, string> = {
  native:     "Agent-Native",
  ready:      "Agent-Ready",
  developing: "Developing",
  emerging:   "Emerging",
};

function getScoreTier(score: number): ScoreTier {
  if (score >= 9.0) return "native";
  if (score >= 7.0) return "ready";
  if (score >= 5.0) return "developing";
  return "emerging";
}

// Enhanced JSON-LD with per-post type metadata
const BLOG_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Rhumb Blog",
  url: "https://rhumb.dev/blog",
  description:
    "API autopsies, head-to-head comparisons, and agent infrastructure insights for the agent-native era.",
  publisher: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
    logo: { "@type": "ImageObject", url: "https://rhumb.dev/api/og" },
  },
  blogPost: POSTS.map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    description: post.description,
    url: `https://rhumb.dev/blog/${post.slug}`,
    datePublished: post.dateISO,
    keywords: [post.contentType, post.category, "AI agents", "API", "agent-native"].join(", "),
    author: { "@type": "Person", name: "Pedro Nunes" },
    ...(post.contentType === "Comparison"
      ? {
          additionalProperty: [
            { "@type": "PropertyValue", name: "contentType", value: "Comparison" },
            { "@type": "PropertyValue", name: "winner", value: post.winner },
            { "@type": "PropertyValue", name: "scoreRange", value: post.scoreRange },
            { "@type": "PropertyValue", name: "verdict", value: post.verdict },
          ],
        }
      : {}),
    ...(post.contentType === "Autopsy"
      ? {
          additionalProperty: [
            { "@type": "PropertyValue", name: "contentType", value: "Autopsy" },
            { "@type": "PropertyValue", name: "score", value: post.score?.toFixed(1) },
            { "@type": "PropertyValue", name: "tier", value: post.tier },
            { "@type": "PropertyValue", name: "keyFinding", value: post.keyFinding },
          ],
        }
      : {}),
    ...(post.contentType === "Guide"
      ? {
          additionalProperty: [
            { "@type": "PropertyValue", name: "contentType", value: "Guide" },
            { "@type": "PropertyValue", name: "difficulty", value: post.difficulty },
            { "@type": "PropertyValue", name: "timeEstimate", value: post.timeEstimate },
          ],
        }
      : {}),
  })),
};
