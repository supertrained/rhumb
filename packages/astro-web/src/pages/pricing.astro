---
import Layout from "../layouts/Layout.astro";
import pricing from "../../../shared/pricing.json";

const managed = pricing.modes.rhumb_managed;
const x402 = pricing.modes.x402;
const byok = pricing.modes.byok;
const pricingEndpoint = `${pricing.canonical_api_base_url}/pricing`;
const estimateEndpoint = `${pricing.canonical_api_base_url}/capabilities/{capability_id}/execute/estimate`;

const PRICING_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Pricing - Rhumb",
  url: pricing.public_pricing_url,
  description:
    "Public pricing contract for Rhumb. Free tier: 1000 executions per month. Managed billing adds 20 percent, x402 adds 15 percent, and BYOK has no Rhumb markup.",
  isPartOf: {
    "@type": "WebSite",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};
---

<Layout
  title="Pricing"
  description="Current Rhumb pricing contract: 1000 free executions per month, 20 percent managed margin, 15 percent x402 margin, and BYOK passthrough with no Rhumb markup."
  canonical="/pricing"
  ogTitle="Pricing - Rhumb"
  ogDescription="Machine-readable Rhumb pricing. Managed billing, x402 on Base, and BYOK passthrough."
  ogUrl="https://rhumb.dev/pricing"
  jsonLd={PRICING_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <header class="max-w-3xl">
        <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Pricing</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 leading-tight tracking-tight">
          Three execution modes.
          <span class="block text-slate-400 mt-2">One public pricing contract.</span>
        </h1>
        <p class="mt-6 text-lg text-slate-400 leading-relaxed">
          Rhumb pricing depends on how execution is authorized. The canonical machine-readable source
          is <code class="font-mono text-sm bg-surface px-2 py-1 rounded text-amber">{pricingEndpoint}</code>.
        </p>
      </header>

      <section class="mt-12">
        <div class="bg-surface border border-amber/20 rounded-2xl p-6 sm:p-8">
          <p class="text-xs font-mono uppercase tracking-[0.24em] text-amber mb-3">Free Tier</p>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="font-display text-4xl sm:text-5xl text-slate-100 font-bold">
                {pricing.free_tier.included_executions_per_month.toLocaleString()}
              </p>
              <p class="text-slate-300 mt-2">executions per month before paid Rhumb billing applies</p>
            </div>
            <p class="text-sm text-slate-400 max-w-md">
              No credit card required for the free tier. Read-only discovery endpoints remain public and do not
              consume it.
            </p>
          </div>
        </div>
      </section>

      <section class="mt-10 grid gap-6 lg:grid-cols-3">
        <article class="bg-surface border border-slate-800 rounded-2xl p-6">
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">{managed.label}</h2>
            <span class="text-xs font-mono text-amber bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1">
              +{managed.margin_percent}%
            </span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-400">
            API-key execution billed by Rhumb. The first {pricing.free_tier.included_executions_per_month.toLocaleString()}
            {" "}executions each month are free, then Rhumb charges upstream cost plus a {managed.margin_percent} percent margin.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Auth</dt>
              <dd class="text-slate-200 font-mono">{managed.execution_auth[0]}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Model</dt>
              <dd class="text-slate-200">Upstream cost + {managed.margin_percent}%</dd>
            </div>
          </dl>
        </article>

        <article class="bg-surface border border-slate-800 rounded-2xl p-6">
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">{x402.label}</h2>
            <span class="text-xs font-mono text-emerald-300 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-2.5 py-1">
              +{x402.margin_percent}%
            </span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-400">
            Zero-signup per-call payment. Rhumb returns exact payment instructions on HTTP 402, and current public
            support stays on {x402.token} over {x402.network}.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Auth</dt>
              <dd class="text-slate-200 font-mono">{x402.execution_auth[0]}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Network</dt>
              <dd class="text-slate-200">{x402.network}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Token</dt>
              <dd class="text-slate-200">{x402.token}</dd>
            </div>
          </dl>
        </article>

        <article class="bg-surface border border-slate-800 rounded-2xl p-6">
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">{byok.label}</h2>
            <span class="text-xs font-mono text-slate-300 bg-slate-800 rounded-full px-2.5 py-1">0% markup</span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-400">
            Use your own upstream credentials. Rhumb routes the call, but provider charges stay with your provider
            account and Rhumb adds no markup.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Model</dt>
              <dd class="text-slate-200">Exact upstream passthrough</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Rhumb markup</dt>
              <dd class="text-slate-200">{byok.margin_percent}%</dd>
            </div>
          </dl>
        </article>
      </section>

      <section class="mt-10 grid gap-6 lg:grid-cols-[1.3fr_0.7fr]">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6">
          <h2 class="font-display text-2xl font-bold text-slate-100">For agents</h2>
          <p class="mt-3 text-slate-400 leading-7">
            Use the pricing endpoint to resolve the contract, then call the estimate endpoint for exact per-execution
            numbers before running anything.
          </p>
          <div class="mt-5 space-y-4">
            <div class="bg-elevated rounded-xl border border-slate-800 p-4">
              <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Contract</p>
              <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl {pricingEndpoint}</code></pre>
            </div>
            <div class="bg-elevated rounded-xl border border-slate-800 p-4">
              <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Estimate</p>
              <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl "{estimateEndpoint}"</code></pre>
            </div>
          </div>
        </div>

        <aside class="bg-surface border border-slate-800 rounded-2xl p-6">
          <h2 class="font-display text-xl font-semibold text-slate-100">Not in this contract</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-400 leading-6">
            {pricing.notes.map((note) => (
              <li>{note}</li>
            ))}
          </ul>
        </aside>
      </section>
    </div>
  </div>
</Layout>
