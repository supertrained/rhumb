---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import pricing from "../../../shared/pricing.json";
import { PUBLIC_TRUTH } from "../lib/public-truth";

const managed = pricing.modes.rhumb_managed;
const pricingEndpoint = `${pricing.canonical_api_base_url}/pricing`;
const estimateEndpoint = `${pricing.canonical_api_base_url}/capabilities/{capability_id}/execute/estimate`;
const signupHref = "/auth/login";
const enterpriseHref = "mailto:team@supertrained.ai?subject=Enterprise%20Pricing%20Inquiry";
const executionExplainerId = "what-counts-as-an-execution";

const EXECUTION_EXAMPLES = [
  {
    label: "Send an email via Resend",
    executions: "1 call",
    note: "Rhumb makes one third-party API call on your behalf.",
    charged: "yes",
  },
  {
    label: "Search for a service on Rhumb",
    executions: "0 calls",
    note: "Discovery is never charged.",
    charged: "no",
  },
  {
    label: "Get an AN Score for a service",
    executions: "0 calls",
    note: "Scoring is always free.",
    charged: "no",
  },
  {
    label: "Execute a 3-step capability chain",
    executions: "3 calls",
    note: "Each provider API call counts separately.",
    charged: "yes",
  },
  {
    label: "Failed call (provider error)",
    executions: "0 calls",
    note: "Provider errors are not charged.",
    charged: "no",
  },
];

const RAIL_CHOOSER = [
  {
    name: "Governed API key",
    badge: "Default",
    badgeClass:
      "text-[11px] font-mono text-amber uppercase tracking-widest bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1",
    useWhen: "You are shipping a production app, internal tool, or repeat agent workflow.",
    authHeader: "X-Rhumb-Key",
    moneyFlow: "Rhumb-managed account billing and controls.",
    bestFor: "Teams that want the simplest default path.",
    tradeoff: "Requires account signup before the first paid call.",
  },
  {
    name: "Wallet-prefund",
    badge: "Wallet-first",
    badgeClass:
      "text-[11px] font-mono text-emerald-300 uppercase tracking-widest bg-emerald-500/10 border border-emerald-500/20 rounded-full px-2.5 py-1",
    useWhen: "You want wallet identity, but you also want repeat throughput and one stable execution key.",
    authHeader: "X-Rhumb-Key",
    moneyFlow: "Top up reusable balance from a wallet, then spend from that balance.",
    bestFor: "Agents that are wallet-native but call Rhumb repeatedly.",
    tradeoff: "Adds a funding step before the steady-state execute path.",
  },
  {
    name: "x402 per-call",
    badge: "Zero signup",
    badgeClass:
      "text-[11px] font-mono text-amber uppercase tracking-widest bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1",
    useWhen: "You want request-level payment authorization and no account signup before the first paid call.",
    authHeader: "X-Payment",
    moneyFlow: "USDC on Base, authorized per request.",
    bestFor: "Ephemeral agents, demos, and strict per-request payment flows.",
    tradeoff: "Not the easiest repeat-traffic rail today; tx-hash proof shape matters.",
  },
  {
    name: "BYOK",
    badge: "Provider control",
    badgeClass:
      "text-[11px] font-mono text-slate-300 uppercase tracking-widest bg-slate-800 rounded-full px-2.5 py-1",
    useWhen: "You already have provider contracts, credentials, or compliance boundaries you must keep.",
    authHeader: "Provider credential via Rhumb",
    moneyFlow: "You pay the provider directly; Rhumb routes without markup on the credential itself.",
    bestFor: "Enterprise teams and direct vendor-control cases.",
    tradeoff: "You keep the credential-management burden.",
  },
];

const BUYER_PATHS = [
  {
    title: "I just want the normal production setup",
    summary: "Start with governed API key unless you have a strong reason not to.",
    steps: [
      "Create an account and get X-Rhumb-Key.",
      "Check the active execution rail, health, and cost before execution.",
      "Execute through Layer 2 with Rhumb-managed routing and billing.",
    ],
    href: "/auth/login",
    cta: "Start with API key",
  },
  {
    title: "My agent is wallet-native and will call repeatedly",
    summary: "Use wallet-prefund when wallet identity matters but repeat traffic matters more than zero-signup purity.",
    steps: [
      "Prove wallet control once and create the wallet session.",
      "Top up reusable balance from the wallet flow.",
      "Execute repeat calls with X-Rhumb-Key instead of paying every request individually.",
    ],
    href: "/payments/agent#wallet-prefund",
    cta: "See wallet-prefund",
  },
  {
    title: "I need a one-off or true pay-per-request flow",
    summary: "Use x402 when payment authorization on each request is the product requirement.",
    steps: [
      "Request the capability and read the payment requirement.",
      "Authorize the payment with X-Payment on the x402 rail.",
      "If your buyer emits wrapped proofs instead of the supported tx-hash flow, switch to wallet-prefund.",
    ],
    href: "/payments/agent",
    cta: "See x402 guide",
  },
];

const FAQ = [
  {
    q: "What counts as a call?",
    a: "A call is one API call to a third-party service routed through Rhumb. Searching, scoring, and browsing are always free, and failed provider calls are not charged.",
  },
  {
    q: "Which rail should most buyers start with?",
    a: "Start with the governed API key unless you specifically need wallet identity or per-request payment authorization. It is the default production path because it gives you one stable execution header, route, health, and cost checks before execution, and simpler repeat-traffic operations.",
  },
  {
    q: "What is the difference between API key, wallet-prefund, and x402?",
    a: "API key and wallet-prefund both execute with X-Rhumb-Key. API key is account-first billing; wallet-prefund is wallet-first funding that tops up reusable balance and currently uses the standard x402 authorization settlement path during top-up verification. x402 direct per-call execute is payment-as-auth using X-Payment, but today the repeatable public execute path expects legacy tx-hash proof rather than wrapped authorization payloads.",
  },
  {
    q: "Do I need crypto to use Rhumb?",
    a: "No. Most buyers should not start with crypto. If you are using the governed API-key path or BYOK, you do not need wallet setup. Wallet-prefund and x402 are wallet-first rails for teams that explicitly want those payment properties.",
  },
];

const PRICING_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Pricing - Rhumb",
  url: pricing.public_pricing_url,
  description:
    "Rhumb pricing: pay only for the calls you make. Discovery, scoring, and browsing are always free. Check the route, health, and cost before execution.",
  isPartOf: {
    "@type": "WebSite",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};
---

<Layout
  title="Pricing"
  description="Pay only for the calls you make. Check the route, health, and cost before execution. Discovery, scoring, and browsing are always free."
  canonical="/pricing"
  ogTitle="Pricing - Rhumb"
  ogDescription="Pay only for the calls you make. Know the route, health, and cost before execution. Discovery is always free."
  ogUrl="https://rhumb.dev/pricing"
  jsonLd={PRICING_JSON_LD}
>
  <div class="bg-navy min-h-screen" data-testid="pricing-page" data-page-type="pricing">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <header class="max-w-3xl" data-section="hero">
        <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Pricing</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 leading-tight tracking-tight">
          Pay for what you use.
          <span class="block text-slate-400 mt-2">Know the route, health, and cost before execution.</span>
        </h1>
        <p class="mt-6 text-lg text-slate-400 leading-relaxed">
          Discovery, scoring, and browsing are always free. When your agent runs a capability
          through Rhumb, you pay per call — and you can check the route, health, and exact price before committing.
          No subscriptions, no seat fees, no minimums.
        </p>
      </header>

      <section class="mt-10" data-section="trust-callout">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8 max-w-4xl">
          <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Before you choose a rail</p>
          <p class="text-sm text-slate-300 leading-6 max-w-3xl">
            Want to inspect the trust story first? Read <a href="/trust" class="text-amber hover:underline underline-offset-2">Trust</a>,
            inspect the public <a href="/methodology" class="text-amber hover:underline underline-offset-2">Methodology</a>,
            or use the provider <a href="/providers#dispute-a-score" class="text-amber hover:underline underline-offset-2">dispute path</a>
            if a score or claim looks wrong.
          </p>
        </div>
      </section>

      <section class="mt-10" data-section="mental-model" aria-label="Resolve pricing mental model">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl mb-6">
            <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Default path</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">Price the default production path first</h2>
            <p class="mt-3 text-slate-400 leading-7">
              {PUBLIC_TRUTH.resolveMentalModel.defaultPath}
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-3">
            <div class="rounded-xl border border-slate-800 bg-navy p-5">
              <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">What you are paying for</p>
              <p class="text-sm leading-6 text-slate-300">
                The main paid surface today is <strong class="text-slate-100">Layer 2 capability routing</strong>: discover a Service, choose a Capability, check the route, health, and cost, then execute.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-navy p-5">
              <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">Default repeat-traffic rails</p>
              <p class="text-sm leading-6 text-slate-300">
                For repeat traffic, default to <strong class="text-slate-100">governed API key</strong> or <strong class="text-slate-100">wallet-prefund</strong>. Both end up executing with <code class="font-mono text-emerald-300 text-xs">X-Rhumb-Key</code>.
              </p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-navy p-5">
              <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">When to use x402</p>
              <p class="text-sm leading-6 text-slate-300">
                Use <strong class="text-slate-100">x402 per-call</strong> when zero-signup, request-level payment authorization is the point — not as the default repeat-throughput path.
              </p>
            </div>
          </div>

          <p class="mt-5 text-sm text-slate-500">
            Canonical onboarding map: <a href="/docs#resolve-mental-model" class="text-amber hover:underline underline-offset-2">/docs#resolve-mental-model</a>
          </p>
        </div>
      </section>

      <section class="mt-12" data-section="path-selection" aria-label="Choose your pricing path">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl mb-6">
            <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Choose your path</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">Same directory, different execution rails.</h2>
            <p class="mt-3 text-slate-400 leading-7">
              Discovery is always free. Execution depends on how you want authorization and payment to work: account API key, wallet-prefunded balance, zero-signup x402 per-call, or BYOK passthrough.
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-5 sm:grid-cols-2">
            <a href="/leaderboard" class="group rounded-xl border border-slate-800 bg-navy p-5 hover:border-slate-600 transition-colors">
              <div class="flex items-center justify-between gap-3 mb-2">
                <h3 class="font-display text-lg font-semibold text-slate-100">Browse</h3>
                <span class="text-[11px] font-mono text-amber uppercase tracking-widest">$0</span>
              </div>
              <p class="text-sm leading-6 text-slate-400">Scores, comparisons, read endpoints, and MCP discovery. No signup, no key, no wallet.</p>
            </a>

            <a href={signupHref} class="group rounded-xl border border-slate-800 bg-navy p-5 hover:border-slate-600 transition-colors">
              <div class="flex items-center justify-between gap-3 mb-2">
                <h3 class="font-display text-lg font-semibold text-slate-100">API key</h3>
                <span class="text-[11px] font-mono text-slate-400 uppercase tracking-widest">Managed</span>
              </div>
              <p class="text-sm leading-6 text-slate-400">Rhumb handles routing, failover, and billing behind one key. Best default for apps and production agents.</p>
            </a>

            <a href="/payments/agent" class="group rounded-xl border border-amber/20 bg-navy p-5 hover:border-amber/40 transition-colors">
              <div class="flex items-center justify-between gap-3 mb-2">
                <h3 class="font-display text-lg font-semibold text-slate-100">x402</h3>
                <span class="text-[11px] font-mono text-amber uppercase tracking-widest">Per call</span>
              </div>
              <p class="text-sm leading-6 text-slate-400">Use USDC on Base when the agent should pay directly and the payment proof should authorize each request.</p>
            </a>

            <a href="/payments/agent#wallet-prefund" class="group rounded-xl border border-emerald-500/20 bg-navy p-5 hover:border-emerald-400/40 transition-colors">
              <div class="flex items-center justify-between gap-3 mb-2">
                <h3 class="font-display text-lg font-semibold text-slate-100">Wallet prefund</h3>
                <span class="text-[11px] font-mono text-emerald-300 uppercase tracking-widest">Reusable</span>
              </div>
              <p class="text-sm leading-6 text-slate-400">Authenticate wallet once, top up balance via x402, then execute repeat calls with <code class="text-emerald-300 font-mono text-xs">X-Rhumb-Key</code>.</p>
            </a>

            <a href="/blog/securing-keys-for-agents" class="group rounded-xl border border-slate-800 bg-navy p-5 hover:border-slate-600 transition-colors">
              <div class="flex items-center justify-between gap-3 mb-2">
                <h3 class="font-display text-lg font-semibold text-slate-100">BYOK</h3>
                <span class="text-[11px] font-mono text-slate-400 uppercase tracking-widest">Zero markup</span>
              </div>
              <p class="text-sm leading-6 text-slate-400">Route through Rhumb with your own provider credentials when you need direct vendor control or enterprise boundaries. Start with <code class="text-amber font-mono text-xs">resolve_capability</code> on the <code class="text-amber font-mono text-xs">byok</code> rail, and if the preferred path is not ready yet follow <code class="text-amber font-mono text-xs">recovery_hint.resolve_url</code>, <code class="text-amber font-mono text-xs">recovery_hint.credential_modes_url</code>, <code class="text-amber font-mono text-xs">recovery_hint.alternate_execute_hint</code>, or <code class="text-amber font-mono text-xs">recovery_hint.setup_handoff</code>.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="mt-10" data-section="payment-rails" aria-label="Payment rail definitions">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <h2 class="font-display text-2xl font-bold text-slate-100">Three payment rails, one execution endpoint</h2>
          <p class="mt-3 text-slate-400 leading-7">
            Rhumb supports three ways to fund execution traffic: account billing with API keys,
            wallet-prefunded balance, or x402 per-call settlement. All roads still end at
            <code class="text-amber font-mono text-sm">POST /v1/capabilities/&#123;capability_id&#125;/execute</code>.
          </p>
          <div class="mt-6 overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead>
                <tr class="border-b border-slate-800 text-left text-slate-500">
                  <th class="py-3 pr-6 font-medium">Rail</th>
                  <th class="py-3 pr-6 font-medium">Auth</th>
                  <th class="py-3 font-medium">Best fit</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-slate-800/80">
                  <td class="py-4 pr-6 text-slate-200">Governed API key</td>
                  <td class="py-4 pr-6 font-mono text-slate-100">X-Rhumb-Key</td>
                  <td class="py-4 text-slate-400">Apps and teams with dashboard-based billing controls.</td>
                </tr>
                <tr class="border-b border-slate-800/80">
                  <td class="py-4 pr-6 text-slate-200">Wallet-prefunded balance</td>
                  <td class="py-4 pr-6 font-mono text-slate-100">X-Rhumb-Key</td>
                  <td class="py-4 text-slate-400">Wallet-first agents that want reusable balance for repeat calls.</td>
                </tr>
                <tr>
                  <td class="py-4 pr-6 text-slate-200">x402 per-call</td>
                  <td class="py-4 pr-6 font-mono text-slate-100">X-Payment</td>
                  <td class="py-4 text-slate-400">Zero-signup and strict request-level payment authorization.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="mt-10" data-section="rail-chooser" aria-label="Human-readable rail chooser">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl mb-6">
            <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Pick the right rail</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">Choose based on how money moves, not on jargon.</h2>
            <p class="mt-3 text-slate-400 leading-7">
              Buyers do not need a protocol lecture first. Ask three questions: do you want the default production path,
              do you need wallet identity, and do you need each request to carry its own payment authorization?
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            {RAIL_CHOOSER.map((rail) => (
              <article class="rounded-xl border border-slate-800 bg-navy p-5">
                <div class="flex items-center justify-between gap-3 flex-wrap mb-4">
                  <h3 class="font-display text-lg font-semibold text-slate-100">{rail.name}</h3>
                  <span class={rail.badgeClass}>{rail.badge}</span>
                </div>
                <dl class="space-y-3 text-sm leading-6">
                  <div>
                    <dt class="text-slate-500">Use when</dt>
                    <dd class="text-slate-200">{rail.useWhen}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">You send</dt>
                    <dd class="text-slate-200 font-mono text-xs">{rail.authHeader}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">Money flow</dt>
                    <dd class="text-slate-200">{rail.moneyFlow}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">Best for</dt>
                    <dd class="text-slate-200">{rail.bestFor}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">Tradeoff</dt>
                    <dd class="text-slate-400">{rail.tradeoff}</dd>
                  </div>
                </dl>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="mt-10" data-section="buyer-paths" aria-label="Common buyer paths">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl mb-6">
            <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Common buyer paths</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">Three realistic ways buyers arrive here.</h2>
            <p class="mt-3 text-slate-400 leading-7">
              If you are unsure which rail fits, find the path that sounds like you and start there.
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-3">
            {BUYER_PATHS.map((path) => (
              <article class="rounded-xl border border-slate-800 bg-navy p-5 h-full flex flex-col">
                <h3 class="font-display text-lg font-semibold text-slate-100">{path.title}</h3>
                <p class="mt-3 text-sm text-slate-400 leading-6">{path.summary}</p>
                <ol class="mt-5 space-y-3 text-sm text-slate-300 leading-6 list-decimal pl-5">
                  {path.steps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>
                <a href={path.href} class="mt-6 inline-flex text-sm text-amber hover:underline underline-offset-2">
                  {path.cta} →
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section
        class="mt-12 grid gap-6 lg:grid-cols-3"
        aria-label="Pricing tiers"
        data-section="tiers"
      >
        <article
          class="bg-surface border border-amber/20 rounded-2xl p-6"
          data-tier="discovery"
          role="region"
          aria-label="Discovery (always free)"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">Discovery</h2>
            <span class="text-xs font-mono text-amber bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1">
              Always free
            </span>
          </div>
          <p class="mt-4 font-display text-4xl text-slate-100 font-bold">
            $0
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-400">
            Browse services, read scores, search the directory, check comparisons, and call any
            read-only endpoint. No signup required. No limits.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Includes</dt>
              <dd class="text-slate-200">Search, scores, comparisons, MCP discovery</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Auth</dt>
              <dd class="text-slate-200">None required</dd>
            </div>
          </dl>
          <a
            href="/search"
            class="mt-6 inline-flex items-center justify-center rounded-lg px-4 py-2.5 text-sm font-semibold transition-colors cta-button"
            aria-label="Start exploring services"
          >
            Explore services
          </a>
        </article>

        <article
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          data-tier="standard"
          data-payment-mode="api-key"
          role="region"
          aria-label="Standard tier"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">Standard</h2>
            <span class="text-xs font-mono text-amber bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1">
              API key
            </span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-400">
            Rhumb handles credentials, routing, failover, and billing. You get route,
            health, and cost checks before execution, smart provider selection, and fail-closed execution safety. Pay per call, no commitments.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Auth</dt>
              <dd class="text-slate-200 font-mono">{managed.execution_auth[0]}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Pricing</dt>
              <dd class="text-slate-200">Per-call, with route, health, and cost checks before execution</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Best for</dt>
              <dd class="text-slate-200">Apps, agents, and production workloads</dd>
            </div>
          </dl>
          <a
            href={signupHref}
            class="mt-6 inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2.5 text-sm font-semibold text-slate-200 hover:border-slate-500 hover:text-slate-100 transition-colors"
            aria-label="Create an API key for standard pricing"
          >
            Get API key
          </a>
        </article>

        <article
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          data-tier="enterprise"
          role="region"
          aria-label="Enterprise tier"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">Enterprise</h2>
            <span class="text-xs font-mono text-slate-300 bg-slate-800 rounded-full px-2.5 py-1">
              Contact
            </span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-400">
            For teams that need procurement support, security review coordination, or a direct
            conversation about rollout and controls.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Best for</dt>
              <dd class="text-slate-200">Security-conscious teams and larger deployments</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Commercial model</dt>
              <dd class="text-slate-200">Discuss with Rhumb</dd>
            </div>
          </dl>
          <a
            href={enterpriseHref}
            class="mt-6 inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2.5 text-sm font-semibold text-slate-200 hover:border-slate-500 hover:text-slate-100 transition-colors"
            aria-label="Contact Rhumb about enterprise pricing"
          >
            Contact
          </a>
        </article>
      </section>

      <section
        id={executionExplainerId}
        class="mt-10"
        data-testid="execution-explainer"
          data-section="execution-explainer"
      >
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl">
            <p class="text-xs font-mono uppercase tracking-[0.24em] text-amber mb-3">Usage</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">What counts as a call?</h2>
            <p class="mt-3 text-slate-400 leading-7" data-testid="execution-definition">
              1 call = 1 API call to a third-party service routed through Rhumb. Scoring, searching, and
              browsing are always free. You&apos;re only charged when Rhumb makes an API call on your behalf.
            </p>
          </div>

          <div class="mt-6 overflow-x-auto">
            <table class="min-w-full text-sm" data-testid="execution-examples-table">
              <thead>
                <tr class="border-b border-slate-800 text-left text-slate-500">
                  <th class="py-3 pr-6 font-medium">Example</th>
                  <th class="py-3 pr-6 font-medium">Counts as</th>
                  <th class="py-3 font-medium">Notes</th>
                </tr>
              </thead>
              <tbody>
                {EXECUTION_EXAMPLES.map((example) => (
                  <tr
                    class="border-b border-slate-800/80 last:border-b-0"
                    data-testid={`execution-example-${example.label
                      .toLowerCase()
                      .replace(/[^a-z0-9]+/g, "-")
                      .replace(/^-|-$/g, "")}`}
                    data-example={example.label}
                    data-executions={example.executions}
                    data-charged={example.charged}
                  >
                    <td class="py-4 pr-6 text-slate-200">{example.label}</td>
                    <td class="py-4 pr-6 font-mono text-slate-100">{example.executions}</td>
                    <td class="py-4 text-slate-400">{example.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="mt-10" data-testid="pricing-faq" data-section="faq">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6 tracking-tight">Pricing FAQ</h2>
        <div class="space-y-4">
          {FAQ.map((item) => (
            <div
              class="bg-surface border border-slate-800 rounded-lg p-5"
              data-testid="pricing-faq-item"
              data-faq-question={item.q}
            >
              <h3 class="font-display font-semibold text-base text-slate-100 mb-2">{item.q}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                {item.a}{" "}
                <a
                  href={`#${executionExplainerId}`}
                  class="text-amber underline decoration-amber/40 underline-offset-4 hover:decoration-amber"
                  data-testid="pricing-faq-link"
                >
                  See the examples above
                </a>
                .
              </p>
            </div>
          ))}
        </div>
      </section>

      <section
        class="mt-10 grid gap-6 lg:grid-cols-[1.25fr_0.75fr]"
        data-section="machine-readable-pricing"
      >
        <div
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="region"
          aria-label="Machine-readable pricing contract"
        >
          <h2 class="font-display text-2xl font-bold text-slate-100">For agents and automation</h2>
          <p class="mt-3 text-slate-400 leading-7">
            The canonical machine-readable source remains public. Resolve the pricing contract,
            then call the estimate endpoint for route, health, and exact per-call numbers before you run anything.
          </p>
          <div class="mt-5 space-y-4">
            <div class="bg-elevated rounded-xl border border-slate-800 p-4">
              <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Contract</p>
              <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl {pricingEndpoint}</code></pre>
            </div>
            <div class="bg-elevated rounded-xl border border-slate-800 p-4">
              <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Estimate</p>
              <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl "{estimateEndpoint}"</code></pre>
            </div>
          </div>
        </div>

        <aside
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="complementary"
          aria-label="Pricing notes"
        >
          <h2 class="font-display text-xl font-semibold text-slate-100">What you get</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-400 leading-6">
            <li>Route, health, and cost checks before execution — know the path and price before you execute.</li>
            <li>Smart provider routing — Rhumb picks the best provider for each call.</li>
            <li>Fail-closed billing — you're never charged for failed calls.</li>
          </ul>
          <p class="mt-5 text-xs font-mono text-slate-500">
            Already have provider API keys? BYOK passthrough routes through Rhumb at zero
            markup — you pay only your provider directly.
          </p>
        </aside>
      </section>

      <section
        class="mt-10 border-t border-slate-800 pt-6"
        data-section="agent-payments-link"
        aria-label="Agent payments link"
      >
        <p class="text-sm text-slate-500">
          For wallet-first flows (x402 per-call and wallet-prefunded balance), see our{" "}
          <a href="/payments/agent" class="text-amber hover:underline underline-offset-2">
            Agent Payments
          </a>{" "}
          guide.
        </p>
      </section>
    </div>
  </div>
</Layout>
