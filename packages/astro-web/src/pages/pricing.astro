---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import pricing from "../../../shared/pricing.json";

const managed = pricing.modes.rhumb_managed;
const pricingEndpoint = `${pricing.canonical_api_base_url}/pricing`;
const estimateEndpoint = `${pricing.canonical_api_base_url}/capabilities/{capability_id}/execute/estimate`;
const signupHref = "/auth/login";
const enterpriseHref = "mailto:team@supertrained.ai?subject=Enterprise%20Pricing%20Inquiry";
const executionExplainerId = "what-counts-as-an-execution";

const EXECUTION_EXAMPLES = [
  {
    label: "Send an email via Resend",
    executions: "1 execution",
    note: "Rhumb makes one third-party API call on your behalf.",
    charged: "yes",
  },
  {
    label: "Search for a service on Rhumb",
    executions: "0 executions",
    note: "Discovery is never charged.",
    charged: "no",
  },
  {
    label: "Get an AN Score for a service",
    executions: "0 executions",
    note: "Scoring is always free.",
    charged: "no",
  },
  {
    label: "Execute a 3-step capability chain",
    executions: "3 executions",
    note: "Each provider API call counts separately.",
    charged: "yes",
  },
  {
    label: "Failed execution (provider error)",
    executions: "0 executions",
    note: "Provider errors are not charged.",
    charged: "no",
  },
];

const FAQ = [
  {
    q: "What counts as an execution?",
    a: "An execution is one API call to a third-party service routed through Rhumb. Searching, scoring, and browsing are always free, and failed provider executions are not charged.",
  },
];

const PRICING_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Pricing - Rhumb",
  url: pricing.public_pricing_url,
  description:
    "Rhumb pricing: pay only for what you execute. Discovery, scoring, and browsing are always free. Per-execution pricing with cost estimates before every call.",
  isPartOf: {
    "@type": "WebSite",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};
---

<Layout
  title="Pricing"
  description="Pay only for what you execute. Per-execution pricing with pre-call cost estimates. Discovery, scoring, and browsing are always free."
  canonical="/pricing"
  ogTitle="Pricing - Rhumb"
  ogDescription="Pay only for what you execute. Know the cost before every call. Discovery is always free."
  ogUrl="https://rhumb.dev/pricing"
  jsonLd={PRICING_JSON_LD}
>
  <div class="bg-navy min-h-screen" data-testid="pricing-page" data-page-type="pricing">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <header class="max-w-3xl" data-section="hero">
        <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Pricing</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 leading-tight tracking-tight">
          Pay for what you use.
          <span class="block text-slate-400 mt-2">Know the cost before every call.</span>
        </h1>
        <p class="mt-6 text-lg text-slate-400 leading-relaxed">
          Discovery, scoring, and browsing are always free. When your agent executes a capability
          through Rhumb, you pay per call — and you can check the exact price before committing.
          No subscriptions, no seat fees, no minimums.
        </p>
      </header>

      <section
        class="mt-12 grid gap-6 lg:grid-cols-3"
        aria-label="Pricing tiers"
        data-section="tiers"
      >
        <article
          class="bg-surface border border-amber/20 rounded-2xl p-6"
          data-tier="discovery"
          role="region"
          aria-label="Discovery (always free)"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">Discovery</h2>
            <span class="text-xs font-mono text-amber bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1">
              Always free
            </span>
          </div>
          <p class="mt-4 font-display text-4xl text-slate-100 font-bold">
            $0
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-400">
            Browse services, read scores, search the directory, check comparisons, and call any
            read-only endpoint. No signup required. No limits.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Includes</dt>
              <dd class="text-slate-200">Search, scores, comparisons, MCP discovery</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Auth</dt>
              <dd class="text-slate-200">None required</dd>
            </div>
          </dl>
          <a
            href="/search"
            class="mt-6 inline-flex items-center justify-center rounded-lg bg-amber px-4 py-2.5 text-sm font-semibold text-navy hover:bg-amber-light transition-colors"
            aria-label="Start exploring services"
          >
            Explore services
          </a>
        </article>

        <article
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          data-tier="standard"
          data-payment-mode="api-key"
          role="region"
          aria-label="Standard tier"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">Standard</h2>
            <span class="text-xs font-mono text-amber bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1">
              API key
            </span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-400">
            Rhumb handles credentials, routing, failover, and billing. You get pre-call cost
            estimates, smart provider selection, and fail-closed execution safety. Pay per call, no commitments.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Auth</dt>
              <dd class="text-slate-200 font-mono">{managed.execution_auth[0]}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Pricing</dt>
              <dd class="text-slate-200">Per-execution, with estimates before every call</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Best for</dt>
              <dd class="text-slate-200">Apps, agents, and production workloads</dd>
            </div>
          </dl>
          <a
            href={signupHref}
            class="mt-6 inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2.5 text-sm font-semibold text-slate-200 hover:border-slate-500 hover:text-slate-100 transition-colors"
            aria-label="Create an API key for standard pricing"
          >
            Get API key
          </a>
        </article>

        <article
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          data-tier="enterprise"
          role="region"
          aria-label="Enterprise tier"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="font-display text-xl font-semibold text-slate-100">Enterprise</h2>
            <span class="text-xs font-mono text-slate-300 bg-slate-800 rounded-full px-2.5 py-1">
              Contact
            </span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-400">
            For teams that need procurement support, security review coordination, or a direct
            conversation about rollout and controls.
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Best for</dt>
              <dd class="text-slate-200">Security-conscious teams and larger deployments</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Commercial model</dt>
              <dd class="text-slate-200">Discuss with Rhumb</dd>
            </div>
          </dl>
          <a
            href={enterpriseHref}
            class="mt-6 inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2.5 text-sm font-semibold text-slate-200 hover:border-slate-500 hover:text-slate-100 transition-colors"
            aria-label="Contact Rhumb about enterprise pricing"
          >
            Contact
          </a>
        </article>
      </section>

      <section
        id={executionExplainerId}
        class="mt-10"
        data-testid="execution-explainer"
        data-section="execution-explainer"
      >
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl">
            <p class="text-xs font-mono uppercase tracking-[0.24em] text-amber mb-3">Usage</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">What counts as an execution?</h2>
            <p class="mt-3 text-slate-400 leading-7" data-testid="execution-definition">
              1 execution = 1 API call to a third-party service routed through Rhumb. Scoring, searching, and
              browsing are always free. You&apos;re only charged when Rhumb makes an API call on your behalf.
            </p>
          </div>

          <div class="mt-6 overflow-x-auto">
            <table class="min-w-full text-sm" data-testid="execution-examples-table">
              <thead>
                <tr class="border-b border-slate-800 text-left text-slate-500">
                  <th class="py-3 pr-6 font-medium">Example</th>
                  <th class="py-3 pr-6 font-medium">Counts as</th>
                  <th class="py-3 font-medium">Notes</th>
                </tr>
              </thead>
              <tbody>
                {EXECUTION_EXAMPLES.map((example) => (
                  <tr
                    class="border-b border-slate-800/80 last:border-b-0"
                    data-testid={`execution-example-${example.label
                      .toLowerCase()
                      .replace(/[^a-z0-9]+/g, "-")
                      .replace(/^-|-$/g, "")}`}
                    data-example={example.label}
                    data-executions={example.executions}
                    data-charged={example.charged}
                  >
                    <td class="py-4 pr-6 text-slate-200">{example.label}</td>
                    <td class="py-4 pr-6 font-mono text-slate-100">{example.executions}</td>
                    <td class="py-4 text-slate-400">{example.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="mt-10" data-testid="pricing-faq" data-section="faq">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6 tracking-tight">Pricing FAQ</h2>
        <div class="space-y-4">
          {FAQ.map((item) => (
            <div
              class="bg-surface border border-slate-800 rounded-lg p-5"
              data-testid="pricing-faq-item"
              data-faq-question={item.q}
            >
              <h3 class="font-display font-semibold text-base text-slate-100 mb-2">{item.q}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                {item.a}{" "}
                <a
                  href={`#${executionExplainerId}`}
                  class="text-amber underline decoration-amber/40 underline-offset-4 hover:decoration-amber"
                  data-testid="pricing-faq-link"
                >
                  See the examples above
                </a>
                .
              </p>
            </div>
          ))}
        </div>
      </section>

      <section
        class="mt-10 grid gap-6 lg:grid-cols-[1.25fr_0.75fr]"
        data-section="machine-readable-pricing"
      >
        <div
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="region"
          aria-label="Machine-readable pricing contract"
        >
          <h2 class="font-display text-2xl font-bold text-slate-100">For agents and automation</h2>
          <p class="mt-3 text-slate-400 leading-7">
            The canonical machine-readable source remains public. Resolve the pricing contract,
            then call the estimate endpoint for exact per-execution numbers before you run anything.
          </p>
          <div class="mt-5 space-y-4">
            <div class="bg-elevated rounded-xl border border-slate-800 p-4">
              <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Contract</p>
              <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl {pricingEndpoint}</code></pre>
            </div>
            <div class="bg-elevated rounded-xl border border-slate-800 p-4">
              <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Estimate</p>
              <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl "{estimateEndpoint}"</code></pre>
            </div>
          </div>
        </div>

        <aside
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="complementary"
          aria-label="Pricing notes"
        >
          <h2 class="font-display text-xl font-semibold text-slate-100">What you get</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-400 leading-6">
            <li>Pre-call cost estimates — know the price before you execute.</li>
            <li>Smart provider routing — Rhumb picks the best provider for each call.</li>
            <li>Fail-closed billing — you're never charged for failed executions.</li>
          </ul>
          <p class="mt-5 text-xs font-mono text-slate-500">
            Already have provider API keys? BYOK passthrough routes through Rhumb at zero
            markup — you pay only your provider directly.
          </p>
        </aside>
      </section>

      <section
        class="mt-10 border-t border-slate-800 pt-6"
        data-section="agent-payments-link"
        aria-label="Agent payments link"
      >
        <p class="text-sm text-slate-500">
          For on-chain agent payments, see our{" "}
          <a href="/payments/agent" class="text-amber hover:underline underline-offset-2">
            Agent Payments
          </a>{" "}
          page.
        </p>
      </section>
    </div>
  </div>
</Layout>
