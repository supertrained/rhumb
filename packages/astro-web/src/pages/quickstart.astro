---
export const prerender = true;
import Layout from "../layouts/Layout.astro";

const API = "https://api.rhumb.dev/v1";
---

<Layout
  title="Quickstart — Rhumb"
  description="Make your first Rhumb API call in 30 seconds. Copy-paste examples for curl, JavaScript, Python, and MCP."
  canonical="https://rhumb.dev/quickstart"
  ogTitle="Rhumb Quickstart"
  ogDescription="Zero to first API response in 30 seconds. No signup required for read endpoints."
  ogUrl="https://rhumb.dev/quickstart"
>
  <div class="bg-navy min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-16">
      <!-- Header -->
      <div class="mb-12">
        <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Quickstart</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 leading-tight tracking-tight">
          First call in 30 seconds
        </h1>
        <p class="mt-4 text-lg text-slate-400 leading-relaxed max-w-2xl">
          No signup required. Copy a command, get a response. Read endpoints are free and open.
        </p>
      </div>

      <!-- Step 1: Try the API -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm">1</span>
          <h2 class="font-display font-bold text-2xl text-slate-100">Try the API</h2>
        </div>
        
        <p class="text-slate-400 mb-6">All read endpoints are free, no key required. Pick your language:</p>

        <!-- curl -->
        <div class="mb-6">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">curl</p>
          <pre class="bg-surface border border-slate-800 rounded-lg p-4 overflow-x-auto text-sm font-mono text-slate-300"><code>curl "{API}/services/stripe/score"</code></pre>
        </div>

        <!-- JavaScript -->
        <div class="mb-6">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">JavaScript</p>
          <pre class="bg-surface border border-slate-800 rounded-lg p-4 overflow-x-auto text-sm font-mono text-slate-300"><code>{`const res = await fetch("${API}/services/stripe/score");
const { data } = await res.json();
console.log(data.overall_score); // 8.1`}</code></pre>
        </div>

        <!-- Python -->
        <div class="mb-6">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">Python</p>
          <pre class="bg-surface border border-slate-800 rounded-lg p-4 overflow-x-auto text-sm font-mono text-slate-300"><code>{`import requests
data = requests.get("${API}/services/stripe/score").json()["data"]
print(data["overall_score"])  # 8.1`}</code></pre>
        </div>

        <div class="bg-surface border border-slate-800 rounded-lg p-4 text-sm text-slate-400">
          <strong class="text-slate-200">Response (abbreviated):</strong>
          <pre class="mt-2 text-xs font-mono overflow-x-auto"><code>{`{
  "data": {
    "slug": "stripe",
    "overall_score": 8.1,
    "tier": "L4 Native",
    "execution_score": 8.4,
    "access_readiness_score": 7.3,
    "failure_count": 2,
    "review_count": 47
  }
}`}</code></pre>
        </div>
      </section>

      <!-- Step 2: Explore -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm">2</span>
          <h2 class="font-display font-bold text-2xl text-slate-100">Explore what's available</h2>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <p class="text-sm font-mono text-amber mb-2">Search by need</p>
            <pre class="text-xs font-mono text-slate-400 overflow-x-auto"><code>curl "{API}/search?q=send+email"</code></pre>
          </div>
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <p class="text-sm font-mono text-amber mb-2">Browse by category</p>
            <pre class="text-xs font-mono text-slate-400 overflow-x-auto"><code>curl "{API}/leaderboard/payments"</code></pre>
          </div>
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <p class="text-sm font-mono text-amber mb-2">Service profile + alternatives</p>
            <pre class="text-xs font-mono text-slate-400 overflow-x-auto"><code>curl "{API}/services/stripe"</code></pre>
          </div>
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <p class="text-sm font-mono text-amber mb-2">Check failure modes</p>
            <pre class="text-xs font-mono text-slate-400 overflow-x-auto"><code>curl "{API}/services/stripe/failures"</code></pre>
          </div>
        </div>
      </section>

      <!-- Step 3: Execute capabilities -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm">3</span>
          <h2 class="font-display font-bold text-2xl text-slate-100">Execute capabilities</h2>
        </div>

        <p class="text-slate-400 mb-6">
          To actually <em>do</em> things through APIs (send emails, create records, charge cards), you need one of:
        </p>

        <div class="grid sm:grid-cols-3 gap-4 mb-8">
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <h3 class="font-display font-semibold text-slate-100 mb-2">API Key</h3>
            <p class="text-xs text-slate-400 mb-3">Sign up, get a key, pass it as <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">X-Rhumb-Key</code></p>
            <span class="text-xs font-mono text-slate-500">Best for: developers</span>
          </div>
          <div class="bg-surface border border-amber/20 rounded-lg p-5">
            <h3 class="font-display font-semibold text-slate-100 mb-2">x402 Payment</h3>
            <p class="text-xs text-slate-400 mb-3">No signup. Pay per call with USDC. The payment is the authentication.</p>
            <span class="text-xs font-mono text-amber">Best for: autonomous agents</span>
          </div>
          <div class="bg-surface border border-slate-800 rounded-lg p-5">
            <h3 class="font-display font-semibold text-slate-100 mb-2">Your Own Key</h3>
            <p class="text-xs text-slate-400 mb-3">Pass your service API key directly. BYOK = full control.</p>
            <span class="text-xs font-mono text-slate-500">Best for: teams, enterprise</span>
          </div>
        </div>

        <div class="bg-surface border border-slate-800 rounded-lg p-5 mb-4">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">Execute via API key</p>
          <pre class="text-sm font-mono text-slate-300 overflow-x-auto"><code>{`curl -X POST "${API}/capabilities/email.send/execute" \\
  -H "X-Rhumb-Key: rhumb_live_..." \\
  -H "Content-Type: application/json" \\
  -d '{"to": "user@example.com", "subject": "Hello", "body": "Hi from Rhumb"}'`}</code></pre>
        </div>

        <div class="bg-surface border border-amber/20 rounded-lg p-5">
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Execute via x402 (zero signup)</p>
          <pre class="text-sm font-mono text-slate-300 overflow-x-auto"><code>{`# Step 1: Get payment requirements
curl -X POST "${API}/capabilities/email.send/execute"
# Returns 402 with payment details (amount, USDC address, network)

# Step 2: Pay on-chain, then include tx proof
curl -X POST "${API}/capabilities/email.send/execute" \\
  -H "X-Payment: {tx_hash}" \\
  -H "Content-Type: application/json" \\
  -d '{"to": "user@example.com", "subject": "Hello"}'`}</code></pre>
        </div>
      </section>

      <!-- Step 4: MCP -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber/10 text-amber font-mono font-bold text-sm">4</span>
          <h2 class="font-display font-bold text-2xl text-slate-100">Connect via MCP</h2>
        </div>

        <p class="text-slate-400 mb-6">
          If your agent supports <a href="https://spec.modelcontextprotocol.io/" class="text-amber hover:underline">MCP</a>, connect directly:
        </p>

        <div class="bg-surface border border-slate-800 rounded-lg p-5 mb-6">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">Install</p>
          <pre class="text-sm font-mono text-slate-300"><code>npx rhumb-mcp</code></pre>
        </div>

        <div class="bg-surface border border-slate-800 rounded-lg p-5 mb-6">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">Claude Desktop config</p>
          <pre class="text-sm font-mono text-slate-300 overflow-x-auto"><code>{`{
  "mcpServers": {
    "rhumb": {
      "command": "npx",
      "args": ["rhumb-mcp"],
      "env": {
        "RHUMB_API_KEY": "rhumb_live_..."
      }
    }
  }
}`}</code></pre>
        </div>

        <p class="text-slate-400 text-sm">
          16 tools available: <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">find_tools</code>, 
          <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">get_score</code>, 
          <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">get_alternatives</code>, 
          <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">get_failure_modes</code>, 
          <code class="bg-elevated px-1 py-0.5 rounded text-amber text-xs">execute_capability</code>, and more.
          <a href="/blog/getting-started-mcp" class="text-amber hover:underline ml-1">Full MCP guide →</a>
        </p>
      </section>

      <!-- Next steps -->
      <section class="border-t border-slate-800 pt-10">
        <h2 class="font-display font-bold text-xl text-slate-100 mb-6">Keep going</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          <a href="/docs" class="group block bg-surface border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors">
            <span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">API Reference</span>
            <span class="block text-xs text-slate-500 mt-1">All endpoints, parameters, responses</span>
          </a>
          <a href="/blog/securing-keys-for-agents" class="group block bg-surface border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors">
            <span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Credential Security</span>
            <span class="block text-xs text-slate-500 mt-1">BYOK, managed, x402 — which is right for you</span>
          </a>
          <a href="/compare" class="group block bg-surface border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors">
            <span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Tool Comparisons</span>
            <span class="block text-xs text-slate-500 mt-1">9 head-to-head comparisons with live data</span>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
