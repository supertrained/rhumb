---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import pricing from "../../../../shared/pricing.json";
import { PUBLIC_TRUTH } from "../../lib/public-truth";

const x402 = pricing.modes.x402;
const pricingEndpoint = `${pricing.canonical_api_base_url}/pricing`;
const estimateEndpoint = `${pricing.canonical_api_base_url}/capabilities/{capability_id}/execute/estimate`;
const executeEndpoint = `${pricing.canonical_api_base_url}/capabilities/{capability_id}/execute`;

const FLOW_STEPS = [
  {
    step: "1",
    title: "Request execution",
    description:
      "Call the execution endpoint without a governed API key when you want the payment rail to handle authorization.",
  },
  {
    step: "2",
    title: "Receive HTTP 402",
    description:
      "Rhumb responds with exact payment requirements for that execution, including amount, token, and network.",
  },
  {
    step: "3",
    title: "Pay in USDC on Base",
    description:
      "Your agent submits the on-chain payment from its wallet instead of relying on pre-issued credentials.",
  },
  {
    step: "4",
    title: "Retry with proof",
    description:
      `Repeat the request with ${x402.execution_auth[0]} using the tx hash, network, and payer wallet so Rhumb can verify payment and execute the capability.`,
  },
];

const WALLET_STEPS = [
  {
    title: "Use a Base-compatible wallet",
    detail:
      "Your agent needs a wallet that can hold USDC on Base and sign transactions programmatically.",
  },
  {
    title: "Fund it with USDC on Base",
    detail:
      "The current public rail is fixed: USDC on Base. Other assets and networks are intentionally not advertised as public options yet.",
  },
  {
    title: "Store the wallet secret like production credentials",
    detail:
      "Keep private keys in your wallet system or secret manager. x402 removes API-key signup, but it does not remove wallet-key security.",
  },
];

const USE_CASES = [
  {
    title: "Autonomous agents",
    detail:
      "Best when the agent should discover, pay for, and execute work without waiting for a human to create an account first.",
  },
  {
    title: "No-signup execution",
    detail:
      "Useful for ephemeral agents, sandboxes, and evaluation flows where provisioning a governed API key would add avoidable friction.",
  },
  {
    title: "Per-call spend control",
    detail:
      "Each execution carries its own payment event, which is easier to reason about when you want strict request-level budget visibility.",
  },
];

const RAIL_CHOOSER = [
  {
    name: "Governed API key",
    badge: "Default",
    badgeClass:
      "text-[11px] font-mono text-amber uppercase tracking-widest bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1",
    useWhen: "You want the normal production setup for an app, team, or repeat agent workflow.",
    authHeader: "X-Rhumb-Key",
    moneyFlow: "Rhumb-managed account billing and controls.",
    bestFor: "Most buyers and most repeat traffic.",
    tradeoff: "Requires account signup before the first paid call.",
  },
  {
    name: "Wallet-prefund",
    badge: "Wallet-first",
    badgeClass:
      "text-[11px] font-mono text-emerald-300 uppercase tracking-widest bg-emerald-500/10 border border-emerald-500/20 rounded-full px-2.5 py-1",
    useWhen: "Wallet identity matters, but the same wallet will call Rhumb repeatedly.",
    authHeader: "X-Rhumb-Key",
    moneyFlow: "Top up reusable balance from a wallet, then spend from that balance.",
    bestFor: "Wallet-native agents that need repeat throughput.",
    tradeoff: "Has an initial wallet verify + top-up step before the steady-state path.",
  },
  {
    name: "x402 per-call",
    badge: "Zero signup",
    badgeClass:
      "text-[11px] font-mono text-amber uppercase tracking-widest bg-amber/10 border border-amber/20 rounded-full px-2.5 py-1",
    useWhen: "You need payment authorization on each request and no account before the first paid call.",
    authHeader: "X-Payment",
    moneyFlow: "USDC on Base, authorized per request.",
    bestFor: "Ephemeral agents, demos, and strict pay-per-request flows.",
    tradeoff: "Not the easiest repeat-traffic rail today; the public execute path still expects tx-hash proof.",
  },
];

const FIRST_SUCCESS_PATHS = [
  {
    title: "Wallet-native buyer with repeat traffic",
    label: "Use wallet-prefund",
    borderClass: "border-emerald-500/20",
    labelClass: "text-emerald-300",
    summary:
      "Use wallet-prefund when wallet identity matters but you want the steady-state call path to look like normal Layer 2 execution.",
    setup:
      "Authenticate the wallet once, top up reusable balance, then execute repeat calls with X-Rhumb-Key.",
    snippet: `# After wallet verify + top-up, the first successful repeatable call looks like this\ncurl -X POST "${executeEndpoint}" \\\n+  -H "X-Rhumb-Key: rk_live_..." \\\n+  -H "Content-Type: application/json" \\\n+  -d '{"body": {"to": "user@example.com", "subject": "Hello from Rhumb"}}'`,
  },
  {
    title: "Zero-signup buyer who wants payment proof on the request",
    label: "Use x402 per-call",
    borderClass: "border-amber/20",
    labelClass: "text-amber",
    summary:
      "Use x402 when the payment authorization itself is the product requirement, not just a funding source behind repeat traffic.",
    setup:
      "Request execution without a governed API key, pay the exact 402 requirement, then retry with X-Payment from the same wallet.",
    snippet: `# One-off zero-signup request\ncurl -X POST "${executeEndpoint}" \\\n+  -H '${x402.execution_auth[0]}: {"tx_hash":"0x...","network":"<network-from-402>","wallet_address":"0x..."}' \\\n+  -H "Content-Type: application/json" \\\n+  -d '{"body": {"to": "user@example.com", "subject": "Hello from Rhumb"}}'`,
  },
];

const AGENT_PAYMENTS_JSON_LD = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      name: "Agent Payments - Rhumb",
      url: "https://rhumb.dev/payments/agent",
      description:
        "Rhumb wallet-first agent payments: when to use governed API key, wallet-prefund, or x402 per-call; current USDC on Base boundary; and first-call examples.",
      isPartOf: {
        "@type": "WebSite",
        name: "Rhumb",
        url: "https://rhumb.dev",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "What is x402 on Rhumb?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Rhumb uses x402 as a zero-signup payment flow where HTTP 402 returns exact execution payment requirements and payment proof authorizes the request.",
          },
        },
        {
          "@type": "Question",
          name: "Which network and token are supported?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Current public support is USDC on Base only.",
          },
        },
      ],
    },
  ],
};
---

<Layout
  title="Agent Payments"
  description="Wallet-first Rhumb payments for agents: when to use wallet-prefund vs x402 per-call, current USDC on Base boundaries, and first-call examples."
  canonical="/payments/agent"
  ogTitle="Agent Payments - Rhumb"
  ogDescription="Wallet-first agent payments on Rhumb: choose governed API key, wallet-prefund, or x402 per-call with the current public compatibility boundary." 
  ogUrl="https://rhumb.dev/payments/agent"
  jsonLd={AGENT_PAYMENTS_JSON_LD}
>
  <div
    class="bg-navy min-h-screen"
    data-testid="agent-payments-page"
    data-page-type="agent-payments"
    data-payment-rail="x402"
  >
    <div class="max-w-5xl mx-auto px-6 py-16">
      <header class="max-w-3xl" data-section="hero">
        <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">
          Agent Payments
        </p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 leading-tight tracking-tight">
          Choose the right wallet rail for agent payments.
        </h1>
        <p class="mt-6 text-lg text-slate-400 leading-relaxed">
          Most buyers should still start with the governed API-key path. This page is for the wallet-first
          cases: use <strong class="text-slate-200">wallet-prefund</strong> when the same wallet will call repeatedly,
          and use <strong class="text-slate-200">x402 per-call</strong> when request-level payment authorization is the actual requirement.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/pricing"
            class="inline-flex items-center justify-center rounded-lg bg-amber px-4 py-2.5 text-sm font-semibold text-navy hover:bg-amber-light transition-colors"
            aria-label="Back to Rhumb pricing"
          >
            Back to pricing
          </a>
          <a
            href="/auth/login"
            class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-4 py-2.5 text-sm font-semibold text-slate-200 hover:border-slate-500 hover:text-slate-100 transition-colors"
            aria-label="Start with governed API key"
          >
            Start with governed API key
          </a>
        </div>
      </header>

      <section class="mt-10" data-section="trust-callout">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8 max-w-4xl">
          <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Before you choose a wallet rail</p>
          <p class="text-sm text-slate-300 leading-6 max-w-3xl">
            Want to inspect the trust story first? Read <a href="/trust" class="text-amber hover:underline underline-offset-2">Trust</a>,
            inspect the public <a href="/methodology" class="text-amber hover:underline underline-offset-2">Methodology</a>,
            or use the provider <a href="/providers#dispute-a-score" class="text-amber hover:underline underline-offset-2">dispute path</a>
            if a score or claim looks wrong.
          </p>
        </div>
      </section>

      <section class="mt-10" data-section="rail-chooser" aria-label="Choose the right wallet or payment rail">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl mb-6">
            <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Choose your rail</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">Pick based on how money moves, not on protocol jargon.</h2>
            <p class="mt-3 text-slate-400 leading-7">
              The buyer-readable version is simple: start with governed API key by default, use wallet-prefund
              when you want wallet identity plus repeat traffic, and use x402 only when each request should carry
              its own payment authorization.
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-3">
            {RAIL_CHOOSER.map((rail) => (
              <article class="rounded-xl border border-slate-800 bg-navy p-5">
                <div class="flex items-center justify-between gap-3 flex-wrap mb-4">
                  <h3 class="font-display text-lg font-semibold text-slate-100">{rail.name}</h3>
                  <span class={rail.badgeClass}>{rail.badge}</span>
                </div>
                <dl class="space-y-3 text-sm leading-6">
                  <div>
                    <dt class="text-slate-500">Use when</dt>
                    <dd class="text-slate-200">{rail.useWhen}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">You send</dt>
                    <dd class="text-slate-200 font-mono text-xs">{rail.authHeader}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">Money flow</dt>
                    <dd class="text-slate-200">{rail.moneyFlow}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">Best for</dt>
                    <dd class="text-slate-200">{rail.bestFor}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500">Tradeoff</dt>
                    <dd class="text-slate-400">{rail.tradeoff}</dd>
                  </div>
                </dl>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="mt-10" data-section="where-x402-fits" aria-label="Where x402 fits in Resolve">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl mb-6">
            <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Where this rail fits</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">x402 is the exception rail, not the whole product model</h2>
            <p class="mt-3 text-slate-400 leading-7">
              {PUBLIC_TRUTH.resolveMentalModel.defaultPath}
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-3">
            <div class="rounded-xl border border-slate-800 bg-navy p-5">
              <p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-2">Default production path</p>
              <p class="text-sm leading-6 text-slate-300">
                Most repeat traffic should run through <strong class="text-slate-100">Layer 2</strong> with governed API key or wallet-prefund on <strong class="text-slate-100">X-Rhumb-Key</strong>. Bring BYOK or Agent Vault only when provider control is the point.
              </p>
            </div>
            <div class="rounded-xl border border-amber/20 bg-navy p-5">
              <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Use x402 when</p>
              <p class="text-sm leading-6 text-slate-300">
                Zero-signup, request-level payment authorization matters more than repeat throughput or broad wallet-proof compatibility.
              </p>
            </div>
            <div class="rounded-xl border border-emerald-500/20 bg-navy p-5">
              <p class="text-xs font-mono text-emerald-300 uppercase tracking-widest mb-2">Switch to wallet-prefund when</p>
              <p class="text-sm leading-6 text-slate-300">
                The same wallet needs repeat calls. Authenticate once, top up reusable balance, then execute with <code class="font-mono text-emerald-300 text-xs">X-Rhumb-Key</code>.
              </p>
            </div>
          </div>

          <p class="mt-5 text-sm text-slate-500">
            Canonical onboarding map: <a href="/docs#resolve-mental-model" class="text-amber hover:underline underline-offset-2">/docs#resolve-mental-model</a>
          </p>
        </div>
      </section>

      <section
        class="mt-12 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]"
        data-section="overview"
      >
        <div
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="region"
          aria-label="x402 overview"
        >
          <h2 class="font-display text-2xl font-bold text-slate-100">What x402 means here</h2>
          <p class="mt-3 text-slate-400 leading-7">
            x402 is the payment-first execution rail. Instead of creating an account and receiving a
            reusable governed API key, an agent asks to run a capability, receives payment requirements on HTTP 402,
            pays that request, and then proves payment to complete execution.
          </p>
          <p class="mt-4 text-slate-400 leading-7">
            Current public support is intentionally narrow: {x402.token} on {x402.network}. That keeps the
            flow deterministic for agents and clear for operators.
          </p>
          <div class="mt-5 rounded-xl border border-amber/30 bg-amber/5 p-4">
            <p class="text-xs font-mono uppercase tracking-widest text-amber">Current compatibility boundary</p>
            <p class="mt-2 text-sm leading-6 text-slate-300">
              The repeatable public x402 execute path today is the plain payment-proof flow shown below: request 402,
              pay the exact requirement, then retry with <code class="font-mono text-amber">X-Payment</code>
              carrying tx-hash proof. Some smart-wallet or wrapped authorization payloads still depend on a
              facilitator path that is not wired in current production. Wallet-prefund top-up verification is the
              standard x402 authorization path today. If your buyer emits wrapped proofs,
              use <a href="#wallet-prefund" class="text-amber hover:underline underline-offset-2">wallet-prefund</a>
              or the standard governed API key rail instead of assuming drop-in x402 interoperability.
            </p>
          </div>
        </div>

        <aside
          class="bg-surface border border-emerald-500/20 rounded-2xl p-6"
          role="complementary"
          aria-label="Agent payments details"
        >
          <h2 class="font-display text-xl font-semibold text-slate-100">Current public rail</h2>
          <dl class="mt-4 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Protocol</dt>
              <dd class="text-slate-200">x402</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Token</dt>
              <dd class="text-slate-200">{x402.token}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Network</dt>
              <dd class="text-slate-200">{x402.network}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Auth header</dt>
              <dd class="text-slate-200 font-mono">{x402.execution_auth[0]}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-slate-500">Markup</dt>
              <dd class="text-emerald-300">+{x402.margin_percent}%</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section
        class="mt-10"
        data-section="flow"
        aria-label="How x402 agent payments work"
      >
        <h2 class="font-display text-2xl font-bold text-slate-100">USDC on Base flow</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4" role="list">
          {FLOW_STEPS.map((item) => (
            <article
              class="bg-surface border border-slate-800 rounded-2xl p-5"
              role="listitem"
              data-step={item.step}
            >
              <p class="text-xs font-mono text-amber uppercase tracking-widest">{item.step}</p>
              <h3 class="mt-3 font-display text-lg font-semibold text-slate-100">{item.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-400">{item.description}</p>
            </article>
          ))}
        </div>

        <div class="mt-6 grid gap-6 lg:grid-cols-2">
          <div class="bg-surface border border-slate-800 rounded-2xl p-6">
            <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Discover contract</p>
            <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl {pricingEndpoint}</code></pre>
          </div>
          <div class="bg-surface border border-slate-800 rounded-2xl p-6">
            <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Estimate before execution</p>
            <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>curl "{estimateEndpoint}"</code></pre>
          </div>
        </div>

        <div class="mt-6 bg-surface border border-slate-800 rounded-2xl p-6">
          <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Execution flow</p>
          <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>{`# Step 1: request execution without a governed API key
curl -X POST "${executeEndpoint}" \\
  -H "Content-Type: application/json" \\
  -d '{"body": {"to": "user@example.com", "subject": "Hello from Rhumb"}}'

# Step 2: pay the exact asset + amount to the exact address on the exact network returned in the 402 response

# Step 3: retry with payment proof from the same wallet
curl -X POST "${executeEndpoint}" \\
  -H '${x402.execution_auth[0]}: {"tx_hash":"0x...","network":"<network-from-402>","wallet_address":"0x..."}' \\
  -H "Content-Type: application/json" \\
  -d '{"body": {"to": "user@example.com", "subject": "Hello from Rhumb"}}'`}</code></pre>
        </div>
      </section>

      <section id="wallet-prefund" class="mt-10" data-section="wallet-prefund-bridge" aria-label="Per-call vs prefund wallet rails">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6">
          <h2 class="font-display text-2xl font-bold text-slate-100">When to switch from per-call x402 to wallet-prefund</h2>
          <p class="mt-3 text-slate-400 leading-7">
            Use pure x402 when you want zero-signup authorization on every request. Use wallet-prefund
            when you still want wallet-first funding, but repeat traffic should execute via
            <code class="text-emerald-300 font-mono text-sm">X-Rhumb-Key</code> against reusable balance.
          </p>

          <div class="mt-6 grid gap-4 lg:grid-cols-2">
            <div class="rounded-xl border border-amber/30 bg-elevated p-5">
              <p class="text-xs font-mono uppercase tracking-widest text-amber mb-2">x402 per-call</p>
              <ul class="space-y-2 text-sm text-slate-300 leading-6">
                <li>• No account or key required before first execution.</li>
                <li>• Every paid call includes <code class="font-mono text-amber">X-Payment</code>.</li>
                <li>• Best for ephemeral agents and strict per-request auth.</li>
              </ul>
            </div>
            <div class="rounded-xl border border-emerald-500/30 bg-elevated p-5">
              <p class="text-xs font-mono uppercase tracking-widest text-emerald-300 mb-2">wallet-prefund</p>
              <ul class="space-y-2 text-sm text-slate-300 leading-6">
                <li>• Wallet signs once to create identity + wallet-scoped X-Rhumb-Key credential.</li>
                <li>• Top-ups settle standard x402 authorization payloads on-chain, then credit reusable <code class="font-mono text-emerald-300">org_credits</code>.</li>
                <li>• Repeat calls run through normal <code class="font-mono text-emerald-300">X-Rhumb-Key</code> execution.</li>
              </ul>
            </div>
          </div>

          <div class="mt-6 bg-elevated rounded-xl border border-slate-800 p-5">
            <p class="text-xs font-mono uppercase tracking-widest text-slate-500 mb-2">Wallet-prefund route map</p>
            <pre class="text-sm font-mono text-slate-200 overflow-x-auto"><code>{`POST /v1/auth/wallet/request-challenge
POST /v1/auth/wallet/verify
POST /v1/billing/x402/topup/request
POST /v1/billing/x402/topup/verify
POST /v1/capabilities/{capability_id}/execute   # with X-Rhumb-Key`}</code></pre>
          </div>
        </div>
      </section>

      <section class="mt-10" data-section="first-successful-call-examples" aria-label="First successful call examples by buyer story">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <div class="max-w-3xl mb-6">
            <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">First successful call</p>
            <h2 class="font-display text-2xl font-bold text-slate-100">Two buyer stories, two correct first-call paths.</h2>
            <p class="mt-3 text-slate-400 leading-7">
              If you are choosing between wallet-prefund and x402, anchor on the first call that should feel normal in production.
            </p>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            {FIRST_SUCCESS_PATHS.map((path) => (
              <article class={`rounded-xl border bg-navy p-5 ${path.borderClass}`}>
                <p class={`text-xs font-mono uppercase tracking-widest mb-2 ${path.labelClass}`}>{path.label}</p>
                <h3 class="font-display text-lg font-semibold text-slate-100">{path.title}</h3>
                <p class="mt-3 text-sm text-slate-400 leading-6">{path.summary}</p>
                <p class="mt-3 text-sm text-slate-300 leading-6">{path.setup}</p>
                <pre class="mt-4 text-sm font-mono text-slate-200 overflow-x-auto"><code>{path.snippet}</code></pre>
              </article>
            ))}
          </div>

          <p class="mt-5 text-sm text-slate-500">
            If neither of those stories sounds like you, go back to <a href="/pricing" class="text-amber hover:underline underline-offset-2">pricing</a> and start with the governed API-key path.
          </p>
        </div>
      </section>

      <section
        class="mt-10 grid gap-6 lg:grid-cols-2"
        data-section="wallet-setup"
      >
        <div
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="region"
          aria-label="Wallet setup instructions"
        >
          <h2 class="font-display text-2xl font-bold text-slate-100">Wallet setup</h2>
          <div class="mt-5 space-y-4">
            {WALLET_STEPS.map((item) => (
              <div class="bg-elevated rounded-xl border border-slate-800 p-4" data-wallet-step={item.title}>
                <h3 class="font-display text-lg font-semibold text-slate-100">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-400">{item.detail}</p>
              </div>
            ))}
          </div>
        </div>

        <div
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="region"
          aria-label="When to use agent payments"
        >
          <h2 class="font-display text-2xl font-bold text-slate-100">Good fits for this rail</h2>
          <div class="mt-5 space-y-4">
            {USE_CASES.map((item) => (
              <div class="border-l-2 border-amber/40 pl-4" data-use-case={item.title}>
                <h3 class="font-display text-lg font-semibold text-slate-100">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-400">{item.detail}</p>
              </div>
            ))}
          </div>
          <p class="mt-6 text-sm text-slate-500">
            If you need team billing, human-friendly procurement, or a reusable credential for repeated app traffic,
            standard API-key pricing is usually the better default.
          </p>
        </div>
      </section>

      <section
        class="mt-10 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]"
        data-section="markup"
      >
        <div
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="region"
          aria-label="Agent payment pricing"
        >
          <h2 class="font-display text-2xl font-bold text-slate-100">Why the {x402.margin_percent}% markup exists</h2>
          <p class="mt-3 text-slate-400 leading-7">
            x402 pricing is still cost-plus pricing. Rhumb passes through the upstream call cost
            and adds a {x402.margin_percent} percent margin on top.
          </p>
          <p class="mt-4 text-slate-400 leading-7">
            That margin covers the agent-payment-specific overhead: verifying payment proof, operating the
            on-chain settlement path, abuse controls around zero-signup execution, and the managed capability
            routing behind the request.
          </p>
        </div>

        <aside
          class="bg-surface border border-slate-800 rounded-2xl p-6"
          role="complementary"
          aria-label="Agent payments summary"
        >
          <h2 class="font-display text-xl font-semibold text-slate-100">Pricing summary</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-400 leading-6">
            <li>Authorization comes from payment proof, not account signup.</li>
            <li>Current public support is {x402.token} on {x402.network} only.</li>
            <li>Exact per-call requirements are returned before execution.</li>
            <li>Rhumb markup on this rail is {x402.margin_percent}%.</li>
          </ul>
        </aside>
      </section>

      <section
        class="mt-10 border-t border-slate-800 pt-6"
        data-section="return-link"
        aria-label="Return to main pricing"
      >
        <p class="text-sm text-slate-500">
          Looking for standard API-key plans instead? Go back to{" "}
          <a href="/pricing" class="text-amber hover:underline underline-offset-2">
            main pricing
          </a>
          .
        </p>
      </section>
    </div>
  </div>
</Layout>
