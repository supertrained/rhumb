---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import CopyTextButton from "../components/CopyTextButton.tsx";
import { getServiceCount } from "../lib/api";
import { PUBLIC_TRUTH } from "../lib/public-truth";
import { STARTER_PROMPT } from "../lib/starter-prompt";

const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.rhumb.dev/v1";
const serviceCount = await getServiceCount().catch(() => PUBLIC_TRUTH.services);
const servicesLabel = new Intl.NumberFormat("en-US").format(serviceCount || PUBLIC_TRUTH.services);

const START_HERE_STEPS = [
  {
    step: "01",
    title: "Discover first",
    body: `Search ${servicesLabel} scored services and ${PUBLIC_TRUTH.capabilitiesLabel} mapped capabilities before you commit to a provider or rail.`,
  },
  {
    step: "02",
    title: "Decide with evidence",
    body: "Use scores, freshness, evidence tiers, and failure modes to explain the route instead of guessing.",
  },
  {
    step: "03",
    title: "Execute what is ready",
    body: `Use Rhumb Resolve when a governed action is supported. Best current fit is ${PUBLIC_TRUTH.beachheadLabel}.`,
  },
];

const DOCS_PROOF = [
  { label: "Services scored", value: servicesLabel },
  { label: "Capabilities mapped", value: PUBLIC_TRUTH.capabilitiesLabel },
  { label: "Providers callable", value: PUBLIC_TRUTH.callableProvidersLabel },
  { label: "Live surfaces", value: "API + MCP" },
];

const AUTH_PATHS = [
  {
    label: "Default",
    title: "Governed API key",
    detail: "Most buyers should start here. Sign in, fund the account, retry with X-Rhumb-Key.",
    tone: "border-amber/20 bg-amber/10 text-amber",
  },
  {
    label: "Wallet-first",
    title: "Wallet-prefund",
    detail: "Use this when wallet identity matters and the same agent will call repeatedly.",
    tone: "border-emerald-500/20 bg-emerald-500/10 text-emerald-300",
  },
  {
    label: "Zero-signup",
    title: "x402 per-call",
    detail: "Use this only when request-level payment authorization is the requirement and the runtime can pay from a wallet.",
    tone: "border-slate-700 bg-slate-900/60 text-slate-300",
  },
];

const ENDPOINTS = [
  {
    method: "GET",
    path: "/v1/services/{slug}/score",
    desc: "Full AN Score breakdown for a service.",
    curl: `curl ${BASE_URL}/services/stripe/score`,
    response: `{
  "data": {
    "slug": "stripe",
    "an_score": 8.1,
    "tier": "L4 Native",
    "execution_score": 8.4,
    "access_readiness_score": 7.3,
    "failure_count": 2,
    "review_count": 47
  },
  "error": null
}`,
  },
  {
    method: "GET",
    path: "/v1/search?q={query}",
    desc: "Search services by need, category, or description.",
    curl: `curl "${BASE_URL}/search?q=send+email"`,
    response: `{
  "data": {
    "query": "send email",
    "results": [
      {
        "service_slug": "google-workspace-apis",
        "name": "Google Workspace APIs",
        "aggregate_recommendation_score": 8.7,
        "tier": "L4"
      }
    ]
  },
  "error": null
}`,
  },
  {
    method: "GET",
    path: "/v1/capabilities/{capability_id}",
    desc: "Inspect a capability and the providers that can fulfill it.",
    curl: `curl ${BASE_URL}/capabilities/email.send`,
    response: `{
  "data": {
    "id": "email.send",
    "provider_count": 8,
    "providers": [
      {
        "service_slug": "resend",
        "credential_modes": ["byok", "rhumb_managed"],
        "cost_per_call": 0.001
      }
    ]
  },
  "error": null
}`,
  },
  {
    method: "GET",
    path: "/v1/capabilities/{capability_id}/resolve",
    desc: "Resolve a capability into ranked providers, execute hints, recovery handoffs when the requested rail is not ready, and search suggestions when the capability ID is wrong.",
    curl: `curl ${BASE_URL}/capabilities/email.send/resolve`,
    response: `Common success response
{
  "data": {
    "capability": "email.send",
    "providers": [
      {
        "service_slug": "resend",
        "recommendation": "preferred",
        "cost_per_call": 0.001,
        "credential_modes": ["byok"]
      }
    ],
    "fallback_chain": ["resend", "sendgrid"],
    "related_bundles": [],
    "execute_hint": {
      "preferred_provider": "resend",
      "selection_reason": "highest_ranked_provider",
      "endpoint_pattern": "POST /emails",
      "estimated_cost_usd": 0.001,
      "auth_method": "api_key",
      "configured": false,
      "credential_modes": ["byok"],
      "credential_modes_url": "/v1/capabilities/email.send/credential-modes",
      "preferred_credential_mode": "byok",
      "fallback_providers": ["sendgrid"],
      "setup_hint": "Set RHUMB_CREDENTIAL_RESEND_API_KEY environment variable or configure via proxy credentials"
    }
  },
  "error": null
}

Representative recovery response when ranked providers exist but none are execute-ready on the requested rail
{
  "data": {
    "capability": "email.send",
    "providers": [
      {
        "service_slug": "resend",
        "recommendation": "preferred",
        "credential_modes": ["byok"]
      },
      {
        "service_slug": "sendgrid",
        "recommendation": "available",
        "credential_modes": ["byok"]
      }
    ],
    "fallback_chain": [],
    "related_bundles": [],
    "execute_hint": null,
    "recovery_hint": {
      "reason": "no_execute_ready_providers",
      "resolve_url": "/v1/capabilities/email.send/resolve",
      "credential_modes_url": "/v1/capabilities/email.send/credential-modes",
      "supported_provider_slugs": ["resend", "sendgrid"],
      "supported_credential_modes": ["byok"],
      "setup_handoff": {
        "preferred_provider": "resend",
        "auth_method": "api_key",
        "configured": false,
        "credential_modes": ["byok"],
        "credential_modes_url": "/v1/capabilities/email.send/credential-modes",
        "preferred_credential_mode": "byok",
        "selection_reason": "highest_ranked_provider",
        "setup_hint": "Set RHUMB_CREDENTIAL_RESEND_API_KEY environment variable or configure via proxy credentials"
      }
    }
  },
  "error": null
}

Other recovery cases reuse the same recovery_hint shape with a different reason.` ,
  },
  {
    method: "GET",
    path: "/v1/capabilities/{capability_id}/execute/estimate",
    desc: "Estimate provider, cost, and circuit state before executing.",
    curl: `curl ${BASE_URL}/capabilities/email.send/execute/estimate`,
    response: `{
  "data": {
    "capability_id": "email.send",
    "provider": "resend",
    "credential_mode": "auto",
    "cost_estimate_usd": 0.001,
    "circuit_state": "closed",
    "endpoint_pattern": "POST /emails"
  },
  "error": null
}`,
  },
  {
    method: "POST",
    path: "/v1/capabilities/{capability_id}/execute",
    desc: "Execute through Rhumb with the rail returned by resolve: governed API key, wallet-prefund, BYOK, or x402 where supported.",
    curl: `curl -X POST "${BASE_URL}/capabilities/email.send/execute" \\
  -H "X-Rhumb-Key: rhumb_live_..." \\
  -H "Content-Type: application/json" \\
  -d '{"body": {"to": "user@example.com", "subject": "Hello", "body": "Hi from Rhumb"}}'`,
    response: `{
  "data": {
    "capability_id": "email.send",
    "provider": "resend",
    "upstream_status": 202,
    "credential_mode": "rhumb_managed"
  },
  "error": null
}`,
  },
  {
    method: "POST",
    path: "/v1/capabilities/{capability_id}/execute (x402)",
    desc: "Anonymous execution path. First request returns HTTP 402 with exact payment requirements.",
    curl: `curl -X POST "${BASE_URL}/capabilities/email.send/execute" \\
  -H "Content-Type: application/json" \\
  -d '{"body": {"to": "user@example.com", "subject": "Hello"}}'`,
    response: `{
  "x402Version": 1,
  "accepts": [
    {
      "scheme": "exact",
      "network": "base",
      "payTo": "0x...",
      "asset": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
      "maxAmountRequired": "10000"
    }
  ],
  "resolution": "Default next step: create or use a funded governed API key at /auth/login and retry with X-Rhumb-Key.",
  "auth_handoff": {
    "recommended_path": "governed_api_key",
    "docs_url": "/docs#resolve-mental-model",
    "paths": [
      { "kind": "governed_api_key", "setup_url": "/auth/login", "retry_header": "X-Rhumb-Key" },
      { "kind": "wallet_prefund", "setup_url": "/payments/agent", "retry_header": "X-Rhumb-Key" },
      { "kind": "x402_per_call", "setup_url": "/payments/agent", "retry_header": "X-Payment" }
    ]
  }
}`,
  },
];

const DOCS_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  name: "How Rhumb works — Docs",
  url: "https://rhumb.dev/docs",
  description:
    "How Rhumb helps agents discover services, compare capabilities, and execute supported actions through governed access rails.",
  author: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
  isPartOf: {
    "@type": "WebSite",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};

const MCP_TOOLS = [
  { name: "find_services", desc: "Search services by need.", example: 'find_services({ query: "payment processing" })' },
  { name: "get_score", desc: "Get the full AN Score breakdown for a service.", example: 'get_score({ slug: "stripe" })' },
  { name: "get_alternatives", desc: "Find alternatives ranked by AN Score.", example: 'get_alternatives({ slug: "paypal" })' },
  { name: "get_failure_modes", desc: "Inspect known breakage patterns before integrating.", example: 'get_failure_modes({ slug: "stripe" })' },
  { name: "discover_capabilities", desc: "Browse capabilities like email.send or scrape.extract.", example: 'discover_capabilities({ search: "email" })' },
  { name: "resolve_capability", desc: "Rank providers, filter by credential mode, surface recovery handoffs, and recover typoed capability IDs with search suggestions.", example: 'resolve_capability({ capability: "email.send", credential_mode: "byok" })' },
  { name: "estimate_capability", desc: "Estimate cost and routing before execution.", example: 'estimate_capability({ capability_id: "email.send", credential_mode: "rhumb_managed" })' },
  { name: "execute_capability", desc: "Execute a capability through Rhumb Resolve.", example: 'execute_capability({ capability_id: "email.send", credential_mode: "rhumb_managed", body: { to: "user@example.com" } })' },
  { name: "credential_ceremony", desc: "Get self-service credential setup instructions.", example: 'credential_ceremony({ service: "github" })' },
  { name: "check_credentials", desc: "See which credential modes are available to you.", example: 'check_credentials({ capability: "email.send" })' },
  { name: "budget", desc: "Check or set spend limits.", example: 'budget({ action: "get" })' },
  { name: "spend", desc: "Review spending by period, capability, and provider.", example: 'spend({ period: "30d" })' },
  { name: "routing", desc: "Get or set routing preferences.", example: 'routing({ action: "get" })' },
  { name: "usage_telemetry", desc: "Inspect latency, errors, provider health, and usage trends.", example: 'usage_telemetry({ days: 7 })' },
  { name: "check_balance", desc: "Check current Rhumb credit balance.", example: 'check_balance()' },
  { name: "get_payment_url", desc: "Generate a top-up URL for prepaid credits.", example: 'get_payment_url({ amount_usd: 25 })' },
  { name: "get_ledger", desc: "Review billing history.", example: 'get_ledger({ limit: 20 })' },
  { name: "rhumb_list_recipes", desc: "Check the current published Layer 3 recipe catalog. Public inventory may be empty while Layer 3 remains in beta.", example: 'rhumb_list_recipes({ limit: 10 })' },
  { name: "rhumb_get_recipe", desc: "Inspect a recipe definition only after confirming it appears in rhumb_list_recipes.", example: 'rhumb_get_recipe({ recipe_id: "published_recipe_id" })' },
  { name: "rhumb_recipe_execute", desc: "Execute a published Rhumb recipe once it is live in the public catalog.", example: 'rhumb_recipe_execute({ recipe_id: "published_recipe_id", inputs: { email: "sam@acme.com" } })' },
  { name: "get_receipt", desc: "Retrieve a chain-hashed execution receipt.", example: 'get_receipt({ receipt_id: "rcpt_123" })' },
];
---

<Layout
  title="How Rhumb works | Docs"
  description="How Rhumb helps agents discover services, compare capabilities, and execute supported actions through governed access rails."
  canonical="/docs"
  ogTitle="How Rhumb works — Rhumb Docs"
  ogDescription="Discover first, decide with evidence, and execute supported actions through Rhumb's governed API and MCP rails."
  ogUrl="https://rhumb.dev/docs"
  jsonLd={DOCS_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <div class="max-w-4xl mx-auto px-6 pt-14 pb-24">
      <header class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">How Rhumb works</span>
        </div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 leading-tight tracking-tight mb-6 max-w-3xl text-balance">
          Discover first. Execute what is ready.
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed mb-6 max-w-3xl">
          Rhumb helps agents discover what services and capabilities exist across the web, compare them with public evidence, and execute supported actions through governed access rails. Discovery is broad. Governed execution is selective and explicit.
        </p>
        <div class="flex flex-wrap gap-3 mb-6">
          <a
            href="#resolve-mental-model"
            class="inline-flex items-center justify-center rounded-xl bg-amber px-4 py-2.5 text-sm font-semibold text-navy transition-colors duration-200 hover:bg-amber-dark"
          >
            Start here
          </a>
          <a
            href="/capabilities"
            class="inline-flex items-center justify-center rounded-xl border border-slate-700 bg-surface/60 px-4 py-2.5 text-sm font-medium text-slate-200 transition-colors duration-200 hover:border-amber/35 hover:text-slate-50"
          >
            Browse capabilities
          </a>
        </div>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="bg-surface border border-emerald-500/20 rounded-xl p-5">
            <p class="text-xs font-mono text-emerald-300 uppercase tracking-wider mb-2">Best current fit</p>
            <p class="text-sm text-slate-300 leading-6">
              Use Rhumb first for {PUBLIC_TRUTH.beachheadLabel}. That is the cleanest launchable surface today.
            </p>
          </div>
          <div class="bg-surface border border-amber/20 rounded-xl p-5">
            <p class="text-xs font-mono text-amber uppercase tracking-wider mb-2">Current boundary</p>
            <p class="text-sm text-slate-300 leading-6">
              Do not read the current docs as a promise of general business-agent automation. Discovery is wider than current governed execution, and that honesty is part of the product.
            </p>
          </div>
        </div>
      </header>

      <section class="mb-16" data-section="trust-callout">
        <div class="bg-surface border border-slate-800 rounded-2xl p-6 sm:p-8">
          <p class="text-xs font-mono font-semibold text-amber uppercase tracking-widest mb-3">Before you wire this deeper</p>
          <p class="text-sm text-slate-300 leading-6 max-w-3xl">
            Want to evaluate the trust story first? Read <a href="/trust" class="text-amber hover:underline underline-offset-2">Trust</a>,
            inspect the public <a href="/methodology" class="text-amber hover:underline underline-offset-2">Methodology</a>,
            or use the provider <a href="/providers#dispute-a-score" class="text-amber hover:underline underline-offset-2">dispute path</a>
            if a score or claim looks wrong.
          </p>
        </div>
      </section>

      <section class="mb-16 scroll-mt-28" id="resolve-mental-model">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">Start here</span>
        </div>
        <h2 class="font-display font-bold text-3xl text-slate-100 mb-4 tracking-tight">The Rhumb mental model in 60 seconds</h2>
        <p class="text-slate-400 leading-relaxed mb-6 max-w-3xl">
          Do not start with install details. Start with the route. Rhumb helps agents discover the landscape, decide with evidence, and execute only where a governed path is truly ready.
        </p>

        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.02fr)_minmax(300px,0.98fr)] mb-6">
          <div class="space-y-4">
            {START_HERE_STEPS.map((item) => (
              <article class="rounded-[24px] border border-slate-800 bg-surface/70 p-5">
                <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-amber">{item.step}</p>
                <h3 class="mt-3 font-display text-xl font-semibold text-slate-100">{item.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-400">{item.body}</p>
              </article>
            ))}
          </div>

          <div class="rounded-[28px] border border-slate-800 bg-[linear-gradient(180deg,rgba(21,29,46,0.96)_0%,rgba(11,17,32,0.92)_100%)] p-6 shadow-[0_24px_80px_rgba(2,6,23,0.28)]">
            <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">If execute blocks</p>
            <h3 class="mt-2 font-display text-2xl font-semibold text-slate-100">A 402 is a handoff, not a dead end.</h3>
            <p class="mt-3 text-sm leading-6 text-slate-400">
              Discovery can keep moving even when execution is not ready. When execute returns an auth or payment handoff, follow the default rail first unless your runtime clearly supports a wallet path.
            </p>
            <div class="mt-5 space-y-3">
              {AUTH_PATHS.map((item) => (
                <div class="rounded-2xl border border-slate-800 bg-slate-950/35 p-4">
                  <div class="flex items-center justify-between gap-3">
                    <h4 class="font-display text-lg font-semibold text-slate-100">{item.title}</h4>
                    <span class={`rounded-full border px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.18em] ${item.tone}`}>{item.label}</span>
                  </div>
                  <p class="mt-2 text-sm leading-6 text-slate-400">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="mb-6 rounded-[28px] border border-slate-800 bg-[linear-gradient(180deg,rgba(21,29,46,0.96)_0%,rgba(11,17,32,0.92)_100%)] p-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div class="max-w-2xl">
              <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-amber">Starter prompt</p>
              <h3 class="mt-2 font-display text-xl font-semibold text-slate-100">This is the cold-start path the homepage points agents to.</h3>
              <p class="mt-2 text-sm leading-6 text-slate-400">
                Use this when a human wants to hand Rhumb to Claude, Codex, or another agent without assuming prior workspace context or a preinstalled integration.
              </p>
            </div>
            <CopyTextButton
              client:load
              text={STARTER_PROMPT}
              label="Copy starter prompt"
              copiedLabel="Starter prompt copied"
              className="shrink-0"
            />
          </div>
          <pre class="mt-5 overflow-x-auto rounded-2xl border border-slate-800 bg-slate-950/45 px-4 py-4 text-sm leading-6 text-slate-300 whitespace-pre-wrap break-words"><code>{STARTER_PROMPT}</code></pre>
        </div>

        <div class="grid gap-4 lg:grid-cols-2 mb-4">
          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">Interface surfaces</p>
            <div class="space-y-3">
              {PUBLIC_TRUTH.resolveMentalModel.surfaces.map((item) => (
                <div>
                  <p class="text-sm font-semibold text-slate-100">{item.name}</p>
                  <p class="text-sm text-slate-400 leading-6">{item.summary}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">Entity types</p>
            <div class="space-y-3">
              {PUBLIC_TRUTH.resolveMentalModel.entities.map((item) => (
                <div>
                  <p class="text-sm font-semibold text-slate-100">{item.name}</p>
                  <p class="text-sm text-slate-400 leading-6">{item.summary}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">Execution layers</p>
            <div class="space-y-3">
              {PUBLIC_TRUTH.resolveMentalModel.layers.map((item) => (
                <div>
                  <p class="text-sm font-semibold text-slate-100">{item.name}</p>
                  <p class="text-sm text-slate-400 leading-6">{item.summary}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">Auth + payment rails</p>
            <div class="space-y-3">
              {PUBLIC_TRUTH.resolveMentalModel.rails.map((item) => (
                <div>
                  <p class="text-sm font-semibold text-slate-100">{item.name}</p>
                  <p class="text-sm text-slate-400 leading-6">{item.summary}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="bg-surface border border-slate-800 rounded-xl p-5">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-3">Credential modes</p>
          <div class="grid gap-4 sm:grid-cols-3">
            {PUBLIC_TRUTH.resolveMentalModel.credentialModes.map((item) => (
              <div>
                <p class="text-sm font-semibold text-slate-100">{item.name}</p>
                <p class="text-sm text-slate-400 leading-6">{item.summary}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-4 tracking-tight">Quick reference</h2>
        <p class="text-slate-400 leading-relaxed mb-6 max-w-3xl">
          Once you have the route, these are the live public surfaces and the base URL behind the examples below.
        </p>
        <div class="bg-surface border border-slate-800 rounded-lg p-4 font-mono text-sm">
          <span class="text-slate-500">Base URL:</span>{" "}
          <span class="text-amber">{BASE_URL}</span>
        </div>
        <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
          {DOCS_PROOF.map(({ label, value }) => (
            <div class="rounded-2xl border border-slate-800 bg-surface/70 p-4">
              <div class="text-[11px] font-mono uppercase tracking-[0.24em] text-slate-500">{label}</div>
              <div class="mt-2 text-sm font-medium text-slate-200">{value}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-4 tracking-tight">Auth + payment rails</h2>
        <div class="grid gap-4 sm:grid-cols-4">
          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">Discovery</p>
            <p class="text-sm text-slate-300">Read endpoints like scores, search, capabilities, and leaderboards are open.</p>
          </div>
          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">Governed API key</p>
            <p class="text-sm text-slate-300">Use <code class="text-amber">X-Rhumb-Key</code> for account-first execution with dashboard-backed billing controls.</p>
          </div>
          <div class="bg-surface border border-emerald-500/20 rounded-xl p-5">
            <p class="text-xs font-mono text-emerald-300 uppercase tracking-wider mb-2">Wallet-prefund</p>
            <p class="text-sm text-slate-300">Wallet signs once, tops up reusable balance, then executes repeat traffic with <code class="text-emerald-300">X-Rhumb-Key</code>.</p>
          </div>
          <div class="bg-surface border border-amber/20 rounded-xl p-5">
            <p class="text-xs font-mono text-amber uppercase tracking-wider mb-2">x402 per-call</p>
            <p class="text-sm text-slate-300">Use <code class="text-amber">X-Payment</code> for zero-signup, per-call USDC payment on Base. Current public execute compatibility is the legacy tx-hash proof flow; standard authorization payloads belong on the wallet-prefund top-up rail.</p>
          </div>
        </div>
      </section>

      <section class="mb-16" data-section="wallet-prefund-flow">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6 tracking-tight">Wallet-prefund flow (API-first)</h2>
        <div class="bg-surface border border-slate-800 rounded-xl p-5">
          <p class="text-sm text-slate-400 leading-relaxed">
            This is the bridge between wallet-first identity and reusable execution balance. Top-ups settle
            through x402, then execution runs through the normal <code class="text-emerald-300">X-Rhumb-Key</code> path.
          </p>
          <pre class="mt-4 text-sm font-mono text-slate-300 overflow-x-auto"><code>{`POST /v1/auth/wallet/request-challenge
POST /v1/auth/wallet/verify
GET  /v1/auth/wallet/me
POST /v1/billing/x402/topup/request
POST /v1/billing/x402/topup/verify
POST /v1/capabilities/{capability_id}/execute   # with X-Rhumb-Key`}</code></pre>
        </div>
      </section>

      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6 tracking-tight">REST API</h2>
        <div class="space-y-8">
          {ENDPOINTS.map((ep) => (
            <div class="bg-surface border border-slate-800 rounded-xl overflow-hidden">
              <div class="p-5 border-b border-slate-800">
                <div class="flex items-center gap-3 mb-2">
                  <span class={`font-mono text-xs font-bold px-2 py-0.5 rounded ${ep.method === "POST" ? "text-amber bg-amber/10" : "text-emerald-400 bg-emerald-500/10"}`}>
                    {ep.method}
                  </span>
                  <code class="font-mono text-sm text-slate-200">{ep.path}</code>
                </div>
                <p class="text-slate-400 text-sm">{ep.desc}</p>
              </div>

              <div class="p-5 border-b border-slate-800 bg-elevated">
                <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Request</span>
                <pre class="mt-2 text-sm font-mono text-slate-300 overflow-x-auto"><code>{ep.curl}</code></pre>
              </div>

              <div class="p-5 bg-elevated">
                <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Response</span>
                <pre class="mt-2 text-sm font-mono text-slate-300 overflow-x-auto"><code>{ep.response}</code></pre>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6 tracking-tight">MCP Server</h2>
        <p class="text-slate-400 leading-relaxed mb-6">
          Rhumb provides an MCP server for discovery, capability routing, supported execution, and account operations.
          Current public server surface: <strong class="text-slate-200">{PUBLIC_TRUTH.mcpToolsLabel} tools</strong>.
        </p>

        <div class="bg-surface border border-slate-800 rounded-xl p-5 mb-6">
          <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Install & run</span>
          <pre class="mt-3 text-sm font-mono text-slate-300 overflow-x-auto"><code>{`RHUMB_API_BASE_URL="${BASE_URL}" npx rhumb-mcp@latest`}</code></pre>
        </div>

        <h3 class="font-display font-semibold text-lg text-slate-200 mb-4">Available tools</h3>
        <div class="space-y-3">
          {MCP_TOOLS.map((tool) => (
            <div class="bg-surface border border-slate-800 rounded-lg p-4">
              <div class="flex items-baseline gap-3 mb-1">
                <code class="font-mono text-sm font-semibold text-amber">{tool.name}</code>
              </div>
              <p class="text-slate-400 text-sm mb-2">{tool.desc}</p>
              <code class="font-mono text-xs text-slate-500 bg-elevated px-2 py-1 rounded">{tool.example}</code>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-elevated border border-slate-800 rounded-xl p-6">
        <h2 class="font-display font-semibold text-lg text-slate-100 mb-3">Notes</h2>
        <ul class="space-y-2 text-slate-400 text-sm">
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">Execution body shape</strong>{" "}
              — send nested JSON like <code class="font-mono text-xs bg-surface px-1 rounded text-amber">{"{\"body\": {...}}"}</code>, not flat top-level fields.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">Estimate first</strong>{" "}
              — use <code class="font-mono text-xs bg-surface px-1 rounded text-amber">GET /v1/capabilities/{"{id}"}/execute/estimate</code> before paid execution.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">x402 proof</strong>{" "}
              — retry direct execute with <code class="font-mono text-xs bg-surface px-1 rounded text-amber">X-Payment</code> carrying <code class="font-mono text-xs bg-surface px-1 rounded text-amber">tx_hash</code>, <code class="font-mono text-xs bg-surface px-1 rounded text-amber">network</code>, and <code class="font-mono text-xs bg-surface px-1 rounded text-amber">wallet_address</code>. If your wallet emits a standard x402 authorization payload instead, use the wallet-prefund top-up flow rather than the direct execute retry path.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">Layer 3 public state</strong>{" "}
              — the recipe tooling is live, but the public catalog can still be empty. Check <a href="/recipes" class="text-amber hover:underline underline-offset-2">/recipes</a> or run <code class="font-mono text-xs bg-surface px-1 rounded text-amber">rhumb_list_recipes</code> before assuming a workflow exists.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">Canonical public pricing contract</strong>{" "}
              — see <a href="/pricing" class="text-amber hover:underline underline-offset-2">/pricing</a> or <code class="font-mono text-xs bg-surface px-1 rounded text-amber">GET /v1/pricing</code>.
            </span>
          </li>
        </ul>
      </section>

      <section class="mt-10 border-t border-slate-800 pt-8">
        <div class="flex flex-wrap gap-4 text-sm">
          <a href="/quickstart" class="text-slate-400 hover:text-amber transition-colors">Quickstart →</a>
          <a href="/payments/agent" class="text-slate-400 hover:text-amber transition-colors">Agent Payments →</a>
          <a href="/pricing" class="text-slate-400 hover:text-amber transition-colors">Pricing →</a>
          <a href="/status" class="text-slate-400 hover:text-amber transition-colors">System Status →</a>
        </div>
      </section>
    </div>
  </div>
</Layout>
