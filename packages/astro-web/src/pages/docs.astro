---
import Layout from "../layouts/Layout.astro";

const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.rhumb.dev/v1";

const ENDPOINTS = [
  {
    method: "GET",
    path: "/v1/services/{slug}/score",
    desc: "Full AN Score breakdown for a service.",
    curl: `curl ${BASE_URL}/services/stripe/score`,
    response: `{
  "data": {
    "slug": "stripe",
    "an_score": 8.1,
    "tier": "L4 Native",
    "execution_score": 8.4,
    "access_readiness_score": 7.3,
    "failure_count": 2,
    "review_count": 47
  },
  "error": null
}`,
  },
  {
    method: "GET",
    path: "/v1/search?q={query}",
    desc: "Search services by need, category, or description.",
    curl: `curl "${BASE_URL}/search?q=send+email"`,
    response: `{
  "data": {
    "query": "send email",
    "results": [
      {
        "service_slug": "google-workspace-apis",
        "name": "Google Workspace APIs",
        "aggregate_recommendation_score": 8.7,
        "tier": "L4"
      }
    ]
  },
  "error": null
}`,
  },
  {
    method: "GET",
    path: "/v1/capabilities/{capability_id}",
    desc: "Inspect a capability and the providers that can fulfill it.",
    curl: `curl ${BASE_URL}/capabilities/email.send`,
    response: `{
  "data": {
    "id": "email.send",
    "provider_count": 8,
    "providers": [
      {
        "service_slug": "resend",
        "credential_modes": ["byo", "rhumb_managed"],
        "cost_per_call": 0.001
      }
    ]
  },
  "error": null
}`,
  },
  {
    method: "GET",
    path: "/v1/capabilities/{capability_id}/resolve",
    desc: "Resolve a capability to ranked providers, with routing hints and fallback chain.",
    curl: `curl ${BASE_URL}/capabilities/email.send/resolve`,
    response: `{
  "data": {
    "capability": "email.send",
    "providers": [
      {
        "service_slug": "resend",
        "recommendation": "preferred",
        "cost_per_call": 0.001,
        "credential_modes": ["byo", "rhumb_managed"]
      }
    ],
    "fallback_chain": ["resend", "sendgrid"]
  },
  "error": null
}`,
  },
  {
    method: "GET",
    path: "/v1/capabilities/{capability_id}/execute/estimate",
    desc: "Estimate provider, cost, and circuit state before executing.",
    curl: `curl ${BASE_URL}/capabilities/email.send/execute/estimate`,
    response: `{
  "data": {
    "capability_id": "email.send",
    "provider": "resend",
    "credential_mode": "auto",
    "cost_estimate_usd": 0.001,
    "circuit_state": "closed",
    "endpoint_pattern": "/emails"
  },
  "error": null
}`,
  },
  {
    method: "POST",
    path: "/v1/capabilities/{capability_id}/execute",
    desc: "Execute through Rhumb with an API key, BYOK / agent token, or x402 payment.",
    curl: `curl -X POST "${BASE_URL}/capabilities/email.send/execute" \\
  -H "X-Rhumb-Key: rhumb_live_..." \\
  -H "Content-Type: application/json" \\
  -d '{"body": {"to": "user@example.com", "subject": "Hello", "body": "Hi from Rhumb"}}'`,
    response: `{
  "data": {
    "capability_id": "email.send",
    "provider": "resend",
    "upstream_status": 202,
    "credential_mode": "rhumb_managed"
  },
  "error": null
}`,
  },
  {
    method: "POST",
    path: "/v1/capabilities/{capability_id}/execute (x402)",
    desc: "Anonymous execution path. First request returns HTTP 402 with exact payment requirements.",
    curl: `curl -X POST "${BASE_URL}/capabilities/email.send/execute" \\
  -H "Content-Type: application/json" \\
  -d '{"body": {"to": "user@example.com", "subject": "Hello"}}'`,
    response: `{
  "x402Version": 1,
  "accepts": [
    {
      "scheme": "exact",
      "network": "base-mainnet",
      "payTo": "0x...",
      "asset": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
      "maxAmountRequired": "10000"
    }
  ],
  "balanceRequiredUsd": 0.01
}`,
  },
];

const DOCS_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  name: "API Documentation — Rhumb",
  url: "https://rhumb.dev/docs",
  description:
    "Rhumb REST API and MCP docs for discovery, capability routing, execution, pricing, and x402 payment flow.",
  author: {
    "@type": "Organization",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
  isPartOf: {
    "@type": "WebSite",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};

const MCP_TOOLS = [
  { name: "find_services", desc: "Search services by need.", example: 'find_services("payment processing")' },
  { name: "get_score", desc: "Get the full AN Score breakdown for a service.", example: 'get_score("stripe")' },
  { name: "get_alternatives", desc: "Find alternatives ranked by AN Score.", example: 'get_alternatives("paypal")' },
  { name: "get_failure_modes", desc: "Inspect known breakage patterns before integrating.", example: 'get_failure_modes("stripe")' },
  { name: "discover_capabilities", desc: "Browse capabilities like email.send or scrape.extract.", example: 'discover_capabilities({ search: "email" })' },
  { name: "resolve_capability", desc: "Rank providers for a capability.", example: 'resolve_capability("email.send")' },
  { name: "estimate_capability", desc: "Estimate cost and routing before execution.", example: 'estimate_capability("email.send")' },
  { name: "execute_capability", desc: "Execute a capability through Rhumb Resolve.", example: 'execute_capability("email.send", { body: { to: "user@example.com" } })' },
  { name: "credential_ceremony", desc: "Get self-service credential setup instructions.", example: 'credential_ceremony("github")' },
  { name: "check_credentials", desc: "See which credential modes are available to you.", example: 'check_credentials("email.send")' },
  { name: "budget", desc: "Check or set spend limits.", example: 'budget()' },
  { name: "spend", desc: "Review spending by period, capability, and provider.", example: 'spend()' },
  { name: "routing", desc: "Get or set routing preferences.", example: 'routing()' },
  { name: "usage_telemetry", desc: "Inspect latency, errors, provider health, and usage trends.", example: 'usage_telemetry({ days: 7 })' },
  { name: "check_balance", desc: "Check current Rhumb credit balance.", example: 'check_balance()' },
  { name: "get_payment_url", desc: "Generate a top-up URL for prepaid credits.", example: 'get_payment_url({ amount_usd: 25 })' },
  { name: "get_ledger", desc: "Review billing history.", example: 'get_ledger()' },
];
---

<Layout
  title="API Documentation"
  description="Rhumb REST API and MCP docs for discovery, capability routing, execution, pricing, and x402 payment flow."
  canonical="/docs"
  ogTitle="API Documentation — Rhumb"
  ogDescription="REST API + MCP docs for discovery, routing, execution, billing, and x402 payments."
  ogUrl="https://rhumb.dev/docs"
  jsonLd={DOCS_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <div class="max-w-4xl mx-auto px-6 pt-14 pb-24">
      <header class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">Documentation</span>
        </div>
        <h1 class="font-display font-bold text-3xl sm:text-4xl text-slate-100 leading-tight tracking-tight mb-6">
          API Documentation
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed mb-6">
          Use Rhumb for discovery, capability routing, pricing, and execution. Discovery reads are open.
          Execution requires one of: <code class="font-mono text-amber text-base">X-Rhumb-Key</code>,
          your own provider credential path, or <code class="font-mono text-amber text-base">X-Payment</code>
          for x402.
        </p>
        <div class="bg-surface border border-slate-800 rounded-lg p-4 font-mono text-sm">
          <span class="text-slate-500">Base URL:</span>{" "}
          <span class="text-amber">{BASE_URL}</span>
        </div>
      </header>

      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-4 tracking-tight">Auth paths</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">Discovery</p>
            <p class="text-sm text-slate-300">Read endpoints like scores, search, capabilities, and leaderboards are open.</p>
          </div>
          <div class="bg-surface border border-slate-800 rounded-xl p-5">
            <p class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-2">Execution</p>
            <p class="text-sm text-slate-300">Use <code class="text-amber">X-Rhumb-Key</code> for account-based execution and dashboard-backed billing.</p>
          </div>
          <div class="bg-surface border border-amber/20 rounded-xl p-5">
            <p class="text-xs font-mono text-amber uppercase tracking-wider mb-2">x402</p>
            <p class="text-sm text-slate-300">Use <code class="text-amber">X-Payment</code> for zero-signup, per-call USDC payment on Base.</p>
          </div>
        </div>
      </section>

      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6 tracking-tight">REST API</h2>
        <div class="space-y-8">
          {ENDPOINTS.map((ep) => (
            <div class="bg-surface border border-slate-800 rounded-xl overflow-hidden">
              <div class="p-5 border-b border-slate-800">
                <div class="flex items-center gap-3 mb-2">
                  <span class={`font-mono text-xs font-bold px-2 py-0.5 rounded ${ep.method === "POST" ? "text-amber bg-amber/10" : "text-emerald-400 bg-emerald-500/10"}`}>
                    {ep.method}
                  </span>
                  <code class="font-mono text-sm text-slate-200">{ep.path}</code>
                </div>
                <p class="text-slate-400 text-sm">{ep.desc}</p>
              </div>

              <div class="p-5 border-b border-slate-800 bg-elevated">
                <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Request</span>
                <pre class="mt-2 text-sm font-mono text-slate-300 overflow-x-auto"><code>{ep.curl}</code></pre>
              </div>

              <div class="p-5 bg-elevated">
                <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Response</span>
                <pre class="mt-2 text-sm font-mono text-slate-300 overflow-x-auto"><code>{ep.response}</code></pre>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6 tracking-tight">MCP Server</h2>
        <p class="text-slate-400 leading-relaxed mb-6">
          Rhumb provides an MCP server for discovery, routing, execution, billing, and telemetry.
          Current public server surface: <strong class="text-slate-200">17 tools</strong>.
        </p>

        <div class="bg-surface border border-slate-800 rounded-xl p-5 mb-6">
          <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Install & run</span>
          <pre class="mt-3 text-sm font-mono text-slate-300 overflow-x-auto"><code>{`RHUMB_API_BASE_URL="${BASE_URL}" npx rhumb-mcp@0.8.2`}</code></pre>
        </div>

        <h3 class="font-display font-semibold text-lg text-slate-200 mb-4">Available tools</h3>
        <div class="space-y-3">
          {MCP_TOOLS.map((tool) => (
            <div class="bg-surface border border-slate-800 rounded-lg p-4">
              <div class="flex items-baseline gap-3 mb-1">
                <code class="font-mono text-sm font-semibold text-amber">{tool.name}</code>
              </div>
              <p class="text-slate-400 text-sm mb-2">{tool.desc}</p>
              <code class="font-mono text-xs text-slate-500 bg-elevated px-2 py-1 rounded">{tool.example}</code>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-elevated border border-slate-800 rounded-xl p-6">
        <h2 class="font-display font-semibold text-lg text-slate-100 mb-3">Notes</h2>
        <ul class="space-y-2 text-slate-400 text-sm">
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">Execution body shape</strong>{" "}
              — send nested JSON like <code class="font-mono text-xs bg-surface px-1 rounded text-amber">{"{\"body\": {...}}"}</code>, not flat top-level fields.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">Estimate first</strong>{" "}
              — use <code class="font-mono text-xs bg-surface px-1 rounded text-amber">GET /v1/capabilities/{"{id}"}/execute/estimate</code> before paid execution.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">x402 proof</strong>{" "}
              — retry execute with <code class="font-mono text-xs bg-surface px-1 rounded text-amber">X-Payment</code> carrying <code class="font-mono text-xs bg-surface px-1 rounded text-amber">tx_hash</code>, <code class="font-mono text-xs bg-surface px-1 rounded text-amber">network</code>, and <code class="font-mono text-xs bg-surface px-1 rounded text-amber">wallet_address</code>.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-amber mt-0.5">&bull;</span>
            <span>
              <strong class="text-slate-200">Canonical public pricing contract</strong>{" "}
              — see <a href="/pricing" class="text-amber hover:underline underline-offset-2">/pricing</a> or <code class="font-mono text-xs bg-surface px-1 rounded text-amber">GET /v1/pricing</code>.
            </span>
          </li>
        </ul>
      </section>

      <section class="mt-10 border-t border-slate-800 pt-8">
        <div class="flex flex-wrap gap-4 text-sm">
          <a href="/quickstart" class="text-slate-400 hover:text-amber transition-colors">Quickstart →</a>
          <a href="/payments/agent" class="text-slate-400 hover:text-amber transition-colors">Agent Payments →</a>
          <a href="/pricing" class="text-slate-400 hover:text-amber transition-colors">Pricing →</a>
          <a href="/status" class="text-slate-400 hover:text-amber transition-colors">System Status →</a>
        </div>
      </section>
    </div>
  </div>
</Layout>
