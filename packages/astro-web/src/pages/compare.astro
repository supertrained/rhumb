---
export const prerender = true;
import Layout from "../layouts/Layout.astro";

const PAGE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Service Comparisons for AI Agents",
  description:
    "Side-by-side comparisons of developer tools scored for AI agent workflows. Each uses the same live AN Score methodology.",
  url: "https://rhumb.dev/compare",
  publisher: { "@type": "Organization", name: "Rhumb", url: "https://rhumb.dev" },
};

type Comparison = {
  slug: string;
  category: string;
  title: string;
  description: string;
  services: string[];
  winner: string;
  winnerNote: string;
  narrative: string;
  accent: string;
  accentSoft: string;
};

const comparisons: Comparison[] = [
  {
    slug: "stripe-vs-square-vs-paypal",
    category: "Payments",
    title: "Stripe vs Square vs PayPal",
    description: "Which payment processor should an AI agent use?",
    services: ["Stripe 8.1 L4", "Square 6.3 L3", "PayPal 4.9 L2"],
    winner: "Stripe",
    winnerNote: "Clear leader — highest execution, best API, most agent-native.",
    narrative: "One clear winner. Stripe dominates on every axis except physical commerce.",
    accent: "#6366F1",
    accentSoft: "rgba(99,102,241,0.14)",
  },
  {
    slug: "resend-vs-sendgrid-vs-postmark",
    category: "Email",
    title: "Resend vs SendGrid vs Postmark",
    description: "Which email delivery API should an AI agent use?",
    services: ["Resend 7.8 L4", "Postmark 6.8 L3", "SendGrid 6.4 L3"],
    winner: "Resend",
    winnerNote: "Default choice — fewest hidden states, highest execution.",
    narrative: "Close competition. Postmark wins for critical transactional; SendGrid wins in Twilio stacks.",
    accent: "#10B981",
    accentSoft: "rgba(16,185,129,0.14)",
  },
  {
    slug: "hubspot-vs-salesforce-vs-pipedrive",
    category: "CRM",
    title: "HubSpot vs Salesforce vs Pipedrive",
    description: "Which CRM should an AI agent integrate with?",
    services: ["Pipedrive 5.7 L3", "Salesforce 4.8 L2", "HubSpot 4.6 L2"],
    winner: "None",
    winnerNote: "No CRM is agent-native. Choice is constraint-driven.",
    narrative: "All score below 6.0. The decision is driven by organizational context, not tool quality.",
    accent: "#F97316",
    accentSoft: "rgba(249,115,22,0.14)",
  },
  {
    slug: "supabase-vs-planetscale-vs-neon",
    category: "Databases",
    title: "Supabase vs PlanetScale vs Neon",
    description: "Which database should an AI agent use?",
    services: ["Neon 7.6 L4", "Supabase 7.5 L3", "PlanetScale 7.2 L3"],
    winner: "Too close to call",
    winnerNote: "0.4-point spread — confidence and platform shape matter more than score.",
    narrative: "Closest race in any category. Decision driven by Postgres vs MySQL and platform breadth, not scores.",
    accent: "#3ECF8E",
    accentSoft: "rgba(62,207,142,0.14)",
  },
  {
    slug: "posthog-vs-mixpanel-vs-amplitude",
    category: "Analytics",
    title: "PostHog vs Mixpanel vs Amplitude",
    description: "Which analytics platform should an AI agent use?",
    services: ["PostHog 6.9 L3", "Mixpanel 6.2 L3", "Amplitude 5.7 L3"],
    winner: "PostHog",
    winnerNote: "Broadest surface — analytics + flags + experiments in one integration.",
    narrative: "All-in-one vs specialist vs enterprise warehouse-native. PostHog covers the most ground.",
    accent: "#F54E00",
    accentSoft: "rgba(245,78,0,0.14)",
  },
  {
    slug: "auth0-vs-clerk-vs-firebase-auth",
    category: "Auth",
    title: "Auth0 vs Clerk vs Firebase Auth",
    description: "Which auth provider should an AI agent use?",
    services: ["Clerk 7.4 L3", "Firebase Auth 6.4 L3", "Auth0 6.3 L3"],
    winner: "Clerk",
    winnerNote: "Best DX and execution. Auth0 wins on enterprise compliance.",
    narrative: "Trust-critical surface. Failures are security incidents, not UX friction.",
    accent: "#8B5CF6",
    accentSoft: "rgba(139,92,246,0.14)",
  },
  {
    slug: "twilio-vs-vonage-vs-plivo",
    category: "Messaging",
    title: "Twilio vs Vonage vs Plivo",
    description: "Which messaging API should an AI agent use?",
    services: ["Twilio 8.0 L4", "Vonage 6.9 L3", "Plivo 6.4 L3"],
    winner: "Twilio",
    winnerNote: "Clear default — highest execution, simplest auth, best error handling.",
    narrative: "Clear winner. Vonage is the platform play; Plivo is the cost optimizer.",
    accent: "#EF4444",
    accentSoft: "rgba(239,68,68,0.14)",
  },
  {
    slug: "linear-vs-jira-vs-asana",
    category: "Project Management",
    title: "Linear vs Jira vs Asana",
    description: "Which project management tool should an AI agent use?",
    services: ["Linear 7.5 L3", "Jira 7.2 L3", "Asana 7.0 L3"],
    winner: "Linear",
    winnerNote: "API-first GraphQL design. Jira wins on enterprise governance.",
    narrative: "Tight race (0.5-point spread). Decision driven by stack context and governance needs, not raw score.",
    accent: "#5E6AD2",
    accentSoft: "rgba(94,106,210,0.14)",
  },
];
---

<Layout
  title="Service Comparisons for AI Agents | Rhumb"
  description="Side-by-side comparisons of developer tools scored for AI agent workflows. Payments, email, CRM, and auth — each using the same live AN Score methodology."
  canonical="/compare"
  ogTitle="Service Comparisons for AI Agents"
  ogDescription="Side-by-side decision pages for operators and agents. Each comparison uses live scoring data."
  ogUrl="https://rhumb.dev/compare"
  ogType="website"
  twitterTitle="Service Comparisons for AI Agents"
  twitterDescription="Which tool should your agent use? Payments, email, CRM, auth — compared with live scores."
  jsonLd={PAGE_JSON_LD}
>
  <div class="bg-navy min-h-screen overflow-hidden">
    <section class="relative border-b border-slate-800/80">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_left,rgba(99,102,241,0.10),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.08),transparent_30%)]"></div>

      <div class="relative max-w-5xl mx-auto px-6 pt-14 pb-12">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-xs font-mono font-semibold text-amber uppercase tracking-[0.28em]">Comparisons</span>
            <span class="text-slate-700">&middot;</span>
            <span class="text-xs font-mono text-slate-500">live score data</span>
          </div>

          <h1 class="font-display font-bold text-4xl sm:text-5xl leading-[0.95] tracking-tight text-slate-100">
            Which tool should your agent use?
          </h1>

          <p class="mt-5 text-lg text-slate-300 leading-relaxed max-w-2xl">
            Side-by-side decision pages for operators and agents. Each comparison uses the same
            live AN Score methodology, so results are directly comparable across categories.
          </p>
        </div>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-12">
      <div class="grid gap-5 sm:grid-cols-2">
        {comparisons.map((c, index) => (
          <a
            href={`/blog/${c.slug}`}
            class="group relative overflow-hidden rounded-[28px] border bg-surface/90 p-6 sm:p-7 transition-all duration-200 hover:border-opacity-70 hover:-translate-y-0.5 reveal"
            style={`border-color:${c.accent}35; animation-delay:${index * 80}ms;`}
          >
            <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`background:radial-gradient(circle_at_top_right, ${c.accentSoft} 0%, transparent 40%);`}></div>
            <div class="relative">
              <div class="flex items-center justify-between gap-4">
                <span class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">{c.category}</span>
                <span class="h-2.5 w-2.5 rounded-full" style={`background:${c.accent}`}></span>
              </div>

              <h2 class="mt-3 font-display font-bold text-2xl text-slate-100 group-hover:text-white transition-colors">{c.title}</h2>
              <p class="mt-2 text-sm text-slate-400">{c.description}</p>

              <div class="mt-5 flex flex-wrap gap-2">
                {c.services.map((svc) => (
                  <span class="inline-flex rounded-lg border border-white/6 bg-navy/65 px-3 py-1.5 text-xs font-mono text-slate-300">{svc}</span>
                ))}
              </div>

              <div class="mt-5 rounded-2xl border border-white/6 bg-navy/70 px-4 py-3">
                <div class="flex items-center gap-2">
                  {c.winner === "None" ? (
                    <span class="inline-flex rounded-full border border-amber-500/25 bg-amber-500/10 px-2.5 py-0.5 text-[11px] font-mono text-amber-300">No clear winner</span>
                  ) : (
                    <span class="inline-flex rounded-full border border-emerald-500/25 bg-emerald-500/10 px-2.5 py-0.5 text-[11px] font-mono text-emerald-300">Pick: {c.winner}</span>
                  )}
                </div>
                <p class="mt-2 text-sm leading-6 text-slate-400">{c.winnerNote}</p>
              </div>

              <p class="mt-4 text-xs leading-5 text-slate-500 italic">{c.narrative}</p>

              <div class="mt-5 flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-amber group-hover:text-amber-dark transition-colors">
                Read comparison
                <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-14 rounded-[28px] border border-slate-800 bg-surface/80 p-8 text-center reveal">
        <p class="text-[11px] font-mono uppercase tracking-[0.28em] text-slate-500">Methodology</p>
        <h2 class="mt-2 font-display font-bold text-2xl text-slate-100">Same framework, different stories</h2>
        <p class="mt-4 max-w-2xl mx-auto text-slate-400 leading-relaxed">
          Every comparison pulls live scores from the Rhumb AN Score — the same methodology applied to all 212+ scored services.
          Different categories tell structurally different stories: clear winners, close races, or no-winner constraint problems.
          That diversity is honest; these pages do not exist to sell a verdict.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
          <a href="/methodology" class="inline-flex rounded-xl bg-amber px-5 py-3 text-navy font-display font-semibold text-sm hover:bg-amber-dark transition-colors">Read methodology</a>
          <a href="/docs" class="inline-flex rounded-xl border border-slate-700 px-5 py-3 text-slate-300 font-display font-semibold text-sm hover:border-slate-500 hover:text-slate-100 transition-colors">API docs</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
