---
import Layout from "../layouts/Layout.astro";
import { PUBLIC_TRUTH } from "../lib/public-truth";

// Fetch all capabilities from the API (paginated)
interface Capability {
  id: string;
  domain: string;
  action: string;
  description: string;
  input_hint: string | null;
  outcome: string | null;
  provider_count: number;
  top_provider: { slug: string; an_score: number; tier_label: string } | null;
}

const API_BASE = "https://api.rhumb.dev/v1";
const allCapabilities: Capability[] = [];
let offset = 0;
const limit = 100;

while (true) {
  try {
    const res = await fetch(`${API_BASE}/capabilities?limit=${limit}&offset=${offset}`, {
      headers: { "X-Rhumb-Client": "web" },
    });
    if (!res.ok) break;
    const json = await res.json();
    const items = json?.data?.items ?? [];
    allCapabilities.push(...items);
    if (items.length < limit || allCapabilities.length >= (json?.data?.total ?? 0)) break;
    offset += limit;
  } catch {
    break;
  }
}

// Derive domains and counts
const domainCounts: Record<string, number> = {};
for (const cap of allCapabilities) {
  domainCounts[cap.domain] = (domainCounts[cap.domain] ?? 0) + 1;
}
const domains = Object.keys(domainCounts).sort();
const totalCapabilities = allCapabilities.length;
const totalDomains = domains.length;

// Sort capabilities alphabetically by id
allCapabilities.sort((a, b) => a.id.localeCompare(b.id));

const CAPABILITIES_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Capabilities | Rhumb",
  url: "https://rhumb.dev/capabilities",
  description: `Browse ${totalCapabilities} capability definitions across ${totalDomains} domains. Discovery breadth is wider than current callable coverage; today ${PUBLIC_TRUTH.callableProvidersLabel} providers are execution-ready through Rhumb.`,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: totalCapabilities,
    itemListElement: allCapabilities.slice(0, 50).map((cap, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "Thing",
        name: cap.id,
        description: cap.description,
      },
    })),
  },
};

// Serialize data for client-side JS
const clientData = allCapabilities.map((c) => ({
  id: c.id,
  domain: c.domain,
  action: c.action,
  description: c.description,
  input_hint: c.input_hint,
  outcome: c.outcome,
  provider_count: c.provider_count,
  top_provider: c.top_provider,
}));

const CAPABILITY_STARTER_QUERIES = [
  "web research",
  "extract webpage text",
  "send email",
  "generate image",
  "transcribe audio",
];
---

<Layout
  title="Capabilities | Rhumb"
  description={`Browse ${totalCapabilities} capability definitions across ${totalDomains} domains. Discovery breadth is wider than current callable coverage; today ${PUBLIC_TRUTH.callableProvidersLabel} providers are execution-ready through Rhumb.`}
  canonical="/capabilities"
  ogTitle="Capabilities | Rhumb"
  ogDescription={`${totalCapabilities} capability definitions across ${totalDomains}+ domains. Current execution-ready surface: ${PUBLIC_TRUTH.callableProvidersLabel} callable providers.`}
  ogUrl="https://rhumb.dev/capabilities"
  jsonLd={CAPABILITIES_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <!-- Hero -->
    <section class="relative border-b border-slate-800 overflow-hidden">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="relative max-w-6xl mx-auto px-6 py-14">
        <p class="text-xs font-mono text-amber uppercase tracking-widest mb-3">Capabilities</p>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-slate-100 tracking-tight">
          Capability definitions
        </h1>
        <p class="mt-3 text-slate-400 max-w-xl leading-relaxed">
          {totalCapabilities} capability definitions across {totalDomains} domains. Discovery breadth is wider than current callable coverage.
        </p>
        <p class="mt-2 text-sm text-slate-500 leading-relaxed max-w-xl">
          Capabilities are abstract actions &mdash; like <code class="text-amber/80 text-xs font-mono">search.query</code> or <code class="text-amber/80 text-xs font-mono">email.send</code> &mdash;
          that map to concrete providers. Agents discover capabilities here, then Rhumb resolves the best provider where execution is actually live.
        </p>
        <div class="mt-5 max-w-2xl rounded-xl border border-amber/20 bg-surface p-4">
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Honest current state</p>
          <p class="text-sm text-slate-300 leading-6">
            {PUBLIC_TRUTH.catalogRealitySummary}
          </p>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pt-8 pb-4">
      <div class="grid gap-4 lg:grid-cols-3 mb-6">
        <div class="rounded-2xl border border-slate-800 bg-surface p-5">
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Choosing vendors?</p>
          <p class="text-sm text-slate-300 leading-6">
            Use service search, leaderboards, and score pages when you want to compare who should handle the job.
          </p>
          <a href="/quickstart#rest-path" class="mt-4 inline-flex text-xs font-mono text-slate-400 hover:text-amber transition-colors">See the REST path →</a>
        </div>
        <div class="rounded-2xl border border-amber/20 bg-surface p-5">
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Naming the action?</p>
          <p class="text-sm text-slate-300 leading-6">
            Search this page when you know the job but not the slug. <code class="text-amber text-xs">/search</code> returns services, not capability IDs.
          </p>
          <a href="#cap-search" class="mt-4 inline-flex text-xs font-mono text-slate-400 hover:text-amber transition-colors">Jump to capability search →</a>
        </div>
        <div class="rounded-2xl border border-emerald-500/20 bg-surface p-5">
          <p class="text-xs font-mono text-emerald-300 uppercase tracking-widest mb-2">Ready to run it?</p>
          <p class="text-sm text-slate-300 leading-6">
            Once you have the capability ID, resolve providers, estimate the active rail, then execute through quickstart or MCP.
          </p>
          <a href="/quickstart#execute-path" class="mt-4 inline-flex text-xs font-mono text-slate-400 hover:text-emerald-300 transition-colors">Go to execute flow →</a>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-800 bg-surface px-5 py-4 mb-6 text-sm text-slate-300 leading-6">
        <strong class="text-slate-100">Service</strong> = vendor. <strong class="text-slate-100">Capability</strong> = executable action. This page exists to bridge from plain-English intent to the exact capability slug your agent can resolve.
      </div>

      <div class="mb-4 flex flex-wrap gap-2">
        {CAPABILITY_STARTER_QUERIES.map((query) => (
          <button
            type="button"
            data-cap-query={query}
            class="rounded-full border border-slate-800 bg-surface px-3 py-1.5 text-xs font-mono text-slate-400 transition-colors hover:border-amber/40 hover:text-amber cursor-pointer"
          >
            {query}
          </button>
        ))}
      </div>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
        <!-- Search -->
        <div class="relative flex-1 max-w-md">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input
            type="text"
            id="cap-search"
            placeholder="Search what you want to do (e.g. scrape website, generate image)"
            class="w-full pl-10 pr-4 py-2.5 rounded-lg bg-surface border border-slate-800 text-sm text-slate-100 placeholder:text-slate-600 focus:outline-none focus:border-amber/40 transition-colors font-mono"
          />
        </div>

        <!-- Domain filter -->
        <div class="relative">
          <select
            id="cap-domain-filter"
            class="appearance-none pl-4 pr-10 py-2.5 rounded-lg bg-surface border border-slate-800 text-sm text-slate-300 focus:outline-none focus:border-amber/40 transition-colors cursor-pointer"
          >
            <option value="">All domains ({totalDomains})</option>
            {domains.map((d) => (
              <option value={d}>{d.replace(/_/g, " ")} ({domainCounts[d]})</option>
            ))}
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <!-- Sort -->
        <div class="relative">
          <select
            id="cap-sort"
            class="appearance-none pl-4 pr-10 py-2.5 rounded-lg bg-surface border border-slate-800 text-sm text-slate-300 focus:outline-none focus:border-amber/40 transition-colors cursor-pointer"
          >
            <option value="alpha">A &rarr; Z</option>
            <option value="providers">Most providers</option>
            <option value="domain">By domain</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Result count -->
      <p id="cap-count" class="mt-4 text-xs font-mono text-slate-500">
        Showing {totalCapabilities} capability definitions
      </p>
    </section>

    <!-- Domain tags (quick filters) -->
    <section class="max-w-6xl mx-auto px-6 pb-6">
      <div id="domain-tags" class="flex flex-wrap gap-2">
        {domains.map((d) => (
          <button
            data-domain={d}
            class="domain-tag px-2.5 py-1 rounded-full border border-slate-800 text-xs font-mono text-slate-500 hover:border-amber/40 hover:text-amber transition-colors bg-surface cursor-pointer"
          >
            {d.replace(/_/g, " ")}
          </button>
        ))}
      </div>
    </section>

    <!-- Capabilities grid -->
    <section class="max-w-6xl mx-auto px-6 pb-16">
      <div id="cap-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {allCapabilities.map((cap, i) => (
          <article
            class="cap-card bg-surface border border-slate-800 rounded-xl p-5 card-lift"
            data-id={cap.id}
            data-domain={cap.domain}
            data-desc={cap.description.toLowerCase()}
            data-providers={cap.provider_count}
            style={i < 30 ? "" : "display:none"}
          >
            <!-- ID -->
            <div class="flex items-start justify-between gap-3 mb-3">
              <code class="text-amber font-mono text-sm font-semibold break-all leading-tight">
                {cap.id}
              </code>
              {cap.provider_count > 0 && (
                <span class="shrink-0 text-xs font-mono text-slate-500 px-2 py-0.5 rounded-full border border-slate-800 bg-navy/40 whitespace-nowrap">
                  {cap.provider_count} provider{cap.provider_count === 1 ? "" : "s"}
                </span>
              )}
            </div>

            <!-- Domain badge -->
            <div class="mb-3">
              <span class="inline-block text-xs font-mono text-slate-400 px-2 py-0.5 rounded-md bg-navy/60 border border-slate-800/60">
                {cap.domain.replace(/_/g, " ")}
              </span>
            </div>

            <!-- Description -->
            <p class="text-sm text-slate-400 leading-relaxed line-clamp-2">
              {cap.description}
            </p>

            <!-- Top provider -->
            {cap.top_provider && (
              <div class="mt-3 pt-3 border-t border-slate-800/60 flex items-center gap-2 text-xs">
                <span class="text-slate-600">Top:</span>
                <a
                  href={`/service/${cap.top_provider.slug}`}
                  class="text-slate-300 hover:text-amber transition-colors font-mono"
                >
                  {cap.top_provider.slug}
                </a>
                <span class="text-score-native font-mono font-semibold">
                  {cap.top_provider.an_score.toFixed(1)}
                </span>
              </div>
            )}
          </article>
        ))}
      </div>

      <!-- Show more button -->
      <div id="cap-show-more" class="mt-8 text-center">
        <button
          id="cap-load-more"
          class="px-6 py-2.5 rounded-lg bg-surface border border-slate-700 text-slate-300 text-sm font-medium hover:border-amber/40 hover:text-amber transition-colors cursor-pointer"
        >
          Show more capability definitions
        </button>
      </div>

      <!-- No results -->
      <div id="cap-empty" class="hidden mt-8">
        <div class="bg-surface border border-slate-800 rounded-xl p-12 text-center">
          <p class="text-slate-500 text-sm mb-4">No capabilities match your filters.</p>
          <button
            id="cap-reset"
            class="text-sm text-amber hover:underline font-mono cursor-pointer"
          >
            Clear filters &rarr;
          </button>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-6xl mx-auto px-6 pb-20">
      <div class="bg-surface border border-amber/20 rounded-xl p-8 text-center">
        <h2 class="font-display font-bold text-xl text-slate-100 mb-3">
          Use these definitions through MCP
        </h2>
        <p class="text-slate-400 text-sm mb-6 max-w-lg mx-auto">
          Discover capability definitions, resolve providers, and execute the subset that is live through
          a single MCP server. Discovery works without a key. Most MCP execution starts with <code class="text-amber">RHUMB_API_KEY</code>
          on the governed or wallet-prefund path, can carry BYOK credentials where supported, and can pass <code class="text-amber">x_payment</code>
          only on capabilities that expose x402 per-call.
        </p>
        <div class="inline-flex items-center gap-3 px-5 py-3 rounded-lg bg-navy border border-slate-700 font-mono text-sm text-amber mb-4">
          <code>npx rhumb-mcp@latest</code>
        </div>
        <div class="mt-4 flex flex-wrap justify-center gap-4">
          <a
            href="/docs"
            class="text-sm text-slate-400 hover:text-amber transition-colors font-mono"
          >
            API docs &rarr;
          </a>
          <a
            href="/trust"
            class="text-sm text-slate-400 hover:text-amber transition-colors font-mono"
          >
            Trust &rarr;
          </a>
          <a
            href="/methodology"
            class="text-sm text-slate-400 hover:text-amber transition-colors font-mono"
          >
            Methodology &rarr;
          </a>
          <a
            href="/providers#dispute-a-score"
            class="text-sm text-slate-400 hover:text-amber transition-colors font-mono"
          >
            Dispute a score &rarr;
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- Client-side search/filter/sort -->
  <script is:inline define:vars={{ clientData }}>
    (function() {
      const data = clientData;
      const cards = document.querySelectorAll('.cap-card');
      const searchInput = document.getElementById('cap-search');
      const domainFilter = document.getElementById('cap-domain-filter');
      const sortSelect = document.getElementById('cap-sort');
      const countEl = document.getElementById('cap-count');
      const gridEl = document.getElementById('cap-grid');
      const showMoreWrap = document.getElementById('cap-show-more');
      const loadMoreBtn = document.getElementById('cap-load-more');
      const emptyEl = document.getElementById('cap-empty');
      const domainTags = document.querySelectorAll('.domain-tag');
      const resetBtn = document.getElementById('cap-reset');
      const queryChips = document.querySelectorAll('[data-cap-query]');

      let visibleLimit = 30;

      const TOKEN_ALIASES = {
        audio: ['speech', 'voice', 'sound', 'video'],
        company: ['business', 'organization', 'org'],
        crawl: ['scrape', 'extract', 'website', 'web'],
        extract: ['scrape', 'crawl', 'parse', 'website', 'webpage', 'url'],
        find: ['search', 'lookup', 'discover', 'query'],
        generate: ['create', 'make', 'write'],
        image: ['images', 'photo', 'picture', 'visual', 'graphic'],
        linkedin: ['profile', 'professional', 'person', 'contact', 'lead'],
        person: ['people', 'profile', 'contact', 'lead', 'professional'],
        scrape: ['extract', 'crawl', 'parse', 'website', 'webpage', 'url'],
        search: ['find', 'lookup', 'discover', 'query'],
        speech: ['audio', 'voice', 'sound'],
        transcribe: ['transcription', 'captions', 'subtitle', 'audio', 'speech', 'voice'],
        website: ['web', 'webpage', 'page', 'site', 'url', 'html'],
        webpage: ['web', 'website', 'page', 'site', 'url', 'html'],
      };

      function normalizeIntentText(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
      }

      function termVariants(term) {
        const variants = new Set([term]);
        if (term.length > 3 && term.endsWith('s')) {
          variants.add(term.slice(0, -1));
        } else if (term.length > 3) {
          variants.add(term + 's');
        }
        return Array.from(variants);
      }

      function expandQueryTerms(term) {
        const expanded = new Set();
        termVariants(term).forEach(function(variant) {
          expanded.add(variant);
          (TOKEN_ALIASES[variant] || []).forEach(function(alias) {
            expanded.add(alias);
          });
        });
        return Array.from(expanded);
      }

      function buildSearchBlob(cap) {
        return normalizeIntentText([
          cap.id,
          cap.domain,
          cap.action,
          cap.description,
          cap.input_hint,
          cap.outcome,
        ].filter(Boolean).join(' '));
      }

      function scoreCapabilityIntent(query, cap) {
        const normalizedQuery = normalizeIntentText(query);
        if (!normalizedQuery) return 0;

        const blob = buildSearchBlob(cap);
        if (!blob) return 0;

        const tokens = normalizedQuery.split(' ').filter(Boolean);
        const blobTokens = new Set(blob.split(' '));
        const paddedBlob = ' ' + blob + ' ';
        const idText = normalizeIntentText(cap.id);
        const domainText = normalizeIntentText(cap.domain);
        const actionText = normalizeIntentText(cap.action);
        let score = 0;
        let matchedGroups = 0;

        if (idText.includes(normalizedQuery)) {
          score += 40;
        } else if (blob.includes(normalizedQuery)) {
          score += 24;
        }

        tokens.forEach(function(token) {
          const expansions = expandQueryTerms(token);
          const directHit = blobTokens.has(token) || paddedBlob.includes(' ' + token + ' ');
          const aliasHits = expansions.filter(function(alias) {
            return alias !== token && (blobTokens.has(alias) || paddedBlob.includes(' ' + alias + ' '));
          });

          if (directHit) {
            matchedGroups += 1;
            score += 12;
            if (idText.includes(token)) score += 10;
            if (token === domainText || token === actionText) score += 6;
          } else if (aliasHits.length > 0) {
            matchedGroups += 1;
            score += 5;
            if (aliasHits.some(function(alias) { return idText.includes(alias); })) score += 4;
          }
        });

        if (tokens.length && matchedGroups === tokens.length) {
          score += 24;
        } else if (tokens.length > 1 && matchedGroups >= tokens.length - 1) {
          score += 10;
        }

        if (idText.startsWith(normalizedQuery)) {
          score += 12;
        }

        return score;
      }

      function getFilteredSorted() {
        const query = (searchInput.value || '').trim();
        const domain = domainFilter.value;
        const sort = sortSelect.value;

        let filtered = data.filter(function(cap) {
          if (domain && cap.domain !== domain) return false;
          if (query) return scoreCapabilityIntent(query, cap) > 0;
          return true;
        });

        if (query) {
          filtered.sort(function(a, b) {
            const scoreDiff = scoreCapabilityIntent(query, b) - scoreCapabilityIntent(query, a);
            if (scoreDiff !== 0) return scoreDiff;
            return a.id.localeCompare(b.id);
          });
          return filtered;
        }

        if (sort === 'providers') {
          filtered.sort(function(a, b) { return b.provider_count - a.provider_count; });
        } else if (sort === 'domain') {
          filtered.sort(function(a, b) {
            var d = a.domain.localeCompare(b.domain);
            return d !== 0 ? d : a.id.localeCompare(b.id);
          });
        } else {
          filtered.sort(function(a, b) { return a.id.localeCompare(b.id); });
        }

        return filtered;
      }

      function render() {
        var filtered = getFilteredSorted();
        var shown = 0;

        // Build a set of visible IDs
        var visibleIds = new Set();
        for (var i = 0; i < Math.min(filtered.length, visibleLimit); i++) {
          visibleIds.add(filtered[i].id);
        }

        // Reorder cards in the grid to match sorted order
        var cardMap = {};
        cards.forEach(function(card) {
          cardMap[card.getAttribute('data-id')] = card;
        });

        // Show/hide and reorder
        for (var i = 0; i < filtered.length; i++) {
          var card = cardMap[filtered[i].id];
          if (!card) continue;
          if (i < visibleLimit) {
            card.style.display = '';
            gridEl.appendChild(card);
            shown++;
          } else {
            card.style.display = 'none';
          }
        }

        // Hide cards not in filtered
        var filteredIds = new Set(filtered.map(function(c) { return c.id; }));
        cards.forEach(function(card) {
          if (!filteredIds.has(card.getAttribute('data-id'))) {
            card.style.display = 'none';
          }
        });

        // Update count
        countEl.textContent = 'Showing ' + Math.min(shown, filtered.length) + ' of ' + filtered.length + ' capability definitions';

        // Show/hide load more
        if (filtered.length > visibleLimit) {
          showMoreWrap.style.display = '';
          loadMoreBtn.textContent = 'Show more capability definitions (' + (filtered.length - visibleLimit) + ' remaining)';
        } else {
          showMoreWrap.style.display = 'none';
        }

        // Show/hide empty state
        emptyEl.classList.toggle('hidden', filtered.length > 0);
      }

      function applyFilters() {
        visibleLimit = 30;
        render();
      }

      searchInput.addEventListener('input', applyFilters);
      domainFilter.addEventListener('change', function() {
        // Sync domain tags
        domainTags.forEach(function(tag) {
          tag.classList.toggle('border-amber/60', tag.getAttribute('data-domain') === domainFilter.value);
          tag.classList.toggle('text-amber', tag.getAttribute('data-domain') === domainFilter.value);
          tag.classList.toggle('border-slate-800', tag.getAttribute('data-domain') !== domainFilter.value);
          tag.classList.toggle('text-slate-500', tag.getAttribute('data-domain') !== domainFilter.value);
        });
        applyFilters();
      });
      sortSelect.addEventListener('change', applyFilters);

      loadMoreBtn.addEventListener('click', function() {
        visibleLimit += 60;
        render();
      });

      // Domain tag click
      domainTags.forEach(function(tag) {
        tag.addEventListener('click', function() {
          var domain = tag.getAttribute('data-domain');
          if (domainFilter.value === domain) {
            domainFilter.value = '';
          } else {
            domainFilter.value = domain;
          }
          domainFilter.dispatchEvent(new Event('change'));
        });
      });

      queryChips.forEach(function(chip) {
        chip.addEventListener('click', function() {
          var query = chip.getAttribute('data-cap-query') || '';
          searchInput.value = query;
          applyFilters();
          searchInput.focus();
        });
      });

      // Reset
      if (resetBtn) {
        resetBtn.addEventListener('click', function() {
          searchInput.value = '';
          domainFilter.value = '';
          sortSelect.value = 'alpha';
          domainTags.forEach(function(tag) {
            tag.classList.remove('border-amber/60', 'text-amber');
            tag.classList.add('border-slate-800', 'text-slate-500');
          });
          applyFilters();
        });
      }
    })();
  </script>
</Layout>
