---
import Layout from "../../layouts/Layout.astro";
import { PUBLIC_TRUTH } from "../../lib/public-truth";

const paths = [
  {
    name: "Rhumb-managed",
    when: "Use when Rhumb can honestly own the upstream provider account and expose the capability as the product.",
    agent: "Fastest path for repeat utility capabilities and low-heroics onboarding.",
    risk: "Do not use it to hide customer-owned system access behind Rhumb credentials.",
  },
  {
    name: "BYOK",
    when: "Use when the workflow touches the operator’s provider account, workspace, or production system.",
    agent: "The agent keeps explicit provider control while Rhumb adds routing, estimates, receipts, and policy checks where supported.",
    risk: "Credential custody and rotation remain an operator responsibility unless paired with vaulting.",
  },
  {
    name: "Agent Vault",
    when: "Use when credentials should be encrypted, scoped to an agent, and injected at execution time.",
    agent: "Best for agent-native custody and repeat execution where plaintext keys should not be copied into prompts or scripts.",
    risk: "Still needs clear scopes, revocation, and route-level receipts — vaulting is not authorization by itself.",
  },
];

const rules = [
  "Start with governed API key for repeat Rhumb-managed execution.",
  "Bring BYOK or Agent Vault when the workflow crosses into operator-owned systems.",
  "Use x402 when zero-signup per-call payment is the point, not as a default repeat-traffic rail.",
  "Pin provider paths when direct control matters more than best-fit routing.",
];

const jsonLdBlocks = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Resolve key management and credential paths",
    url: PUBLIC_TRUTH.resolveKeysUrl,
    description: "How Rhumb Resolve handles governed API keys, Rhumb-managed credentials, BYOK, Agent Vault, provider pinning, and x402 per-call payment.",
    isPartOf: { "@type": "WebSite", name: "Rhumb", url: "https://rhumb.dev" },
  },
];

const agentContext = "Resolve key management: use governed API key for repeat Rhumb-managed execution; use BYOK or Agent Vault when workflows touch operator-owned systems; use x402 only when zero-signup per-call payment is the point; provider pinning remains available for direct control.";
---

<Layout
  title="Resolve key management | Rhumb"
  description="How agents should choose between governed API keys, Rhumb-managed credentials, BYOK, Agent Vault, x402, and explicit provider pinning."
  canonical="/resolve/keys"
  ogTitle="Resolve key management"
  ogDescription="The credential model for governed agent execution: managed keys, BYOK, Agent Vault, x402, and provider pinning."
  ogUrl={PUBLIC_TRUTH.resolveKeysUrl}
  jsonLdBlocks={jsonLdBlocks}
  agentContext={agentContext}
>
  <div class="min-h-screen bg-navy text-slate-100">
    <section class="relative overflow-hidden border-b border-slate-800">
      <div class="absolute inset-0 bg-grid opacity-25 pointer-events-none"></div>
      <div class="absolute inset-x-0 top-0 h-[520px] pointer-events-none" style="background: radial-gradient(circle at 20% 20%, rgba(16,185,129,0.16), transparent 34%), radial-gradient(circle at 78% 16%, rgba(245,158,11,0.12), transparent 34%);"></div>
      <div class="relative mx-auto max-w-6xl px-6 py-20 lg:py-24">
        <p class="mb-4 text-xs font-mono uppercase tracking-[0.3em] text-emerald-300">Credential authority</p>
        <h1 class="max-w-5xl font-display text-5xl font-bold leading-[1.02] tracking-tight sm:text-6xl lg:text-7xl">Keys are a routing constraint, not an implementation detail.</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
          Resolve has to know who owns the upstream credential before it can honestly route a call. The right key path changes the route, cost, risk, and receipt.
        </p>
        <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
          <span class="text-slate-200">One key, many superpowers</span> does not mean one credential model for every workflow. Start with the governed key for Rhumb-managed capabilities, then bring BYOK or Agent Vault only when the work crosses into your systems.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/pricing" class="rounded-xl bg-amber px-5 py-3 text-sm font-semibold text-navy transition-colors hover:bg-amber-dark">Pricing and rails</a>
          <a href="/blog/agent-credential-paths-managed-key-byok-agent-vault-x402?rhumb_source=resolve-keys-credential-guide" class="rounded-xl border border-sky-500/40 px-5 py-3 text-sm text-sky-200 transition-colors hover:border-sky-300/70 hover:text-slate-100">Credential path guide</a>
          <a href="/resolve/routing" class="rounded-xl border border-slate-700 px-5 py-3 text-sm text-slate-300 transition-colors hover:border-amber/40 hover:text-slate-100">Routing proof</a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-5 lg:grid-cols-3">
        {paths.map((path) => (
          <article class="rounded-[30px] border border-slate-800 bg-surface p-6">
            <h2 class="font-display text-2xl font-semibold text-slate-100">{path.name}</h2>
            <div class="mt-5 space-y-3 text-sm leading-6">
              <p class="rounded-2xl border border-emerald-500/15 bg-emerald-500/10 p-4 text-slate-300"><span class="text-emerald-200">When:</span> {path.when}</p>
              <p class="rounded-2xl border border-slate-800 bg-navy/70 p-4 text-slate-400"><span class="text-slate-200">Agent effect:</span> {path.agent}</p>
              <p class="rounded-2xl border border-amber/15 bg-amber/10 p-4 text-slate-300"><span class="text-amber">Watch:</span> {path.risk}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-slate-800 bg-surface/35">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-16 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-xs font-mono uppercase tracking-[0.28em] text-amber">Operating rules</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-100">The honest default is simple.</h2>
          <p class="mt-4 text-sm leading-7 text-slate-400">Use the smallest credential boundary that can do the work safely. Do not introduce provider control, wallet payment, or vault ceremony unless the job actually needs it.</p>
        </div>
        <div class="grid gap-3">
          {rules.map((rule) => (
            <div class="rounded-2xl border border-slate-800 bg-navy/75 p-5 text-sm leading-6 text-slate-300">{rule}</div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
