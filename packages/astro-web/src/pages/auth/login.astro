---
import Layout from "../../layouts/Layout.astro";

const API_URL = import.meta.env.PUBLIC_API_URL ?? "https://api.rhumb.dev";
const error = Astro.url.searchParams.get("error");
const LOGIN_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Sign in | Rhumb",
  url: "https://rhumb.dev/auth/login",
  description: "Sign in to Rhumb to get your API key and access the developer dashboard.",
};
---

<Layout
  title="Sign in | Rhumb"
  description="Sign in to Rhumb to get your API key and access the developer dashboard."
  noindex={true}
  jsonLd={LOGIN_JSON_LD}
>
  <main class="min-h-screen bg-midnight px-4 py-12 sm:py-20">
    <div class="mx-auto max-w-5xl">
      <div class="mx-auto max-w-2xl text-center mb-10">
        <h1 class="text-3xl font-semibold text-white mb-3">Sign in to Rhumb</h1>
        <p class="text-sm text-slate-400">
          Use OAuth or request a one-time email code to access your dashboard, API key, and billing controls.
        </p>
      </div>

      {error && (
        <div class="mx-auto max-w-2xl mb-6 p-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm text-center">
          {decodeURIComponent(error)}
        </div>
      )}

      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6 sm:p-7">
          <div class="mb-6">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-score-native mb-2">
              Email code sign-in
            </p>
            <h2 class="text-xl font-semibold text-white mb-2">Request a one-time code</h2>
            <p class="text-sm text-slate-400">
              Email sign-in is useful for direct access, automation handoff, and non-browser agent setups.
            </p>
          </div>

          <div class="rounded-xl border border-amber/20 bg-amber/10 p-4 mb-6">
            <p class="text-sm font-medium text-amber mb-1">Execution credit is separate</p>
            <p class="text-sm text-slate-300">
              Email OTP access does not include automatic free execution credit. Run traffic through x402,
              use your own provider credentials where supported, or add funded balance in the dashboard.
            </p>
          </div>

          <form id="request-code-form" class="space-y-4 mb-6">
            <div>
              <label for="email" class="block text-sm font-medium text-slate-200 mb-2">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                inputmode="email"
                required
                placeholder="you@company.com"
                class="w-full rounded-lg border border-slate-700 bg-midnight px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-score-native focus:outline-none focus:ring-2 focus:ring-score-native/20"
              />
            </div>

            <button
              id="request-code-btn"
              type="submit"
              class="inline-flex w-full items-center justify-center rounded-lg bg-score-native px-4 py-3 text-sm font-medium text-midnight transition-colors hover:bg-score-native/90 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Send sign-in code
            </button>
          </form>

          <div
            id="request-feedback"
            class="hidden rounded-lg border px-4 py-3 text-sm"
            role="status"
            aria-live="polite"
          ></div>

          <div
            id="verify-panel"
            class="hidden mt-6 rounded-xl border border-slate-800 bg-midnight/70 p-5"
          >
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <h3 class="text-base font-semibold text-white">Enter your code</h3>
                <p class="text-sm text-slate-400">
                  Use the latest 6-digit code sent to <span id="verify-email-label" class="text-slate-200"></span>.
                </p>
              </div>
              <button
                id="edit-email-btn"
                type="button"
                class="text-xs text-slate-500 transition-colors hover:text-slate-300"
              >
                Change email
              </button>
            </div>

            <form id="verify-code-form" class="space-y-4">
              <div>
                <label for="code" class="block text-sm font-medium text-slate-200 mb-2">Verification code</label>
                <input
                  id="code"
                  name="code"
                  type="text"
                  inputmode="numeric"
                  autocomplete="one-time-code"
                  pattern="[0-9]{6}"
                  maxlength="6"
                  required
                  placeholder="123456"
                  class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-sm tracking-[0.35em] text-white placeholder:tracking-normal placeholder:text-slate-500 focus:border-score-native focus:outline-none focus:ring-2 focus:ring-score-native/20"
                />
              </div>

              <div>
                <label for="device-label" class="block text-sm font-medium text-slate-200 mb-2">
                  Device label <span class="text-slate-500 font-normal">(optional)</span>
                </label>
                <input
                  id="device-label"
                  name="device_label"
                  type="text"
                  autocomplete="nickname"
                  maxlength="80"
                  placeholder="Studio MacBook"
                  class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-score-native focus:outline-none focus:ring-2 focus:ring-score-native/20"
                />
                <p class="mt-2 text-xs text-slate-500">
                  New email-OTP users can use this as the initial label on their default agent.
                </p>
              </div>

              <button
                id="verify-code-btn"
                type="submit"
                class="inline-flex w-full items-center justify-center rounded-lg bg-white px-4 py-3 text-sm font-medium text-midnight transition-colors hover:bg-slate-200 disabled:cursor-not-allowed disabled:opacity-60"
              >
                Sign in with email
              </button>
            </form>

            <p class="mt-4 text-xs text-slate-500">
              For security, requesting a code never confirms whether an address already has an account.
            </p>

            <div
              id="verify-feedback"
              class="hidden mt-4 rounded-lg border px-4 py-3 text-sm"
              role="alert"
              aria-live="polite"
            ></div>
          </div>
        </section>

        <section class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 sm:p-7">
          <div class="mb-6">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-2">
              OAuth
            </p>
            <h2 class="text-xl font-semibold text-white mb-2">Continue with your identity provider</h2>
            <p class="text-sm text-slate-400">
              Existing GitHub and Google sign-in remain unchanged.
            </p>
          </div>

          <div class="space-y-3 mb-8">
            <a
              href={`${API_URL}/v1/auth/login/github`}
              class="flex items-center justify-center gap-3 w-full px-4 py-3 rounded-lg bg-slate-800 text-white font-medium text-sm hover:bg-slate-700 transition-colors border border-slate-600"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Continue with GitHub
            </a>

            <a
              href={`${API_URL}/v1/auth/login/google`}
              class="flex items-center justify-center gap-3 w-full px-4 py-3 rounded-lg bg-slate-800 text-white font-medium text-sm hover:bg-slate-700 transition-colors border border-slate-600"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"></path>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
              </svg>
              Continue with Google
            </a>
          </div>

          <div class="rounded-xl border border-slate-800 bg-midnight/70 p-5 mb-6">
            <p class="text-sm font-semibold text-white mb-2">When to use email instead</p>
            <p class="text-sm text-slate-400">
              Choose the email code path if you want direct dashboard access without routing through GitHub or Google.
            </p>
          </div>

          <div class="border-t border-slate-800 pt-6">
            <p class="text-sm text-slate-400 mb-2">Don't need an account?</p>
            <p class="text-sm text-slate-500">
              Use the <a href="/quickstart" class="text-score-native hover:underline">API directly</a> with
              x402 payment. Signup is optional when you only need pay-per-call execution.
            </p>
          </div>

          <div class="mt-8 text-center text-xs text-slate-500">
            <a href="/terms" class="hover:text-slate-400">Terms</a>
            <span class="mx-2">·</span>
            <a href="/privacy" class="hover:text-slate-400">Privacy</a>
          </div>
        </section>
      </div>
    </div>
  </main>

  <script define:vars={{ API_URL }}>
    const requestForm = document.getElementById("request-code-form");
    const verifyForm = document.getElementById("verify-code-form");
    const emailInput = document.getElementById("email");
    const codeInput = document.getElementById("code");
    const deviceLabelInput = document.getElementById("device-label");
    const requestButton = document.getElementById("request-code-btn");
    const verifyButton = document.getElementById("verify-code-btn");
    const verifyPanel = document.getElementById("verify-panel");
    const requestFeedback = document.getElementById("request-feedback");
    const verifyFeedback = document.getElementById("verify-feedback");
    const verifyEmailLabel = document.getElementById("verify-email-label");
    const editEmailButton = document.getElementById("edit-email-btn");

    function setFeedback(element, message, tone) {
      element.textContent = message;
      element.classList.remove(
        "hidden",
        "border-slate-700",
        "bg-slate-900/70",
        "text-slate-300",
        "border-red-500/20",
        "bg-red-500/10",
        "text-red-300",
        "border-score-native/20",
        "bg-score-native/10",
        "text-score-native",
      );

      if (tone === "error") {
        element.classList.add("border-red-500/20", "bg-red-500/10", "text-red-300");
        return;
      }

      if (tone === "success") {
        element.classList.add("border-score-native/20", "bg-score-native/10", "text-score-native");
        return;
      }

      element.classList.add("border-slate-700", "bg-slate-900/70", "text-slate-300");
    }

    function clearFeedback(element) {
      element.textContent = "";
      element.classList.add("hidden");
    }

    function showVerifyPanel(email) {
      verifyPanel.classList.remove("hidden");
      verifyEmailLabel.textContent = email;
      codeInput.value = "";
      clearFeedback(verifyFeedback);
      window.requestAnimationFrame(() => codeInput.focus());
    }

    async function requestCode(email) {
      const response = await fetch(`${API_URL}/v1/auth/email/request-code`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ email }),
      });

      const payload = await response.json().catch(() => null);

      if (!response.ok) {
        if (response.status === 400) {
          throw new Error(payload?.detail || "Enter a valid email address.");
        }
        throw new Error("We couldn't send a code right now. Please try again in a moment.");
      }

      return payload;
    }

    async function verifyCode({ email, code, deviceLabel }) {
      const response = await fetch(`${API_URL}/v1/auth/email/verify-code`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          email,
          code,
          device_label: deviceLabel,
        }),
      });

      const payload = await response.json().catch(() => null);

      if (!response.ok) {
        if (response.status === 400) {
          throw new Error(payload?.detail || "Invalid or expired verification code.");
        }
        throw new Error("We couldn't complete sign-in. Request a fresh code and try again.");
      }

      return payload?.data || {};
    }

    requestForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      clearFeedback(requestFeedback);
      clearFeedback(verifyFeedback);

      const email = emailInput.value.trim().toLowerCase();
      if (!email) {
        setFeedback(requestFeedback, "Enter an email address to continue.", "error");
        emailInput.focus();
        return;
      }

      requestButton.disabled = true;
      requestButton.textContent = "Sending...";

      try {
        const payload = await requestCode(email);
        emailInput.value = email;
        showVerifyPanel(email);
        setFeedback(
          requestFeedback,
          payload?.data?.message ||
            "If the address can receive a sign-in code, it should arrive shortly.",
          "success",
        );
      } catch (error) {
        setFeedback(requestFeedback, error.message, "error");
      } finally {
        requestButton.disabled = false;
        requestButton.textContent = "Send sign-in code";
      }
    });

    verifyForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      clearFeedback(verifyFeedback);

      const email = emailInput.value.trim().toLowerCase();
      const code = codeInput.value.replace(/\s+/g, "");
      const deviceLabel = deviceLabelInput.value.trim();

      if (!email) {
        setFeedback(verifyFeedback, "Request a code before trying to sign in.", "error");
        emailInput.focus();
        return;
      }

      if (!/^\d{6}$/.test(code)) {
        setFeedback(verifyFeedback, "Enter the 6-digit code from your email.", "error");
        codeInput.focus();
        return;
      }

      verifyButton.disabled = true;
      verifyButton.textContent = "Signing in...";

      try {
        const data = await verifyCode({ email, code, deviceLabel });
        const apiKeyFragment = data.api_key ? `?new=1#${data.api_key}` : "";
        window.location.assign(`/dashboard${apiKeyFragment}`);
      } catch (error) {
        const message =
          error.message === "Invalid or expired verification code."
            ? "That code is invalid or expired. Request a new code and try again."
            : error.message;
        setFeedback(verifyFeedback, message, "error");
      } finally {
        verifyButton.disabled = false;
        verifyButton.textContent = "Sign in with email";
      }
    });

    editEmailButton?.addEventListener("click", () => {
      verifyPanel.classList.add("hidden");
      clearFeedback(verifyFeedback);
      emailInput.focus();
      emailInput.select();
    });
  </script>
</Layout>
