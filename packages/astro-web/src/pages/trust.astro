---
import Layout from "../layouts/Layout.astro";
import { PUBLIC_TRUTH } from "../lib/public-truth";

const TRUST_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Why Trust Rhumb?",
  url: "https://rhumb.dev/trust",
  description: "Rhumb's trust model: open methodology, self-scoring, dispute process, CC BY 4.0 data license, and transparent limitations.",
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["h1", "h2", ".bg-surface p"],
  },
  isPartOf: {
    "@type": "WebSite",
    name: "Rhumb",
    url: "https://rhumb.dev",
  },
};
---

<Layout
  title="Why Trust Rhumb?"
  description="Rhumb's trust model: open methodology, self-scoring, dispute process, CC BY 4.0 data license, and transparent limitations."
  canonical="/trust"
  ogTitle="Why Trust Rhumb?"
  ogDescription="Open methodology. Self-scoring. Disputable. Here's why you can trust the AN Score."
  ogUrl="https://rhumb.dev/trust"
  jsonLd={TRUST_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <div class="max-w-3xl mx-auto px-6 pt-14 pb-24">
      <!-- Header -->
      <header class="mb-16">
        <span class="text-xs font-mono font-semibold text-amber uppercase tracking-widest">
          Trust
        </span>
        <h1 class="font-display font-bold text-3xl sm:text-4xl text-slate-100 leading-tight tracking-tight mt-4 mb-6">
          Why trust Rhumb?
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed">
          A scoring system is only as good as its integrity. Here&#39;s
          how we earn trust — and what we&#39;re still working on.
        </p>
      </header>

      <!-- Agent-native trust -->
      <section class="mb-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-4 tracking-tight">
          Trust should be inspectable
        </h2>
        <div class="bg-surface border border-slate-800 rounded-xl p-6 space-y-4">
          <p class="text-slate-400 text-sm leading-relaxed">
            Agent-native trust means we do not ask humans or agents to rely on
            vibes. Each trust claim on this page should resolve to a public,
            inspectable artifact.
          </p>
          <ul class="space-y-3 text-sm text-slate-400 leading-relaxed">
            <li>
              <strong class="text-slate-200">Method:</strong>{" "}
              <a href={PUBLIC_TRUTH.methodologyUrl} class="text-amber hover:underline underline-offset-2">
                published methodology
              </a>
            </li>
            <li>
              <strong class="text-slate-200">Self-audit:</strong>{" "}
              <a href={PUBLIC_TRUTH.currentSelfAssessmentUrl} class="text-amber hover:underline underline-offset-2">
                current self-assessment
              </a>
              {" "}and{" "}
              <a href={PUBLIC_TRUTH.historicalSelfAssessmentUrl} class="text-amber hover:underline underline-offset-2">
                historical baseline
              </a>
            </li>
            <li>
              <strong class="text-slate-200">Machine-readable entry point:</strong>{" "}
              <a href={PUBLIC_TRUTH.llmsUrl} class="text-amber hover:underline underline-offset-2">
                llms.txt
              </a>{" "}
              and{" "}
              <a href={PUBLIC_TRUTH.publicAgentCapabilitiesUrl} class="text-amber hover:underline underline-offset-2">
                agent capabilities JSON
              </a>
            </li>
            <li>
              <strong class="text-slate-200">Canonical definitions:</strong>{" "}
              <a href="/glossary" class="text-amber hover:underline underline-offset-2">
                public glossary
              </a>
            </li>
            <li>
              <strong class="text-slate-200">Dispute path:</strong>{" "}
              <a href={PUBLIC_TRUTH.providersUrl} class="text-amber hover:underline underline-offset-2">
                provider guide
              </a>{" "}
              with public GitHub template, private email path, and a {PUBLIC_TRUTH.disputeResponseSlaBusinessDays}-business-day response target
            </li>
          </ul>
        </div>
      </section>

      <!-- Trust signals -->
      <div class="space-y-8">
        <!-- Neutrality -->
        <div class="bg-surface border border-slate-800 rounded-xl p-6">
          <div class="flex items-start gap-4">
            <span class="text-2xl">&#9878;</span>
            <div>
              <h2 class="font-display font-semibold text-lg text-slate-100 mb-2">
                Neutrality is non-negotiable
              </h2>
              <p class="text-slate-400 text-sm leading-relaxed">
                Scores cannot be bought. We do not accept payment for
                higher scores. Our pricing model charges for operations
                (API access, webhooks, enterprise features) — never for
                outcomes (score changes). This is a hard boundary, not a
                preference.
              </p>
            </div>
          </div>
        </div>

        <!-- Self-scoring -->
        <div class="bg-surface border border-slate-800 rounded-xl p-6">
          <div class="flex items-start gap-4">
            <span class="text-2xl">&#128300;</span>
            <div>
              <h2 class="font-display font-semibold text-lg text-slate-100 mb-2">
                We scored ourselves first
              </h2>
              <p class="text-slate-400 text-sm leading-relaxed">
                Before scoring anyone else, we ran the AN Score
                methodology on Rhumb itself. We first published a{" "}
                <strong class="text-slate-200">
                  3.5/10 (L1 Emerging)
                </strong>{" "}
                baseline before launch, then later published a fuller{" "}
                <a
                  href={PUBLIC_TRUTH.currentSelfAssessmentUrl}
                  class="text-amber hover:underline underline-offset-2"
                >
                  6.8/10 (L3 Fluent) self-assessment
                </a>
                . The original{" "}
                <a
                  href={PUBLIC_TRUTH.historicalSelfAssessmentUrl}
                  class="text-amber hover:underline underline-offset-2"
                >
                  March 11 baseline
                </a>{" "}
                is still public too. If we can&#39;t be honest about our own shortcomings,
                why would you trust our assessment of anyone else?
              </p>
            </div>
          </div>
        </div>

        <!-- Open methodology -->
        <div class="bg-surface border border-slate-800 rounded-xl p-6">
          <div class="flex items-start gap-4">
            <span class="text-2xl">&#128214;</span>
            <div>
              <h2 class="font-display font-semibold text-lg text-slate-100 mb-2">
                Open methodology
              </h2>
              <p class="text-slate-400 text-sm leading-relaxed">
                Our{" "}
                <a
                  href={PUBLIC_TRUTH.methodologyUrl}
                  class="text-amber hover:underline underline-offset-2"
                >
                  scoring methodology
                </a>{" "}
                is fully documented — 20 dimensions, 2 axes, tier
                definitions, data sources, limitations. You can read
                exactly how every score is calculated. The code is{" "}
                <a
                  href="https://github.com/supertrained/rhumb"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-amber hover:underline underline-offset-2"
                >
                  open source (MIT)
                </a>
                .
              </p>
            </div>
          </div>
        </div>

        <!-- Dispute -->
        <div class="bg-surface border border-slate-800 rounded-xl p-6">
          <div class="flex items-start gap-4">
            <span class="text-2xl">&#9889;</span>
            <div>
              <h2 class="font-display font-semibold text-lg text-slate-100 mb-2">
                Dispute any score
              </h2>
              <p class="text-slate-400 text-sm leading-relaxed">
                Disagree with a score? File a dispute via{" "}
                <a
                  href={PUBLIC_TRUTH.publicDisputeTemplateUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-amber hover:underline underline-offset-2"
                >
                  GitHub issue template
                </a>{" "}
                or{" "}
                <a
                  href={PUBLIC_TRUTH.privateDisputeMailto}
                  class="text-amber hover:underline underline-offset-2"
                >
                  email
                </a>
                . Every dispute is reviewed, we aim to respond within {PUBLIC_TRUTH.disputeResponseSlaBusinessDays} business days, and public outcomes live on{" "}
                <a
                  href={PUBLIC_TRUTH.publicDisputesUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-amber hover:underline underline-offset-2"
                >
                  GitHub
                </a>
                . We don&#39;t hide from criticism — we use it to improve.
              </p>
            </div>
          </div>
        </div>

        <!-- Data license -->
        <div class="bg-surface border border-slate-800 rounded-xl p-6">
          <div class="flex items-start gap-4">
            <span class="text-2xl">&#128196;</span>
            <div>
              <h2 class="font-display font-semibold text-lg text-slate-100 mb-2">
                CC BY 4.0 data license
              </h2>
              <p class="text-slate-400 text-sm leading-relaxed">
                All scores and failure modes are licensed{" "}
                <strong class="text-slate-200">
                  Creative Commons Attribution 4.0 International
                </strong>
                . Use them in your research, embed them in your products,
                cite them in your papers. We just ask for attribution.
              </p>
            </div>
          </div>
        </div>

        <!-- Limitations -->
        <div class="bg-elevated border border-amber/20 rounded-xl p-6">
          <div class="flex items-start gap-4">
            <span class="text-2xl">&#9888;</span>
            <div>
              <h2 class="font-display font-semibold text-lg text-slate-100 mb-2">
                Honest about limitations
              </h2>
              <div class="space-y-3 text-slate-400 text-sm leading-relaxed">
                <p>
                  Most scores start as{" "}
                  <strong class="text-slate-200">
                    documentation-derived
                  </strong>
                  , built from published API docs and provider claims.
                  These capture what should work, but cannot catch
                  undocumented behaviors, silent schema changes, or
                  production edge cases.
                </p>
                <p>
                  We are actively closing this gap.{" "}
                  <strong class="text-slate-200">
                    A growing share of our reviews are runtime-backed
                  </strong>
                  {" "}— supported by real evidence from agent execution,
                  tester-generated probes, and live API calls. Every
                  review labels its evidence source. You can inspect
                  the evidence behind any score via our{" "}
                  <a
                    href="/docs"
                    class="text-amber hover:underline underline-offset-2"
                  >
                    API
                  </a>
                  .
                </p>
                <p>
                  We will always be transparent about what we know and
                  how we know it. Our goal is 100% runtime-backed
                  coverage — but we won&#39;t hide the gap while we
                  close it.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
