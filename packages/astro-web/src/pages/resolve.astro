---
import Layout from "../layouts/Layout.astro";
import { PUBLIC_TRUTH } from "../lib/public-truth";

const heroCards = [
  {
    title: "Best-fit routing",
    body:
      "Index publishes the AN Score. Resolve uses that score as a major input, then routes the call based on capability fit, freshness, provider health, credential mode, and your constraints.",
  },
  {
    title: "Intent-first or explicit control",
    body:
      "Say what job you want done and let Resolve route it, or explicitly pin the supported provider/tool path when direct control is the point.",
  },
  {
    title: "Honest execution boundary",
    body:
      `Resolve is launchable today for ${PUBLIC_TRUTH.beachheadLabel} across ${PUBLIC_TRUTH.callableProvidersLabel} callable providers. It does not pretend every scored service is executable.`,
  },
];

const routeFactors = [
  {
    title: "AN Score",
    body: "Rhumb’s public quality prior. Important, but not the only routing input.",
  },
  {
    title: "Capability fit",
    body: "Which supported provider is actually strongest for the requested job.",
  },
  {
    title: "Freshness",
    body: "When the task depends on current information, recency matters more than generic rank purity.",
  },
  {
    title: "Provider health",
    body: "Live route condition, recent failures, and whether the provider is healthy enough to trust right now.",
  },
  {
    title: "Credential mode",
    body: "Rhumb-managed, BYOK, and Agent Vault create different honest execution paths.",
  },
  {
    title: "Constraints",
    body: "Budget, policy, and operator preferences should shape the route when they materially matter.",
  },
];

const routingSteps = [
  {
    step: "01",
    title: "Index ranks the field",
    body: "Rhumb Index scores services for AI-agent compatibility and gives Resolve a public quality prior.",
  },
  {
    step: "02",
    title: "Resolve chooses the route — unless you do",
    body: "Resolve picks the best-fit supported provider for the call by default instead of blindly following the global leaderboard, while still allowing explicit provider pinning when the agent wants direct control.",
  },
  {
    step: "03",
    title: "You see the operating truth",
    body: "Estimate the route, cost, and readiness before execution so the agent can explain the path it took.",
  },
];

const routeExamples = [
  {
    title: "Fresh social / live context",
    body:
      "When the task depends on current X-native information or real user-input-sensitive context, Resolve can prefer the provider that is strongest for that job instead of blindly following the generic overall ranking.",
  },
  {
    title: "Web extraction",
    body:
      "When structure and extraction quality matter more than generic ranking, Resolve can route to the provider that best fits extraction work.",
  },
  {
    title: "Generation / transform",
    body:
      "When the task is generation or transformation, Resolve routes based on the real capability path, not just the broad service score.",
  },
];

const credentialPaths = [
  {
    name: "Rhumb-managed",
    label: "Default path",
    description:
      "Best for zero-config utility capabilities where Rhumb can honestly own the provider account, route the call, and expose the capability as the product.",
  },
  {
    name: "BYOK",
    label: "Your systems",
    description:
      "Use when the workflow touches your account data, workspace, or production systems and you want direct control over the upstream credential.",
  },
  {
    name: "Agent Vault",
    label: "Agent-native custody",
    description:
      "Use when the credential should stay encrypted in Rhumb custody, scoped to the agent, and be injected only at execution time.",
  },
];

const faqItems = [
  {
    question: "Does Resolve just follow the top score?",
    answer:
      "No. AN Score is a major routing input, not the only one. Resolve chooses the best-fit supported provider for the call using AN Score, capability fit, freshness, provider health, credential mode, and your constraints.",
  },
  {
    question: "Can I pick the provider or tool path myself?",
    answer:
      "Yes. Rhumb supports both intent-first routing and explicit provider choice. Ask for the job and let Resolve route it, or pin the provider yourself on the raw-provider surface when direct control is the point.",
  },
  {
    question: "What is executable today?",
    answer: `${PUBLIC_TRUTH.beachheadSummary} Resolve is strongest today in ${PUBLIC_TRUTH.beachheadLabel} across ${PUBLIC_TRUTH.callableProvidersLabel} callable providers.`,
  },
  {
    question: "When should I bring my own systems?",
    answer:
      "Start with Rhumb-managed capabilities where Rhumb can honestly own the execution path. Bring BYOK or Agent Vault only when the workflow touches your own systems, permissions, or compliance boundary.",
  },
];

const resolveJsonLdBlocks = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Resolve | Rhumb",
    url: "https://rhumb.dev/resolve",
    description:
      "Rhumb Resolve is a governed execution layer for AI agents that routes each supported call to the best-fit provider for the call using AN Score, capability fit, provider health, credential mode, and call-specific constraints.",
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Rhumb Resolve",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Web",
    url: "https://rhumb.dev/resolve",
    description: PUBLIC_TRUTH.resolveEntityShort,
    featureList: [
      "Governed execution for AI agents",
      "Explainable task-aligned provider routing",
      "Managed credentials, BYOK, and Agent Vault",
      "Pay-per-call pricing",
      "Current callable beachhead in research, extraction, generation, and narrow enrichment",
    ],
    offers: {
      "@type": "Offer",
      availability: "https://schema.org/InStock",
      price: "0",
      priceCurrency: "USD",
      description: "Discovery is free. Execution is pay-per-call.",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];

const agentContext =
  "Rhumb Resolve is Rhumb’s governed execution layer for AI agents. Agents can tell Resolve the job they want done or explicitly pin the supported provider path they want. By default, Resolve routes supported capability calls to the best-fit provider for the call using AN Score as a major input alongside capability fit, freshness, provider health, credential mode, and operator constraints. Current launchable scope is 16 callable providers, strongest in research, extraction, generation, and narrow enrichment.";
---

<Layout
  title="Resolve | Governed execution for AI agents"
  description="Rhumb Resolve lets agents ask for the job or pin the provider path directly, with best-fit-by-default routing using AN Score, capability fit, provider health, credential mode, and your constraints."
  canonical="/resolve"
  ogTitle="Resolve | Governed execution for AI agents"
  ogDescription="Rhumb Resolve lets agents ask for the job or pin the provider path directly, with best-fit-by-default routing using AN Score, capability fit, provider health, credential mode, and your constraints."
  ogUrl="https://rhumb.dev/resolve"
  jsonLdBlocks={resolveJsonLdBlocks}
  agentContext={agentContext}
>
  <div class="bg-navy min-h-screen">
    <section class="relative overflow-hidden border-b border-slate-800">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="absolute inset-x-0 top-0 h-[420px] pointer-events-none" style="background: radial-gradient(circle at 20% 20%, rgba(245,158,11,0.12), transparent 38%), radial-gradient(circle at 80% 10%, rgba(16,185,129,0.08), transparent 34%), radial-gradient(circle at 50% 100%, rgba(148,163,184,0.08), transparent 42%);"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-20 pb-16">
        <div class="max-w-4xl">
          <p class="text-xs font-mono text-amber uppercase tracking-[0.3em] mb-4">Rhumb Resolve</p>
          <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl text-slate-100 leading-[1.02] tracking-tight max-w-4xl">
            Your agent needs APIs. Stop managing the keys.
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
            {PUBLIC_TRUTH.resolveEntityShort}
          </p>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
            {PUBLIC_TRUTH.routingHumanSummary} <span class="text-slate-200">{PUBLIC_TRUTH.resolveTagline}</span>
          </p>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
            Tell Resolve what you want accomplished, or use the supported provider/tool path you want in the way you want when direct control is better.
          </p>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
            Today Resolve is strongest in <span class="text-slate-200">{PUBLIC_TRUTH.beachheadLabel}</span> across <span class="text-slate-200">{PUBLIC_TRUTH.callableProvidersLabel} callable providers</span>. Discovery is broader than current execution coverage, and Rhumb keeps that boundary explicit.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a data-rhumb-propagate href="/quickstart" class="px-5 py-3 rounded-xl bg-amber text-navy font-display font-semibold text-sm hover:bg-amber-dark transition-colors duration-200">
              Start with Resolve &rarr;
            </a>
            <a data-rhumb-propagate href="/start-managed-execution?rhumb_experiment=e004&rhumb_source=resolve-hero" class="px-5 py-3 rounded-xl border border-emerald-500/30 text-sm text-emerald-200 hover:border-emerald-400/60 hover:text-emerald-100 transition-colors duration-200">
              Start managed execution
            </a>
            <a data-rhumb-propagate href="/docs#resolve-mental-model" class="px-5 py-3 rounded-xl border border-slate-700 text-sm text-slate-300 hover:border-amber/40 hover:text-slate-100 transition-colors duration-200">
              Open mental model
            </a>
            <a data-rhumb-propagate href="/capabilities" class="px-5 py-3 rounded-xl border border-slate-700 text-sm text-slate-300 hover:border-amber/40 hover:text-slate-100 transition-colors duration-200">
              Browse capabilities
            </a>
          </div>
        </div>

        <div class="mt-12 grid gap-4 lg:grid-cols-3">
          {heroCards.map((item) => (
            <div class="rounded-2xl border border-slate-800 bg-surface/85 p-6 backdrop-blur-sm">
              <p class="text-xs font-mono uppercase tracking-[0.25em] text-slate-500 mb-3">{item.title}</p>
              <p class="text-sm leading-6 text-slate-300">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pt-12">
      <div class="rounded-3xl border border-slate-800 bg-surface p-6 sm:p-8">
        <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Before you wire this deeper</p>
        <p class="text-sm text-slate-300 leading-6 max-w-3xl">
          Want to inspect the trust story first? Read <a data-rhumb-propagate href="/trust" class="text-amber hover:underline underline-offset-2">Trust</a>,
          inspect the public <a data-rhumb-propagate href="/methodology" class="text-amber hover:underline underline-offset-2">Methodology</a>,
          or use the provider <a data-rhumb-propagate href="/providers#dispute-a-score" class="text-amber hover:underline underline-offset-2">dispute path</a>
          if a score, routing claim, or coverage claim looks wrong.
        </p>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid gap-6 xl:grid-cols-[1.12fr_0.88fr]">
        <div class="rounded-3xl border border-amber/20 bg-surface p-7 sm:p-8">
          <p class="text-xs font-mono text-amber uppercase tracking-[0.25em] mb-3">What Resolve is</p>
          <h2 class="font-display font-bold text-3xl text-slate-100 tracking-tight">Governed execution for agents that need real work done.</h2>
          <div class="mt-6 space-y-4 text-slate-300 leading-7">
            <p>
              {PUBLIC_TRUTH.resolveEntityExpanded}
            </p>
            <p>
              Start with Rhumb-managed capabilities where Rhumb can honestly own the execution path. Bring BYOK or Agent Vault only when the workflow touches your own systems, permissions, or compliance boundary.
            </p>
            <p>
              The product truth is simple: <span class="text-slate-200">Index ranks. Resolve routes.</span>
            </p>
            <p>
              And agent control stays first-class: say what you want done, or pin the supported provider path yourself when that is the better way to work.
            </p>
          </div>
        </div>

        <div class="rounded-3xl border border-emerald-500/20 bg-surface p-7 sm:p-8">
          <p class="text-xs font-mono text-emerald-300 uppercase tracking-[0.25em] mb-3">How it works</p>
          <div class="space-y-5">
            {routingSteps.map((item) => (
              <div>
                <p class="text-sm font-semibold text-slate-100">{item.step}. {item.title}</p>
                <p class="mt-1 text-sm leading-6 text-slate-400">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-slate-800 bg-surface/45">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="max-w-3xl mb-8">
          <p class="text-xs font-mono text-amber uppercase tracking-[0.25em] mb-3">What decides the route?</p>
          <h2 class="font-display font-bold text-3xl text-slate-100 tracking-tight">Task-aligned routing, not blind leaderboard routing.</h2>
          <p class="mt-4 text-sm leading-7 text-slate-300">
            Resolve does not blindly pick the global top score. It picks the best-fit supported provider for the call by default, while still allowing explicit provider choice when the agent wants direct control.
          </p>
          <p class="mt-3 text-sm leading-7 text-slate-400">
            <span class="text-slate-200">{PUBLIC_TRUTH.routingPrinciple}</span> AN Score stays central, but it works as a quality prior inside an explainable routing system.
          </p>
          <a href="/resolve/routing" class="mt-5 inline-flex rounded-xl border border-amber/25 bg-amber/10 px-4 py-2.5 text-sm font-medium text-amber transition-colors hover:border-amber/50 hover:bg-amber/15">
            Read how Resolve routes calls &rarr;
          </a>
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {routeFactors.map((item) => (
            <div class="rounded-2xl border border-slate-800 bg-navy/70 p-5">
              <h3 class="font-display font-semibold text-lg text-slate-100">{item.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-400">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid gap-6 xl:grid-cols-[0.92fr_1.08fr]">
        <div class="rounded-3xl border border-amber/20 bg-surface p-7 sm:p-8">
          <p class="text-xs font-mono text-amber uppercase tracking-[0.25em] mb-3">Current launchable surface</p>
          <h2 class="font-display font-bold text-3xl text-slate-100 tracking-tight">Broad enough to matter. Narrow enough to stay honest.</h2>
          <p class="mt-4 text-sm leading-6 text-slate-300">
            {PUBLIC_TRUTH.beachheadSummary}
          </p>
          <p class="mt-3 text-sm leading-6 text-slate-400">
            {PUBLIC_TRUTH.callableRealitySummary}
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1.5 text-xs font-mono text-emerald-200">{PUBLIC_TRUTH.callableProvidersLabel} callable providers</span>
            <span class="rounded-full border border-slate-700 bg-navy px-3 py-1.5 text-xs font-mono text-slate-300">Research</span>
            <span class="rounded-full border border-slate-700 bg-navy px-3 py-1.5 text-xs font-mono text-slate-300">Extraction</span>
            <span class="rounded-full border border-slate-700 bg-navy px-3 py-1.5 text-xs font-mono text-slate-300">Generation</span>
            <span class="rounded-full border border-slate-700 bg-navy px-3 py-1.5 text-xs font-mono text-slate-300">Narrow enrichment</span>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-800 bg-surface p-7 sm:p-8">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-[0.25em] mb-3">Examples</p>
          <h2 class="font-display font-bold text-3xl text-slate-100 tracking-tight">When task fit beats raw rank</h2>
          <div class="mt-6 grid gap-4">
            {routeExamples.map((item) => (
              <div class="rounded-2xl border border-slate-800 bg-navy/70 p-5">
                <h3 class="font-display font-semibold text-lg text-slate-100">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-400">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="credential-paths" class="max-w-6xl mx-auto px-6 pb-16">
      <div class="rounded-3xl border border-slate-800 bg-surface p-7 sm:p-8">
        <div class="max-w-3xl">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-[0.25em] mb-3">Credential paths</p>
          <h2 class="font-display font-bold text-3xl text-slate-100 tracking-tight">Three credential paths, one trust story</h2>
          <p class="mt-3 text-sm leading-6 text-slate-400">
            Resolve should not force every capability through the same trust model. Rhumb-managed, BYOK, and Agent Vault each exist for a reason.
          </p>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {credentialPaths.map((path) => (
            <div class="rounded-2xl border border-slate-800 bg-navy/70 p-5">
              <p class="text-xs font-mono uppercase tracking-[0.22em] text-slate-500 mb-2">{path.label}</p>
              <h3 class="font-display font-semibold text-xl text-slate-100">{path.name}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-400">{path.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-16">
      <div class="rounded-3xl border border-slate-800 bg-surface p-7 sm:p-8">
        <div class="max-w-3xl">
          <p class="text-xs font-mono text-slate-500 uppercase tracking-[0.25em] mb-3">FAQ</p>
          <h2 class="font-display font-bold text-3xl text-slate-100 tracking-tight">Resolve, plainly</h2>
        </div>
        <div class="mt-8 grid gap-4 lg:grid-cols-3">
          {faqItems.map((item) => (
            <div class="rounded-2xl border border-slate-800 bg-navy/70 p-5">
              <h3 class="font-display font-semibold text-lg text-slate-100">{item.question}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-400">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
  <script is:inline>
    (() => {
      if (typeof window === "undefined") return;
      const params = new URLSearchParams(window.location.search);
      const experiment = params.get("rhumb_experiment");
      const source = params.get("rhumb_source");
      const parentSource = params.get("rhumb_parent_source");
      if (!experiment && !source && !parentSource) return;

      document.querySelectorAll("a[data-rhumb-propagate]").forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;

        const url = new URL(href, window.location.origin);
        if (experiment && !url.searchParams.has("rhumb_experiment")) {
          url.searchParams.set("rhumb_experiment", experiment);
        }
        if (source) {
          url.searchParams.set("rhumb_parent_source", source);
        }
        if (parentSource) {
          url.searchParams.set("rhumb_grandparent_source", parentSource);
        }

        link.setAttribute("href", `${url.pathname}${url.search}${url.hash}`);
      });
    })();
  </script>
</Layout>
