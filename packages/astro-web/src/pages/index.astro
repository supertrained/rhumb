---
import Layout from "../layouts/Layout.astro";
import ScoreDisplay from "../components/ScoreDisplay.astro";
import TierBadge from "../components/TierBadge.astro";
import CopyInstall from "../components/CopyInstall.tsx";
import { getLeaderboard, getServiceCount } from "../lib/api";
import type { EvidenceTier } from "../lib/types";

const EVIDENCE_BADGE_STYLES: Record<EvidenceTier, { className: string; label: string }> = {
  pending: { className: "border-slate-700 text-slate-500 bg-slate-800/40", label: "Pending" },
  assessed: { className: "border-slate-600/40 text-slate-400 bg-slate-700/20", label: "Assessed" },
  tested: { className: "border-amber/30 text-amber bg-amber/10", label: "Tested" },
  verified: { className: "border-score-native/30 text-score-native bg-score-native/10", label: "Verified" },
};

function scoreLabel(value: number | null): string {
  return value === null ? "Pending" : value.toFixed(1);
}

function freshnessLabel(item: any): string {
  if (item.freshness) return item.freshness;
  if (item.calculatedAt) return `Updated ${item.calculatedAt}`;
  return "Freshness pending";
}

const [leaderboard, serviceCount] = await Promise.all([
  getLeaderboard("payments", { limit: 3 }),
  getServiceCount(),
]);

const HOME_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Rhumb",
  url: "https://rhumb.dev",
  description:
    `Most APIs weren't built for agents. Rhumb scores ${serviceCount} services for AI agent compatibility across 20 dimensions — auth, error handling, rate limits, schema stability. Neutral scores, real failure mode data, zero-signup access via MCP or REST API.`,
  logo: "https://rhumb.dev/favicon.ico",
};

const previewItems = leaderboard.items.slice(0, 3);
const stats = [
  { value: String(serviceCount), label: "services scored" },
  { value: "11", label: "categories" },
  { value: "20", label: "scored dimensions" },
  { value: "live", label: "evidence data" },
];
---

<Layout
  title="Rhumb — Most APIs weren't built for agents. Now you know which ones were."
  description={`Rhumb scores ${serviceCount} services for AI agent compatibility across 20 dimensions — auth, error handling, rate limits, schema stability, and more. Neutral scores, real failure mode data, zero-signup access via MCP or REST API.`}
  canonical="https://rhumb.dev/"
  ogTitle="Rhumb — Most APIs weren't built for agents"
  ogDescription={`${serviceCount} services scored for AI agent compatibility. Neutral scores, real failure modes, zero-signup access. Browse, query via REST API, or connect via MCP.`}
  ogUrl="https://rhumb.dev/"
  jsonLd={HOME_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-grid opacity-50 pointer-events-none"></div>
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full pointer-events-none"
        style="background: radial-gradient(ellipse at top, rgba(245,158,11,0.08) 0%, transparent 70%)"
      ></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-20 pb-16">
        <div class="animate-fade-up flex items-center gap-2 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-amber"></span>
          <span class="text-xs font-mono text-slate-400 uppercase tracking-widest">{serviceCount} scored services for agent compatibility</span>
        </div>

        <h1 class="animate-fade-up animate-delay-100 font-display font-bold text-5xl sm:text-6xl lg:text-7xl text-slate-100 leading-[1.05] tracking-tight max-w-3xl">
          Most APIs weren't built for agents. Now you know which ones were.
        </h1>

        <p class="animate-fade-up animate-delay-200 mt-6 text-lg text-slate-400 max-w-xl leading-relaxed">
          Rhumb measures execution reliability and access readiness for every
          service your agent might call. Neutral scores. Real failure mode data.
          Zero-signup access via MCP or REST API.
        </p>

        <form
          action="/search"
          method="get"
          class="animate-fade-up animate-delay-300 mt-8 flex flex-col sm:flex-row gap-3 max-w-xl"
        >
          <div class="relative flex-1">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-slate-500">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path
                  d="M11 6.5C11 9.0 9.0 11 6.5 11C4.0 11 2 9.0 2 6.5C2 4.0 4.0 2 6.5 2C9.0 2 11 4.0 11 6.5ZM10.2 10.9L14 14.7"
                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                />
              </svg>
            </div>
            <input
              aria-label="Search services"
              name="q"
              type="search"
              placeholder="Search services (e.g. payments API)"
              class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-surface border border-slate-700 text-slate-100 placeholder-slate-500 text-sm outline-none focus:border-amber focus:ring-2 focus:ring-amber/20 transition-all duration-200"
            />
          </div>
          <button
            type="submit"
            class="px-6 py-3.5 rounded-xl bg-amber text-navy font-display font-semibold text-sm hover:bg-amber-dark transition-colors duration-200 shrink-0"
          >
            Search
          </button>
        </form>

        <div class="animate-fade-up animate-delay-400 mt-5 flex flex-wrap gap-3">
          <a
            href="/leaderboard"
            class="px-5 py-2.5 rounded-lg border border-slate-700 text-sm text-slate-300 hover:border-slate-500 hover:text-slate-100 transition-colors duration-200 font-medium"
          >
            Search {serviceCount} services &rarr;
          </a>
          <CopyInstall client:load command="npx rhumb-mcp" />
        </div>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="border-y border-slate-800 bg-surface/50">
      <div class="max-w-6xl mx-auto px-6 py-5">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {stats.map(({ value, label }, i) => (
            <div
              class="animate-fade-up text-center"
              style={`animation-delay: ${(i + 5) * 100}ms`}
            >
              <div class="font-mono font-bold text-2xl text-amber">{value}</div>
              <div class="text-xs text-slate-500 mt-0.5 font-mono uppercase tracking-wide">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured leaderboard (Payments) -->
    <section class="max-w-6xl mx-auto px-6 py-16 reveal">
      <div class="flex items-center justify-between mb-8">
        <div>
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Featured &middot; Payments</p>
          <h2 class="font-display font-bold text-2xl text-slate-100">Top services in payments</h2>
        </div>
        <a
          href="/leaderboard/payments"
          class="hidden sm:inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-amber transition-colors font-mono"
        >
          Open full payments leaderboard
        </a>
      </div>

      {leaderboard.error ? (
        <div class="bg-surface border border-slate-800 rounded-xl p-8 text-center">
          <p class="text-slate-400 text-sm">
            Live leaderboard preview is temporarily unavailable. You can still browse the
            {" "}
            <a href="/leaderboard/payments" class="text-amber hover:underline">full leaderboard</a>.
          </p>
        </div>
      ) : previewItems.length === 0 ? (
        <div class="bg-surface border border-slate-800 rounded-xl p-8 text-center">
          <p class="text-slate-500 text-sm">No ranked services published yet.</p>
        </div>
      ) : (
        <ol class="space-y-3" style="list-style: none; padding: 0">
          {previewItems.map((item, index) => (
            <li>
              <article class="bg-surface border border-slate-800 rounded-xl p-5 flex items-center gap-5 card-lift group">
                <span class="font-mono text-2xl font-bold text-slate-700 w-8 shrink-0 text-right">
                  {index + 1}
                </span>
                <ScoreDisplay score={item.aggregateRecommendationScore} size="medium" showLabel />
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 flex-wrap">
                    <a
                      href={`/service/${item.serviceSlug}`}
                      class="font-display font-semibold text-slate-100 hover:text-amber transition-colors"
                    >
                      {item.name}
                    </a>
                    <TierBadge tier={item.tier} />
                  </div>
                  <div class="mt-1.5 flex items-center gap-4 flex-wrap text-xs font-mono text-slate-500">
                    <span>Aggregate {scoreLabel(item.aggregateRecommendationScore)}</span>
                    <span>&middot; Freshness {freshnessLabel(item)}</span>
                    <span class={`rounded-full border px-2 py-0.5 ${EVIDENCE_BADGE_STYLES[item.evidenceTier].className}`}>
                      {EVIDENCE_BADGE_STYLES[item.evidenceTier].label}
                    </span>
                  </div>
                </div>
              </article>
            </li>
          ))}
        </ol>
      )}

      <p class="mt-6">
        <a
          href="/leaderboard/payments"
          class="text-sm text-slate-400 hover:text-amber transition-colors font-mono sm:hidden"
        >
          Open full payments leaderboard
        </a>
      </p>
    </section>

    <!-- What is Rhumb -->
    <section class="border-t border-slate-800 bg-navy reveal">
      <div class="max-w-4xl mx-auto px-6 py-16">
        <h2 class="font-display font-bold text-2xl text-slate-100 mb-6">What is the AN Score?</h2>
        <div class="grid sm:grid-cols-2 gap-8 text-sm text-slate-400 leading-relaxed">
          <div>
            <p class="mb-4">
              The Agent-Native (AN) Score measures how well a developer API works for
              autonomous AI agents — not humans reading documentation, but machines making
              API calls without supervision.
            </p>
            <p>
              Each service is evaluated across <strong class="text-slate-300">20 dimensions</strong> on two axes:
              <strong class="text-slate-300">Execution</strong> (70% weight — reliability, error handling,
              schema stability, idempotency, latency) and <strong class="text-slate-300">Access Readiness</strong>
              (30% weight — signup friction, credential management, rate limits, documentation, sandbox availability).
            </p>
          </div>
          <div>
            <p class="mb-4">
              Services are ranked into four tiers: <strong class="text-score-native">L4 Native</strong> (8.0–10.0),
              <strong class="text-score-ready">L3 Ready</strong> (6.0–7.9),
              <strong class="text-amber">L2 Developing</strong> (4.0–5.9), and
              <strong class="text-score-limited">L1 Emerging</strong> (0.0–3.9).
            </p>
            <p>
              Every score is <a href="/methodology" class="text-amber hover:underline">published, transparent, and disputable</a>.
              Rhumb surfaces active failure modes, evidence tiers, and freshness timestamps so agents
              can make informed routing decisions at runtime.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Research & Analysis -->
    <section class="border-t border-slate-800 bg-navy reveal">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="mb-10">
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Research</p>
          <h2 class="font-display font-bold text-2xl text-slate-100">Deep dives, not hot takes</h2>
          <p class="text-slate-400 text-sm mt-2 max-w-xl">Comparisons backed by AN Score data. Autopsies that show exactly where APIs break for agents. Guides that get you running in minutes.</p>
        </div>

        <div class="grid sm:grid-cols-3 gap-6">
          <!-- Comparisons column -->
          <div>
            <h3 class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-4">Comparisons</h3>
            <ul class="space-y-3">
              <li><a href="/blog/stripe-vs-square-vs-paypal" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Stripe vs Square vs PayPal</span><span class="block text-xs text-slate-500 mt-1">Payments &middot; 9 min</span></a></li>
              <li><a href="/blog/resend-vs-sendgrid-vs-postmark" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Resend vs SendGrid vs Postmark</span><span class="block text-xs text-slate-500 mt-1">Email &middot; 9 min</span></a></li>
              <li><a href="/blog/anthropic-vs-openai-vs-google-ai" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Anthropic vs OpenAI vs Google AI</span><span class="block text-xs text-slate-500 mt-1">AI / LLM &middot; 9 min</span></a></li>
              <li><a href="/blog/hubspot-vs-salesforce-vs-pipedrive" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">HubSpot vs Salesforce vs Pipedrive</span><span class="block text-xs text-slate-500 mt-1">CRM &middot; 9 min</span></a></li>
            </ul>
            <a href="/compare" class="inline-block mt-3 text-xs font-mono text-slate-500 hover:text-amber transition-colors">All 9 comparisons &rarr;</a>
          </div>

          <!-- Autopsies column -->
          <div>
            <h3 class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-4">Tool Autopsies</h3>
            <ul class="space-y-3">
              <li><a href="/blog/hubspot-api-autopsy" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">HubSpot API Autopsy</span><span class="block text-xs text-slate-500 mt-1">AN Score: 4.6 &middot; 6 failure modes</span></a></li>
              <li><a href="/blog/salesforce-api-autopsy" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Salesforce API Autopsy</span><span class="block text-xs text-slate-500 mt-1">AN Score: 4.8 &middot; 6 failure modes</span></a></li>
              <li><a href="/blog/twilio-api-autopsy" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Twilio API Autopsy</span><span class="block text-xs text-slate-500 mt-1">AN Score: 8.0 &middot; What it gets right</span></a></li>
              <li><a href="/blog/shopify-api-autopsy" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Shopify API Autopsy</span><span class="block text-xs text-slate-500 mt-1">AN Score: 7.8 &middot; GraphQL friction</span></a></li>
            </ul>
            <a href="/autopsy" class="inline-block mt-3 text-xs font-mono text-slate-500 hover:text-amber transition-colors">All 4 autopsies &rarr;</a>
          </div>

          <!-- Guides column -->
          <div>
            <h3 class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-4">Guides & Articles</h3>
            <ul class="space-y-3">
              <li><a href="/blog/getting-started-mcp" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Getting Started with Rhumb MCP</span><span class="block text-xs text-slate-500 mt-1">Guide &middot; 5 min</span></a></li>
              <li><a href="/blog/how-agents-pay" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">How Agents Pay for APIs</span><span class="block text-xs text-slate-500 mt-1">Article &middot; x402 deep dive</span></a></li>
              <li><a href="/blog/payments-for-agents" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Payments for Agents</span><span class="block text-xs text-slate-500 mt-1">Article &middot; The infrastructure gap</span></a></li>
              <li><a href="/blog/securing-keys-for-agents" class="group block bg-surface border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-colors"><span class="text-sm font-medium text-slate-200 group-hover:text-amber transition-colors">Secure Your API Keys for Agents</span><span class="block text-xs text-slate-500 mt-1">Guide &middot; Three credential modes</span></a></li>
            </ul>
            <a href="/blog" class="inline-block mt-3 text-xs font-mono text-slate-500 hover:text-amber transition-colors">All 23 posts &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Three paths -->
    <section class="border-t border-slate-800 bg-surface/30 reveal">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="mb-10">
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-2">Three ways in</p>
          <h2 class="font-display font-bold text-2xl text-slate-100">Browse. Query. Connect.</h2>
          <p class="text-slate-400 text-sm mt-2"><a href="/quickstart" class="text-amber hover:underline">Quickstart guide →</a> Make your first API call in 30 seconds.</p>
        </div>

        <div class="grid sm:grid-cols-3 gap-6">
          <!-- Browse -->
          <div class="bg-navy border border-slate-800 rounded-xl p-6 hover:border-slate-600 transition-colors">
            <div class="text-2xl mb-3">🔍</div>
            <h3 class="font-display font-semibold text-slate-100 text-lg mb-2">Browse</h3>
            <p class="text-sm text-slate-400 leading-relaxed mb-4">Explore scores, comparisons, and failure modes. No account needed.</p>
            <p class="text-xs font-mono text-slate-500">Free &middot; No signup</p>
          </div>

          <!-- REST API -->
          <div class="bg-navy border border-slate-800 rounded-xl p-6 hover:border-slate-600 transition-colors">
            <div class="text-2xl mb-3">⚡</div>
            <h3 class="font-display font-semibold text-slate-100 text-lg mb-2">REST API</h3>
            <p class="text-sm text-slate-400 leading-relaxed mb-4">Query scores and execute capabilities from any language. Standard HTTP.</p>
            <p class="text-xs font-mono text-slate-500">API key or x402 per-call payment</p>
          </div>

          <!-- MCP -->
          <div class="bg-navy border border-slate-800 rounded-xl p-6 hover:border-slate-600 transition-colors">
            <div class="text-2xl mb-3">🔌</div>
            <h3 class="font-display font-semibold text-slate-100 text-lg mb-2">MCP Server</h3>
            <p class="text-sm text-slate-400 leading-relaxed mb-4">Connect directly from Claude, GPT, or any MCP-compatible agent. All tools available instantly.</p>
            <p class="text-xs font-mono text-slate-500"><code>npx rhumb-mcp</code></p>
          </div>
        </div>

        <!-- x402 callout -->
        <div class="mt-8 bg-navy border border-amber/20 rounded-xl p-6 flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-amber uppercase tracking-widest">Zero-signup agent payments</span>
            </div>
            <p class="text-sm text-slate-300">
              Agents with <a href="/blog/how-agents-pay" class="text-amber hover:underline">x402</a> can execute capabilities and pay per call with USDC — no account, no API key, no human in the loop. The payment is the authentication.
            </p>
          </div>
          <a
            href="/blog/how-agents-pay"
            class="shrink-0 px-5 py-2.5 rounded-lg border border-amber/30 text-sm text-amber hover:bg-amber/10 transition-colors font-mono"
          >
            Learn about x402 &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- MCP Server -->
    <section id="install" class="border-t border-slate-800 bg-surface/30 reveal">
      <div class="max-w-6xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-mono text-amber uppercase tracking-widest mb-3">MCP</p>
          <h2 class="font-display font-bold text-2xl text-slate-100 mb-4">
            Query Rhumb from your agents
          </h2>
          <p class="text-slate-400 text-sm leading-relaxed">
            Add Rhumb to any MCP-compatible agent. AN Scores at decision time. Perfect for
            agent routing logic, tool-selection prompts, and automated dependency
            evaluation.
          </p>
          <a
            href="/leaderboard"
            class="mt-6 inline-flex px-5 py-2.5 rounded-lg bg-amber text-navy font-semibold text-sm hover:bg-amber-dark transition-colors duration-200"
          >
            Explore all categories &rarr;
          </a>
        </div>

        <div class="bg-navy border border-slate-800 rounded-xl overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-800">
            <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
            <span class="ml-2 text-xs font-mono text-slate-600">terminal</span>
          </div>
          <div class="p-5 font-mono text-sm space-y-2">
            <div>
              <span class="text-slate-600">$ </span>
              <span class="text-amber">npx rhumb-mcp</span>
              <span class="text-slate-600"> # starts MCP server</span>
            </div>
            <div class="text-slate-400 pl-4 space-y-0.5">
              <div class="text-score-native">&#10003; Rhumb MCP server running</div>
              <div class="text-slate-600">&nbsp;&nbsp;tools: find_tools, get_score, get_alternatives, get_failure_modes</div>
            </div>
            <div class="pt-2">
              <span class="text-slate-600">&rarr; </span>
              <span class="text-amber">find_tools</span>
              <span class="text-slate-500"> (&quot;payment processing&quot;)</span>
            </div>
            <div class="text-slate-400 pl-4">
              <div><span class="text-slate-600">1.</span> stripe <span class="text-score-native">8.1</span> <span class="text-score-native">L4 Native</span></div>
              <div><span class="text-slate-600">2.</span> lemon-squeezy <span class="text-score-ready">6.6</span> <span class="text-score-ready">L3 Ready</span></div>
              <div><span class="text-slate-600">3.</span> square <span class="text-score-ready">6.3</span> <span class="text-score-ready">L3 Ready</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
