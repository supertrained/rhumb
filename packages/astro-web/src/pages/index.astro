---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import StatsStrip from "../components/StatsStrip.astro";
import DualEntry from "../components/DualEntry.astro";
import JourneySection from "../components/JourneySection.astro";
import ProductModel from "../components/ProductModel.astro";
import EvidenceSection from "../components/EvidenceSection.astro";
import QuickstartSection from "../components/QuickstartSection.astro";
import FinalCTA from "../components/FinalCTA.astro";
import { PUBLIC_TRUTH } from "../lib/public-truth";

const description =
  "Rhumb helps humans and agents discover capabilities, compare providers with evidence, and execute supported actions through governed API and MCP surfaces.";

const HOME_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Rhumb",
  alternateName: "Rhumb Labs",
  url: "https://rhumb.dev",
  description,
  logo: "https://rhumb.dev/favicon.ico",
  sameAs: ["https://github.com/supertrained/rhumb"],
  knowsAbout: [
    "AI agent tool discovery",
    "agent-native services",
    "MCP tools",
    "governed API execution",
    "AN Score",
    "capability routing",
  ],
};

const AGENT_ROUTE_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: "Rhumb homepage agent route",
  description:
    "Agent-readable operating instructions for using Rhumb Index first, inspecting evidence, and using Rhumb Resolve only when a capability is callable.",
  mainEntity: {
    "@type": "HowTo",
    name: "Choose the correct Rhumb route",
    step: [
      { "@type": "HowToStep", name: "Search Index", text: "Start by searching Rhumb Index for the task, capability, or provider." },
      { "@type": "HowToStep", name: "Inspect trust", text: "Inspect AN Score, evidence, freshness, credential mode, and estimate before execution." },
      { "@type": "HowToStep", name: "Use Resolve when callable", text: "Use Rhumb Resolve only when the selected capability is callable and governed." },
      { "@type": "HowToStep", name: "Stop honestly", text: "If execution is not supported, do not invent execution. Return the best next step." },
    ],
  },
};

const agentContext = `surface: homepage
purpose: choose the correct Rhumb route
first_action: search Index
index_definition: discovery and comparison
resolve_definition: governed execution when callable
before_execution: inspect AN Score, evidence, freshness, credential mode, and estimate
if_not_callable: do not invent execution; return best next step
machine_entrypoints: MCP, REST API, /llms.txt, /.well-known/agent-capabilities.json
current_public_truth: ${PUBLIC_TRUTH.catalogRealitySummary}`;
---

<Layout
  title="Rhumb | From task to trusted tool call"
  description={description}
  canonical="https://rhumb.dev/"
  ogTitle="Rhumb | From task to trusted tool call"
  ogDescription={description}
  ogUrl="https://rhumb.dev/"
  jsonLdBlocks={[HOME_JSON_LD, AGENT_ROUTE_JSON_LD]}
  agentContext={agentContext}
>
  <Hero />
  <StatsStrip />
  <DualEntry />
  <JourneySection />
  <ProductModel />
  <EvidenceSection />
  <QuickstartSection />
  <FinalCTA />
</Layout>
