---
import Layout from "../layouts/Layout.astro";
import Search from "../components/Search.tsx";
import ScoreDisplay from "../components/ScoreDisplay.astro";
import { getServiceCount, getServices } from "../lib/api";

// Bypass Vercel edge caching — search results depend on query params
Astro.response.headers.set('Cache-Control', 'private, no-cache, no-store, must-revalidate');
Astro.response.headers.set('CDN-Cache-Control', 'no-store');
Astro.response.headers.set('Vercel-CDN-Cache-Control', 'no-store');

const query = Astro.url.searchParams.get("q")?.trim() ?? "";
const serviceCountPromise = getServiceCount();

// Fetch and filter services
const allServices = query ? await getServices() : [];
const serviceCount = query ? allServices.length : await serviceCountPromise;
const results = allServices.filter((s) => {
  const search = query.toLowerCase();
  return (
    s.name.toLowerCase().includes(search) ||
    s.slug.toLowerCase().includes(search) ||
    s.category.toLowerCase().includes(search) ||
    (s.description?.toLowerCase().includes(search) ?? false)
  );
});

const SEARCH_JSON_LD = {
  "@context": "https://schema.org",
  "@type": "SearchResultsPage",
  name: "Search | Rhumb",
  url: "https://rhumb.dev/search",
  description: "Search agent-native services scored by Rhumb.",
  ...(query
    ? {
        mainEntity: {
          "@type": "ItemList",
          numberOfItems: results.length,
          itemListElement: results.slice(0, 10).map((s, i) => ({
            "@type": "ListItem",
            position: i + 1,
            item: {
              "@type": "SoftwareApplication",
              name: s.name,
              url: `https://rhumb.dev/service/${s.slug}`,
            },
          })),
        },
      }
    : {}),
};
---

<Layout
  title="Search | Rhumb"
  description="Search agent-native services scored by Rhumb."
  canonical="https://rhumb.dev/search"
  jsonLd={SEARCH_JSON_LD}
>
  <div class="bg-navy min-h-screen">
    <!-- Header -->
    <section class="relative border-b border-slate-800 overflow-hidden">
      <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none"></div>
      <div class="relative max-w-3xl mx-auto px-6 py-12">
        <p class="text-xs font-mono text-amber uppercase tracking-widest mb-4">Search</p>
        <h1 class="font-display font-bold text-3xl text-slate-100 tracking-tight mb-6">
          Find agent-native tools
        </h1>
        <Search client:load />
      </div>
    </section>

    <!-- Results -->
    <section class="max-w-3xl mx-auto px-6 py-10">
      {query ? (
        <>
          <p class="text-xs font-mono text-slate-500 mb-6">
            {results.length > 0
              ? `${results.length} result${results.length === 1 ? "" : "s"} for "${query}"`
              : `No results for "${query}"`}
          </p>

          {results.length > 0 ? (
            <div class="space-y-3">
              {results.map((service) => (
                <a href={`/service/${service.slug}`} class="block group">
                  <article class="bg-surface border border-slate-800 rounded-xl p-5 flex items-center gap-4 transition-all duration-200 hover:border-slate-600 hover:bg-elevated">
                    <ScoreDisplay score={null} size="small" showLabel={false} />

                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="font-display font-semibold text-slate-100 group-hover:text-amber transition-colors">
                          {service.name}
                        </span>
                        <span class="text-xs text-slate-600 px-2 py-0.5 rounded-full border border-slate-800 bg-navy/40 font-mono">
                          {service.category}
                        </span>
                      </div>
                      {service.description && (
                        <p class="mt-1 text-sm text-slate-500 leading-relaxed line-clamp-1">
                          {service.description}
                        </p>
                      )}
                    </div>

                    <span class="text-slate-600 group-hover:text-amber transition-colors text-sm shrink-0">&rarr;</span>
                  </article>
                </a>
              ))}
            </div>
          ) : (
            <div class="bg-surface border border-slate-800 rounded-xl p-12 text-center">
              <p class="text-slate-500 text-sm mb-4">No services match your search.</p>
              <a
                href="/leaderboard"
                class="text-sm text-amber hover:underline font-mono"
              >
                Browse the full leaderboard &rarr;
              </a>
            </div>
          )}
        </>
      ) : (
        <div class="py-12">
          <p class="text-slate-400 text-sm leading-relaxed mb-6 max-w-xl mx-auto text-center">
            Search across {serviceCount} scored services. Every service is rated on 20 dimensions using
            the AN Score methodology — 70% Execution reliability + 30% Access Readiness. Results are
            server-rendered for both human and agent access.
          </p>
          <p class="text-xs font-mono text-slate-500 mb-4 text-center">Popular categories</p>
          <div class="flex flex-wrap justify-center gap-2 mb-8">
            {["payments", "ai", "auth", "email", "database", "devops", "search", "cms", "crm", "calendar"].map((cat) => (
              <a
                href={`/leaderboard/${cat}`}
                class="px-3 py-1.5 rounded-full border border-slate-800 text-xs font-mono text-slate-500 hover:border-amber/40 hover:text-amber transition-colors bg-surface"
              >
                {cat}
              </a>
            ))}
          </div>
          <p class="text-xs text-slate-600 text-center">
            Or use <a href="/docs" class="text-amber hover:underline">the API</a> or <code class="text-amber/80">npx rhumb-mcp</code> for programmatic access.
          </p>
        </div>
      )}
    </section>
  </div>
</Layout>
