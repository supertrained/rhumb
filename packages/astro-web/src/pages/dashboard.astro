---
import Layout from "../layouts/Layout.astro";

const API_URL = import.meta.env.PUBLIC_API_URL ?? "https://api.rhumb.dev";
---

<Layout
  title="Dashboard | Rhumb"
  description="Your Rhumb developer dashboard — governed API key, usage, and quickstart."
  noindex={true}
>
  <main class="min-h-screen bg-midnight px-4 py-12">
    <div class="max-w-2xl mx-auto">
      <!-- Loading state -->
      <div id="loading" class="text-center py-20">
        <div class="inline-block w-6 h-6 border-2 border-slate-600 border-t-score-native rounded-full animate-spin"></div>
        <p class="text-slate-400 mt-4 text-sm">Loading dashboard...</p>
      </div>

      <!-- Not authenticated -->
      <div id="not-auth" class="hidden text-center py-20">
        <h1 class="text-xl font-semibold text-white mb-4">Not signed in</h1>
        <p class="text-slate-400 mb-6">Sign in to access your dashboard.</p>
        <a
          href="/auth/login"
          class="inline-flex items-center px-6 py-2.5 rounded-lg bg-score-native text-midnight font-medium text-sm hover:bg-score-native/90 transition-colors"
        >
          Sign in
        </a>
      </div>

      <!-- Dashboard content -->
      <div id="dashboard" class="hidden">
        <!-- Welcome header -->
        <div class="flex items-center justify-between mb-8">
          <div>
            <h1 class="text-xl font-semibold text-white" id="welcome-name">Dashboard</h1>
            <p class="text-sm text-slate-400" id="welcome-email"></p>
          </div>
          <button
            id="logout-btn"
            class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
          >
            Sign out
          </button>
        </div>

        <!-- Email OTP credit policy -->
        <div
          id="email-credit-policy-card"
          class="hidden mb-4 rounded-lg border border-amber/20 bg-amber/10 p-5"
        >
          <div class="flex items-start gap-3">
            <div class="mt-0.5 flex h-9 w-9 items-center justify-center rounded-full bg-amber/15 text-amber">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86l-7.53 13A1 1 0 003.62 18h16.76a1 1 0 00.86-1.5l-7.53-13a1 1 0 00-1.72 0z" />
              </svg>
            </div>
            <div>
              <h2 class="text-sm font-semibold text-amber mb-2">Email sign-in does not include starter execution credit</h2>
              <p class="text-sm text-slate-300 mb-3">
                Your dashboard access and governed API key are active, but execution starts only when you bring a payment path.
              </p>
              <p class="text-xs text-slate-400">
                For repeat traffic, default to the governed API key path by adding funded balance below. Use x402 per-call only when zero-signup, request-level payment authorization is the point, and use BYOK or Agent Vault only when provider control is the point.
              </p>
            </div>
          </div>
        </div>

        <!-- New user: show API key -->
        <div id="new-key-banner" class="hidden mb-6 p-4 rounded-lg bg-score-native/10 border border-score-native/20">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-score-native" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
            <h2 class="text-sm font-semibold text-score-native">Your governed API key</h2>
          </div>
          <p class="text-xs text-slate-400 mb-3">Save this key — it won't be shown again.</p>
          <div class="flex items-center gap-2">
            <code id="api-key-value" class="flex-1 px-3 py-2 rounded bg-midnight text-sm text-white font-mono break-all"></code>
            <button
              id="copy-key-btn"
              class="px-3 py-2 rounded bg-slate-700 text-slate-300 text-xs hover:bg-slate-600 transition-colors"
            >
              Copy
            </button>
          </div>
        </div>

        <!-- API Key card -->
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-lg p-5 mb-4">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-semibold text-white">Governed API key</h2>
            <button
              id="rotate-btn"
              class="text-xs text-slate-400 hover:text-red-400 transition-colors"
            >
              Rotate key
            </button>
          </div>
          <div class="flex items-center gap-2">
            <code id="key-prefix" class="text-sm text-slate-400 font-mono">rhumb_****</code>
            <span class="text-xs text-slate-500">•••••••••</span>
          </div>
        </div>

        <!-- New secondary key banner -->
        <div id="new-secondary-key-banner" class="hidden mb-6 p-4 rounded-lg bg-slate-900 border border-slate-700">
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-score-native" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
            <h2 class="text-sm font-semibold text-white">New agent key</h2>
          </div>
          <p class="text-xs text-slate-400 mb-3">Save this key — it won't be shown again.</p>
          <div class="flex items-center gap-2">
            <code id="secondary-api-key-value" class="flex-1 px-3 py-2 rounded bg-midnight text-sm text-white font-mono break-all"></code>
            <button
              id="copy-secondary-key-btn"
              class="px-3 py-2 rounded bg-slate-700 text-slate-300 text-xs hover:bg-slate-600 transition-colors"
            >
              Copy
            </button>
          </div>
        </div>

        <!-- Agent keys -->
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-lg p-5 mb-4">
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-sm font-semibold text-white">Agent keys</h2>
            <span class="text-xs text-slate-500">Create a capped key for a friend/agent</span>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <label class="text-xs text-slate-400">
              Name
              <input
                id="secondary-agent-name"
                type="text"
                placeholder="Friend Agent"
                class="mt-1 w-full rounded bg-midnight border border-slate-700 px-2 py-1.5 text-xs text-white"
              />
            </label>
            <label class="text-xs text-slate-400">
              Monthly budget ($)
              <input
                id="secondary-agent-budget"
                type="number"
                min="1"
                step="0.5"
                value="10"
                class="mt-1 w-full rounded bg-midnight border border-slate-700 px-2 py-1.5 text-xs text-white"
              />
            </label>
            <label class="text-xs text-slate-400">
              QPM limit
              <input
                id="secondary-agent-qpm"
                type="number"
                min="1"
                step="1"
                value="20"
                class="mt-1 w-full rounded bg-midnight border border-slate-700 px-2 py-1.5 text-xs text-white"
              />
            </label>
            <label class="text-xs text-slate-400">
              Notes (optional)
              <input
                id="secondary-agent-description"
                type="text"
                placeholder="What is this key for?"
                class="mt-1 w-full rounded bg-midnight border border-slate-700 px-2 py-1.5 text-xs text-white"
              />
            </label>
          </div>

          <div class="flex items-center justify-between gap-3 mt-3">
            <p class="text-xs text-slate-500" id="secondary-agent-help"></p>
            <button
              id="create-secondary-agent-btn"
              class="px-3 py-2 rounded bg-score-native text-midnight text-xs font-semibold hover:bg-score-native/90 transition-colors"
            >
              Create key
            </button>
          </div>

          <div class="border-t border-slate-700/40 pt-3 mt-3">
            <p class="text-xs text-slate-500 mb-2">Existing agent keys</p>
            <div id="agent-keys-loading" class="text-xs text-slate-500">Loading agent keys...</div>
            <div id="agent-keys-empty" class="hidden text-xs text-slate-500">No additional agent keys yet.</div>
            <div id="agent-keys-list" class="hidden space-y-2"></div>
          </div>
        </div>

        <!-- Usage card -->
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-lg p-5 mb-4">
          <h2 class="text-sm font-semibold text-white mb-3">Usage</h2>
          <div id="usage-loading" class="text-xs text-slate-500">Loading usage...</div>
          <div id="usage-content" class="hidden">
            <div class="grid grid-cols-2 gap-4 mb-3">
              <div>
                <p class="text-2xl font-semibold text-white" id="calls-month">0</p>
                <p class="text-xs text-slate-500">calls this month</p>
              </div>
              <div>
                <p class="text-2xl font-semibold text-white" id="calls-today">0</p>
                <p class="text-xs text-slate-500">calls today</p>
              </div>
            </div>
            <div id="service-breakdown" class="hidden">
              <p class="text-xs text-slate-500 mb-2">Top services</p>
              <div id="service-bars" class="space-y-1.5"></div>
            </div>
          </div>
          <div id="usage-empty" class="hidden">
            <p class="text-xs text-slate-500">No API calls yet. Make your first request to see usage here.</p>
          </div>
        </div>

        <!-- Billing card -->
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-lg p-5 mb-4">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-semibold text-white">Billing</h2>
            <button
              id="add-funds-btn"
              class="text-xs text-score-native hover:text-score-native/80 transition-colors"
            >
              Add funds →
            </button>
          </div>
          <div id="billing-loading" class="text-xs text-slate-500">Loading billing...</div>
          <div id="billing-content" class="hidden">
            <div class="flex items-baseline gap-2 mb-3">
              <p class="text-2xl font-semibold text-white" id="balance-amount">$0.00</p>
              <span class="text-xs px-2 py-0.5 rounded-full bg-slate-700 text-slate-400" id="plan-badge">free</span>
            </div>
            <div id="billing-checkout-message" class="hidden mb-3 rounded-md border px-3 py-2 text-xs"></div>
            <div class="space-y-1 mb-3 text-xs">
              <p class="text-slate-400" id="payment-method-status">No saved payment method yet.</p>
              <p class="text-slate-500" id="auto-reload-status">Auto-reload is off.</p>
            </div>

            <div id="auto-reload-controls" class="border-t border-slate-700/40 pt-3 mt-3">
              <div class="flex items-center justify-between gap-3">
                <label class="flex items-center gap-2 text-xs text-slate-300">
                  <input id="auto-reload-enabled" type="checkbox" class="accent-score-native" />
                  Enable auto-reload
                </label>
                <button
                  id="auto-reload-save-btn"
                  class="px-3 py-1.5 rounded bg-slate-700 text-slate-200 text-xs hover:bg-slate-600 transition-colors"
                >
                  Save
                </button>
              </div>

              <div class="grid grid-cols-2 gap-2 mt-2">
                <label class="text-xs text-slate-400">
                  Threshold ($)
                  <input
                    id="auto-reload-threshold"
                    type="number"
                    min="1"
                    step="1"
                    class="mt-1 w-full rounded bg-midnight border border-slate-700 px-2 py-1.5 text-xs text-white"
                  />
                </label>
                <label class="text-xs text-slate-400">
                  Reload amount ($)
                  <input
                    id="auto-reload-amount"
                    type="number"
                    min="5"
                    step="1"
                    class="mt-1 w-full rounded bg-midnight border border-slate-700 px-2 py-1.5 text-xs text-white"
                  />
                </label>
              </div>

              <p id="auto-reload-help" class="mt-2 text-xs text-slate-500"></p>
            </div>

            <div id="transactions-list" class="hidden">
              <p class="text-xs text-slate-500 mb-2">Recent activity</p>
              <div id="transactions" class="space-y-1.5"></div>
            </div>
          </div>
        </div>

        <!-- Quick Start checklist -->
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-lg p-5 mb-4">
          <h2 class="text-sm font-semibold text-white mb-4">Quick Start</h2>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full border-2 border-score-native bg-score-native/20 flex items-center justify-center mt-0.5">
                <svg class="w-3 h-3 text-score-native" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-white">Create account</p>
                <p class="text-xs text-slate-500">Done!</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div id="step2-circle" class="w-5 h-5 rounded-full border-2 border-slate-600 mt-0.5"></div>
              <div>
                <p class="text-sm text-white">Copy your governed API key</p>
                <p class="text-xs text-slate-500">Use the key above in your requests.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full border-2 border-slate-600 mt-0.5"></div>
              <div>
                <p class="text-sm text-white">Make your first API call</p>
                <pre class="mt-1 text-xs text-slate-400 bg-midnight rounded px-2 py-1.5 overflow-x-auto"><code>curl https://api.rhumb.dev/v1/services/stripe/score \
  -H "X-Rhumb-Key: YOUR_KEY"</code></pre>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full border-2 border-slate-600 mt-0.5"></div>
              <div>
                <p class="text-sm text-white">Try the MCP server</p>
                <pre class="mt-1 text-xs text-slate-400 bg-midnight rounded px-2 py-1.5 overflow-x-auto"><code>npx rhumb-mcp@latest</code></pre>
              </div>
            </div>
          </div>
        </div>

        <!-- Useful links -->
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-lg p-5">
          <h2 class="text-sm font-semibold text-white mb-3">Resources</h2>
          <div class="grid grid-cols-2 gap-2">
            <a href="/quickstart" class="text-sm text-score-native hover:underline">Quickstart →</a>
            <a href="/docs" class="text-sm text-score-native hover:underline">API Docs →</a>
            <a href="/methodology" class="text-sm text-score-native hover:underline">Methodology →</a>
            <a href="/pricing" class="text-sm text-score-native hover:underline">Pricing →</a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ API_URL }}>
    const loading = document.getElementById("loading");
    const notAuth = document.getElementById("not-auth");
    const dashboard = document.getElementById("dashboard");
    const emailCreditPolicyCard = document.getElementById("email-credit-policy-card");

    const autoReloadEnabledEl = document.getElementById("auto-reload-enabled");
    const autoReloadThresholdEl = document.getElementById("auto-reload-threshold");
    const autoReloadAmountEl = document.getElementById("auto-reload-amount");
    const autoReloadSaveBtn = document.getElementById("auto-reload-save-btn");
    const autoReloadHelpEl = document.getElementById("auto-reload-help");

    const newSecondaryKeyBanner = document.getElementById("new-secondary-key-banner");
    const secondaryApiKeyValue = document.getElementById("secondary-api-key-value");
    const copySecondaryKeyBtn = document.getElementById("copy-secondary-key-btn");

    const secondaryAgentNameEl = document.getElementById("secondary-agent-name");
    const secondaryAgentBudgetEl = document.getElementById("secondary-agent-budget");
    const secondaryAgentQpmEl = document.getElementById("secondary-agent-qpm");
    const secondaryAgentDescriptionEl = document.getElementById("secondary-agent-description");
    const secondaryAgentHelpEl = document.getElementById("secondary-agent-help");
    const createSecondaryAgentBtn = document.getElementById("create-secondary-agent-btn");

    const agentKeysLoadingEl = document.getElementById("agent-keys-loading");
    const agentKeysEmptyEl = document.getElementById("agent-keys-empty");
    const agentKeysListEl = document.getElementById("agent-keys-list");

    function isEmailOtpUser(user) {
      return user?.signup_method === "email_otp" || user?.credit_policy === "email_no_trial";
    }

    function setAutoReloadInputsEnabled(enabled) {
      if (autoReloadThresholdEl) autoReloadThresholdEl.disabled = !enabled;
      if (autoReloadAmountEl) autoReloadAmountEl.disabled = !enabled;
    }

    function hydrateAutoReloadControls(data) {
      if (!autoReloadEnabledEl || !autoReloadThresholdEl || !autoReloadAmountEl || !autoReloadHelpEl) return;

      const hasPaymentMethod = !!data?.has_payment_method;
      const enabled = !!data?.auto_reload_enabled;

      autoReloadEnabledEl.checked = enabled;
      autoReloadEnabledEl.disabled = !hasPaymentMethod;

      autoReloadThresholdEl.value = (data?.auto_reload_threshold_usd ?? 10).toString();
      autoReloadAmountEl.value = (data?.auto_reload_amount_usd ?? 50).toString();

      if (!hasPaymentMethod) {
        autoReloadHelpEl.textContent = "Add funds once to save a payment method before enabling auto-reload.";
        setAutoReloadInputsEnabled(false);
        return;
      }

      autoReloadHelpEl.textContent = "";
      setAutoReloadInputsEnabled(enabled);
    }

    autoReloadEnabledEl?.addEventListener("change", () => {
      if (!autoReloadEnabledEl) return;
      setAutoReloadInputsEnabled(!!autoReloadEnabledEl.checked);
    });

    autoReloadSaveBtn?.addEventListener("click", async () => {
      if (!autoReloadEnabledEl || !autoReloadThresholdEl || !autoReloadAmountEl) return;

      const enabled = !!autoReloadEnabledEl.checked;
      const threshold = Number(autoReloadThresholdEl.value);
      const amount = Number(autoReloadAmountEl.value);

      const originalText = autoReloadSaveBtn.textContent;
      autoReloadSaveBtn.textContent = "Saving…";
      autoReloadSaveBtn.disabled = true;

      try {
        const resp = await fetch(`${API_URL}/v1/auth/me/billing/auto-reload`, {
          method: "PUT",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            enabled,
            threshold_usd: enabled ? threshold : null,
            amount_usd: enabled ? amount : null,
          }),
        });

        const data = await resp.json();
        if (!resp.ok) {
          throw new Error(data.detail || "Unable to save auto-reload settings");
        }

        await loadBilling();
      } catch (e) {
        window.alert(`Failed to save auto-reload: ${e.message}`);
      } finally {
        autoReloadSaveBtn.textContent = originalText;
        autoReloadSaveBtn.disabled = false;
      }
    });

    async function init() {
      // Check for new signup API key in URL fragment
      const hash = window.location.hash;
      const isNew = new URLSearchParams(window.location.search).get("new") === "1";

      try {
        const resp = await fetch(`${API_URL}/v1/auth/me`, {
          credentials: "include",
        });

        if (!resp.ok) {
          loading.classList.add("hidden");
          notAuth.classList.remove("hidden");
          return;
        }

        const user = await resp.json();

        // Populate dashboard
        document.getElementById("welcome-name").textContent =
          user.name ? `Welcome, ${user.name}` : "Dashboard";
        document.getElementById("welcome-email").textContent = user.email || "";
        document.getElementById("key-prefix").textContent =
          user.api_key_prefix ? `${user.api_key_prefix}••••••••` : "No key";
        if (isEmailOtpUser(user)) {
          emailCreditPolicyCard?.classList.remove("hidden");
        }

        // Show new API key if present
        if (isNew && hash && hash.length > 1) {
          const apiKey = hash.substring(1);
          const keyBanner = document.getElementById("new-key-banner");
          const keyValue = document.getElementById("api-key-value");
          keyBanner.classList.remove("hidden");
          keyValue.textContent = apiKey;

          // Clean URL (remove hash + new param) without reload
          history.replaceState(null, "", "/dashboard");
        }

        loading.classList.add("hidden");
        dashboard.classList.remove("hidden");

        // Load usage + billing in parallel (non-blocking)
        loadUsage();
        await confirmCheckoutFromQuery();
        loadBilling();
        loadAgentKeys();
      } catch (e) {
        console.error("Dashboard init error:", e);
        loading.classList.add("hidden");
        notAuth.classList.remove("hidden");
      }
    }

    // Copy key button
    document.getElementById("copy-key-btn")?.addEventListener("click", () => {
      const key = document.getElementById("api-key-value")?.textContent;
      if (key) {
        navigator.clipboard.writeText(key);
        const btn = document.getElementById("copy-key-btn");
        btn.textContent = "Copied!";
        setTimeout(() => (btn.textContent = "Copy"), 2000);
      }
    });

    copySecondaryKeyBtn?.addEventListener("click", () => {
      const key = secondaryApiKeyValue?.textContent;
      if (key) {
        navigator.clipboard.writeText(key);
        copySecondaryKeyBtn.textContent = "Copied!";
        setTimeout(() => (copySecondaryKeyBtn.textContent = "Copy"), 2000);
      }
    });

    // Rotate key button
    document.getElementById("rotate-btn")?.addEventListener("click", async () => {
      if (!confirm("Rotate your governed API key? The old key will stop working immediately.")) return;
      try {
        const resp = await fetch(`${API_URL}/v1/auth/rotate-key`, {
          method: "POST",
          credentials: "include",
        });
        if (!resp.ok) throw new Error("Rotation failed");
        const data = await resp.json();
        const keyBanner = document.getElementById("new-key-banner");
        const keyValue = document.getElementById("api-key-value");
        keyBanner.classList.remove("hidden");
        keyValue.textContent = data.api_key;
        document.getElementById("key-prefix").textContent = data.api_key.substring(0, 12) + "••••••••";
      } catch (e) {
        alert("Failed to rotate key: " + e.message);
      }
    });

    createSecondaryAgentBtn?.addEventListener("click", async () => {
      if (!secondaryAgentNameEl || !secondaryAgentBudgetEl || !secondaryAgentQpmEl) return;

      const name = secondaryAgentNameEl.value.trim();
      const budget = Number(secondaryAgentBudgetEl.value);
      const qpm = Number(secondaryAgentQpmEl.value);
      const description = secondaryAgentDescriptionEl?.value?.trim() || "";

      if (!name) {
        secondaryAgentHelpEl.textContent = "Pick a short agent name.";
        return;
      }

      secondaryAgentHelpEl.textContent = "";

      const originalText = createSecondaryAgentBtn.textContent;
      createSecondaryAgentBtn.textContent = "Creating…";
      createSecondaryAgentBtn.disabled = true;

      try {
        const resp = await fetch(`${API_URL}/v1/auth/me/agents`, {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name,
            description: description || null,
            budget_usd: budget,
            period: "monthly",
            hard_limit: true,
            rate_limit_qpm: qpm,
          }),
        });

        const data = await resp.json();
        if (!resp.ok) {
          throw new Error(data.detail || "Unable to create agent key");
        }

        if (secondaryApiKeyValue && newSecondaryKeyBanner) {
          secondaryApiKeyValue.textContent = data.api_key;
          newSecondaryKeyBanner.classList.remove("hidden");
        }

        secondaryAgentNameEl.value = "";
        if (secondaryAgentDescriptionEl) secondaryAgentDescriptionEl.value = "";

        await loadAgentKeys();
      } catch (e) {
        window.alert(`Failed to create agent key: ${e.message}`);
      } finally {
        createSecondaryAgentBtn.textContent = originalText;
        createSecondaryAgentBtn.disabled = false;
      }
    });

    // Logout button
    document.getElementById("logout-btn")?.addEventListener("click", async () => {
      await fetch(`${API_URL}/v1/auth/logout`, {
        method: "POST",
        credentials: "include",
      });
      window.location.href = "/auth/login";
    });

    // ── Usage + Billing loaders ────────────────────────────────────

    function escapeHtml(input) {
      return (input || "")
        .toString()
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function renderAgentKeys(agents) {
      if (!agentKeysLoadingEl || !agentKeysEmptyEl || !agentKeysListEl) return;

      agentKeysLoadingEl.classList.add("hidden");

      const secondaryAgents = (agents || []).filter((a) => !a.is_default);
      if (secondaryAgents.length === 0) {
        agentKeysEmptyEl.classList.remove("hidden");
        agentKeysListEl.classList.add("hidden");
        agentKeysListEl.innerHTML = "";
        return;
      }

      agentKeysEmptyEl.classList.add("hidden");
      agentKeysListEl.classList.remove("hidden");
      agentKeysListEl.innerHTML = secondaryAgents
        .map((agent) => {
          const budget = agent.budget;
          const budgetLine = budget
            ? `Budget: $${Number(budget.budget_usd).toFixed(2)} (${escapeHtml(budget.period)}) — remaining $${Number(budget.remaining_usd ?? 0).toFixed(2)}`
            : "No budget cap configured";

          return `<div class="rounded border border-slate-700/60 bg-midnight px-3 py-2">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold text-white">${escapeHtml(agent.name)}</p>
                <p class="text-xs text-slate-500 font-mono">${escapeHtml(agent.api_key_prefix)}••••••••</p>
                <p class="text-xs text-slate-500 mt-1">${budgetLine}</p>
                <p class="text-xs text-slate-500">Rate limit: ${Number(agent.rate_limit_qpm || 0)} qpm</p>
              </div>
              <span class="text-[10px] uppercase tracking-widest text-slate-500">${escapeHtml(agent.status)}</span>
            </div>
          </div>`;
        })
        .join("");
    }

    async function loadAgentKeys() {
      if (!agentKeysLoadingEl || !agentKeysEmptyEl || !agentKeysListEl) return;

      agentKeysLoadingEl.textContent = "Loading agent keys...";
      agentKeysLoadingEl.classList.remove("hidden");
      agentKeysEmptyEl.classList.add("hidden");
      agentKeysListEl.classList.add("hidden");

      try {
        const resp = await fetch(`${API_URL}/v1/auth/me/agents`, { credentials: "include" });
        if (!resp.ok) throw new Error("fetch failed");
        const data = await resp.json();
        renderAgentKeys(data.agents || []);
      } catch (e) {
        agentKeysLoadingEl.textContent = "Unable to load agent keys";
      }
    }

    async function loadUsage() {
      try {
        const resp = await fetch(`${API_URL}/v1/auth/me/usage`, { credentials: "include" });
        if (!resp.ok) throw new Error("fetch failed");
        const data = await resp.json();

        document.getElementById("usage-loading").classList.add("hidden");

        if (data.total_calls === 0 && data.calls_this_month === 0) {
          document.getElementById("usage-empty").classList.remove("hidden");
          return;
        }

        document.getElementById("usage-content").classList.remove("hidden");
        document.getElementById("calls-month").textContent = data.calls_this_month.toLocaleString();
        document.getElementById("calls-today").textContent = data.calls_today.toLocaleString();

        // Service breakdown bars
        const services = data.calls_by_service || {};
        const sorted = Object.entries(services).sort((a, b) => b[1] - a[1]).slice(0, 5);
        if (sorted.length > 0) {
          const maxCalls = sorted[0][1];
          const barsEl = document.getElementById("service-bars");
          document.getElementById("service-breakdown").classList.remove("hidden");
          barsEl.innerHTML = sorted.map(([svc, calls]) => {
            const pct = Math.max(8, (calls / maxCalls) * 100);
            return `<div class="flex items-center gap-2">
              <span class="text-xs text-slate-400 w-20 truncate">${svc}</span>
              <div class="flex-1 h-1.5 bg-slate-700 rounded-full overflow-hidden">
                <div class="h-full bg-score-native/60 rounded-full" style="width:${pct}%"></div>
              </div>
              <span class="text-xs text-slate-500 w-8 text-right">${calls}</span>
            </div>`;
          }).join("");
        }
      } catch (e) {
        document.getElementById("usage-loading").textContent = "Unable to load usage";
      }
    }

    async function loadBilling() {
      try {
        const resp = await fetch(`${API_URL}/v1/auth/me/billing`, { credentials: "include" });
        if (!resp.ok) throw new Error("fetch failed");
        const data = await resp.json();

        document.getElementById("billing-loading").classList.add("hidden");
        document.getElementById("billing-content").classList.remove("hidden");
        document.getElementById("balance-amount").textContent = `$${data.balance_usd.toFixed(2)}`;
        document.getElementById("plan-badge").textContent = data.plan;

        const checkoutState = new URLSearchParams(window.location.search).get("checkout");
        const checkoutMessage = document.getElementById("billing-checkout-message");
        if (checkoutState === "success") {
          checkoutMessage.textContent = "Stripe checkout completed. Balance and saved-card status should refresh shortly.";
          checkoutMessage.className = "mb-3 rounded-md border border-score-native/30 bg-score-native/10 px-3 py-2 text-xs text-score-native";
          checkoutMessage.classList.remove("hidden");
        } else if (checkoutState === "cancel") {
          checkoutMessage.textContent = "Checkout was canceled. You can try again anytime.";
          checkoutMessage.className = "mb-3 rounded-md border border-slate-600 bg-slate-800 px-3 py-2 text-xs text-slate-300";
          checkoutMessage.classList.remove("hidden");
        }

        const paymentMethodStatus = document.getElementById("payment-method-status");
        paymentMethodStatus.textContent = data.has_payment_method
          ? "Saved payment method on file for future top-ups and auto-reload."
          : "No saved payment method yet.";
        paymentMethodStatus.className = data.has_payment_method
          ? "text-score-native"
          : "text-slate-400";

        const autoReloadStatus = document.getElementById("auto-reload-status");
        if (data.auto_reload_enabled && data.auto_reload_threshold_usd && data.auto_reload_amount_usd) {
          autoReloadStatus.textContent = `Auto-reload is on: add $${data.auto_reload_amount_usd.toFixed(2)} when balance drops below $${data.auto_reload_threshold_usd.toFixed(2)}.`;
        } else {
          autoReloadStatus.textContent = "Auto-reload is off.";
        }

        hydrateAutoReloadControls(data);

        // Style plan badge
        const badge = document.getElementById("plan-badge");
        if (data.plan === "prepaid") {
          badge.classList.remove("bg-slate-700", "text-slate-400");
          badge.classList.add("bg-score-native/20", "text-score-native");
        }

        // Transactions
        const txns = data.recent_transactions || [];
        if (txns.length > 0) {
          document.getElementById("transactions-list").classList.remove("hidden");
          const txnEl = document.getElementById("transactions");
          txnEl.innerHTML = txns.map(t => {
            const sign = t.type === "deposit" || t.type === "credit" ? "+" : "-";
            const color = sign === "+" ? "text-green-400" : "text-red-400";
            const date = t.timestamp ? new Date(t.timestamp).toLocaleDateString() : "";
            return `<div class="flex items-center justify-between text-xs">
              <span class="text-slate-400">${t.description || t.type}</span>
              <div class="flex items-center gap-2">
                <span class="${color}">${sign}$${Math.abs(t.amount_usd).toFixed(2)}</span>
                <span class="text-slate-600">${date}</span>
              </div>
            </div>`;
          }).join("");
        }
      } catch (e) {
        document.getElementById("billing-loading").textContent = "Unable to load billing";
      }
    }

    async function confirmCheckoutFromQuery() {
      const params = new URLSearchParams(window.location.search);
      if (params.get("checkout") !== "success") return;

      const sessionId = params.get("session_id");
      if (!sessionId) return;

      try {
        await fetch(`${API_URL}/v1/auth/me/billing/checkout/confirm`, {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ session_id: sessionId }),
        });
      } catch (e) {
        // Non-fatal: billing will still load and show the current state.
        console.warn("Checkout confirm failed", e);
      }
    }

    // Add funds button
    document.getElementById("add-funds-btn")?.addEventListener("click", async () => {
      const rawAmount = window.prompt("How much balance should we add?", "25");
      if (!rawAmount) return;

      const amount = Number(rawAmount);
      if (!Number.isFinite(amount) || amount < 5 || amount > 5000) {
        window.alert("Enter an amount between $5 and $5000.");
        return;
      }

      const button = document.getElementById("add-funds-btn");
      const originalText = button?.textContent;
      if (button) button.textContent = "Opening checkout…";

      try {
        const resp = await fetch(`${API_URL}/v1/auth/me/billing/checkout`, {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ amount_usd: amount }),
        });

        const data = await resp.json();
        if (!resp.ok || !data.checkout_url) {
          throw new Error(data.detail || "Unable to create checkout session");
        }

        window.location.href = data.checkout_url;
      } catch (e) {
        window.alert(`Failed to open checkout: ${e.message}`);
        if (button && originalText) button.textContent = originalText;
      }
    });

    init();
  </script>
</Layout>
