---
import { PUBLIC_TRUTH } from "../lib/public-truth";

const routeSteps = [
  {
    label: "01 · Task",
    title: "Research Acme and summarize the current facts.",
    body: "A human gives the agent an outcome, not a provider decision.",
    status: "Intent received",
    tone: "amber",
  },
  {
    label: "02 · Index",
    title: "Search capability: company.research",
    body: "Index is discovery and comparison: services, capabilities, AN Score, evidence, freshness, and failure modes.",
    status: "Compare routes",
    tone: "slate",
  },
  {
    label: "03 · Evidence",
    title: "Inspect trust before action.",
    body: "Check score, proof, freshness, credentials, estimate, and failure modes before the agent acts.",
    status: "AN 91 · Fresh",
    tone: "teal",
  },
  {
    label: "04 · Resolve",
    title: "Execute only when supported.",
    body: "Resolve is governed execution for supported capabilities: estimate, apply policy, route, and run.",
    status: "420ms · $0.02",
    tone: "teal",
  },
  {
    label: "05 · Outcome",
    title: "Return the result or stop honestly.",
    body: "If execution is unsupported, do not invent it. Return the evidence and next best step.",
    status: "Execute / stop",
    tone: "amber",
  },
];
---

<section id="hero" class="home-section home-hero relative overflow-hidden border-b border-white/10">
  <div class="chart-field" aria-hidden="true"></div>
  <div class="home-shell hero-shell relative z-10 grid py-24 lg:grid-cols-[minmax(0,0.9fr)_minmax(560px,1.1fr)] lg:items-start lg:py-32">
    <div class="hero-copy max-w-3xl">
      <p class="eyebrow animate-fade-up"><span aria-hidden="true">🧭</span> THE NAVIGATION LAYER FOR AGENT TOOLS</p>
      <h1 class="animate-fade-up animate-delay-100 mt-5 font-display text-[clamp(3.25rem,8vw,7.35rem)] font-semibold leading-[0.88] tracking-[-0.075em] text-rhumb-cream text-balance">
        From task to trusted tool call.
      </h1>
      <p class="animate-fade-up animate-delay-200 mt-8 max-w-[39rem] text-lg leading-8 text-rhumb-mist sm:text-xl">
        Rhumb is the tool discovery and governed access layer for AI agents: Index shows what can be trusted, and Resolve runs what is actually supported.
      </p>
      <p class="animate-fade-up animate-delay-300 mt-5 max-w-[36rem] text-base leading-7 text-rhumb-muted">
        Discovery leads. Execution follows only when a route is callable. If coverage is missing, Rhumb returns the next best step instead of pretending.
      </p>
      <div class="animate-fade-up animate-delay-400 mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="/#quickstart" class="btn-primary">Run the MCP server</a>
        <a href="/search" class="btn-secondary">Browse the Index</a>
      </div>
      <p class="animate-fade-up animate-delay-500 mt-7 max-w-2xl border-l border-rhumb-gold/45 pl-4 text-sm leading-6 text-rhumb-mist">
        Broad discovery first. Governed execution when ready. Honest stop when unsupported.
      </p>
      <div class="animate-fade-up animate-delay-600 mt-8 flex flex-wrap gap-2 text-xs text-rhumb-muted">
        <a class="route-pill" href="/llms.txt">llms.txt</a>
        <a class="route-pill" href="/.well-known/agent-capabilities.json">agent-capabilities.json</a>
        <a class="route-pill" href="/docs">docs</a>
        <span class="route-pill">{PUBLIC_TRUTH.mcpToolsLabel} MCP tools</span>
      </div>
    </div>

    <div id="agent-route" class="route-instrument animate-fade-up animate-delay-300" aria-label="Example Rhumb route from task to governed action">
      <div class="instrument-topline">
        <span>Read-only route trace</span>
        <span>Index → Evidence → Resolve → Stop</span>
      </div>
      <div class="route-map" aria-hidden="true">
        <svg viewBox="0 0 640 430" role="img" aria-label="Rhumb route line" preserveAspectRatio="none">
          <defs>
            <linearGradient id="routeGlow" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0" stop-color="#E6B35A" />
              <stop offset="0.55" stop-color="#6BD6C3" />
              <stop offset="1" stop-color="#E6B35A" />
            </linearGradient>
          </defs>
          <path class="route-path-shadow" d="M44 356 C145 264 166 110 278 150 C384 188 367 309 482 262 C548 236 574 154 606 83" />
          <path class="route-path" d="M44 356 C145 264 166 110 278 150 C384 188 367 309 482 262 C548 236 574 154 606 83" />
        </svg>
      </div>
      <ol class="route-trace" aria-label="Rhumb route trace from task to outcome">
        {routeSteps.map((step, index) => (
          <li class={`trace-step trace-${step.tone}`} style={`--i:${index}`}>
            <div class="trace-node" aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
            <div class="trace-copy">
              <div class="trace-topline">
                <span>{step.label}</span>
                <em>{step.status}</em>
              </div>
              <h2>{step.title}</h2>
              <p>{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
      <div class="instrument-footer">
        <span>Stop rule active</span>
        <span>If unsupported, return best next step.</span>
      </div>
    </div>
  </div>
</section>
