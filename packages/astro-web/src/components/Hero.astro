---
import { PUBLIC_TRUTH } from "../lib/public-truth";

const routeCards = [
  {
    label: "Task",
    title: "Find current facts about Acme and summarize them.",
    meta: "Ambiguous human intent",
    tone: "amber",
  },
  {
    label: "Capability",
    title: "company.research",
    meta: "Mapped by Index",
    tone: "slate",
  },
  {
    label: "Evidence",
    title: "AN Score 91 / 100",
    meta: "Fresh · 2h ago",
    tone: "teal",
  },
  {
    label: "Resolve",
    title: "Callable",
    meta: "420ms · $0.02 · governed",
    tone: "teal",
  },
  {
    label: "Outcome",
    title: "Execute or stop honestly",
    meta: "Never invent unsupported execution",
    tone: "amber",
  },
];

const compassPoints = [
  { label: "N", glyph: "↑", className: "compass-n" },
  { label: "E", glyph: "→", className: "compass-e" },
  { label: "S", glyph: "↓", className: "compass-s" },
  { label: "W", glyph: "←", className: "compass-w" },
];
---

<section id="hero" class="home-section home-hero relative overflow-hidden border-b border-white/10">
  <div class="chart-field" aria-hidden="true"></div>
  <div class="hero-bearing" aria-hidden="true">
    <span>🧭</span>
    <span>N</span><span>·</span><span>E</span><span>·</span><span>S</span><span>·</span><span>W</span>
  </div>
  <div class="home-shell hero-shell relative z-10 grid py-24 lg:grid-cols-[minmax(0,0.94fr)_minmax(510px,1.06fr)] lg:items-center lg:py-32">
    <div class="hero-copy max-w-3xl">
      <p class="eyebrow animate-fade-up"><span aria-hidden="true">🧭</span> THE NAVIGATION LAYER FOR AGENT TOOLS</p>
      <h1 class="animate-fade-up animate-delay-100 mt-5 font-display text-[clamp(3.25rem,8vw,7.35rem)] font-semibold leading-[0.88] tracking-[-0.075em] text-rhumb-cream text-balance">
        From task to trusted tool call.
      </h1>
      <p class="animate-fade-up animate-delay-200 mt-8 max-w-2xl text-lg leading-8 text-rhumb-mist sm:text-xl">
        Rhumb helps humans and agents discover capabilities, compare providers with evidence, and execute supported actions through governed API and MCP surfaces.
      </p>
      <div class="animate-fade-up animate-delay-300 mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="/#quickstart" class="btn-primary">Run the MCP server</a>
        <a href="/search" class="btn-secondary">Browse the Index</a>
      </div>
      <p class="animate-fade-up animate-delay-400 mt-7 max-w-2xl border-l border-rhumb-gold/45 pl-4 text-sm leading-6 text-rhumb-muted">
        Broad discovery now. Governed execution where coverage is ready. Honest next step when it is not.
      </p>
      <div class="animate-fade-up animate-delay-500 mt-8 flex flex-wrap gap-2 text-xs text-rhumb-muted">
        <a class="route-pill" href="/llms.txt">llms.txt</a>
        <a class="route-pill" href="/.well-known/agent-capabilities.json">agent-capabilities.json</a>
        <a class="route-pill" href="/docs">docs</a>
        <span class="route-pill">{PUBLIC_TRUTH.mcpToolsLabel} MCP tools</span>
      </div>
    </div>

    <div id="agent-route" class="route-instrument animate-fade-up animate-delay-300" aria-label="Example Rhumb route from task to governed action">
      <div class="instrument-topline">
        <span>Route plot</span>
        <span>Index → Evidence → Resolve</span>
      </div>
      <div class="compass-rose" aria-hidden="true">
        <span class="compass-core">🧭</span>
        {compassPoints.map((point) => (
          <span class={point.className}><b>{point.label}</b><em>{point.glyph}</em></span>
        ))}
      </div>
      <div class="route-map" aria-hidden="true">
        <svg viewBox="0 0 640 430" role="img" aria-label="Rhumb route line" preserveAspectRatio="none">
          <defs>
            <linearGradient id="routeGlow" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0" stop-color="#E6B35A" />
              <stop offset="0.55" stop-color="#6BD6C3" />
              <stop offset="1" stop-color="#E6B35A" />
            </linearGradient>
          </defs>
          <path class="route-path-shadow" d="M44 356 C145 264 166 110 278 150 C384 188 367 309 482 262 C548 236 574 154 606 83" />
          <path class="route-path" d="M44 356 C145 264 166 110 278 150 C384 188 367 309 482 262 C548 236 574 154 606 83" />
        </svg>
      </div>
      <div class="route-cards">
        {routeCards.map((card, index) => (
          <article class={`route-card route-${card.tone}`} style={`--i:${index}`}>
            <div class="route-card-kicker">{card.label}</div>
            <h2>{card.title}</h2>
            <p>{card.meta}</p>
          </article>
        ))}
      </div>
      <div class="instrument-footer">
        <span>Stop rule active</span>
        <span>If unsupported, return best next step.</span>
      </div>
    </div>
  </div>
</section>
