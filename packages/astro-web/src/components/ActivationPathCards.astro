---
import type { ActivationPath } from "../lib/activation-paths";

interface Props {
  id?: string;
  eyebrow: string;
  title: string;
  description: string;
  routes: ActivationPath[];
}

const { id, eyebrow, title, description, routes } = Astro.props as Props;
---

<section id={id} class="mb-16 scroll-mt-28">
  <div class="rounded-[28px] border border-slate-800 bg-[linear-gradient(180deg,rgba(21,29,46,0.96)_0%,rgba(11,17,32,0.92)_100%)] p-6 sm:p-8 shadow-[0_24px_80px_rgba(2,6,23,0.24)]">
    <div class="max-w-2xl mb-6">
      <p class="text-[11px] font-mono uppercase tracking-[0.24em] text-amber">{eyebrow}</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-slate-100">{title}</h2>
      <p class="mt-3 text-sm leading-6 text-slate-400">{description}</p>
    </div>

    <div class="grid gap-4 lg:grid-cols-3">
      {routes.map((route) => (
        <a
          href={route.href}
          class="group rounded-[22px] border border-slate-800 bg-slate-950/35 p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-amber/30 hover:bg-slate-950/55"
        >
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-[11px] font-mono uppercase tracking-[0.22em] text-slate-500">{route.kicker}</p>
              <h3 class="mt-2 font-display text-lg font-semibold text-slate-100">{route.title}</h3>
            </div>
            <span class={`shrink-0 rounded-full border px-2.5 py-1 text-[10px] font-mono uppercase tracking-[0.18em] ${route.tone}`}>
              {route.badge}
            </span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-300">{route.summary}</p>
          <p class="mt-3 text-xs leading-5 text-slate-500">{route.detail}</p>
          <span class="mt-4 inline-flex items-center text-xs font-mono text-amber transition-transform duration-200 group-hover:translate-x-0.5">
            Start here →
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
