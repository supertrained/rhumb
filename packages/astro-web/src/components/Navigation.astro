---
import MobileNav from "./MobileNav.tsx";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const NAV_LINKS = [
  { href: "/leaderboard", label: "Leaderboard" },
  { href: "/compare", label: "Compare" },
  { href: "/search", label: "Search" },
  { href: "/docs", label: "Docs" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];
---

<nav class="sticky top-0 z-50 border-b border-slate-800 bg-navy/85 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center font-display font-bold text-lg tracking-tight group"
      aria-label="Rhumb home"
    >
      <span class="text-slate-100 group-hover:text-slate-50 transition-colors">rhumb</span>
      <span class="text-amber">.</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      {NAV_LINKS.map(({ href, label }) => {
        const active = currentPath === href || currentPath.startsWith(href + "/");
        return (
          <a
            href={href}
            class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors duration-150 ${
              active
                ? "text-slate-100 bg-slate-800/60"
                : "text-slate-400 hover:text-slate-100 hover:bg-slate-800/40"
            }`}
          >
            {label}
          </a>
        );
      })}

      <!-- Search icon shortcut -->
      <a
        href="/search"
        aria-label="Search"
        class="ml-2 p-2 text-slate-500 hover:text-slate-300 transition-colors"
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M10 6.5C10 8.43 8.43 10 6.5 10C4.57 10 3 8.43 3 6.5C3 4.57 4.57 3 6.5 3C8.43 3 10 4.57 10 6.5ZM9.38 10.44L12 13.06"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </svg>
      </a>
    </div>

    <!-- Mobile nav (React island) -->
    <MobileNav client:load currentPath={currentPath} />
  </div>
</nav>
