---
import Navigation from "../components/Navigation.astro";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  twitterCard?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
  jsonLdBlocks?: Record<string, unknown>[];
  agentContext?: string;
}

const {
  title = "Rhumb | Agent gateway for discovery and governed execution",
  description = "Rhumb helps AI agents discover, evaluate, and execute against external services. Rhumb Index scores the field. Rhumb Resolve routes supported calls through governed execution.",
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  ogUrl,
  ogType = "website",
  twitterCard = "summary_large_image",
  twitterTitle,
  twitterDescription,
  twitterImage,
  noindex = false,
  jsonLd,
  jsonLdBlocks = [],
  agentContext,
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID ?? import.meta.env.NEXT_PUBLIC_GA_ID;
const clarityId = import.meta.env.PUBLIC_CLARITY_ID ?? import.meta.env.NEXT_PUBLIC_CLARITY_ID;
const currentPath = Astro.url.pathname;

// Ensure canonical + og:url are always absolute
function toAbsolute(path: string | undefined): string {
  if (!path) return `https://rhumb.dev${currentPath}`;
  if (path.startsWith("https://")) return path;
  return `https://rhumb.dev${path}`;
}
const resolvedCanonical = toAbsolute(canonical);
const resolvedOgUrl = toAbsolute(ogUrl);
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
const generatedOgImage = `https://rhumb.dev/api/og?title=${encodeURIComponent(resolvedOgTitle)}&subtitle=${encodeURIComponent(resolvedOgDescription)}`;
const resolvedOgImage = !ogImage || ogImage === "https://rhumb.dev/api/og" ? generatedOgImage : ogImage;
const allJsonLdBlocks = jsonLd ? [jsonLd, ...jsonLdBlocks] : jsonLdBlocks;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Rhumb" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:url" content={resolvedOgUrl} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:site" content="@pedrorhumb" />
    <meta name="twitter:creator" content="@pedrorhumb" />
    <meta name="twitter:title" content={twitterTitle ?? resolvedOgTitle} />
    <meta name="twitter:description" content={twitterDescription ?? resolvedOgDescription} />
    <meta name="twitter:image" content={twitterImage ?? resolvedOgImage} />

    <!-- Favicon + machine-readable brand assets -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" href="/logo.png" />

    {allJsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    {/* Microsoft Clarity */}
    {clarityId && (
      <script is:inline define:vars={{ clarityId }}>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", clarityId);
      </script>
    )}

    {/* Google Analytics 4 */}
    {gaId && (
      <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} async />
    )}
    {gaId && (
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}
  </head>
  <body class="bg-navy text-slate-100 antialiased min-h-screen flex flex-col noise-overlay">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Navigation currentPath={currentPath} />
    <main id="main-content" class="flex-1">
      {agentContext && <div class="sr-only" data-agent-context>{agentContext}</div>}
      <slot />
    </main>

    <footer class="border-t border-white/10 bg-rhumb-ink">
      <div class="mx-auto max-w-7xl px-5 py-14 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[1.2fr_2fr]">
          <div class="max-w-md">
            <a href="/" class="inline-flex items-center gap-3" aria-label="Rhumb home">
              <span class="logo-mark" aria-hidden="true">⌖</span>
              <span class="font-display text-2xl font-semibold tracking-[-0.04em] text-rhumb-cream">
                rhumb<span class="text-rhumb-gold">.</span>
              </span>
            </a>
            <p class="mt-4 text-sm leading-6 text-rhumb-muted">The navigation layer for agent tools.</p>
            <p class="mt-8 text-xs text-rhumb-faint">© 2025 Rhumb Labs, Inc. All rights reserved.</p>
          </div>

          <div class="grid grid-cols-2 gap-8 text-sm sm:grid-cols-3 lg:grid-cols-5">
            <div>
              <p class="footer-heading">Product</p>
              <div class="footer-links">
                <a href="/search">Index</a>
                <a href="/resolve">Resolve</a>
                <a href="/#quickstart">MCP</a>
                <a href="/docs#rest-api">API</a>
              </div>
            </div>

            <div>
              <p class="footer-heading">Trust</p>
              <div class="footer-links">
                <a href="/methodology">AN Score</a>
                <a href="/trust#evidence">Evidence</a>
                <a href="/trust#freshness">Freshness</a>
                <a href="/docs/failure-modes">Failure modes</a>
              </div>
            </div>

            <div>
              <p class="footer-heading">Resources</p>
              <div class="footer-links">
                <a href="/docs">Docs</a>
                <a href="/blog">Guides</a>
                <a href="/recipes">Examples</a>
                <a href="/changelog">Changelog</a>
              </div>
            </div>

            <div>
              <p class="footer-heading">Company</p>
              <div class="footer-links">
                <a href="/about">About</a>
                <a href="/blog">Blog</a>
                <a href="/about#careers">Careers</a>
                <a href="mailto:providers@supertrained.ai">Contact</a>
              </div>
            </div>

            <div>
              <p class="footer-heading">Legal</p>
              <div class="footer-links">
                <a href="/privacy">Privacy</a>
                <a href="/terms">Terms</a>
                <a href="/security">Security</a>
                <a href="/status">Status</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </footer>
    <!-- Scroll reveal (progressive enhancement — works without JS via .reveal CSS) -->
    <script is:inline>
      if ('IntersectionObserver' in window) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
      }
    </script>
  </body>
</html>
